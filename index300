<script>
const CHAPTERS = [{"n":301,"t":"ยุคสมัยมันเปลี่ยนไปแล้ว เจ้าโง่!","c":["“คุ้มกันฝ่าบาท!”","“ฆ่าพวกกบฏพวกนั้น!”","ภายในพระราชวังฮัดลาตา ซิมมอนส์หัวหน้าองครักษ์ตะโกนก้อง สั่งการให้องครักษ์ของเขาใช้โล่ในมือต้านทานการโจมตีอันดุเดือดจากปืนคาบศิลา","แม้กองกำลังส่วนใหญ่ในเมืองหลวงถูกส่งไปปฏิบัติภารกิจในคืนนี้ แต่บาเซลก็คาดการณ์ถึงความเป็นไปได้ที่จะล้มเหลว หรือแม้แต่ความเป็นไปได้ที่จะเป็นการล่อเสือออกจากถ้ำ ดังนั้นย่อมเป็นไปไม่ได้ที่พระราชวังจะปราศจากการป้องกัน","นอกจากองครักษ์ส่วนหนึ่งที่อยู่เฝ้าแล้ว ยังมีบิชอปหลายคนและนักบวชอีกสิบกว่าคนคอยช่วยในการป้องกัน ดังนั้นแม้ว่าเรย์เดลจะนำกำลังมาเป็นจำนวนมากและใช้ปืนคาบศิลา แต่ก็ยังไม่สามารถบุกทะลวงเข้ามาได้ในทันที","จนกระทั่งเสาสายฟ้าขนาดมหึมาที่สว่างไสวพอจะทำให้เมืองหลวงยามค่ำคืนนั้นสว่างจ้าตกลงมาจากฟากฟ้า สถานการณ์จึงพลิกผัน","เรย์เดลและคนอื่นๆ ต่างก็ตกตะลึง และโชคดีที่พวกเขาได้รับคำสั่งมาก่อนหน้านี้ ซึ่งพอจะคาดเดาได้ว่าเกิดอะไรขึ้น","องครักษ์ที่เฝ้าพระราชวังตกอยู่ในความโกลาหลอย่างหลีกเลี่ยงไม่ได้ โดยเฉพาะเหล่านักบวชและบิชอปที่ช่วยป้องกัน เพราะเสาสายฟ้าที่ตกลงมาจากฟากฟ้านั้น ไม่ใช่พลังศักสิทธิ์ที่พวกเขารู้จัก!","“อย่าตื่นตระหนก นั่นคือการลงทัณฑ์พวกกบฏโดยท่านคาร์ดินัลโลซัค พระเจ้า...ทรงอยู่กับข้า!”","ซิมมอนส์ตะโกนเสียงแหบพร่า พยายามหยุดความโกลาหลของกองทัพไว้ แต่ก็ไม่อาจขวางกั้นเหล่าทหารที่ล้มลงจากการระดมยิงของปืนและกระสุนที่พุ่งเข้ามาได้","แต่สิ่งที่ทำให้ซิมมอนส์นั้นถอนหายใจด้วยความโล่งอกเพียงอย่างเดียวก็คือ หลังจากที่ถูกยิงไปไม่กี่ชุด เสียงของปืนก็เงียบลง","เรย์เดลและพวกพ้องกระสุนหมดแล้ว!","จากการสู้รบระหว่างทางตั้งแต่เมืองหลวงจนมาถึงพระราชวัง กระสุนที่พกติดตัวมาได้ใช้ไปจนหมดสิ้น ซึ่งทำให้ทุกคนต้องยกปืนคาบศิลาขึ้น เพื่อเตรียมพร้อมสำหรับการต่อสู้ประชิดตัว!","ซิมมอนส์จึงตระหนักได้อย่างรวดเร็วจากการกระทำของคนเหล่านั้น และเริ่มฮึกเหิมขึ้นมาทันที","“ทุกคน ตั้งสติให้ดี โอกาสของตอบโต้มาถึงแล้ว พวกสาวกของปีศาจเหล่านั้นไม่สามารถใช้อาวุธเวทมนตร์ที่ทรงพลังได้อีกแล้ว และตอนนี้ก็เป็นเวลาที่เราจะได้รับชัยชนะ!”","เหล่าองครักษ์ที่ถูกบีบให้รวมกลุ่มอยู่ในแนวโล่และถูกระดมยิงด้วยปืนคาบศิลา ต่างก็กำดาบยาวแน่นและพุ่งเข้าใส่ฝ่ายตรงข้ามราวกับหมาป่า","ซิมมอนส์ก็ไม่เว้น โดยเล็งเป้าหมายไปที่เรย์เดลซึ่งเป็นผู้บัญชาการในทันที ตราบใดที่เขาสังหารผู้นำได้ก่อน มันจะต้องสร้างความเสียหายต่อขวัญกำลังใจของพวกกบฏเหล่านี้อย่างมหาศาล!","ซิมมอนส์สะบัดดาบด้วยความเร็วที่เหนือชั้น สังหารนักแม่นปืนสองคนที่ล้อมเขาอยู่ได้ในพริบตา","เพราะในฐานะหัวหน้าองครักษ์ที่กษัตริย์บาเซลทรงวางพระทัย แม้ว่าซิมมอนส์จะไม่ใช่อัศวินขุนนางที่มีสายเลือดชั้นเลิศ แต่เขานั้นก็ได้รับน้ำยาพรศักดิ์สิทธิ์จากผลงานทางทหาร และมีสมรรถภาพร่างกายเหนือกว่าคนทั่วไป ซึ่งเมื่อคมดาบฟาดฟันลงมา ย่อมต้องมีใครสักคนโหยหวนและล้มลงในกองเลือด","“ถอยไปจากข้า!”","เรย์เดลตะโกนลั่น หยุดไม่ให้ผู้คนมารุมล้อมเพื่อปกป้องตน","“ก็กล้าหาญดีนี่!”","ซิมมอนส์สลัดเลือดบนอาวุธในมือออก จากนั้นรอยยิ้มที่โหดเหี้ยมก็ปรากฏขึ้นที่มุมปากของเขา","“แต่ชีวิตของเจ้าน่ะ ข้าขอรับไว้เอง!”","สิ้นเสียงนั้น ร่างกายของซิมมอนส์ก็พุ่งทะยานราวกับพายุ ซึ่งข้ามระยะทางกว่าสิบเมตรในเวลาเพียงสองหรือสามก้าว และเหวี่ยงดาบขนาดใหญ่ในมือหมายฟันใส่เรย์เดล","อย่างไรก็ตาม เรย์เดลที่กำลังเผชิญหน้ากับเขากลับโยนปืนคาบศิลาในมือทิ้งโดยตรง แล้วดึงปืนสั้นขนาดเท่าฝ่ามือสีดำสนิทออกมาจากกระเป๋าที่ติดกับเข็มขัดแทน และเล็งปากกระบอกสีดำไปที่ซิมมอนส์","ความเย็นเยียบแล่นพล่านจากฝ่าเท้าขึ้นสู่ศีรษะในทันที ซิมมอนส์ ผู้ซึ่งเพิ่งเห็นการยิงของปืนคาบศิลา ย่อมคาดเดาได้ว่ามันคือสิ่งที่คล้ายคลึงกัน","แต่ในระยะประชิดเช่นนี้ การหลบหลีกย่อมสายเกินไป ซิมมอนส์จึงทำได้เพียงวางดาบขวางลำตัว เปลี่ยนจากการรุกเป็นรับ และด้วยความเร็วในการตอบสนองอันยอดเยี่ยมเช่นนี้ เขานั้นสามารถปัดป้องลูกธนูที่พุ่งเข้ามาได้ด้วยซ้ำ...","แม้ว่าอาวุธเวทมนตร์แปลกๆ ชนิดนี้จะยิงกระสุนได้เร็วกว่าธนูหน้าไม้มาก แต่เขาก็มั่นใจว่าจะสามารถป้องกันมันได้!","ปัง!","เสียงปืนก็ดังขึ้นอย่างฉับพลัน!","สีหน้าของซิมมอนส์เปลี่ยนจากเคร่งขรึมเป็นหวาดกลัว เพราะสิ่งที่พุ่งออกมาจากปากกระบอกปืนไม่ใช่กระสุนเพียงนัดเดียว แต่เป็นนับสิบหรือนับร้อย!","ซึ่งมีกระสุนจำนวนมากพุ่งออกจากปากกระบอกปืนแล้วกระจายตัวออกเป็นรูปกรวย ภายใต้ระยะครอบคลุมของกระสุนที่กว้างขวางเช่นนี้ จึงทำให้ซิมมอนส์นั้นไม่สามารถแม้แต่จะหลบหลีกขั้นพื้นฐานได้ แขนซ้าย หัวไหล่ เอว และช่องท้องของเขาล้วนถูกกระสุนตะกั่วที่พุ่งเข้ามาเจาะทะลุ จนแตกละเอียดกลายเป็นชิ้นส่วนกระจายไปทั่วท้องฟ้า และโปรยปรายลงสู่พื้นดิน…โดยมีร่างของซิมมอนส์ที่ล้มลงบนพื้นราวกับใบไม้ร่วง พร้อมดวงตาที่เต็มไปด้วยความแค้นเคืองและไม่ยินยอม นี่ไม่ใช่วิธีการต่อสู้และความตายที่อัศวินควรได้รับ...","“ยุคสมัยมันเปลี่ยนไปแล้ว เจ้าโง่!”","เรย์เดลส่ายหน้า นี่เป็นสินค้าชั้นเลิศที่โรงงานเล่นแร่แปรธาตุผลิตขึ้นมาเพื่อเขาโดยเฉพาะ","เดิมทีมันตั้งใจจะเอาไว้ใช้รับมือกับพวกบิชอปในสถานการณ์ฉุกเฉิน แต่ในเมื่อซิมมอนส์ยืนกรานที่จะเข้ามาหา ก็ให้เขาได้ลิ้มลองอาวุธปืนนี้เสียหน่อย!","เรย์เดลเก็บปืนสั้น หยิบดาบอัศวินของคู่ต่อสู้ขึ้นมา พร้อมกับเสียบมันลงบนศพของซิมมอนส์แล้วชูขึ้นสูง จากนั้นก็ตะโกนก้องว่าผู้นำตายแล้ว เพื่อทำลายจิตวิญญาณการต่อสู้ของทหารองครักษ์","ในขณะนี้ภายในพระราชวัง เหล่าข้าราชบริพารและขุนนางต่างตกอยู่ในความโกลาหล มีเสียงดาบและเสียงปืนดังมาจากภายนอกอย่างต่อเนื่อง แต่บาเซลก็ยังคงนั่งอยู่บนบัลลังก์โดยไม่มีท่าทีว่าจะขยับเขยื้อน","“ฝ่าบาทบาเซล พวกคนงานเหมืองสารเลวนั่นกำลังจะบุกเข้ามาแล้ว หากไม่รีบหนีไปตอนนี้ มันจะสายเกินไปพะย่ะค่ะ”","ข้าราชบริพารผู้จงรักภักดีคุกเข่าลงกับพื้นและกล่าวด้วยความกระวนกระวาย","“ไม่ พวกเขาอยู่ที่หน้าประตูแล้ว”","สีหน้าของบาเซลสงบนิ่งมาก ในวินาทีที่เขาได้รับรายงานว่าพระราชวังถูกโจมตี เขาก็คาดเดาได้แล้วว่าปฏิบัติการต่อต้านพวกพ่อมดในคืนนี้นั้นเป็นเพียงกับดัก","ราวกับเหยื่อที่ติดอยู่ในใยแมงมุม ที่แม้จะดิ้นรนไปก็เปล่าประโยชน์ ซึ่งบาเซลนั้นก็ตระหนักถึงเรื่องนี้เป็นอย่างดี และไม่มีความตั้งใจที่จะหลบหนี พร้อมด้วยอายุขัยของเขาที่มาถึงจุดสิ้นสุดแล้ว","ยิ่งไปกว่านั้น นี่คืออาณาจักรของเขา ดินแดนของตระกูลบาเซลที่ปกครองสืบทอดกันมาหลายชั่วอายุคน เขานั้นยังคงต้องตรวจสอบผู้สืบทอดคนใหม่ ว่าบุตรชายที่โง่เขลาของเขาจะมีความสามารถในการปกครองอาณาจักรหรือไม่!","เสียงดังสนั่นหวั่นไหวดังมาจากที่ไกลๆ ก็เข้าใกล้มาเรื่อยๆ พร้อมกับการสังหารและเสียงฝีเท้าจำนวนมาก จนทำให้พระราชวังทั้งหลังเริ่มสั่นสะเทือนเล็กน้อย ราวกับว่ามันกำลังจะพังทลายลง","หลังจากนั้นไม่นาน ทุกอย่างก็กลับสู่ความสงบ และประตูพระราชวังก็เปิดออกในที่สุด","ฮัตตาร์เป็นคนแรกที่ก้าวเข้าสู่พระราชวัง โดยมีดาบเปื้อนเลือดอยู่ในมือ พร้อมกับลินน์ที่ไม่ได้คิดจะแย่งซีนของเขา จึงเดินตามหลังมาพร้อมกับแอนโธนี","สายตาของกษัตริย์บาเซลกวาดผ่านร่างของแอนโธนี และหยุดอยู่ที่ร่างของลินน์เป็นเวลานาน สุดท้ายจึงหันไปมองฮัตตาร์และถอนหายใจ","“หากเจ้าเดินเข้ามาในโถงนี้เพียงลำพังในคืนนี้ ข้าคงจะมีความสุขมาก ฮัตตาร์!”"]},{"n":302,"t":"พลังที่ไร้การควบคุมย่อมนำพาหายนะมาสู่อาณาจักรแห่งนี้ไม่ช้าก็เร็ว!","c":["“แน่นอนสิ ท่านคงมีความสุขมาก ถ้าข้ามาตามนัดเพียงลำพัง ข้าคงกลายเป็นผีเฝ้าที่นี้ไปแล้ว!”","ฮัตตาร์ตอบกลับพร้อมรอยยิ้มเยาะเย้ย","“ข้าไม่นึกเลยว่าเจ้าจะมองข้าเช่นนี้ ฮัตตาร์...”","กษัตริย์กล่าวด้วยถอนหายใจ","“แต่นั่นคือสิ่งที่ท่านทำไม่ใช่หรือ? ท่านพ่อ?”","สีหน้าของฮัตตาร์พลันเย็นชาลง พร้อมจ้องมองบาเซลผู้แก่ชราที่นั่งอยู่บนบัลลังก์ตรงหน้า โดยมีน้ำเสียงสูงขึ้นเล็กน้อยขณะถามอย่างกึกก้อง","“แล้วแฮโรลด์ล่ะ? ไอ้ขยะนั่นที่ไม่มีประโยชน์อะไรเลยนอกจากคอยเอาใจศาสนจักร ข้าด้อยกว่ามันตรงไหน?”","“ตอบข้ามา ท่านพ่อ!”","ฮัตตาร์คำราม กัดฟันแน่น ดวงตาเบิกโพลงตะโกนอย่างโกรธจัด","บาเซลจ้องมองฮัตตาร์อย่างเงียบงัน แต่ฮัตตาร์ยังคงตั้งคำถามกับเขาอย่างไม่ลดละ","“การลดอำนาจของศาสนจักรและรวบรวมสิทธิ์ทั้งหมดไว้ในมือท่าน นั่นไม่ใช่สิ่งที่ท่านทำมาตลอดหรือ? หรือว่าท่านกลัว? กลัวอำนาจของศาสนจักรเหมือนกับแฮโรลด์ เต็มใจจะเป็นเพียงกษัตริย์หุ่นเชิด?”","“การที่เจ้ายังไม่เข้าใจในเรื่องนี้ นั่นก็หมายความว่าเจ้านั้นยังไม่มีคุณสมบัติ และยังห่างไกลจากการที่จะแบกรับภาระสำคัญในฐานะกษัตริย์”","บาเซลมองบุตรชายคนที่สองของเขาด้วยความผิดหวังอย่างยิ่ง","“จริงหรือ?”","ใบหน้าของฮัตตาร์บิดเบี้ยว แต่ไม่นานเขาก็กลับมาสงบนิ่งและหัวเราะลั่น","“แต่ตอนนี้มันพิสูจน์แล้วว่าข้าคิดถูก แฮโรลด์พ่ายแพ้และคาร์ดินัลโลซัคตายแล้ว ตั้งแต่วันพรุ่งนี้เป็นต้นไป ข้าจะเป็นกษัตริย์องค์ใหม่ของฮัดลาตา!”","“และข้า...ก็เหนือกว่าท่านแล้ว ท่านพ่อ! เพราะข้าจะขับไล่นักบวชพวกนั้นทั้งหมดออกจากดินแดน โดยจะนำพื้นที่ทุกตารางนิ้วเข้าสู่การปกครองของกษัตริย์และเหล่าขุนนาง ซึ่งจะกลายเป็นกษัตริย์แห่งฮัดลาตาอย่างแท้จริง!”","ฮัตตาร์กล่าวอย่างตื่นเต้นอย่างหาที่สุดไม่ได้","“หากเป็นเช่นนั้น เจ้าก็เข้ามาสิ”","บาเซลลุกขึ้นจากบัลลังก์อย่างยากลำบาก จากนั้นก็ชักดาบออกมาแล้วชี้ไปที่ฮัตตาร์","“เมื่อร้อยกว่าปีก่อน ณ ที่แห่งนี้ ปู่ของเจ้า เขาก็ตัดหัวกษัตริย์องค์ก่อนและยึดบัลลังก์แห่งฮัดลาตามา...และในวันนี้ เจ้าจงแสดงให้ข้าได้เห็น ถึงความสง่างามของกษัตริย์ในตัวเจ้าหน่อยซิ!”","ฮัตตาร์ผู้ถูกดาบชี้ใส่ชะงักไปครู่หนึ่ง และไม่คิดว่าบาเซลผู้มีอายุเกินแปดสิบปีจะคิดต่อสู้กับเขาเพื่อตัดสินในการเป็นเจ้าของบัลลังก์ ซึ่งนั่นก็ทำให้เขาทำอะไรไม่ถูกไปชั่วขณะ","แม้ว่าเขาจะมาเพื่อยึดบัลลังก์ แต่เขาก็ไม่ได้หมายความว่าต้องฆ่ากษัตริย์ เขาเพียงแค่อยากให้บาเซลเข้าใจว่าเขาเป็นผู้สมัครที่ดีที่สุดที่จะเป็นขึ้นกษัตริย์","“แน่นอน เจ้าจะเลือกให้คนอื่นมาฆ่าพ่อของเจ้าก็ได้!”","คำพูดของบาเซลเฉียบคมมาก แฝงด้วยการเสียดสี","ในเมื่อเรื่องมาถึงขั้นนี้ ฮัตตาร์จึงไม่ลังเลอีกต่อไป โดยสลัดเลือดบนดาบยาวทิ้งแล้วพุ่งเข้าใส่บาเซลในขณะที่กำด้ามดาบแน่น","เคร้ง","เสียงโลหะปะทะกันดังบาดหูพร้อมประกายไฟ โดยที่บาเซลผู้แก่ชราและร่างกายทรุดโทรมราวกับจะถูกลมพัดปลิว กลับถือดาบยาวไว้แน่นและรับการโจมตีเอาไว้ได้","“เจ้ามีฝีมือแค่นี้หรือ ฮัตตาร์?”","กษัตริย์บาเซลกล่าวด้วยความผิดหวัง","“อำนาจและฐานะนั้นเป็นสิ่งสำคัญ แต่พลังต่างหากคือสิ่งที่เป็นของเจ้าอย่างแท้จริง และมันจะเป็นที่พึ่งสุดท้ายของเจ้า...”","ฮัตตาร์โกรธจัดในทันที ตวัดดาบฟันไปที่ศีรษะของบาเซลขณะคำรามอย่างโกรธเคือง","“นั่นคือเหตุผลที่ข้าไม่อยากฆ่าท่านเมื่อครู่นี้ไง!”","เสียงดาบปะทะกันดังก้องอยู่ในพระราชวังอันกว้างใหญ่ ซึ่งท่วงท่าของฮัตตาร์นั้นทั้งรวดเร็วและสวยงาม ในฐานะเจ้าชาย เขาจึงได้รับการฝึกฝนที่ดีที่สุดและเข้มงวดที่สุด พร้อมด้วยพลังของสายเลือดที่ทรงพลัง ความแข็งแกร่งของเขาจึงไม่ควรมองข้าม","แต่คู่ต่อสู้ของเขาคือกษัตริย์แห่งฮัดลาตา ผู้ซึ่งเคยนำทัพเปิดศึกไปทั่วทุกแห่งหน และเป็นที่รู้จักในนาม ‘บาเซล สิงโตผู้พิชิต!’","“อย่าปล่อยให้โทสะชี้นำการกระทำของเจ้า นี่คือข้อห้ามร้ายแรง และจงอย่าแสดงสีหน้าให้ข้าเห็นเป็นอันขาด เพราะมันจะเปิดเผยการเคลื่อนไหวต่อไปของเจ้าจนหมดสิ้น!”","บาเซลรับการโจมตีอันหนักหน่วงของฮัตตาร์อีกครั้ง จากนั้นจึงหมุนดาบและทิ้งรอยเลือดที่ชัดเจนไว้บนใบหน้าของฮัตตาร์ และกล่าวด้วยน้ำเสียงเย็นชา","“คมดาบของศัตรูนั้นไม่มีความเมตตา!”","ลินน์สังเกตการต่อสู้ระหว่างพ่อลูกด้วยความสนใจอย่างยิ่ง โดยสนใจราชวงศ์และขุนนางที่สืบทอดสายเลือดเหล่านี้มาก","ตามที่ผู้สร้างเวทมนตร์วิตตอริโอ้กล่าว ‘สายเลือดชั้นเลิศ’ ที่สืบทอดกันมาเหล่านี้อาจเป็นซากปรักหักพังของยุคเก่า และอาจเป็นลูกหลานของพ่อมดสายแปรสภาพที่ทรงพลังบางคน","ซึ่งมันก็เหมือนกับโอเว่นที่ดื่มน้ำยาเวทมนตร์เพื่อรับพลังของสัตว์ประหลาด...","สำหรับความแข็งแกร่งของทั้งสอง ฮัตตาร์นั้นมีสมรรถภาพร่างกายประมาณพ่อมดสายแปรสภาพระดับสอง ในขณะที่กษัตริย์บาเซลนั้นแข็งแกร่งกว่าอย่างเห็นได้ชัด แม้ร่างกายจะชราแต่เขาก็ยังคงรับดาบทุกเล่มของฮัตตาร์ได้อย่างใจเย็น","แม้ภายนอกดูเหมือนว่าทั้งสองจะสูสีกัน แต่ไม่นานความแตกต่างก็เริ่มปรากฏชัดขึ้น โดยฮัตตาร์นั้นรู้สึกกระวนกระวายมากขึ้นเรื่อยๆ เมื่อไม่อาจโจมตีให้ชนะได้เป็นเวลานาน","“การฝืนใช้พลังที่ไม่อาจควบคุม สิ่งที่เจ้าจะได้รับมีเพียงการสะท้อนกลับ!”","สีหน้าของบาเซลนั้นยังคงเรียบเฉย แต่ครั้งนี้เขาไม่ได้ตั้งรับอีกต่อไป และดาบยาวในมือก็ฉวยจังหวะตวัดฟันเข้าปะทะกับใบดาบของอีกฝ่ายในมุมที่ยากจะรับมือ","“สำหรับวิชาดาบ ไม่ใช่แค่ยิ่งเร็วยิ่งดีเสมอไปหรอกนะ!”","ฮัตตาร์รู้สึกชาหนึบที่มือขวา ก่อนที่ดาบยาวจะหลุดปลิวออกจากมือไป","แต่บาเซลกลับไม่ได้ใช้โอกาสนั้นโจมตีซ้ำและทิ้งดาบในมือไป จากนั้นจึงคว้าร่างของฮัตตาร์เข้ามาใกล้ โดยกำลังอ้าปากพูดบางสิ่ง แต่ในวินาทีต่อมาเขากลับรู้สึกเจ็บแปลบที่หน้าอก ซึ่งมีกริชเล่มหนึ่งได้แทงทะลุเข้าที่หัวใจของเขา","และผู้ที่ลงมือก็คือ ฮัตตาร์!","“นี่คือสิ่งที่ท่านสอนข้า…ว่าไม่ควรลดการป้องกันลงเด็ดขาด”","ฮัตตาร์สงบนิ่งท่ามกลางความบ้าคลั่ง โดยที่ถ้อยคำเหล่านี้แทบจะเค้นลอดออกมาจากไรฟัน","เลือดก้อนโตไหลออกมาจากมุมปากของบาเซล แต่รอยยิ้มกลับปรากฏขึ้นบนใบหน้า เขากลับจับมือของฮัตตาร์และแทงมีดสั้นให้ลึกเข้าไปอีก พร้อมดวงตาของเขาที่เผาไหม้ราวกับคบเพลิง","“อย่าได้หวาดกลัว จงจดจำความรู้สึกนี้ไว้ ลูกข้า...บัลลังก์นั้นถูกหล่อหลอมขึ้นจากเหล็กและเลือด และผู้เดียวที่เจ้าสามารถเชื่อใจได้อย่างแท้จริงก็คือตัวเจ้าเอง”","“ไม่ว่าจะนักบวช ขุนนาง หรือพ่อมด...ล้วนไม่แตกต่างกัน...พลังที่ไร้การควบคุมย่อมนำพาหายนะมาสู่อาณาจักรแห่งนี้ไม่ช้าก็เร็ว!”","เสียงของบาเซลเบามาก ผสมกับเสียงครวญครางที่เจ็บปวด ซึ่งแทบจะดังอยู่ในหูของฮัตตาร์","“เจ้าทำพลาดแล้ว เจ้าไม่ควรทำลายล้างศาสนจักรจนย่อยยับและทำลายสมดุลนี้ลงเลย แต่มันสายไปแล้ว...ตอนนี้มันสายเกินไปแล้ว!”","“และสำหรับข้าแล้ว ไม่ว่าจะเป็นเจ้าหรือแฮโรลด์ก็ล้วนเหมือนกัน....”","บาเซลต้องการพูดต่อ แต่เลือดที่พุ่งขึ้นมานั้นได้ปิดกั้นลำคอของเขา และร่างกายของเขาก็ทรุดลงลงอย่างหมดเรี่ยวแรง..."]},{"n":303,"t":"มงกุฎเปื้อนเลือด","c":["ภายในท้องพระโรง เมื่อร่างของบาเซลล้มลงกระแทกพื้น มงกุฎทองคำก็ร่วงหล่นจากบนศีรษะแล้วกลิ้งไปจนหยุดอยู่ตรงหน้าฮัตตาร์","ในที่สุดเขาก็ได้ในสิ่งที่ปรารถนามาตลอด แต่ฮัตตาร์กลับไม่อาจเค้นความยินดีใดๆ ออกมาได้เลยแม้แต่น้อย เพราะถ้อยคำของบาเซลนั้นยังคงดังกึกก้องอยู่ในหัวราวกับมนสะกด","ลินน์ทอดสายตาไปยังกษัตริย์แห่งฮัดลาตาอยู่ครู่หนึ่ง","ไม่ว่าจะเป็นความกล้าหาญชาญชัยที่ยอมใช้พวกพ่อมดเพื่อต่อกรกับศาสนจักร การพยายามค้นหาสมดุลระหว่างสองขั้วอำนาจ หรือการยอมรับความตายอย่างสงบนิ่ง และใช้ความตายนั้นสอนบทเรียนสุดท้ายแก่บุตรชาย ทั้งหมดนี้ทำให้เขาสัมผัสได้ถึงความสามารถและอุปนิสัยของกษัตริย์ผู้นี้","แต่เขาก็แก่เกินไป และระดับของเขากับบุตรชายทั้งสองนั้นยังห่างชั้นอยู่มาก ซึ่งอาจเป็นเหตุผลที่บาเซลไม่ตัดสินใจเลือกผู้สืบทอดบัลลังก์เสียทีเป็นเวลานาน","ลินน์รออยู่นาน เมื่อเห็นว่าฮัตตาร์ยังคงเหม่อลอยไม่ได้สติเสียที เขาก็อดไม่ได้ที่จะเอ่ยเตือน","“ขอแสดงความยินดีที่ทรงได้ครองบัลลังก์ องค์ชายฮัตตาร์ อ้อ ไม่สิ ข้าควรเรียกท่านว่าฝ่าบาทต่างหาก!”","“สถานการณ์ในเมืองหลวงนั้นยุ่งเหยิงเป็นอย่างมาก เราจำเป็นต้องระดมกำลังคนเพิ่มเพื่อปราบปรามพวกกองกำลังต่อต้านเหล่านั้น และที่สำคัญไปกว่านั้น เรายังจับตัวแฮโรลด์พี่ชายของท่านไม่ได้ ซึ่งนั่นถือเป็นภัยคุกคามที่ไม่อาจมองข้าม...”","ฮัตตาร์ก้มลงเก็บมงกุฎเปื้อนเลือดที่ตกอยู่บนพื้น จากนั้นหันไปมองเหล่าข้าราชบริพารที่ตัวสั่นเทาด้วยความหวาดกลัวอยู่ตรงมุมห้อง แล้วกล่าวด้วยน้ำเสียงเย็นชา","“สังหารพวกมันซะ ท่านแอนโธนี...”","คนพวกนี้เห็นบาเซลสิ้นพระชนม์ด้วยน้ำมือของเขาเอง จะปล่อยให้พวกมันมีชีวิตรอดต่อไปไม่ได้เด็ดขาด!","ซึ่งแอนโธนีก็ไม่ได้ลงมือทันที แต่เหลือบมองลินน์ก่อนเป็นอันดับแรก และเมื่อเห็นว่าอีกฝ่ายไม่คัดค้าน เขาจึงยื่นมือออกไป พร้อมกับกระแสไฟฟ้าสีน้ำเงินอมม่วงที่แผ่คลุมทุกคนในทันที","ในชั่วพริบตา เหล่าข้าราชบริพารภายในวังก็สิ้นใจลงท่ามกลางอาการชักกระตุกและเสียงร้องโหยหวน","ซึ่งฮัตตาร์เองก็มองเห็นความลังเลในสายตาของแอนโธนี แต่เขาก็ไม่ได้เอ่ยอะไร เพียงแค่เรียกทหารยามที่ประจำการอยู่นอกประตูเข้ามา แล้วออกคำสั่งให้ไล่จับแฮโรลด์ทั่วทั้งเมือง","“ด้วยข้อหาที่ว่าเขาไม่พอใจที่ถูกเสด็จพ่อกักบริเวณ จึงได้สมคบคิดกับคาร์ดินัลโลซัคเพื่อลอบปลงพระชนม์กษัตริย์ จงนำข่าวนี้ไปกระจายให้ทั่วทั้งเมืองหลวงภายในเวลาที่สั้นที่สุด!”","“ขอรับ ฝ่าบาท!”","ทหารยามตอบรับโดยไม่ลังเล ก่อนจะรีบวิ่งออกไปเพื่อถ่ายทอดคำสั่ง","นขณะนั้นเอง คลื่นพลังศักดิ์สิทธิ์อันรุนแรงก็ปะทุขึ้นมาจากที่ไกลๆ อย่างกะทันหัน ซึ่งแอนโธนีก็สัมผัสได้ถึงความผิดปกติทันที และมองออกไปนอกพระราชวังพร้อมกับขมวดคิ้วเล็กน้อย","ในเมื่อคาร์ดินัลโลซัคตายไปแล้ว จะมีใครที่ไหนสามารถใช้พลังศักดิ์สิทธิ์ที่ทรงอานุภาพขนาดนี้ได้อีก?","ลินน์ไม่ได้รับรู้ถึงคลื่นพลังนั้นเลยแม้แต่น้อย แต่เขาก็สังเกตเห็นความเคลื่อนไหวของแอนโธนี และกำลังจะเอ่ยถาม แต่ในตอนนั้น เขาก็มองเห็นลำแสงสีแดงฉานพุ่งทะยานขึ้นสู่ท้องฟ้า ก่อนจะระเบิดออก","“นั่นมันพลุสัญญาณ!”","ด้านนอกคฤหาสน์ของฮัตตาร์ เหล่าพลปืนคาบศิลาที่ประจำการอยู่ที่นี่ต่างเอาแต่คิดเรื่อยเปื่อยว่าจะได้รับรางวัลแบบไหนบ้าง หลังจากที่สร้างผลงานบุกยึดเมืองหลวงสำเร็จ","“เมืองหลวงแห่งฮัดลาตานี่มันรกไปหมดทุกที่เลย ไม่สวยงามเหมือนอิเยตาสักนิด”","เฒ่ายอร์คเบะปากด้วยความเหยียดหยาม ตอนที่ได้ยินว่าพวกเขากำลังจะบุกโจมตีเมืองหลวงของอาณาจักร เขาก็แอบตั้งตารอ แต่เมื่อเข้ามาถึง กลับพบว่ามันไม่มีอะไรน่าประทับใจเลย","“พวกพ่อมดเคยบอกไว้ไม่ใช่เหรอ? ว่าพวกคนที่อยู่นอกดินแดนพ่อมดน่ะ เป็นพวกป่าเถื่อนโง่เขลา พวกเขายังแยกไม่ออกด้วยซ้ำว่าพวกเรากำลังยืนอยู่บนทวีปหรือบนลูกบอลกลมๆ”","พลปืนคาบศิลาที่ชื่ออาปูตอบกลับด้วยเสียงเยาะเย้ย จากนั้นก็สะบัดตัวแล้วพึมพำ","“พวกเจ้าเฝ้าตรงนี้ไปก่อนนะ ข้าจะไปปลดทุกข์สักหน่อย...”","อาปูซึ่งเกิดในดินแดนพ่อมดนั้นไม่ได้เคารพยำเกรงพวกที่เรียกตัวเองว่าขุนนางเลยสักนิด ซึ่งเขาหันหลังเดินไปที่กองซากปรักหักพังบนพื้น ก่อนจะถอดกางเกงลงแล้วปัสสาวะรดในคฤหาสน์ขององค์ชาย เขาควรจะเป็นคนแรกที่ได้ทำแบบนี้สินะ?","อาปูคิดอย่างภาคภูมิใจ พร้อมสายน้ำที่พุ่งกระฉูดออกมาจากใต้ร่าง และในขณะที่เขากำลังปลดปล่อยอย่างสบายตัวอยู่นั้น เขาก็เหลือบไปเห็นสิ่งของใสแจ๋วราวคริสตัลที่ดูเหมือนจะส่องประกายอยู่ท่ามกลางซากปรักหักพัง...","หรือว่านั่นจะเป็นสมบัติล้ำค่าที่องค์ชายทรงเก็บซ่อนไว้ในคฤหาสน์กัน?","อาปูเปลี่ยนความคิดทันที แม้ว่ากองกำลังพลปืนคาบศิลาจะมีกฎสั่งห้ามซุกซ่อนและปล้นสะดมอย่างเด็ดขาด แต่ตราบใดที่ไม่มีใครเห็น ก็แปลว่าเขาไม่ได้ทำผิดกฎ ด้วยการใช้วิธีมือไวตาไวเช่นนี้ในยามปกติ เขาจึงแอบกอบโกยของดีๆ ไปได้ไม่น้อยเลย","เมื่อคิดได้ดังนั้น อาปูก็ย่อตัวลงนั่งยองๆ อย่างเงียบเชียบ แต่ผิดคาด วัตถุที่สะท้อนแสงคริสตัลชิ้นนั้นกลับลอยพุ่งตรงดิ่งมาหาเขา","ของชิ้นนี้ถึงกับร่อนมาเสิร์ฟถึงที่ด้วยตัวเองเลยหรือเนี่ย?","ความคิดสุดท้ายนี้แล่นเข้ามาในหัวของอาปู ก่อนที่ตราสัญลักษณ์ขนาดเล็กชิ้นนั้นจะพุ่งกระแทกเข้าที่หัวของเขา ทำให้เขาสูญเสียสติไปในทันที และล้มพับลงไปกองกับพื้น","“อาปู เจ้าไม่ได้ลื่นฉี่ตัวเองล้มลงไปหรอกนะ?”","เฒ่ายอร์คเห็นอาปูนอนอยู่บนพื้นจึงเดินเข้าไปหาแล้วพูดหยอกล้อ","อาปูหยัดตัวลุกขึ้นยืนอย่างโอนเอน โดยมีตราสัญลักษณ์อันงดงามฝังแน่นอยู่บนหน้าผากของเขา","เฒ่ายอร์คเดินไปได้ไม่กี่ก้าวก็สังเกตเห็นสิ่งนี้เช่นกัน ขณะที่เขากำลังจะเอ่ยถาม จู่ๆ อาปูก็ยกปืนคาบศิลาขึ้นประทับบ่า!","เป็นเพราะไม่มีเสียงปืนดังขึ้น เฒ่ายอร์คจึงตระหนักได้ว่าปืนคาบศิลาในมือของอาปูคงจะใช้งานไม่ได้แล้วเนื่องจากเปียกฝนและความชื้น และอีกฝ่ายก็ไม่มีทางเอาปืนคาบศิลามาล้อเล่นกับเขาแบบนี้แน่ เขาจึงรีบตะโกนบอกคนรอบข้างทันที","“ระวังตัวด้วยทุกคน! อาปูอาจจะถูกใครบางคนควบคุมอยู่ มาช่วยกันมัดเขาไว้เร็ว!”","พลปืนคาบศิลาหลายคนที่ได้ยินเสียงตะโกนรีบวิ่งเข้ามาล้อมเขาไว้ทันที เนื่องจากอาปูเป็นสหายของพวกเขา จึงไม่มีใครใช้ปืนคาบศิลาเล็งใส่ และต้องการเพียงแค่จับมัดเขาไว้เท่านั้น","แต่อาปู ซึ่งปกติเป็นคนชอบลักขโมยและชอบเล่นตลก กลับแสดงพละกำลังและทักษะการต่อสู้ที่เหนือธรรมดาออกมา โดยใช้ปืนคาบศิลาเป็นค้อน แล้วฟาดทุกคนล้มลงกับพื้นได้ในเวลาเพียงสองสามนาที","โชคดีที่เวลาไม่นานก็มีคนแห่เข้ามาสมทบมากขึ้นเรื่อยๆ หลายคนถึงขั้นง้างนกสับแล้วเล็งปืนมาทางนี้","สีหน้าของอาปูเปลี่ยนเป็นเคร่งเครียด พร้อมปากที่ขยับมุบมิบเบาๆ จากนั้นก็ยื่นนิ้วชี้ออกไป โดยมีแสงสีขาวสว่างจ้าบาดตาสาดส่องขับไล่ความมืดมิดในทันที ซึ่งทำให้ดวงตาของทุกคนที่อยู่ที่นั่นพร่ามัว","เสียงอุทานดังระงม เฒ่ายอร์คและคนอื่นๆ ที่ตาบอดไปชั่วขณะจึงทำได้เพียงพึ่งพาสัญชาตญาณของตน เล็งปืนคาบศิลาไปทางตำแหน่งของอาปูแล้วยิงกราดสุ่มไปมั่วๆ จนทำให้เกิดการบาดเจ็บจากการยิงพวกเดียวกันเองไม่น้อย","ซึ่งเมื่อพวกเขาได้รับการมองเห็นกลับคืนมา และแฮมม์นำคนกลับมาถึง อาปูก็หายตัวไปนานแล้ว","“ใช้พลุสัญญาณแจ้งให้ท่านลินน์ทราบ!”","เฒ่ายอร์คตะโกนเสียงดัง","แฮมม์ซึ่งไม่มีเวลาซักถามรายละเอียด ก็รีบหยิบกระสุนพิเศษออกมายัดใส่ปืนคาบศิลาทันที แล้วยิงเตือนขึ้นสู่ท้องฟ้า โดยมีแสงสีแดงฉานสว่างวาบและระเบิดออกท่ามกลางท้องฟ้ายามราตรีอันมืดมิด..."]},{"n":304,"t":"ร่างจำแลงแห่งองค์พระผู้เป็นเจ้าปรากฏขึ้นอีกครั้ง!","c":["ภายในตรอกมืดแห่งหนึ่งในเมืองหลวงของฮัดลาตา อาปูผู้หลบหนีมาได้กุมบาดแผลที่ไหล่ซ้ายพลางหอบหายใจ ซึ่งมีเลือดสีเข้มหยดไหลลงมาจากบาดแผลจนย้อมชุดเกราะหนังสีดำจนชุ่มโชก","อาปูขมวดคิ้วแน่นและเริ่มร่ายเวทรักษาแผล แต่เขาก็สัมผัสได้ว่าเศษกระสุนที่แตกกระจายยังคงฝังลึกอยู่ในร่างกายของเขา","“ร่างกายนี้มันอ่อนแอเกินไป...”","อาปูพึมพำกับตัวเองด้วยความหงุดหงิด ในฐานะนักบวชระดับหกวงแหวนผู้ทรงพลัง เขาไม่เคยนึกฝันเลยว่าจะมีวันที่ตนเองต้องตกต่ำถึงเพียงนี้","หากไม่ใช่เพราะพลังจากตราสัญลักษณ์ศักดิ์สิทธิ์ ป่านนี้เขาคงสิ้นใจไปนานแล้ว","และตราสัญลักษณ์ศักดิ์สิทธิ์ชิ้นนี้ ก็ทำขึ้นจากกระดูกนิ้วของนักบุญองค์แรก โดยถูกเก็บรักษาไว้ในโบสถ์หลักเพื่อสั่งสมพลังแห่งศรัทธา ซึ่งสามารถนำมาใช้ช่วยในการร่ายพลังศักดิ์สิทธิ์ระดับสูงได้","นั่นคือสิ่งที่ทำให้เขามั่นใจว่าจะสามารถเผชิญหน้ากับจอมเวทผู้ยิ่งใหญ่ทั้งสองคนได้ แต่สิ่งที่โลซัคไม่คาดคิดก็คือ โคดี้ผู้ที่เขาเคยตรวจสอบความทรงจำด้วยตนเอง กลับใช้วิธีการบางอย่างที่เขาไม่รู้ลบร่องรอยและซ่อนตัวจากการตรวจสอบของพลังศักดิ์สิทธิ์ แล้วล่อลวงพวกเขาทั้งหมดให้ติดกับดัก...","และพลังเวทมนตร์นั้นก็ถาโถมเข้ามาเร็วเกินกว่าที่เขาจะตั้งตัวทัน ซึ่งทำให้ร่างกายของเขากลายเป็นอัมพาตและหมดสติไปในทันที โลซัคจึงทำได้เพียงส่งจิตสำนึกที่เหลืออยู่เพียงน้อยนิดเข้าไปในตราสัญลักษณ์ศักดิ์สิทธิ์ ก่อนที่ร่างเนื้อของเขาจะถูกทำลายจนแหลกสลายไปในสายฟ้าและการระเบิด","ทำให้ตอนนี้เขาต้องตัดสินใจ ว่าจะอยู่ที่นี่เพื่อจัดการกับสาวกปีศาจทั้งสอง หรือจะส่งข่าวกลับไปยังจักรวรรดิเซคัส","“องค์พระผู้เป็นเจ้าผู้ยิ่งใหญ่ โปรดช่วยผู้ศรัทธาที่เคร่งครัดที่สุดของพระองค์ด้วย...”","“โปรดประทานบทลงโทษ และลงทัณฑ์คนชั่วเหล่านั้นด้วยเถิด!”","“ผู้ศรัทธาที่เคร่งครัดที่สุดของพระองค์พร้อมจะสละทุกสิ่ง ณ ที่แห่งนี้...”","เสียงตะโกนดังก้องแว่วออกมาจากตราสัญลักษณ์ศักดิ์สิทธิ์อย่างเลือนราง มันคือเสียงของชาวเมืองหลวงที่ต่างพากันซ่อนตัวอยู่ในบ้านด้วยความหวาดกลัว และกำลังสวดอ้อนวอนต่อองค์พระผู้เป็นเจ้าผู้ยิ่งใหญ่","นั่นทำให้โลซัคสัมผัสได้ในทันทีว่า นี่คือโอกาส และเป็นโอกาสในการโต้กลับ โดยที่คำอธิษฐานของคนนับหมื่น ซึ่งเพียงพอแล้วที่จะทำให้เขาสามารถใช้พิธีกรรมอัญเชิญเทพจุติ เพื่อให้เศษเสี้ยวแห่งร่างจำแลงขององค์พระผู้เป็นเจ้าผู้ยิ่งใหญ่ลงมาจุติบนโลกนี้","“จงมา! เหล่าผู้ศรัทธาที่เคร่งครัดที่สุดของพระผู้เป็นเจ้า จงมาที่นี่!”","โลซัคส่งเสียงผ่านจิตสำนึกที่เชื่อมต่อกับตราสัญลักษณ์ศักดิ์สิทธิ์ ไปยังผู้ศรัทธาทุกคนซ้ำแล้วซ้ำเล่า","ทั่วทั้งเมืองหลวง เหล่าชาวเมืองที่กำลังสวดอ้อนวอนอย่างเคร่งครัดต่างได้ยินเสียงเรียกนั้นดังก้องอยู่ในหัว","“นี่คือพระประสงค์ของพระผู้เป็นเจ้า!”","“องค์พระผู้เป็นเจ้า พระองค์มิได้ทอดทิ้งผู้ศรัทธาของพระองค์...”","บรรดาผู้ศรัทธาต่างตะโกนด้วยความตื่นเต้น โดยไม่สนการปะทะที่ยังคงดำเนินอยู่ในจุดต่างๆ ของเมืองหลวง พวกเขาเปิดประตูบ้านแล้วเดินออกมาอย่างมุ่งมั่น ก่อนจะมารวมตัวกันจากทุกทิศทางยังจัตุรัสใจกลางเมืองหลวง","“เกิดอะไรขึ้น คนพวกนี้เป็นบ้าไปแล้วหรือไง?”","เรย์เดลผู้ซึ่งนำกำลังเข้ายึดประตูเมืองทั้งสามแห่งของเมืองหลวง และกำลังจะจับกุมแฮโรลด์องค์ชายใหญ่ ก็ได้เห็นฉากอันน่าประหลาดนี้","ซึ่งมีครอบครัวจำนวนมากที่ก่อนหน้านี้ซ่อนตัวอยู่ในบ้านต่างพากันออกมาที่ถนน พากันตะโกนก้องว่านี่คือพระประสงค์ของพระผู้เป็นเจ้า และคลื่นฝูงชนที่มืดฟ้ามัวดินก็เดินถาโถมเข้ามาราวกับพายุ","โดยมีเหล่าพลปืนคาบศิลาที่รับหน้าที่รักษาความสงบต่างก็ตกตะลึง เพราะถึงแม้พวกเขาจะยิงปืนเตือนนัดแล้วนัดเล่า แต่ก็ไม่อาจหยุดยั้งสถานการณ์นี้ได้","“เราควรทำอย่างไรดี? เราจะสังหารคนพวกนี้เลยไหม?”","เพื่อนร่วมหน่วยพลปืนคนหนึ่งถามด้วยความทำอะไรไม่ถูก","ซึ่งนั่นก็ทำให้เรย์เดลนั้นลังเลใจ แม้ว่าชาวเมืองเหล่านี้จะไม่ได้โจมตีพวกเขา แต่ใครที่ตาถึงหน่อยก็ย่อมดูออกว่าคนเหล่านี้มีบางอย่างผิดปกติ","แต่การจะสังหารพลเรือนที่ไร้ทางสู้ ย่อมขัดต่อเป้าหมายของพวกเขา","เสียงสวดอ้อนวอนในใจกลางจัตุรัสดังกระหึ่มขึ้นเรื่อยๆ พลังศรัทธาของคนนับหมื่นได้กลายเป็นกุญแจสำคัญและเป็นจุดเชื่อมประสาน เมื่อเห็นว่าจังหวะเวลาเหมาะสมแล้ว โลซัคก็ได้ถอดตราสัญลักษณ์ศักดิ์สิทธิ์ที่หน้าผากแล้วโยนขึ้นไปในอากาศ","“สรรเสริญ สวรรค์จุติ!”","โลซัคกล่าวคำร่ายโบราณที่ลึกลับและยากจะเข้าใจ","ในพริบตา ลำแสงสีขาวในตราสัญลักษณ์ศักดิ์สิทธิ์ก็พุ่งตรงขึ้นสู่ท้องฟ้า ส่องสว่างไปทั่วทั้งเมืองหลวง ราวกับดวงดาวในยามราตรีกำลังสั่นสะเทือนและร่วงหล่นลงมา โดยที่แสงสีขาวบริสุทธิ์นั้นค่อยๆ แปรเปลี่ยนเป็นร่างจำแลงของเทพธิดาผู้ศักดิ์สิทธิ์และสูงส่ง ซึ่งก้มมองลงมายังเหล่าสรรพชีวิตด้วยสายตาที่เปี่ยมไปด้วยพลังอำนาจและบรรยากาศอันศักดิ์สิทธิ์","บทเพลงสวดสรรเสริญอันไพเราะดังก้องอยู่บนฟากฟ้า และความยิ่งใหญ่ที่ไม่อาจเอื้อนเอ่ยได้ก็แผ่ซ่านปกคลุมไปทั่วท้องนภา ซึ่งทำให้ผู้ศรัทธาทุกคนต่างคุกเข่าลงกับพื้น พร้อมสรรเสริญความเมตตาและความยิ่งใหญ่ของพระผู้เป็นเจ้าด้วยท่าทีที่นอบน้อมที่สุด","เรย์เดลและเหล่าพลปืนต่างตกตะลึงจนยืนแข็งทื่อ เมื่อจ้องมองไปยังร่างจำแลงของเทพธิดาบนท้องฟ้า เหงื่อเย็นเยียบก็ผุดพรายบนหน้าผากของพวกเขา และขาทั้งสองข้างต่างพากันอ่อนแรงโดยไม่รู้ตัว","แม้แต่แฮมม์และคนอื่นๆ ที่เคยทอดทิ้งความศรัทธาไปแล้ว ก็ยังทรุดตัวลงคุกเข่ากับพื้นอย่างไม่อาจควบคุม พร้อมทั้งสารภาพบาปออกมาด้วยเสียงอันดัง","“ข้าไม่นึกเลยว่าโลซัคจะหลงเหลือพลังถึงเพียงนี้”","ลินน์ซึ่งอยู่ในเมืองหลวงก็กำลังจับตามองเหตุการณ์นี้อยู่เช่นกัน และได้รับรายงานจากหน่วยพลปืนคาบศิลามาแล้ว จึงรู้ดีว่าเกิดอะไรขึ้นที่คฤหาสน์ของฮัตตาร์","อาปูที่จู่ๆ ก็มีพฤติกรรมแปลกไปและหายตัวไปอย่างลึกลับหลังจากทำร้ายเพื่อนร่วมงาน น่าจะถูกเข้าสิงไปแล้ว และคนเดียวที่จะสามารถทำเรื่องเช่นนี้ได้ก็มีเพียงคาร์ดินัลโลซัคเท่านั้น","อีกฝ่ายยังฉลาดแกมโกงถึงขั้นแฝงตัวมากับกลุ่มฝูงชนนับหมื่นคน โดยใช้คนยากไร้เหล่านี้เป็นโล่กำบัง ซึ่งลินน์ก็ไม่เต็มใจที่จะทำการสังหารหมู่หากไม่จำเป็นถึงที่สุด เพราะมันจะไม่เป็นผลดีต่อการปกครองในระยะยาวของพวกเขา","“ท่านมีวิธีจัดการกับเจ้านี่ไหม แอนโธนี?”","ลินน์ถามด้วยความใคร่รู้","“ท่านล้อข้าเล่นหรือไร แม้ว่านี่จะเป็นเพียงร่างจำแลงที่บรรจุพลังของนางเอาไว้เพียงเล็กน้อย แต่มันก็อยู่เหนือไปอีกระดับแล้ว”","สีหน้าของแอนโธนีเคร่งเครียดถึงขีดสุด บัดนี้เขารู้ตัวแล้วว่าตนเองได้ประเมินพลังของพระคาร์ดินัลนั่นต่ำเกินไป เพราะต่อให้เขาจะกลายเป็นพ่อมดระดับหกวงแหวนแล้ว แต่พลังของสถาบันเวทมนตร์เพียงแห่งเดียวก็ยังห่างไกลนักจากการสถาปนาอาณาจักรเวทมนตร์ขึ้นมาได้","“ด้วยพลังของท่านในตอนนี้ ท่านยังสามารถร่ายเวทมนตร์ระดับตำนานบทที่สองได้อยู่ไหม?”","แอนโธนีถามเชิงหยั่งเชิง","“เพราะเมื่อครู่ ข้าสัมผัสได้ถึงพลังศักดิ์สิทธิ์อันรุนแรง โดยวัตถุที่สนับสนุนร่างจุตินี้ควรจะอยู่ที่จุดกึ่งกลางระหว่างคิ้วของนาง”","“แน่นอนว่าไม่ได้!”","ลินน์ส่ายหน้า","เขาเป็นเพียงพ่อมดระดับสามวงแหวน และยังไม่มีความสามารถถึงระดับนั้น","เวทมนตร์ที่ลินน์เตรียมการมาหลายวันและแสดงผลลัพธ์ได้อย่างยอดเยี่ยมเมื่อครู่ เป็นเพราะความช่วยเหลือจากปรากฏการณ์ทางธรรมชาติและค่ายกลเล่นแร่แปรธาตุเท่านั้น","“เช่นนั้นเราก็ทำได้เพียงถอยทัพในตอนนี้!”","แอนโธนีถอนหายใจ เขาไม่นึกเลยว่าพวกเขาจะทุ่มเททำมาขนาดนี้จนสามารถยึดเมืองหลวงได้สำเร็จ แต่กลับต้องหนีเอาตัวรอดอย่างทุลักทุเล","ซึ่งไม่มีใครจะกระวนกระวายไปกว่าฮัตตาร์อีกแล้ว เขาอุตส่าห์ได้ขึ้นครองบัลลังก์อย่างยากลำบาก แต่ตอนนี้กลับต้องถอยทัพและมอบเมืองหลวงคืนให้กับพี่ชายของตน นี่คือสิ่งที่ฮัตตาร์จะไม่มีวันยอมให้เกิดขึ้นเด็ดขาด","“แล้วหน่วยพลปืนคาบศิลาในเมืองหลวงล่ะ? ไม้เท้าพ่นไฟในมือของพวกเขามันไม่ทรงพลังหรือไง? ข้ายังมีพลหน้าไม้อีกสามพันคน รวมกันเป็นพันๆ คนก็น่าจะยิงนางให้ร่วงลงมาได้บ้างสิ!”","ฮัตตาร์เอ่ยด้วยสีหน้าดุดัน","แอนโธนีชำเลืองมองเขา แล้วกำลังจะเอ่ยเยาะเย้ยข้อสันนิษฐานอันเพ้อฝันของฮัตตาร์ แต่เขากลับได้ยินเสียงของลินน์ที่เอ่ยขึ้นเสียก่อน","“ไม่จำเป็นต้องถอยทัพหรอก ข้าเตรียมบางอย่างไว้รับมือกับสถานการณ์ที่ไม่คาดคิดเช่นนี้อยู่แล้ว เพียงแต่ข้าไม่คิดว่ามันจะได้ใช้...”","ลินน์ที่เอ่ยขึ้นอย่างกะทันหัน ทำเอาทุกคนที่กำลังหมดหวังต่างพากันกลับมามีความหวังขึ้นอีกครั้ง"]},{"n":305,"t":"ตอนนี้ข้าก็แค่อยากจะอัดนางให้ยับ!","c":["“ท่านลินน์ ท่านมีวิธีจัดการกับนางด้วยหรือ?”","ฮัตตาร์เอ่ยถามอย่างร้อนรน เพราะเขาก็ไม่ต้องการสูญเสียเมืองหลวงไปตั้งแต่คืนแรกที่ยึดบัลลังก์มาได้เช่นกัน","แอนโธนีเองก็มองลินน์ด้วยความประหลาดใจอย่างยิ่ง ไม่ใช่ว่าเขาไม่อาจใช้เวทมนตร์ระดับตำนานได้อีกแล้วหรอกหรือ?","ลินน์ไม่ได้อธิบายสิ่งใด เขาเพียงยิ้มแล้วกล่าวว่า","“พวกเขามาถึงแล้ว!”","สิ้นคำ เสียงล้อรถบดเบียดพื้นถนนก็ดังแว่วมาจากอีกฟากของถนน ซึ่งก็ทำให้แอนโธนีและคนอื่นๆ ต่างหันขวับไปมองตามเสียง","บนถนนปูอิฐนั้น มีอูฐหลายตัวกำลังออกแรงลากรถม้าสามคันซึ่งคลุมด้วยผ้าใบสีดำมุ่งหน้ามาทางพวกเขา โดยมีผู้นำขบวนคือ ฟิลิปและคนอื่นๆ ที่หายหน้าไปนานตั้งแต่ตอนอพยพออกจากคฤหาสน์ นอกจากนี้ยังมีจอห์นนี่ ฟูล่า และพรรคพวกวิ่งตามขบวนรถมาติดๆ","“พวกเจ้าปลอดภัยกันดีใช่ไหม?”","ลินน์กวาดสายตามองไปรอบๆ เพื่อนับจำนวนคน เมื่อเห็นว่าไม่มีใครขาดหายไป เขาก็ถอนหายใจออกมาด้วยความโล่งอก","“พวกเราไม่เป็นอะไรหรอก แต่ก็มันน่ากลัวจนเกือบจะตายอยู่แล้ว...”","เอล็อคบ่นอุบอิบเสียงแผ่ว","แม้ลินน์จะกำชับไว้แล้วว่าให้รีบหนีทันทีที่เห็นแอนโธนีลงมือ และให้ไปหลบในหลุมหลบภัยของคฤหาสน์ แต่ฟูล่าและคนอื่นๆ กลับดื้อดึงไม่ยอมถอย จึงทำให้เสียเวลาไปไม่น้อย จนเกือบต้องเอาชีวิตไปทิ้งเพราะสายฟ้าที่ฟาดกระหน่ำลงมาพร้อมกับแรงระเบิดที่ตามมาติดๆ","“ท่านน่าจะบอกพวกเราล่วงหน้านะ ท่านศาสตราจารย์ลินน์”","เพียร์ซกล่าวด้วยน้ำเสียงที่ยังคงสั่นเทา","ลินน์ไม่ได้เอ่ยตอบ เพราะสิ่งสำคัญที่สุดในการวางกับดัก ก็คือการเก็บรักษาความลับ แม้จะไม่ใช่ว่าเขาจะไม่ไว้ใจเอล็อคและพรรคพวก แต่เขานั้นต้องเผื่อใจรับความเป็นไปได้ที่คนเหล่านี้อาจถูกจับกุมและถูกค้นความทรงจำ","แอนโธนีซึ่งยืนอยู่ด้านข้างดึงผ้าคลุมรถออก ก่อนจะตระหนักได้ว่าสิ่งที่อยู่ตรงหน้าไม่ใช่รถม้า แต่เป็นสิ่งประดิษฐ์รูปร่างแปลกประหลาดที่ดูคล้ายปืนใหญ่","แต่มันกลับมีขนาดที่กะทัดรัด และดูทรงอานุภาพกว่าปืนใหญ่ทั่วไปมาก!","ตัวเครื่องมีความสูงกว่าสองเมตร พร้อมมีล้อสี่ล้อติดตั้งอยู่บนฐานอันแข็งแกร่ง แต่สิ่งที่ดึงดูดสายตาที่สุด ก็คือรางปืนยาวสองเส้นที่ทอดยาวออกไปเบื้องหน้า ซึ่งสลักอักขระเวทมนตร์แม่เหล็กไฟฟ้าไว้อย่างหนาแน่น","“นี่คือสิ่งใดกัน?”","แอนโธนีเอ่ยถามด้วยความประหลาดใจ","“อาวุธแม่เหล็กไฟฟ้าอันทรงอานุภาพ ซึ่งข้าคิดว่าจะไม่ได้ใช้มันเสียแล้วในครั้งนี้”","ลินน์เดินไปหยุดอยู่หน้าปืนใหญ่แม่เหล็กไฟฟ้ากระบอกหนึ่ง และเริ่มปรับทิศทางปากกระบอกปืนทันที โดยเล็งเป้าหมายไปยังร่างจำแลงของเทพธิดาขนาดมหึมาบนท้องฟ้า","เดิมทีนี่คือแผนสำรองเพื่อป้องกันไม่ให้พระคาร์ดินัลหลุดรอดจากแผนการที่ไม่ยอมเดินเข้าสู่กับดัก หรือในกรณีที่ค่ายกลเล่นแร่แปรธาตุของเขาเกิดขัดข้องจนไม่สามารถทำงานได้ตามปกติ จึงตั้งใจให้ฟิลิปและคนอื่นๆ ที่ซ่อนตัวอยู่ในเงามืด หาจังหวะยิงปืนใหญ่แม่เหล็กไฟฟ้าและปลิดชีพโลซัคในทันที","ไม่นึกฝันเลยว่า ไม้ตายนี้จะต้องถูกนำมาใช้เพื่อต่อกรกับเทพเจ้าที่แท้จริง...แม้ว่าจะเป็นเพียงแค่ร่างจำแลงก็ตามที...","ทันทีที่ลินน์สับคันโยก คลื่นพลังเวทอันรุนแรงก็ปะทุขึ้น โดยมีกระแสไฟฟ้าปริมาณมหาศาลที่ถูกกักเก็บไว้ในหินอสนีบาตถูกดึงออกมาใช้ ซึ่งทำให้รูนบนรางปืนสว่างวาบขึ้นทีละตัว ก่อกำเนิดสนามแม่เหล็กอันทรงพลังที่พันธนาการลูกปืนใหญ่ขนาดเท่าหัวคนไว้ตรงกลางอย่างแน่นหนา...","เนื่องจากเวลาในการวิจัยยังมีจำกัด ปืนใหญ่แม่เหล็กไฟฟ้ารุ่นทดลองนี้จึงสามารถเร่งความเร็วกระสุนได้เพียงประมาณเจ็ดเท่าของความเร็วเสียงเท่านั้น","แม้ว่ามันจะเป็นพลังทำลายล้างที่น่าสะพรึงกลัว แต่มันก็ยังห่างไกลจากขีดจำกัดสูงสุดของมันอยู่อีกมาก!","“ทุกคน ใช้เวทโซ่สายฟ้า!”","ลินน์ตะโกนลั่น พร้อมยื่นมือออกไปร่ายเวท ซึ่งทำให้มีกระแสไฟฟ้าจำนวนมากฟาดเข้าใส่รูนรับกระแสไฟฟ้าในทันที","ฟูล่าและคนอื่นๆ เข้าใจถึงความตึงเครียดของสถานการณ์ดี พวกเขาจึงลงมือทำตามโดยไม่ลังเล ซึ่งมีพ่อมดฝึกหัดและพ่อมดหลายร้อยคนจากทั้งสถาบันต่างทุ่มเทปล่อยพลังเวททั้งหมดที่มีลงในปืนใหญ่แม่เหล็กไฟฟ้า","รางปืนยาวที่เปลี่ยนเป็นสีแดงฉานจากอุณหภูมิ และความผันผวนของพลังเวทที่รุนแรงขึ้นเรื่อยๆ มันจึงเปิดเผยตำแหน่งของพวกเขาในที่สุด...","ร่างจำแลงของเทพธิดาที่ลอยตระหง่านอยู่บนฟากฟ้าหันขวับมามองทันที","ห้วงเวลาคล้ายกับไหลย้อนกลับไปเมื่อสองปีก่อน ซึ่งลินน์นั้นก็จำได้อย่างแม่นยำ ว่าตอนที่เขาหลบหนีออกจากจักรวรรดิเซคัสด้วยเรือ เขาก็เคยเผชิญหน้ากับเหตุการณ์เช่นนี้มาแล้ว","ในตอนนั้น เขาทำได้เพียงหนีเอาชีวิตรอดอย่างทุลักทุเลโดยอาศัยทะเลหมอกคอยช่วยเหลือ แต่ตอนนี้...ลินน์ก็แค่อยากจะอัดนางให้ยับ!","“องค์พระผู้เป็นเจ้าผู้ยิ่งใหญ่เสด็จมาแล้ว!”","ในขณะนี้ ณ จัตุรัสใจกลางเมืองหลวง ผู้ศรัทธานับหมื่นคนกำลังคุกเข่ากราบอยู่บนพื้นอย่างภักดี และสวดอ้อนวอนอย่างต่อเนื่อง ซึ่งแสดงความปีติยินดีด้วยการจุมพิตลงบนผืนดินใต้ฝ่าเท้า","โลซัคยืนโดดเดี่ยวอยู่กลางจัตุรัส หลังจากปลดปล่อยพลังของตราสัญลักษณ์ศักดิ์สิทธิ์ เขาก็ทำได้เพียงควบคุมร่างจำแลงนั้นผ่านสายใยบางเบา ซ้ำยังสูญเสียความสามารถในการใช้พลังศักดิ์สิทธิ์ไปจนหมดสิ้น","แต่มันไม่สำคัญอีกต่อไป!","เพราะพระประสงค์ของพระผู้เป็นเจ้าได้ลงมาจุติแล้ว!","ผ่านทางเนตรแห่งเทพที่เชื่อมต่อกับตราสัญลักษณ์ศักดิ์สิทธิ์ โลซัคจึงค้นพบเป้าหมายอย่างรวดเร็ว ซึ่งเป็นจอมเวทผู้ยิ่งใหญ่แอนโธนีที่กำลังรวมตัวอยู่กับบรรดาลูกศิษย์บนถนนสายหนึ่งทางทิศตะวันตกของเมืองหลวง","ฮัตตาร์ก็อยู่ที่นั่นด้วย นอกจากนี้ยังมีพ่อมดหนุ่มที่ปรากฏตัวพร้อมเวทจำลองร่าง ซึ่งน่าจะเป็นลินน์ที่ศาสนจักรต้องการตัว","ถือโอกาสนี้กำจัดพวกมันไปพร้อมๆ กันเลย!","รังสีอำมหิตและโทสะวาบผ่านดวงตาของโลซัค เขาหลับตาลงและอธิษฐานขอให้องค์พระผู้เป็นเจ้าผู้ยิ่งใหญ่ประทานทัณฑ์แก่พวกคนบาปเหล่านั้น","ร่างจำแลงของเทพธิดาที่หยุดนิ่งอยู่บนท้องฟ้าก็ยกมือขวาขึ้น ก่อนที่นิ้วชี้ที่เรียวยาวราวกับหยกจะทะลวงผ่านกำแพงมิติและกาลเวลา มาปรากฏอยู่เบื้องหน้าของทุกคนในพริบตา","นิ้วชี้ที่ใหญ่มหึมาราวกับภูผาก็ได้กดทับลงมาจากเบื้องบน ประหนึ่งกำลังจะบดขยี้มดปลวกให้ตายคาที่","แต่มดปลวกก็ยังมีเขี้ยวเล็บ แอนโธนีนั้นก้าวออกมาข้างหน้าหนึ่งก้าว พร้อมร่ายเวทป้องกันที่ทรงพลังที่สุดเท่าที่เขาเคยเรียนรู้มา","พลังเวทแปรสภาพอย่างรวดเร็วกลายเป็นเกล็ดงูเรียงซ้อนกัน ก่อตัวเป็นโดมครึ่งวงกลมเพื่อปกป้องทุกคน ก่อนจะปะทะเข้ากับนิ้วชี้ขนาดมหึมา","แต่ม่านเกล็ดงูอันแข็งแกร่งกลับยุบตัวลงทันที พร้อมกับมีรอยร้าวเล็กๆ ปรากฏขึ้น และแตกกระจายออกเป็นเสี่ยงๆ ในเวลาเพียงเสี้ยววินาที","ภายใต้แรงสะท้อนกลับของพลังเวทอันมหาศาล ร่างของแอนโธนีก็สั่นสะท้านอย่างรุนแรง แต่โชคดีที่ในจังหวะนั้น ลำแสงสีฟ้าครามสองสายก็ได้พุ่งทะยานผ่านไป ซึ่งทะลวงผ่านดัชนีที่พยายามจะบดขยี้พวกเขาจนแหลกละเอียด","เป็นปืนใหญ่แม่เหล็กไฟฟ้าอีกสองกระบอกภายใต้การควบคุมของฟิลิปและธีโอดอร์ที่เปิดฉากโจมตีก่อน!","แต่บาดแผลที่เกิดขึ้นกลับมีจำกัดยิ่งนัก ไม่มีเลือดไหลริน ไม่มีเศษเนื้อปลิวว่อน เพราะสิ่งที่ทะลวงผ่านนั้นเป็นเพียงแค่ภาพลวงตา และนิ้วที่ถูกเจาะทะลุก็สมานตัวกลับมาด้วยความเร็ว จากนั้น นิ้วชี้ก็แปรเปลี่ยนเป็นฝ่ามือ พร้อมด้วยแสงศักดิ์สิทธิ์อันเข้มข้นและรุนแรงก็ได้แผ่พุ่งออกมาจากฝ่ามือนั้น","ซึ่งทำให้รัศมีที่ถูกฝ่ามือปกคลุมได้แปรเปลี่ยนเป็นอาณาเขตปิดตาย โดยที่อากาศภายในนั้นถูกอัดแน่นและเต็มไปด้วยแรงกดดันอันหนักหน่วง จนทำให้การหายใจนั้นกลายเป็นเรื่องที่ยากลำบากอย่างยิ่ง...","และในเวลาเดียวกันนั้นเอง ปืนใหญ่แม่เหล็กไฟฟ้าที่ตั้งอยู่ตรงกลางก็พร้อมยิงในที่สุด!","ด้วยการรวบรวมพลังเวทจากพ่อมดนับร้อย กระสุนซึ่งถูกพันธนาการไว้ด้วยแรงแม่เหล็กอย่างแน่นหนาก็เปล่งเสียงคำรามกึกก้องไปทั่วฟ้าดิน ภายใต้การควบคุมของลินน์ มันพุ่งทะยานเข้าหาฝ่ามือที่บดบังท้องฟ้าด้วยความเร็วที่ไม่อาจมองตามทัน..."]},{"n":306,"t":"แสงที่บิดเบือนเวลาและปืนใหญ่แม่เหล็กไฟฟ้า","c":["ความเร็ว 25 เท่าของความเร็วเสียง!","ในวินาทีที่กระสุนพุ่งออกจากลำกล้อง ปัญญาประดิษฐ์สนับสนุนได้คำนวณความเร็วขาออกไว้เรียบร้อยแล้ว การผสานรวมระหว่างเวทมนตร์และเทคโนโลยีปะทุขึ้นด้วยพลังที่ไม่อาจจินตนาการได้ ส่งผลให้พลังทำลายล้างของปืนใหญ่แม่เหล็กไฟฟ้าก้าวขึ้นสู่ระดับใหม่!","เสียงโซนิคบูมที่เกิดขึ้นในเสี้ยววินาทีทำลายแผ่นกระเบื้องและผนังดินของบ้านเรือนโดยรอบจนพังยับเยิน ฟูล่า เพียร์ซ และคนอื่นๆ ที่อยู่ใกล้มากต่างถูกแรงปะทะกระแทกลงไปกองกับพื้น มือทั้งสองข้างปิดหูไว้แน่น...","ในขณะเดียวกันบนท้องฟ้า ลำแสงที่ส่องประกายพุ่งเข้าปะทะกับฝ่ามือที่บดบังท้องฟ้า กระสุนโลหะแข็งแกร่งถูกความร้อนสูงเผาจนกลายเป็นสีแดงฉาน บนพื้นผิวของทรงกลมสลักอักขระเวทมนตร์เสริมพลังทั้งการทลายเวท ความคม และความแข็งแกร่งไว้โดยรอบ","ภาพที่เห็นราวกับก้อนกรวดพุ่งชนภูเขาลูกใหญ่ ทว่าผลลัพธ์กลับตาลปัตรอย่างสิ้นเชิง ในจังหวะที่ปะทะกัน ฝ่ามือข้างนั้นกลับบอบบางราวกับกระดาษ ไม่สามารถแม้แต่จะขวางกั้นมันไว้ได้แม้แต่น้อย แต่กลับถูกเจาะทะลวงอย่างง่ายดาย... ลำแสงสีแดงฉานพุ่งผ่านไป โดยมีเป้าหมายคือใจกลางหน้าผากของร่างจำแลงแห่งพระผู้เป็นเจ้า!","ราวกับสัมผัสได้ถึงภัยคุกคามจากอาวุธชิ้นนี้ แสงสว่างเจิดจ้ามากมายพลันพวยพุ่งออกมาจากร่างศักดิ์สิทธิ์นั้น","ระยะห่างจากจุดยิงของปืนใหญ่แม่เหล็กไฟฟ้าไปยังกึ่งกลางระหว่างคิ้วของร่างเทพนั้นมีเพียง 700 เมตร สำหรับกระสุนที่มีความเร็ว 25 เท่าของความเร็วเสียง มันใช้เวลาเดินทางเพียง 0.08 วินาทีเท่านั้น!","ทว่าการเดินทางนี้กลับยาวนานอย่างน่าประหลาด ความเร็วของกระสุนปืนใหญ่แม่เหล็กไฟฟ้าค่อยๆ ลดลงจนมองเห็นได้ด้วยตาเปล่า จากยี่สิบห้าเท่าเหลือยี่สิบเท่า สิบห้าเท่า และสุดท้ายเหลือเพียงเก้าเท่าของความเร็วเสียง!","ลินน์ผู้ฝึกฝนสนามพลังเบี่ยงเบนเข้าใจในทันทีว่า นี่ไม่ใช่เพราะความเร็วของปืนใหญ่แม่เหล็กไฟฟ้าลดลง แต่เป็นเพราะมิติและเวลาต่างหากที่กำลังบิดเบี้ยวในขณะนี้!","การที่มันช้าลงเป็นเพียงปรากฏการณ์ของการบิดเบือนมิติและเวลาเท่านั้น!","แต่ถึงกระนั้น พลังทำลายล้างที่น่าสะพรึงกลัวของปืนใหญ่แม่เหล็กไฟฟ้าก็ยังคงเจาะทะลุเกราะป้องกันที่สร้างขึ้นจากแสงศักดิ์สิทธิ์ได้อย่างง่ายดาย และพุ่งตรงผ่านเปลือกนอกที่เป็นส่วนประกอบของร่างจำแลงเทพไป","สิ่งที่ต่างออกไปคือเสี้ยววินาทีนั้นทำให้ร่างเงาของเทพธิดาเบี่ยงออกไปเพียงไม่กี่เซนติเมตร จึงไม่ถูกจุดกึ่งกลางระหว่างคิ้ว และทำให้ตราสัญลักษณ์ศักดิ์สิทธิ์ที่กำลังสั่นไหวอยู่ท่ามกลางความว่างเปล่านั้นรอดพ้นไปได้","โลซัคผู้เฝ้ามองฉากนี้ผ่านเนตรแห่งเทพถึงกับถอนหายใจด้วยความโล่งอก ตราบใดที่แกนกลางยังไม่ได้รับความเสียหาย ส่วนที่เหลือก็สามารถซ่อมแซมได้ด้วยวิชาศักดิ์สิทธิ์","น่าเสียดายที่โลซัคลืมไปว่าปืนใหญ่แม่เหล็กไฟฟ้าไม่ได้มีแค่กระบอกเดียว!","ลินน์ไม่ใช่คนไร้เดียงสาถึงขนาดจะฝากทุกอย่างไว้กับการโจมตีครั้งเดียว!","ห่างกันไม่ถึงหนึ่งวินาที ปืนใหญ่แม่เหล็กไฟฟ้าอีกสองกระบอกที่เล็งไว้ก่อนหน้าก็คำรามลั่น คราวนี้แม้จะไม่มีพลังเวทจากพ่อมดหลายร้อยคนช่วยหนุน ทำให้ความเร็วของกระสุนช้าลงกว่าเดิมมาก แต่ก็ยังมีความเร็วสูงถึงเจ็ดเท่าของความเร็วเสียง!","ด้วยการสนับสนุนจากพลังประมวลผลอันมหาศาลของเหล่าพ่อมด กระสุนทั้งสองเปรียบเสมือนด้ายเงินที่พุ่งเข้าปะทะกับตราสัญลักษณ์ศักดิ์สิทธิ์ขนาดเล็กได้อย่างแม่นยำ","“ไม่!” โลซัคแผดเสียงร้องโหยหวนอย่างเจ็บปวด","แรงแม่เหล็กไฟฟ้าที่ความเร็วเจ็ดเท่าของความเร็วเสียงนั้นเทียบเท่ากับเวทมนตร์ระดับหกวงแหวน ต่อให้ตราสัญลักษณ์ศักดิ์สิทธิ์จะทำขึ้นจากกระดูกนิ้วของนักบุญองค์แรก ก็ไม่อาจต้านทานแรงปะทะอันรุนแรงนี้ได้ และแตกสลายลงในทันที","กระสุนความเร็วเหนือเสียงสองนัดปะทะเข้าหากัน คลื่นเสียงและแรงระเบิดรุนแรงดังกึกก้องไปทั่วทั้งเมืองหลวง เมืองทั้งเมืองสั่นสะเทือนภายใต้แรงกระแทกอันรุนแรง","แสงจากเนตรแห่งเทพหรี่เลือนลงอย่างรวดเร็ว และร่างจำแลงขนาดมหึมาของเทพก็เริ่มแตกสลาย ราวกับกระจกที่ร้าวราน มันค่อยๆ ลอกลอกออกทีละส่วนจนกลายเป็นจุดแสงสว่างไสว ก่อนจะเลือนหายไปในความว่างเปล่า...","สิ่งที่ถูกทำลายไปพร้อมกันนั้น คือดวงจิตของโลซัคที่สถิตอยู่ในตราสัญลักษณ์ศักดิ์สิทธิ์","จิตสำนึกของโลซัคกำลังถูกดึงออกไปทีละน้อย เลือดสีแดงสดทะลักออกจากมุมปากของเขา แววตาเต็มไปด้วยความสิ้นหวังและความไม่ยินยอม...","จัตุรัสทั้งแห่งตกอยู่ในความเงียบงันราวกับป่าช้า ผู้ศรัทธาที่เคร่งครัดนับหมื่นคนซึ่งเมื่อครู่ยังตะโกนร้องด้วยความตื่นเต้นให้องค์พระผู้เป็นเจ้าลงทัณฑ์พวกคนบาป กลับต้องมาเห็นร่างจำแลงแห่งเจตจำนงของพระองค์ถูกทำลายลงด้วยลำแสงพราวระยับไม่กี่สาย","“พระผู้เป็นเจ้าพ่ายแพ้งั้นหรือ?” “เป็นไปไม่ได้! นี่ต้องเป็นภาพลวงตา นี่ต้องเป็นภาพลวงตาแน่ๆ!”","เสียงกรีดร้องด้วยความหวาดกลัวดังระงมไปทั่วจัตุรัส ผู้คนนับไม่ถ้วนที่ความเชื่อพังทลายลงต่างพากันตะโกนอย่างเสียสติว่าสิ่งที่เห็นเป็นเพียงภาพหลอน หรือไม่ก็เอาแต่โขกหัวลงกับพื้นด้วยความสิ้นหวัง แต่ถึงกระนั้นก็ไม่อาจเปลี่ยนผลลัพธ์ที่เกิดขึ้นได้","ร่างจำแลงเจตจำนงแห่งพระผู้เป็นเจ้าถูกทำลายลงแล้ว!","“ในที่สุด...” ลินน์ถอนหายใจออกมาด้วยความโล่งอกเมื่อเห็นร่างจำแลงอันน่าสะพรึงกลัวนั้นเลือนหายไปในความว่างเปล่า","เขารู้ดีว่าตนเองไม่มีความมั่นใจมากนักในการเอาชนะเมื่อครู่ เขาเพียงแค่เกร็งทำหน้าตายต่อหน้าแอนโธนีและคนอื่นๆ เท่านั้น แต่โชคดีที่เขาตัดสินใจขนอาวุธสังหารชิ้นนี้มาล่วงหน้าเพราะอุบัติเหตุที่เกิดขึ้น ไม่อย่างนั้นพวกเขาคงทำได้เพียงถอยทัพออกจากเมืองหลวงด้วยความผิดหวัง และทุกสิ่งที่ทำมาทั้งหมดก็จะสูญเปล่า","“นี่คือเวทมนตร์ประเภทใดกัน? ดูเหมือนจะเกี่ยวข้องกับแม่เหล็กไฟฟ้าหรือ?” แอนโธนีที่ยังไม่อาจดึงสติกลับมาจากลำแสงที่สามารถทำลายล้างทุกสิ่งได้ เอ่ยถามอย่างไม่หยุดหย่อน","“สิ่งนี้เรียกว่า ปืนใหญ่แม่เหล็กไฟฟ้า!” ลินน์ตอบพร้อมรอยยิ้ม","“ใช้แรงแม่เหล็กอันแข็งแกร่งที่เกิดจากกระแสไฟฟ้าในการผลักดันกระสุนอย่างนั้นหรือ?” แอนโธนีผู้ซึ่งเพิ่งเริ่มศึกษาบทสมการของแมกซ์เวลล์วิเคราะห์หลักการของมันได้อย่างรวดเร็ว","ในอดีต เขาเคยใช้พลังแห่งอสนีบาตโดยตรงในการสังหารศัตรู แต่เขาไม่เคยคิดฝันเลยว่าเวทมนตร์แม่เหล็กไฟฟ้าจะสามารถนำมาประยุกต์ใช้ได้ถึงเพียงนี้ แถมพลังของมันยังร้ายกาจอย่างยิ่ง","“ถูกต้องแล้ว” ลินน์พยักหน้าโดยไม่ได้อธิบายรายละเอียดมากเกินไป ท้ายที่สุดแล้ว พวกเขายังมีเรื่องยุ่งยากอีกมากมายที่ต้องเร่งจัดการในคืนนี้","เมื่อลินน์และคนอื่นๆ มาถึงจัตุรัส สถานการณ์ที่วุ่นวายก็ถูกควบคุมไว้ได้โดยกองพลปืนคาบศิลาที่นำโดยเรย์เดล แม้จะมีผู้ศรัทธาจำนวนมาก แต่ทั้งหมดต่างก็ขวัญเสียและไม่มีใครคิดจะขัดขืนอีกต่อไป","ส่วนอาปูที่หายตัวไปนั้นถูกพบตัวแล้ว แต่ร่างของเขากลับเย็นชืดไปเสียแล้ว หลังจากตรวจสอบ ลินน์ก็ยืนยันได้ในที่สุดว่าอีกฝ่ายถูกควบคุมร่างอยู่จริงๆ","“ท่านลินน์ เราควรจัดการกับชาวเมืองเหล่านี้อย่างไรดี?” เรย์เดลหันมาถามด้วยความกังวลเล็กน้อย เขาเกรงว่าลินน์จะสั่งประหารคนทั้งหมด แต่ในใจเขาก็รู้ดีว่าการปล่อยคนเหล่านี้ไว้จะเป็นภัยแฝงขนาดไหน","“ควบคุมตัวไว้ก่อน แล้วค่อยตัดสินใจหลังจากสอบสวนอีกครั้ง” ลินน์กล่าวหลังครุ่นคิดชั่วครู่","ต้องบอกว่าการที่โลซัครวบรวมผู้ศรัทธาที่เคร่งครัดมาไว้ในจัตุรัสจำนวนมากเช่นนี้ ช่วยเขากำจัดเสี้ยนหนามก้อนโตไปได้มาก หากคนคลั่งศาสนาเหล่านี้แฝงตัวอยู่ในเมืองหลวงและคอยแอบเคลื่อนไหว ก็อาจจะสร้างปัญหาเล็กๆ น้อยๆ ให้พวกเขาจากภายในได้","ตอนนี้ดีแล้วที่ปัญหาทั้งหมดโผล่ออกมาพร้อมกัน จะได้แก้ไขไปคราวเดียว!","ผู้ที่ยอมรับการปรับทัศนคติจะยังคงได้เป็นพลเมืองของเมืองหลวงต่อไป และเขาจะไม่เอาความเรื่องในอดีต","ส่วนพวกที่ถูกล้างสมองจนกู่ไม่กลับ... ก็นำไปใช้ประโยชน์ในการสร้างสะพานและถนนเพื่อวางรากฐานโครงสร้างพื้นฐานเสียสิ!","แรงงานของคนนับหมื่นจะไม่เสียเปล่าอย่างแน่นอน!"]},{"n":307,"t":"แม้แต่ทวยเทพก็ยังต้องร่วงหล่นภายใต้พลังแห่งเวทมนตร์และเทคโนโลยี!","c":["เวลาหนึ่งวันผ่านไปอย่างรวดเร็ว ภายใต้การควบคุมร่วมกันระหว่างกองทหารองครักษ์ที่ยอมสวามิภักดิ์และหน่วยพลปืนคาบศิลา ความวุ่นวายในเมืองหลวงก็สงบลงในที่สุด","ศาสนจักรถูกทำลายล้างโดยตรง นักบวชทั้งหมดที่อยู่ภายในถูกจับกุมและประหารชีวิต แม้แต่องค์ชายใหญ่แฮโรลด์ก็ไม่อาจหนีรอดจากการไล่ล่า เพราะในขณะที่เขาพยายามหลบหนีออกจากเมืองหลวงท่ามกลางความชุลมุน เขาก็ถูกระดมยิงด้วยปืนคาบศิลาเข้าที่หน้าอกจนสิ้นใจตายคาที่อย่างหมดทางรอด","และฮัตตาร์ก็ประกาศต่อโลกภายนอกในทันทีว่า ต้นตอที่ก่อให้เกิดความวุ่นวายในเมืองหลวงจนส่งผลให้มีผู้เสียชีวิตจำนวนมากได้ถูกประหารแล้ว และในวันรุ่งขึ้น เขาก็ได้ขึ้นครองบัลลังก์อย่างเร่งด่วนท่ามกลางสายตาของกลุ่มขุนนางที่ร่วมเป็นพยาน จากนั้นจึงเริ่มปูนบำเหน็จรางวัลอย่างงาม!","ขุนนางบางส่วนที่แสดงความสนับสนุนล้วนได้รับมอบทองคำ เงิน และดินแดน ส่วนลินน์และแอนโธนีซึ่งมีผลงานมากที่สุด ก็ได้รับการแต่งตั้งให้เป็นดยุกแห่งอาณาจักร และตามที่เคยให้สัญญาไว้ ดินแดนขนาดใหญ่ทางตะวันออกของอาณาจักรซึ่งติดกับทะเลทั้งหมดได้ถูกมอบให้เป็นอาณาเขตของพวกเขา","ดินแดนเหล่านี้เดิมทีเป็นของเอิร์ลจอยซ์และมาร์ควิสอีกหลายคนในอาณาจักร แต่ตอนนี้พวกเขาเหล่านั้นไม่ตายในสนามรบ ก็ถูกจับกุมในฐานะผู้เลือกข้างผิด เพื่อเป็นการดึงตัวพวกพ่อมดให้มาร่วมกันต่อกรกับจักรวรรดิและศาสนจักร ฮัตตาร์จึงยินดีที่จะแสดงความใจกว้างอย่างยิ่ง","สำหรับคนอื่นๆ ที่มีผลงานในศึกชิงบัลลังก์ครั้งนี้ ฮัตตาร์ก็ไม่ได้ละเลยพวกเขาแต่อย่างใด ยกตัวอย่างเช่น เรย์เดลที่ได้รับการแต่งตั้งให้เป็นเอิร์ล เพราะท้ายที่สุด เขาคือผู้นำกองกำลังเข้าโจมตีเมืองหลวงและเอาชนะกองทหารองครักษ์ประจำเมืองได้ ผลงานเช่นนี้ย่อมไม่เล็กน้อยเลย","ส่วนพลปืนคาบศิลาที่โชคดีสังหารแฮโรลด์ได้ ก็ได้กลายเป็นขุนนางและได้รับบรรดาศักดิ์เป็นไวเคานต์","“รู้สึกอย่างไรบ้างกับการได้เป็นขุนนาง เรย์เดล?”","ลินน์เอ่ยเย้า","“ไม่ดีเลยครับ ท่านลินน์ การยอมรับการแต่งตั้งจากกษัตริย์ฮัตตาร์ มันก็จะขัดแย้งกับทุกสิ่งที่เราเคยทำมาทั้งหมด พวกเรากวาดล้างขุนนางเก่าพวกนั้น เพื่อมาเป็นขุนนางใหม่เสียเองอย่างนั้นหรือ?”","เรย์เดลกล่าวด้วยน้ำเสียงสับสน","“แน่นอนว่าความพยายามของพวกเราจะไม่สูญเปล่า แต่ทุกอย่างย่อมต้องเป็นไปตามขั้นตอน จริงไหม?”","ลินน์ส่ายหน้า","ลินน์รู้สึกยินดีเล็กน้อยที่เรย์เดลยังคงยึดมั่นในอุดมการณ์เดิม และไม่ถูกสั่นคลอนจากการเปลี่ยนแปลงฐานะอย่างกะทันหัน ต่างจากในหน้าประวัติศาสตร์ ที่มีผู้คนมากมายนั้นสามารถระเบิดพลังใจอันน่าทึ่งออกมาได้ในช่วงต้นของการปฏิวัติ แต่ท้ายที่สุดก็ต้องพ่ายแพ้ต่อความเสื่อมทราม ซึ่งคือรากเหง้าของการมีอยู่ของกฎแห่งวัฏจักรประวัติศาสตร์ที่พบเห็นได้ทั่วไป...","“อีกไม่กี่วัน เจ้าค่อยแวะมาที่อิเยตาสิ ข้าคิดว่าเจ้าน่าจะค้นพบคำตอบบางอย่างได้ที่นั่น!”","ลินน์กล่าวพร้อมรอยยิ้ม","“อิเยตาหรือ?”","เรย์เดลกระซิบด้วยความปรารถนา เพราะเขาก็เคยได้ยินพวกพ่อมดพูดถึงสถานที่อันมหัศจรรย์แห่งนี้มาบ้าง","มันคือเมืองที่ถูกสร้างขึ้นโดยเหล่าพ่อมด และเปี่ยมล้นไปด้วยพลังแห่งเวทมนตร์","“ท่านลินน์! พลุที่ท่านให้พวกเราทำเตรียมไว้พร้อมหมดแล้วนะ!”","ขณะที่ทั้งสองกำลังคุยกัน ลิเดียก็รีบวิ่งเข้ามาและตะโกนด้วยความตื่นเต้น","“ตกลง ไปดูด้วยกันเถอะ!”","ลินน์พยักหน้า","ค่ำคืนนี้ เพื่อเฉลิมฉลองการขึ้นครองราชย์ของกษัตริย์องค์ใหม่ จึงมีการจัดงานเลี้ยงอันยิ่งใหญ่ขึ้นในเมืองหลวง แต่ลินน์ไม่ได้สนใจที่จะไปปั้นหน้าเสแสร้งกับพวกขุนนางเหล่านั้น เพราะเขามีวิธีเฉลิมฉลองในแบบของเขาเอง!","ในขณะนี้ จัตุรัสในเมืองหลวงเต็มไปด้วยผู้คน หลังจากต้องเดินทางรอนแรมและต่อสู้มาตลอดทั้งคืน ในที่สุดพลปืนคาบศิลาและเหล่าคนงานเหมืองก็ได้พักผ่อนอย่างเต็มที่เสียที พวกเขาจุดกองไฟตรงกลางจัตุรัส ดื่มด่ำกับเนื้อย่างและเหล้าองุ่นที่ถูกส่งมาให้ พลางพูดคุยกันถึงชัยชนะและเกียรติยศเมื่อคืนที่ผ่านมา","โดยเฉพาะพลปืนคาบศิลาที่ตามแฮมม์ไปยังคฤหาสน์ขององค์ชาย พวกเขากำลังใช้คลังคำศัพท์อันน้อยนิดที่มีเพื่อบรรยายถึงฉากอันน่าตื่นตะลึงตอนที่สายฟ้าฟาดกระหน่ำลงมา","แม้แต่ชาวเมืองหลวงบางส่วนก็มาร่วมงานด้วย ซึ่งนี่เป็นสิ่งที่ลินน์จงใจจัดเตรียมไว้เป็นพิเศษ","หลังจากการต่อสู้ในเมืองหลวงจบลง ลินน์ก็ได้ขอให้คนที่ว่างงานไปช่วยชาวเมืองที่ได้รับผลกระทบจากภัยพิบัติสร้างบ้านเรือนขึ้นใหม่ และมอบเงินชดเชยให้จำนวนหนึ่งเพื่อแลกกับความไว้วางใจจากพวกเขา","สำหรับเรื่องเงินทุน ย่อมมาจากความใจกว้างของกษัตริย์องค์ใหม่อยู่แล้ว...","ฮัตตาร์ไม่ได้ใส่ใจเรื่องความเป็นความตายของชาวเมืองเหล่านี้นัก แต่เขาก็จะไม่หักหน้าพวกลินน์เพียงเพราะเรื่องเล็กน้อยเช่นนี้","ดังนั้นเมื่องานเฉลิมฉลองจัดขึ้นในคืนนี้ ลินน์จึงให้พวกเขาไปเชิญชาวเมืองที่เคยช่วยเหลือไว้มาร่วมงานทั้งหมด","แม้ท้ายที่สุด จะมีชาวเมืองไม่ถึงหนึ่งในสี่ที่กล้าตอบรับคำเชิญ แต่นี่ก็นับเป็นจุดเริ่มต้นที่ดีอย่างไม่ต้องสงสัย เพราะการเปลี่ยนแปลงค่านิยมย่อมต้องค่อยเป็นค่อยไปเสมอ...","“ท่านลินน์...”","เมื่อเห็นร่างของลินน์ปรากฏตัว เสียงโห่ร้องยินดีก็ดังกระหึ่มขึ้นทั่วจัตุรัสทันที ทุกคนต่างลุกขึ้นยืนและแหวกทางให้เขาอย่างพร้อมเพรียง","หลังจากผ่านการต่อสู้เมื่อคืน จึงไม่มีใครไม่รู้ว่าพ่อมดผู้นี้ทรงพลังเพียงใด ซึ่งสามารถเปลี่ยนสีท้องฟ้าได้ด้วยการสะบัดมือ และเรียกสายฟ้าอันน่าสะพรึงกลัวลงมาทำลายล้างกองทหารองครักษ์นับพันนาย","แถมยังมีข่าวลืออีกว่า ร่างจำแลงแห่งพระผู้เป็นเจ้าที่ปรากฏขึ้นเหนือเมืองหลวงเมื่อวานนี้ ก็ถูกพ่อมดหนุ่มผู้นี้บดขยี้จนแหลกสลายเช่นกัน","ในสายตาของใครหลายคน ลินน์ได้กลายเป็นร่างอวตารของเทพแห่งอสนีบาต เป็นเทพเจ้าที่แท้จริง หรือไม่ก็เป็นทูตสวรรค์ไปเสียแล้ว","เมื่อมองดูสีหน้าอันตื่นเต้นของทุกคน ลินน์ก็แย้มยิ้มแล้วกล่าว","“ทุกคน นั่งลงเถิด ชัยชนะในครั้งนี้เป็นผลพวงมาจากความพยายามร่วมกันของพวกเราทุกคน พลังของทุกๆ คนล้วนเป็นสิ่งที่ขาดไม่ได้...”","“แต่พวกเจ้าต้องจดจำไว้ว่า ชัยชนะนี้เป็นเพียงแค่จุดเริ่มต้น เพราะจักรวรรดิและศาสนจักรยังคงมีอยู่ โดยพยายามที่จะทำลายชัยชนะของเรา และจะต้อนพวกเจ้าทุกคน ให้กลับเข้าไปในเหมืองอันมืดมิด ที่ซึ่งการทำงานหนักไม่อาจแลกมาซึ่งรางวัลที่คู่ควร...”","ลินน์กวาดสายตามองทุกคนที่อยู่ที่นั่น เฝ้าดูสีหน้าของพวกเขาที่ค่อยๆ แปรเปลี่ยนเป็นความโกรธแค้น","“ถ้าอย่างนั้นก็อัดพวกมันสิ!”","คนงานเหมืองที่กำลังเมามายคนหนึ่งตะโกนลั่น ราวกับเป็นการจุดชนวนระเบิดในฝูงชน ซึ่งทำให้ทั่วทั้งจัตุรัสเดือดพล่านขึ้นมาทันที ผู้คนต่างตะโกนก้องว่าจะโค่นล้มศาสนจักรและจักรวรรดิ และจะเป่าหัวพวกมันให้กระจุยด้วยปืนคาบศิลา","“ถูกต้อง! จักรวรรดิและศาสนจักรไม่มีอะไรให้น่าหวาดกลัว จงใช้ปืนคาบศิลาในมือพวกเจ้าบดขยี้พวกมันให้หมด และต่อให้เป็นทวยเทพ ก็ยังต้องร่วงหล่นภายใต้พลังอันยิ่งใหญ่ของเวทมนตร์และเทคโนโลยี!”","ลินน์ตะโกนเสียงดังกึกก้อง พร้อมชูแก้วไม้ในมือขึ้น","“ส่วนตอนนี้ จงสนุกกับงานเลี้ยงและเฉลิมฉลองชัยชนะของพวกเราเสียเถิด! จากนี้เป็นต้นไป ฐานะของพวกเจ้าไม่ใช่ทาสในเหมืองอีกต่อไป และพวกเจ้าจะไม่ถูกอาณาจักรตามล่า เพราะพวกเจ้าทุกคนล้วนเป็นอิสระแล้ว!”","เมื่อได้ยินคำพูดของลินน์ เสียงโห่ร้องยินดีดังสนั่นหวั่นไหวไปทั่วจัตุรัส ทุกคนต่างชูแก้วไม้ในมือขึ้น ปากตะโกนคำว่า “อิสรภาพจงเจริญ” และ “ช่างหัวพระเจ้าสิ” จากนั้นก็หัวเราะร่วนและกระดกเหล้าองุ่นรสแรงในแก้วลงคอ","ลินน์ส่งสัญญาณเงียบๆ ซึ่งลิเดียที่รอคอยอยู่แล้วก็รีบจุดพลุที่วางเรียงรายอยู่บนจัตุรัส","ฟิ้ว ฟิ้ว","ในไม่ช้าทุกคนในจัตุรัสก็ได้เห็นฉากอันงดงามตระการตา ลำแสงหลากสีพุ่งทะยานขึ้นสู่ท้องฟ้าก่อนจะระเบิดออก ดอกไม้ไฟสีสันสดใสราวกับช่อดอกไม้ในกลางฤดูร้อน บานสะพรั่งแต่งแต้มสีสันอันวิจิตรตระการตาอยู่บนฟากฟ้า"]},{"n":308,"t":"ดาบเปลี่ยนเป็นคันไถได้ และคันไถก็แปรเปลี่ยนเป็นดาบได้เช่นกัน!","c":["ประกายพลุสว่างวาบได้ทำลายความเงียบสงบของเมืองหลวง ซึ่งทำเอาชาวเมืองจำนวนมากที่เพิ่งผ่านพ้นไฟสงครามมาหมาดๆ คิดไปว่าสงครามได้ปะทุขึ้นอีกครั้งแล้ว และต่างหวาดผวากันไปหมด แม้จะได้มองเห็นดอกไม้ไฟอันงดงามตระการตาอยู่ภายนอกบ้าน แต่พวกเขาก็ยังอดกังวลไม่ได้ว่ามันอาจจะเป็นเวทมนตร์ประหลาดอันใดอีกหรือไม่","โชคดีที่หลังจากเฝ้ารออยู่นานก็ไม่มีทหารบุกรุกเข้ามา เหล่าพลเรือนที่เพิ่งผ่านพ้นการสู้รบมาจึงเริ่มเพลิดเพลินไปกับการแสดงพลุอันเป็นเอกลักษณ์นี้","“งดงามเหลือเกิน!”","จอห์นนี่จ้องมองท้องฟ้ายามราตรีอันสว่างไสว ที่ซึ่งดอกไม้ไฟหลากสีสันยังคงเบ่งบานอย่างต่อเนื่อง ประกายของมันสว่างไสวเสียจนบดบังแสงดาวไปจนหมดสิ้น","“สิ่งนี้ก็ทำมาจากดินปืนด้วยอย่างนั้นหรือ?”","จอห์นนี่หันหน้าไปมองลินน์ เพราะผงสีดำอันเป็นเอกลักษณ์นี้คือผงเล่นแร่แปรธาตุอันน่าสะพรึงกลัวในความทรงจำของเธอ","ไม่ว่าจะเป็นกองทหารองครักษ์ชั้นยอดนับพันนายที่ถูกกวาดล้างจนสิ้นซากในเมืองท่า หรือจะเป็นปืนคาบศิลาและปืนใหญ่ที่สามารถเจาะทะลุชุดเกราะและระเบิดก้อนหินได้ ล้วนเป็นสิ่งที่แสดงแสนยานุภาพของมันออกมาได้อย่างเต็มที่","แต่ในครั้งนี้ จอห์นนี่ได้เห็นอีกด้านหนึ่งของดินปืน โดยที่พลุเหล่านี้นั้นเปรียบเสมือนปืนใหญ่ขนาดเล็ก แต่สิ่งที่พุ่งทะยานออกมาจากพวกมันไม่ใช่กระสุนปืนใหญ่ที่มุ่งสังหารชีวิต แต่กลับเป็นช่อดอกไม้ไฟที่ส่องประกายสว่างไสวยิ่งกว่าดวงดาว...","“ดาบสามารถเปลี่ยนเป็นคันไถได้ และคันไถก็สามารถแปรเปลี่ยนเป็นดาบได้เช่นกัน ทั้งหมดนี้ขึ้นอยู่กับว่าผู้มีสติปัญญาต้องการจะใช้งานมันอย่างไร!”","ลินน์เอ่ยพร้อมรอยยิ้ม","“มันก็เหมือนกับเวทสายฟ้า ที่เจ้าสามารถใช้มันเพื่อสังหารคน และก็สามารถใช้มันเพื่อส่องสว่างในยามค่ำคืนได้เช่นกัน...”","“บางทีสักวันหนึ่ง หากโลกนี้ไม่มีสงครามอีกต่อไป คงจะมีพ่อมดอีกมากมายที่ยินดีจะเรียนรู้เวทมนตร์สายก่อสร้างเหล่านี้ และใช้พลังเวทมนตร์เพื่อยกระดับคุณภาพชีวิตของทุกคน”","ลินน์กล่าวด้วยความซาบซึ้ง","ในอนาคต อาจจะมีพ่อมดสถาปัตยกรรมผู้เชี่ยวชาญด้านอัตราส่วนซีเมนต์และโครงสร้างเหล็ก หรือพ่อมดวิศวกรรมผู้เชี่ยวชาญด้านการผลิตและบำรุงรักษาเครื่องมือต่างๆ","“จะต้องมีวันนั้นอย่างแน่นอน!”","จอห์นนี่กล่าวด้วยความมั่นใจ เพราะทุกสิ่งที่ลินน์เคยกล่าวไว้ล้วนกลายเป็นจริงแล้วในตอนนี้ และเธอก็เชื่อว่าวันนั้นคงอยู่ไม่ไกลเกินรอ","“ศาสตราจารย์ลินน์ ท่านจะไม่มาดื่มด้วยกันสักหน่อยหรือ?”","เอล็อคและคนอื่นๆ ที่จับกลุ่มกันอยู่รอบกองไฟโบกมือทักทาย","ลิเดียซึ่งอยู่ด้านข้างแทรกตัวกลมกลืนไปกับฝูงชนอย่างเป็นกันเอง โดยเธอร่วมแบ่งปันเหล้าองุ่นกับเหล่าทหาร และกระดกเหล้าแก้วใหญ่ลงคอ ซึ่งเรียกเสียงปรบมือเกรียวกราวจากทุกคน","ร่างนี้ไม่สามารถดื่มเหล้าได้...ลินน์นึกอยากจะปฏิเสธ แต่เมื่อคิดดูอีกที เขาก็ไม่อยากทำลายบรรยากาศอันสนุกสนานของทุกคน จึงเดินเข้าไปร่วมวงด้วยรอยยิ้ม","ในยามปกติ พวกเขามักจะถูกปั่นหัวด้วยคำถามแปลกประหลาดที่ศาสตราจารย์มอบให้อยู่เสมอ เมื่อตอนนี้มีโอกาส พวกเขาย่อมต้องการที่จะเอาคืนเป็นธรรมดา","ลินน์รู้ทันความคิดอันซุกซนของเอล็อคและคนอื่นๆ เป็นอย่างดี แต่เขาก็ไม่เคยปฏิเสธ ซึ่งดื่มแก้วแล้วแก้วเล่าโดยที่สีหน้าไม่ได้เปลี่ยนไปเลยแม้แต่น้อย","แท้จริงแล้ว เหล้าทั้งหมดนี้ได้ถูกเขาแอบใช้เวทมนตร์ย่อยสลายจนกลายเป็นธาตุพื้นฐานไปหมดแล้ว ใครใช้ให้เขาเป็นเพียงเวทจำลองร่างในตอนนี้กันล่ะ ต่อให้อยากดื่มแค่ไหนก็ไม่อาจดื่มได้อยู่ดี","จนกระทั่งมีใครบางคนนึกขึ้นได้ว่า ตอนนี้ท่านศาสตราจารย์น่าจะยังอยู่ที่อิเยตา แต่มันก็สายเกินไปเสียแล้ว เอล็อคและคนอื่นๆ ที่เมามายต่างก็ล้มพับกองกันไปเป็นแถบ","วันรุ่งขึ้น เมื่อแสงแรกแห่งยามเช้าสาดส่องลงมายังเมืองหลวง เรย์เดลก็ตื่นขึ้น เขาถูศีรษะที่ปวดตุบจากอาการเมาค้างเพราะดื่มหนักไปเมื่อวาน ซึ่งรอบกายก็รายล้อมไปด้วยกลิ่นเหล้าคละคลุ้ง","บนพื้นกระเบื้องของจัตุรัสนั้นเต็มไปด้วยเหล่าคนงานเหมืองหน้าแดงก่ำและนอนแผ่หลาอย่างไม่สนใจภาพลักษณ์อยู่บนพื้นสกปรกที่เต็มไปด้วยคราบเหล้า พร้อมกับส่งเสียงกรนดังสนั่น","เรย์เดลก้าวไปข้างหน้าเพื่อปลุกแฮมม์และคนอื่นๆ จากนั้นก็ขอให้พวกเขาไปไล่ปลุกคนอื่นๆ ทีละคน เพื่อให้มาช่วยกันทำความสะอาดจัตุรัสที่เละเทะแห่งนี้","ลินน์เดินทางไปยังพระราชวังตั้งแต่เช้าตรู่ เพื่อหารือเกี่ยวกับภารกิจต่อไป","แม้ว่าการต่อสู้จะจบลงแล้ว แต่ก็ยังมีอีกหลายสิ่งที่ต้องจัดการภายในอาณาจักร ตัวอย่างเช่น โบสถ์ในแต่ละเขตแดนที่ยังคงถูกคุ้มกันโดยเหล่านักบวชและบิชอป","นั่นหมายความว่าพวกเขาจะต้องเร่งจัดการกับปัญหาภายในเหล่านี้ให้มากที่สุดเท่าที่จะทำได้ก่อนที่ข่าวจะแพร่สะพัดออกไป เพื่อเตรียมความพร้อมสำหรับสงครามครั้งต่อไปกับจักรวรรดิและศาสนจักร","“แต่อาณาจักรของเรานั้นกว้างใหญ่ยิ่งนัก น่าจะมีดินแดนที่มีโบสถ์ตั้งอยู่ไม่ต่ำกว่า 200 แห่ง การจะกำจัดพวกมันในระยะเวลาอันสั้นย่อมไม่ใช่เรื่องง่ายเลย”","มาร์ควิสการ์ด ซึ่งเพิ่งได้รับการเลื่อนตำแหน่งเป็นอัครมหาเสนาบดีแห่งอาณาจักร เอ่ยพลางขมวดคิ้ว","“เราสามารถใช้ประโยชน์จากความเร็วของเรือเหาะ ร่วมมือกับลอร์ดในพื้นที่ต่างๆ เพื่อใช้ยุทธวิธีเด็ดหัว ซึ่งใช้พ่อมดเพียงไม่กี่คนและหน่วยพลปืนคาบศิลา 100 นายก็พอแล้วที่จะบดขยี้โบสถ์หนึ่งแห่งให้ราบคาบ!”","ลินน์กล่าวด้วยน้ำเสียงทุ้มต่ำ","“หากเราทำได้รวดเร็วพอ ดินแดนทั้งหมดในเขตใจกลางอาณาจักรก็จะตกอยู่ภายใต้การควบคุมของเราภายในไม่กี่วัน ส่วนพื้นที่อื่นๆ เราคงต้องค่อยๆ จัดการไป”","“บางทีเราอาจจะพิจารณาปล่อยข่าวลวงบางอย่าง เพื่อล่อลวงให้บิชอปเหล่านั้นเดินทางมายังเมืองหลวง”","แอนโธนีเสนอแนะ","ดวงตาของฮัตตาร์เป็นประกายขึ้นมาทันที นี่นับว่าเป็นความคิดที่ดีทีเดียว","แม้ว่าการต่อสู้ในเมืองหลวงเมื่อสองวันก่อนจะดุเดือดเลือดพล่าน โดยมีทั้งเกลียวคลื่นสายฟ้าและร่างจำแลงของเทพปรากฏขึ้น แต่เนื่องจากการปิดกั้นข่าวสารอย่างรัดกุม ผลลัพธ์สุดท้ายของสงครามจึงยังคงถูกจำกัดอยู่แค่ในขอบเขตของเมืองหลวงเท่านั้น","เกรงว่าคนของศาสนจักรในเขตแดนต่างๆ คงไม่มีทางจินตนาการได้เลยว่า เมืองหลวงอันกว้างใหญ่จะถูกตีแตกได้ภายในชั่วข้ามคืน และโลซัคที่ซึ่งถือครองความได้เปรียบอย่างสมบูรณ์แบบจะจบชีวิตลงอย่างง่ายดายเช่นนี้ แล้วหากพวกเขาสามารถล่อลวงพวกมันมาที่เมืองหลวงได้...","ท่ามกลางการปรึกษาหารือของทุกคน แผนการถอนรากถอนโคนศาสนจักรออกจากอาณาจักรอย่างสมบูรณ์ก็ถูกร่างขึ้นอย่างรวดเร็ว โดยหลักๆ แล้ว ปฏิบัติการเด็ดหัวและแผนล่อลวงจะถูกดำเนินไปพร้อมๆ กัน ซึ่งขึ้นอยู่กับระยะห่างระหว่างแต่ละดินแดนกับเมืองหลวง รวมถึงความแข็งแกร่งของโบสถ์ในท้องถิ่นนั้นๆ ว่าควรจะล่อพวกมันมาที่เมืองหลวง หรือจะส่งคนไปสังหารทิ้งโดยตรง","“ถ้าเช่นนั้น เราควรจะปิดบังเรื่องการสวรรคตของฝ่าบาทไว้ก่อนดีหรือไม่?”","ขุนนางแห่งอาณาจักรผู้หนึ่งเสนอขึ้นอย่างกะทันหัน","ทั้งโถงพลันเงียบกริบจนแทบจะได้ยินเสียงเข็มตกพื้น แม้ว่าข้อเสนอนี้อาจจะเป็นการล่วงเกินกษัตริย์ฮัตตาร์องค์ปัจจุบัน แต่มันก็ถือเป็นวิธีหนึ่งที่ใช้ได้จริง","หากแสร้งทำเป็นว่ากษัตริย์บาเซลยังคงมีชีวิตอยู่ และอาณาจักรยังคงเชื่อฟังคำสั่งของจักรวรรดิ บางทีสงครามครั้งนี้อาจถูกยืดเวลาออกไปหรือกระทั่งหลีกเลี่ยงได้เลย","เพราะจักรวรรดิและศาสนจักรนั้นเปรียบเสมือนภูเขาสูงตระหง่าน ที่เพียงพอจะบดขยี้ทุกคนให้แหลกสลาย","สีหน้าของฮัตตาร์ดูย่ำแย่อย่างถึงที่สุด เขาไม่เห็นด้วยกับข้อเสนอนี้เลยแม้แต่น้อย เพราะนั่นหมายความว่าตัวเขาซึ่งเป็นกษัตริย์ จะยังไม่ได้รับการยอมรับจากพสกนิกรในอาณาจักรไปอีกเป็นเวลานาน","“ข้าเกรงว่ามันคงจะยาก การตายของพระคาร์ดินัลไม่น่าจะปิดบังไว้ได้นานหรอก”","ลินน์ส่ายหน้าและปฏิเสธข้อเสนอนั้นทันที","หากพวกเขาสามารถจับเป็นได้โดยตรงแบบเดียวกับนูเออร์ แล้วทำการปิดกั้นประสาทสัมผัสทั้งห้าและจองจำเอาไว้ บางทีอาจจะพอยับยั้งไม่ให้อีกฝ่ายหวนคืนสู่อาณาจักรแห่งพระผู้เป็นเจ้าในรูปแบบของวิญญาณได้","ยิ่งไม่ต้องพูดถึงเลยว่า ก่อนหน้านี้โลซัคได้ทำการอัญเชิญร่างจำแลงของตัวตนผู้นั้นให้มาจุติแล้ว ป่านนี้พวกเบื้องบนของศาสนจักรก็คงจะได้รับเทวโองการและทราบข่าวการล่มสลายของอาณาจักรแล้วเช่นกัน","และศาสนจักรย่อมไม่มีทางยอมปล่อยให้อาณาจักรใดหลุดพ้นจากการควบคุมของตนไปได้หรอก..."]},{"n":309,"t":"ก้าวข้ามสู่จอมเวทผู้ยิ่งใหญ่!","c":["ในช่วงบ่ายของวันที่สามหลังสิ้นสุดสงครามในเมืองหลวง เรือเหาะที่บรรทุกทหารและเหล่าพ่อมดได้ค่อยๆ ลอยตัวขึ้นสู่ท้องฟ้า และมุ่งหน้าไปยังส่วนต่างๆ ของอาณาจักรเพื่อปฏิบัติภารกิจเด็ดหัว","เรือเหาะสามลำมุ่งหน้าไปยังจุดรอยต่อระหว่างอาณาจักรฮัดลาตาและจักรวรรดิเซคัส เพื่อจับตาดูความเคลื่อนไหวของกองกำลังศัตรู หากพบสัญญาณการรวบรวมกำลังทหารหรือการข้ามพรมแดน พวกเขาก็จะส่งข่าวกลับมาทันที!","นอกจากนี้ เรย์เดล แฮมม์ และคนอื่นๆ ก็ได้ขึ้นเรือเหาะไปด้วยเช่นกัน แต่จุดหมายของพวกเขาคือ อิเยตา","ในฐานะลอร์ดคนใหม่ของดินแดนทางตะวันออกของอาณาจักร เรย์เดลที่ยังไม่มีความรู้เรื่องการสร้างดินแดนและการจัดสรรที่อยู่ให้แก่คนยากไร้เลย ครั้งนี้เขาจึงเดินทางไปอิเยตาเพื่อแสวงหาหนทางใหม่ๆ ให้กับผู้คนที่สละฐานะคนงานเหมืองและได้รับอิสรภาพมา โดยผู้ร่วมทางไปกับเขาก็คือจอมเวทผู้ยิ่งใหญ่แอนโธนีและคนอื่นๆ","แม้พ่อมดส่วนใหญ่ของสถาบันจะถูกส่งตัวไปช่วยปฏิบัติภารกิจเด็ดหัว แต่ลูกศิษย์ระดับหัวกะทิอย่างฟูล่ายังคงอยู่เคียงข้างแอนโธนี ซึ่งเดินทางไปอิเยตาเพื่อเข้าพบลินน์ด้วยตนเอง และลินน์ก็ถือโอกาสนี้เชิญชวนให้เข้าร่วมงานสัมมนาวิชาการประจำปีนี้ไปด้วยเลย!","ถึงแม้สงครามกับจักรวรรดิจะใกล้เข้ามาทุกที แต่การรวบรวมกองทัพและเตรียมเสบียงศึกก็ต้องใช้เวลา ไม่ว่าศาสนจักรจะรวดเร็วเพียงใด พวกเขาก็คงมาไม่ถึงที่นี่ในวันพรุ่งนี้หรอก","จากการประเมินของพวกเขา อย่างเร็วที่สุดน่าจะใช้เวลาประมาณครึ่งเดือนในการเตรียมการ และมีความเป็นไปได้สูงที่ข้อมูลเรื่องปืนคาบศิลาและปืนใหญ่จะรั่วไหลออกไป ดังนั้น การจะหวังพึ่งอาวุธเทคโนโลยีเหล่านี้เพื่อช่วงชิงความได้เปรียบอีกครั้งอาจไม่ใช่เรื่องง่ายนัก","โชคยังดีที่ลินน์ไม่ได้ตั้งใจจะแบกรับภาระนี้ไว้เพียงลำพัง เพราะถ้าปราศจากการช่วยเหลือจากสภาเวทมนตร์ พวกเขาก็คงยากที่จะเอาชนะสงครามครั้งนี้ได้","ด้วยอิทธิพลของศาสนจักรที่กว้างใหญ่ไพศาล และดินแดนของจักรวรรดิก็ใหญ่โตกว่าอาณาจักรหลายเท่า ซึ่งมีพระคาร์ดินัลอย่างโลซัคอยู่ไม่ต่ำกว่าหลายสิบคน รวมถึงบุคคลระดับสูงอย่างพระสันตะปาปาและประธานศาลพิพากษา ซึ่งเรายังไม่รู้ระดับพลังที่แท้จริงของพวกเขาทั้งสิ้น","อย่างไรก็ตาม ก่อนที่แอนโธนีและคนอื่นๆ จะมาถึง ลินน์ก็กำลังเตรียมการ ทำเรื่องสำคัญที่สุดเรื่องหนึ่ง นั่นคือการก้าวข้ามผ่านสู่การเป็นจอมเวทผู้ยิ่งใหญ่!","เขารอคอยวันนี้มานาน และมันกำลังจะมาถึงเร็วกว่าที่คาดไว้ ทั้งหมดนี้เป็นผลมาจากการที่ลินน์ฝึกฝนเวทแยกแยะวัสดุพื้นฐานอย่างต่อเนื่องผ่านการเชื่อมต่อทางจิตกับปัญญาประดิษฐ์สนับสนุนในช่วงนี้ ซึ่งเป็นแก่นแท้ของพ่อมดและเป็นหนทางเดียวในการฝึกฝนพลังจิต","เวลานี้ ช่วงเวลาแห่งการก้าวข้ามมาถึงแล้ว!","“ท่านลินน์ ท่านพร้อมที่จะก้าวข้ามแล้วหรือ?”","เควิน ศาสตราจารย์เวทมนตร์สายแปรสภาพที่เพิ่งทราบข่าวถึงกับตกใจ และดูจะตื่นเต้นยิ่งกว่าตัวลินน์เองเสียอีก","ทำอย่างไรได้ ในเมื่อความหวังของสถาบันอิเยตาทั้งหมดฝากไว้กับลินน์ พวกเขาจึงอดไม่ได้ที่จะกังวล","เพราะจอมเวทผู้ยิ่งใหญ่นั้นมีความสำคัญต่อทุกสถาบันเป็นอย่างยิ่ง และบ่อยครั้งที่สถานะนี้เป็นตัวบ่งชี้ถึงความรุ่งโรจน์หรือความเสื่อมถอยของสถาบันพ่อมด แถมยังเป็นหลักประกันด้านพลังและสิทธิ์ในการออกเสียงอีกด้วย","“แต่มันไม่เร็วเกินไปหรือ? ท่านอยากจะเลื่อนไปสักสองสามวันไหม?”","หลังจากความยินดีในช่วงแรกผ่านไป เควินก็เริ่มลังเลขึ้นมาอีกครั้ง เพราะท้ายที่สุด การจะก้าวข้ามสู่ระดับจอมเวทผู้ยิ่งใหญ่นั้นมาพร้อมกับความเสี่ยงมากมาย และหากล้มเหลวอาจจมดิ่งสู่สภาวะจิตใจพังทลายเป็นเวลานาน หรือเลวร้ายที่สุดก็คือเสียสติไปเลย","“ต้องเป็นวันนี้ จะไม่เตรียมการอะไรอีกแล้ว!”","ลินน์กล่าวอย่างมั่นใจ เพราะตอนนี้เขานั้นต้องการพลังที่มากขึ้น","ในศึกชิงเมืองหลวงครั้งนี้ เขายังต้องอาศัยปัจจัยภายนอกเป็นหลักในการโค่นพระคาร์ดินัล และหากพึ่งพาเพียงพลังของตนเอง เขาคงไม่มีแม้แต่คุณสมบัติที่จะยืนเผชิญหน้ากับอีกฝ่ายด้วยซ้ำ","นี่ไม่ใช่เรื่องดี เพราะไม่ว่าเจ้าจะเตรียมการมาดีเพียงใด ความผิดพลาดย่อมเกิดขึ้นได้เสมอ และพลังของตนเองต่างหากคือรากฐานของจริง","ลินน์ละทิ้งภารกิจในฐานะศาสตราจารย์ แล้วพาเควินและคนอื่นๆ ไปยังหอคอยวิสลิ่ง ซึ่งเป็นเขตพื้นที่แก่นกลางของท่าเรืออิเยตาทั้งหมด!","เดิมทีสถานที่นี้ถูกเฮลรามใช้เพื่อจัดตั้งค่ายกลวิญญาณที่ครอบคลุมทั่วเมืองทางใต้ ตอนนี้หลังจากการปรับปรุงใหม่ หอคอยวิสลิ่งก็ได้กลายเป็นสถานที่สำหรับเก็บรักษาสิ่งของสำคัญ","ที่ชั้นใต้ดินชั้นล่างสุด ซึ่งเป็นที่เก็บคริสตัลเวทมนตร์จำนวนมหาศาล และปรมาจารย์นักเล่นแร่แปรธาตุอย่างเดนนิสก็กำลังจดจ่ออยู่กับการวาดค่ายกลการเล่นแร่แปรธาตุขนาดใหญ่","นี่คือค่ายกลการเล่นแร่แปรธาตุ เนตรแห่งธาตุ ที่ใช้เพื่อสนับสนุนพ่อมดเต็มตัวให้ก้าวข้ามสู่ระดับจอมเวทผู้ยิ่งใหญ่ โดยมันจะสร้างสภาพแวดล้อมที่มีพลังเวทหนาแน่นอย่างมหาศาล และทำให้ผู้ที่อยู่ภายในสามารถเข้าถึงโลกแห่งธาตุที่จอมเวทผู้ยิ่งใหญ่เท่านั้นที่จะมองเห็นได้เป็นการชั่วคราว","โดยผู้ที่สร้างค่ายกลนี้ขึ้น ก็คือผู้ควบคุมธาตุอัลทอค","และก่อนที่จะก้าวข้ามสู่จอมเวทผู้ยิ่งใหญ่ได้นั้น จำเป็นต้องดื่มยาแสงจันทร์ของซินเธีย ที่จะสามารถเพิ่มขีดจำกัดพลังจิตของผู้ดื่มได้ภายในหนึ่งชั่วโมง ซึ่งจะช่วยให้พ่อมดระดับสามวงแหวนนั้นสามารถก้าวข้ามขีดจำกัดของตนเองได้","แต่เนื่องจากยาตัวนี้มีผลข้างเคียงที่รุนแรง หากก้าวข้ามล้มเหลวจะเพิ่มความเสี่ยงที่จิตจะแตกสลายได้ จึงถูกสั่งห้ามใช้ไปเมื่อเจ็ดสิบปีก่อน","เดนนิสอธิบายข้อควรระวังในการก้าวข้ามสู่จอมเวทผู้ยิ่งใหญ่ให้ลินน์ฟังอย่างเคร่งขรึม โดยทั่วไปแล้ว ทั้งค่ายกลการเล่นแร่แปรธาตุและตัวยานั้นเป็นเพียงปัจจัยสนับสนุนเท่านั้น","การเป็นจอมเวทผู้ยิ่งใหญ่นั้นไม่มีหนทางลัด มิเช่นนั้นในดินแดนพ่อมดที่มีพ่อมดเต็มตัวนับพันคน คงไม่เหลือจอมเวทผู้ยิ่งใหญ่เพียงแค่สามสิบคนเช่นนี้","ลินน์รับฟังอย่างตั้งใจ การมีความมั่นใจก็เป็นเรื่องหนึ่ง แต่ไม่ได้หมายความว่าเขาจะประมาทเลินเล่อได้","“เริ่มกันเถอะ!”","ลินน์สูดหายใจเข้าลึกๆ หลังจากปรับสภาพร่างกายและจิตใจจนสมบูรณ์แบบ เขาก็เดินเข้าไปยังใจกลางค่ายกลการเล่นแร่แปรธาตุ","อืมมมม","เสียงพลังเวทที่พุ่งพล่านดังขึ้นกะทันหัน ลวดลายการเล่นแร่แปรธาตุบนพื้นสว่างวาบขึ้นตามรอยเท้าของเขา ไม่นานชั้นล่างสุดของหอคอยวิสลิ่งทั้งหมดก็ถูกปกคลุมด้วยแสงเรืองรองสีน้ำเงิน","“ว่าแต่ ท่านลินน์น่าจะมีอายุ 20 ปีในปีนี้ใช่ไหม?”","เดนนิสถามขึ้นกะทันหัน","“เรื่องนี้...ข้าเองก็ไม่แน่ใจ แต่เมื่อสองปีก่อน ตอนที่ศาสตราจารย์ลินน์มาที่นี่ครั้งแรก เขาน่าจะมีอายุไม่ถึง 20 ปีนะ”","เควินชะงักไปครู่หนึ่งก่อนกล่าวอย่างลังเล","“หากการก้าวข้ามครั้งนี้สำเร็จ นี่จะเป็นการสร้างสถิติใหม่ขึ้นมาอีกครั้ง!”","เดนนิสกล่าวด้วยความตื้นตันใจ เพราะจอมเวทผู้ยิ่งใหญ่ที่มีอายุไม่ถึง 22 ปี นี้ไม่ใช่แค่อัจฉริยะธรรมดาแล้ว","แม้ก่อนหน้านี้สถิตินี้จะถูกถือครองโดยออกัสต์ แต่เมื่อดาวรุ่งแห่งเวทมนตร์ดวงนี้ถูกพิสูจน์ว่าเป็นของปลอม สถิตินั้นย่อมไม่นับรวม","และในตอนที่เขาได้ก้าวข้ามเป็นจอมเวทผู้ยิ่งใหญ่ เขาก็มีอายุเกินสี่สิบปีไปแล้ว ซึ่งต่อให้ถือว่ารวดเร็วแล้วก็เถอะ...","เมื่อค่ายกลการเล่นแร่แปรธาตุเริ่มทำงาน พลังเวทอันมหาศาลก็ถูกสกัดออกจากคริสตัลเวทมนตร์และรวบรวมไว้ที่ใจกลางค่ายกลอย่างต่อเนื่องโดยไม่มีท่าทีว่าจะหยุดลง","เมื่อเห็นดังนั้น เดนนิสก็อดไม่ได้ที่จะขมวดคิ้ว","“ท่านเดนนิส มีปัญหาอะไรหรือ?”","เควินรีบถามขึ้น พร้อมกับเหล่าพ่อมดจากสถาบันที่มารวมตัวกันในหอคอยวิสลิ่งต่างก็มีสีหน้าเคร่งเครียด","“จำเป็นต้องใช้พลังเวทมหาศาลขนาดนี้เชียวหรือ...”","เดนนิสพึมพำกับตัวเองเสียงแผ่ว บัดนี้ไม่ใช่เขาที่ควบคุมค่ายกล แต่เป็นลินน์ที่อยู่ใจกลางค่ายกล และคริสตัลเวทมนตร์หนึ่งร้อยก้อนที่เตรียมไว้ก่อนหน้านี้ก็ถูกดูดกลืนไปจนหมดสิ้น แต่ค่ายกลเวทมนตร์ก็ยังไม่มีทีท่าว่าจะหยุดทำงานแต่อย่างใด"]},{"n":310,"t":"การสร้างอาณาเขตและทะเลแห่งธาตุ!","c":["“ไปเอาคริสตัลเวทมนตร์มาเพิ่มอีก!”","เดนนิสเอ่ยด้วยน้ำเสียงเคร่งขรึม","เควินรีบปฏิบัติตามอย่างรวดเร็ว โดยร่วมมือกับพ่อมดจากสถาบันอีกกว่าสิบคน เร่งขนย้ายลังบรรจุคริสตัลเวทมนตร์มาให้เร็วที่สุดเท่าที่จะทำได้ จากนั้นก็นำมันไปวางไว้ตามจุดศูนย์กลางแต่ละแห่งของวงเวทตามคำสั่งของเดนนิส เมื่อแล้วเสร็จ เควินจึงเอ่ยถามต่อ","“ท่านเดนนิส เกิดอะไรขึ้นกันแน่ครับ พิธีเลื่อนระดับนี้มีความผิดปกติอะไรหรือเปล่า?”","เมื่อเห็นความหนาแน่นของพลังเวทที่พุ่งทะยานขึ้นตรงใจกลางวงเวท ต่อให้เป็นเควินที่ไม่ได้เชี่ยวชาญด้านการแปรธาตุมากนัก ก็ยังพอมองออกว่ามีบางอย่างผิดปกติ","“ตามหลักแล้ว มันไม่ควรจะต้องใช้พลังเวทมากมายขนาดนี้ ในช่วงเจ็ดสิบปีที่ผ่านมา มีจอมเวทผู้ยิ่งใหญ่กว่าสิบคนที่เลื่อนระดับผ่านเนตรแห่งธาตุ ถึงแม้ในอดีตพวกเขาจะเคยล้มเหลว แต่ก็ไม่เคยเกิดสถานการณ์แบบนี้ขึ้นมาก่อน...”","เดนนิสเอ่ยอย่างสับสนเช่นกัน หลังจากครุ่นคิดอยู่นาน เขาก็พูดขึ้นอีกครั้ง","“อย่างไรก็ตาม ตัวอย่างที่เกี่ยวข้องก็ยังมีน้อยเกินไป ซึ่งแต่ละคนก็ล้วนมีพรสวรรค์ จุดแข็ง และอาณาเขตที่สร้างขึ้นแตกต่างกันไป ไม่มีอะไรรับประกันได้ว่าการคาดเดาของข้าจะถูกต้อง และสิ่งเดียวที่เราทำได้ในตอนนี้คือการรอคอย”","เควินมองร่างที่อยู่ตรงใจกลางวงแหวนแปรธาตุด้วยความกังวลใจอย่างยิ่ง และไม่มีทางเลือกอื่นนอกจากแอบหวังให้ทุกอย่างผ่านพ้นไปด้วยดี","ในเวลาเดียวกัน ลินน์ผู้ซึ่งกำลังถูกเควินพูดถึง ก็กำลังทุ่มเทสมาธิทั้งหมดไปกับการควบคุมวงแหวนแปรธาตุ โดยที่พลังจิตของเขาก็ดูเหมือนจะได้รับการยกระดับขนานใหญ่จากวงเวท","เดิมที พลังจิตของเขาสามารถครอบคลุมพื้นที่รอบตัวได้เพียงสามเมตรเท่านั้น และเขาสามารถควบคุมธาตุต่างๆ ได้ภายในขอบเขตนี้ แต่ตอนนี้ ภายใต้อิทธิพลของวงแหวนแปรธาตุ มันได้ขยายอาณาเขตออกไปมากกว่าสิบเท่า","และกุญแจสำคัญในการเลื่อนระดับขึ้นเป็นจอมเวทผู้ยิ่งใหญ่นั้นมีอยู่สองประการ","หนึ่งคือการบรรลุการทะลวงขีดจำกัดของพลังจิต และสองคือการสร้างอาณาเขตขนาดเล็กขึ้นมา","ภายในอาณาเขตนี้ ธาตุทั้งหมดล้วนประกอบขึ้นจากพลังเวท โดยที่พ่อมดคนนั้นสามารถควบคุมและเปลี่ยนรูปพวกมันได้อย่างง่ายดาย เพียงแค่ยกมือ ก็สามารถสร้างพื้นที่สูญญากาศในอาณาเขตนั้นได้","และสิ่งนี้เองที่ทำให้จอมเวทผู้ยิ่งใหญ่นั้นมีพลังที่จะกดข่มพ่อมดเต็มตัวได้อย่างเบ็ดเสร็จ","เนื่องจากธาตุทั้งหมดในอาณาเขตตกอยู่ภายใต้การควบคุมของเขา นั่นก็หมายความว่าคู่ต่อสู้จะไม่สามารถใช้ธาตุใดๆ ในอากาศเพื่อเสริมพลังได้โดยตรง ในขณะที่อันตรายอาจพุ่งโจมตีมาจากจุดใดก็ได้ภายในอาณาเขตของเขา","ลินน์พยายามหดระยะครอบคลุมของพลังจิตลงเรื่อยๆ จากที่เคยครอบคลุมวงแหวนแปรธาตุทั้งหมด ให้ลดลงมาเหลือ 20 เมตร 18 เมตร และ 15 เมตรห่างจากร่างกาย...","ซึ่งทำให้ธาตุชนิดต่างๆ ในอากาศเริ่มปรากฏชัดเจนขึ้นเรื่อยๆ ภายใต้การรับรู้ของเขา แม้เขาจะไม่สามารถมองเห็นรูปร่างของพวกมันได้โดยตรง แต่มันก็ควบคุมได้ง่ายกว่าเมื่อก่อนมาก","เมื่อระยะครอบคลุมของพลังจิตมาหยุดอยู่ที่สิบสองเมตรรอบตัว ลินน์ก็รู้สึกว่าเขาถึงจุดที่ต้องหยุดพัก จากนั้นจึงทุ่มเทพลังจิตทั้งหมดเข้าไปสู่ห้วงมิติแห่งจิตสำนึกอันกว้างใหญ่","ทุกสิ่งทุกอย่างในที่แห่งนี้ช่างมืดมิดและว่างเปล่า","แต่ในความว่างเปล่านี้ กลับมีจุดแสงจางๆ ปรากฏขึ้น ซึ่งเจิดจรัสราวกับดวงดาวที่ทอแสงระยิบระยับบนท้องฟ้ายามค่ำคืน โดยที่แต่ละจุดแสงล้วนเป็นตัวแทนของช่องเก็บเวท","นี่คือรูปร่างพื้นฐานของอาณาเขตพ่อมด หรือแก่นแท้ของอาณาเขตที่เกิดจากการฉายภาพห้วงจิตสำนึกออกสู่ภายนอก...","ตอนนี้เขาจำเป็นต้องสร้างทะเลแห่งธาตุของตนเองขึ้นมา และใช้มันเพื่อทดแทนธาตุภายนอก จากนั้นจึงทำให้ทั่วทั้งอาณาเขตเกิดความเสถียร เพื่อที่เขาจะสามารถก้าวผ่านขั้นตอนที่สำคัญที่สุดในการเลื่อนระดับเป็นจอมเวทผู้ยิ่งใหญ่ได้","เมื่อลินน์รวบรวมความคิด จุดแสงสองจุดก็ปรากฏขึ้นในห้วงจิตสำนึกอันว่างเปล่า","พวกมันคือธาตุไฮโดรเจนและออกซิเจน!","พวกมันคือสองธาตุที่ลินน์ได้สัมผัสและใช้งานบ่อยที่สุดนับตั้งแต่ทะลุมิติมา ตามมาด้วยไนโตรเจน ฟอสฟอรัส ฟลูออรีน ฮีเลียม...ธาตุชนิดต่างๆ เริ่มล่องลอยอยู่ในห้วงจิตสำนึกมากขึ้นเรื่อยๆ ราวกับเซลล์เนื้อเยื่อที่แบ่งตัวทำซ้ำ จนในไม่ช้าก็เติมเต็มทุกซอกทุกมุมของห้วงจิตสำนึก...","หลังจากควบแน่นธาตุพื้นฐานกว่าสิบชนิด ธาตุโลหะอย่างเช่น ทองแดง เหล็ก และอะลูมิเนียม ก็ตามมา...นี่นับเป็นครั้งแรกที่ลินน์เปลี่ยนพลังเวทให้กลายเป็นธาตุโลหะโดยไม่ได้รับความช่วยเหลือจากสมองกลของเขา โดยกระบวนการนี้ก็มีความยากลำบากเป็นพิเศษ และต้องใช้เวลามากกว่าการสร้างธาตุชนิดอื่นๆ เกือบสิบเท่า","โชคดีที่ลินน์ได้บันทึกธาตุโลหะเหล่านี้เอาไว้แล้วด้วยเวทแยกแยะวัสดุขั้นสูง ดังนั้นหลังจากใช้ความพยายามอยู่พักหนึ่ง ในที่สุดเขาก็สามารถเลียนแบบและสร้างธาตุโลหะพื้นฐานขึ้นมาได้ถึงเก้าชนิด","ณ วินาทีนี้ ทะเลแห่งธาตุได้ก่อตัวขึ้นแล้ว และมีธาตุทั้งหมดสี่สิบเก้าชนิดปรากฏอยู่บนนั้น","พวกมันล้วนเป็นสมบัติล้ำค่าของโลกเวทมนตร์ เป็นผลึกแห่งการสำรวจโลกธรรมชาติของเหล่าพ่อมดนับไม่ถ้วน แต่ลินน์ยังไม่พร้อมที่จะจบลงเพียงแค่นี้","ด้วยการใช้ประโยชน์จากการเลื่อนระดับและวงแหวนแปรธาตุใต้ฝ่าเท้า ลินน์จึงอยากทดสอบดูว่า เขาจะสามารถพัฒนาทะเลแห่งธาตุให้ดียิ่งขึ้นไปอีกได้หรือไม่","เงื่อนไขพื้นฐานสำหรับพ่อมดในการควบคุมและเลียนแบบธาตุ คือการใช้เวทแยกแยะวัสดุเพื่อวิเคราะห์ธาตุชนิดนั้นอย่างละเอียดลึกซึ้ง แล้วถ้าหากทำในทางกลับกันล่ะ?","หลังจากล่วงรู้ถึงโครงสร้างจำลองของธาตุชนิดใดชนิดหนึ่งแล้ว จะสามารถข้ามกระบวนการค้นหาและวิเคราะห์ธาตุนั้นไป แล้วใช้พลังเวทเลียนแบบมันขึ้นมาโดยตรงได้หรือไม่","นี่เป็นความคิดที่บ้าระห่ำอย่างแน่นอน...แต่หากมันเป็นไปได้ ในทางทฤษฎีแล้ว เขาก็จะสามารถสร้างธาตุใดๆ ก็ตามบนตารางธาตุได้ทั้งหมด!","เมื่อถึงเวลานั้น อย่าว่าแต่การสร้างระเบิดนิวเคลียร์ด้วยมือเปล่าเลย แม้แต่การปั้นระเบิดปฏิสสารก็ไม่ใช่ปัญหาอีกต่อไป","เมื่อคิดได้ดังนี้ ลินน์ก็แทบรอไม่ไหวที่จะทำการทดลอง และเป้าหมายที่เขาเลือกก็คือ ธาตุพลูโทเนียม!","นี่คือธาตุกัมมันตรังสีซึ่งเป็นวัตถุดิบสำคัญสำหรับอุตสาหกรรมพลังงานปรมาณู โดยมันสามารถใช้เป็นเชื้อเพลิงนิวเคลียร์และสารตั้งต้นฟิชชันสำหรับอาวุธนิวเคลียร์ ซึ่งหาได้ยากยิ่งในธรรมชาติ และการจะได้มา ก็จำเป็นต้องสกัดพลูโทเนียมที่มีอยู่น้อยนิดออกมาจากแร่ยูเรเนียม","ลินน์ได้ดึงข้อมูลงานวิจัยของสหพันธ์เกี่ยวกับธาตุพลูโทเนียมออกมาจากสมองกลโดยตรง และพยายามใช้พลังเวทสร้างมันขึ้นมาใหม่โดยอ้างอิงจากข้อมูลเหล่านี้","“จำนวนอิเล็กตรอนรอบนอกและโปรตอนของธาตุพลูโทเนียม คือ 94 จำนวนนิวตรอนคือ 145 และมวลอะตอมสัมพัทธ์คือ…”","ลินน์พึมพำแผ่วเบา จุดแสงแห่งพลังเวทส่องประกายวาบขึ้นในห้วงจิตสำนึก และธาตุชนิดใหม่ก็ค่อยๆ ก่อตัวขึ้น","ทุกสิ่งที่เกิดขึ้นในห้วงจิตสำนึกถูกฉายภาพออกไปยังอาณาเขตที่กำลังควบแน่นอย่างต่อเนื่อง โดยมีพลังเวทอันมหาศาลกำลังถูกเผาผลาญและเปลี่ยนสภาพกลายเป็นธาตุชนิดต่างๆ ไม่หยุดหย่อน","ในที่สุดเดนนิสก็เข้าใจว่าเหตุใดอัตราการเผาผลาญคริสตัลเวทมนตร์จึงได้น่าสะพรึงกลัวถึงเพียงนี้ โดยทั่วไปแล้ว อาณาเขตที่ก่อตัวขึ้นในขั้นต้นจะมีความกว้างเพียงประมาณห้าเมตรเท่านั้น แต่รูปร่างพื้นฐานของอาณาเขตที่ลินน์สร้างขึ้นกลับขยายอาณาเขตออกไปมากกว่าสิบเมตรแล้ว","ไม่เพียงเท่านั้น แต่อีกฝ่ายยังสร้างธาตุรวดเดียวถึงสี่สิบเก้าชนิดเพื่อเติมเต็มทะเลแห่งธาตุ นี่คือการเตรียมความพร้อมแบบรวดเดียวจบเลยงั้นหรือ?","มันช่างบ้าระห่ำเหลือเกิน แต่สิ่งสำคัญที่สุดในตอนนี้คือการทำให้อาณาเขตเสถียรภาพและเสร็จสิ้นการเลื่อนระดับต่างหาก ส่วนการสร้างทะเลแห่งธาตุนั้นสามารถค่อยๆ ทำในภายหลังก็ยังได้!","เดนนิสส่ายศีรษะ แต่หลังจากนั้น ใบหน้าของเขาก็พลันแข็งค้าง โดยเขากำลังมองตรงไปยังใจกลางของวงแหวนแปรธาตุ ที่ซึ่งสัมผัสได้ถึงขุมพลังใหม่ที่ค่อยๆ ก่อตัวขึ้น และเอ่ยออกมาด้วยความตกตะลึง","“นี่มัน...ธาตุชนิดใหม่หรือ?!”"]},{"n":311,"t":"เขากำลังสร้างธาตุชนิดใหม่!","c":["เดนนิสอดไม่ได้ที่จะก้าวไปข้างหน้าสองสามก้าว และยืนจ้องมองลินน์ซึ่งอยู่ใจกลางวงเวทอย่างตาไม่กะพริบ โดยที่ธาตุชนิดใหม่นี้กำลังค่อยๆ ก่อตัวขึ้นบนมือขวาที่ยื่นออกมาของอีกฝ่าย","ซึ่งมีขนาดเล็กเกินเปรียบและไม่อาจมองเห็นได้ด้วยตาเปล่า แต่มันกลับปรากฏเด่นชัดเป็นพิเศษภายใต้การรับรู้","นั่นจึงทำให้เดนนิสนั้นมั่นใจอย่างยิ่งยวดว่านี่ไม่ใช่ธาตุใดๆ ที่เขารู้จักอย่างแน่นอน และมันไม่ได้จัดอยู่ในหมวดหมู่ของประเภทธาตุที่เคยค้นพบมาก่อนเลยด้วยซ้ำ","เพราะนับตั้งแต่วินาทีที่มันปรากฏตัวขึ้น ธาตุชนิดนี้ก็แผ่ซ่านพลังอำนาจอันแปลกประหลาดบางอย่างออกมาอย่างต่อเนื่อง","เมื่อคิดได้ดังนี้ เดนนิสก็ไม่อาจระงับความตื่นเต้นเอาไว้ได้","ธาตุ คืออะไร?","ตามทฤษฎีเวทมนตร์แห่งดินแดนพ่อมด ธาตุคือแก่นแท้ของสรรพสิ่ง และเป็นรากฐานของการดำรงอยู่ทั้งมวล!","แล้วธาตุบนโลกนี้มีทั้งหมดกี่ชนิดกันล่ะ?","ตราบใดที่เป็นพ่อมดที่เคยศึกษาศาสตร์แห่งธาตุอย่างเป็นระบบ ย่อมสามารถตอบได้ทันทีว่า มีทั้งหมดสี่สิบเก้าชนิด!","เพื่อที่จะค้นหาธาตุเหล่านี้ พวกเขาได้รื้อค้นและตรวจสอบทุกสิ่งทุกอย่างเท่าที่จะหาได้ในดินแดนพ่อมด โดยใช้เวทแยกแยะวัสดุเพื่อย่อยสลายพวกมันทีละชิ้น จากนั้นจึงนำมาจัดหมวดหมู่","และธาตุทั้งสี่สิบเก้าชนิดคือคำตอบ ซึ่งพ่อมดแห่งสถาบันธาตุบางคนถึงกับฟันธงว่า บางทีอาจจะไม่มีธาตุชนิดอื่นใดหลงเหลืออยู่ในโลกนี้อีกแล้ว และใช้สิ่งนี้เป็นรากฐานในการสร้างสรรค์เวทมนตร์ที่สอดคล้องกัน","แน่นอนว่าเดนนิสเย้ยหยันคำกล่าวอ้างนั้น","โดยเฉพาะอย่างยิ่งหลังจากที่เขาได้คำนวณพื้นที่ของดาวนิรันดร์ผ่านการทดลอง เดนนิสก็ต้องตกตะลึงเมื่อตระหนักว่าโลกใบนี้ช่างกว้างใหญ่ไพศาลนัก และต้องมีธาตุชนิดใหม่ที่ยังไม่มีใครรู้จักซุกซ่อนอยู่อีกมากมาย ซึ่งพวกเขายังหาไม่พบ","อย่างไรก็ตาม โลกเวทมนตร์ทั้งใบไม่ได้มีการค้นพบธาตุชนิดใหม่มานานเกือบ 30 ปีแล้ว และด้วยเหตุนี้เอง ผู้ควบคุมธาตุอัลทอค จึงได้ฝากความหวังของเขาไว้กับโลกในระดับอนุภาคที่เล็กยิ่งกว่าเดิม","แต่บัดนี้ ธาตุชนิดใหม่ได้ปรากฏขึ้นตรงหน้าเขาแล้ว และมันอาจเป็นประเภทธาตุที่ใหม่เอี่ยมอ่องเลยด้วยซ้ำ แล้วสิ่งนี้จะไม่ทำให้เดนนิสรู้สึกตื่นเต้นจนเนื้อเต้นได้อย่างไร","สำหรับพ่อมดทุกคนที่เชี่ยวชาญศาสตร์แห่งธาตุ นี่คือข่าวดีอันยิ่งใหญ่!","หากไม่ใช่เพราะลินน์กำลังอยู่ระหว่างการทะลวงขีดจำกัด และวงแหวนแปรธาตุยังคงทำงานไม่หยุด เดนนิสคงจะพุ่งพรวดเข้าไปสอบถามในทันทีว่าเกิดอะไรขึ้นกับธาตุชนิดใหม่นี้","ในขณะที่เดนนิสกำลังรอคอยด้วยความกระวนกระวายใจ วงแหวนแปรธาตุที่กำลังทำงานอย่างราบรื่นก็พลันเกิดความปั่นป่วนขึ้นมา โดยแก่นกลางของความไม่เสถียรนี้ ก็มีต้นตอมาจากธาตุชนิดใหม่ในมือของลินน์","“หยุดนะ!”","สีหน้าของเดนนิสเปลี่ยนไปอย่างฉับพลัน เขาไม่สนใจเรื่องธาตุชนิดใหม่อีกต่อไป แล้วรีบตะโกนออกไปสุดเสียง","แต่ก่อนที่สิ้นเสียง พลังธาตุอันมหาศาลก็เกิดการปะทุขึ้น พร้อมกับพลังเวทอันมหาศาลที่ถูกกักเก็บไว้ในวงเวทก็สูญเสียการควบคุมในชั่วพริบตา ซึ่งก่อตัวเป็นพายุธาตุอันรุนแรงและกวาดล้างทุกสรรพสิ่งรอบด้าน","วงแหวนแปรธาตุทั้งวงแหลกสลาย พายุธาตุพุ่งเข้าปะทะกับโครงสร้างอิฐหินรอบๆ จนแตกกระจุยกระจาย...","เควินและคนอื่นๆ ที่อยู่ใกล้เคียงต่างเซถลาและเกือบถูกพัดเข้าไปในพายุธาตุ หลังจากทรงตัวยืนหยัดได้ในที่สุด พวกเขาล้วนเผยให้เห็นถึงความหวาดหวั่น","หรือว่าการทะลวงระดับจะล้มเหลว?","เควินลอบคิดด้วยความกังวลใจ","หลังจากพายุธาตุสงบลง ร่างของลินน์ก็ปรากฏขึ้นตรงหน้าทุกคนอย่างรวดเร็ว ดูเหมือนว่าจะไม่มีอะไรบาดเจ็บร้ายแรง นอกเสียจากใบหน้าที่มอมแมม แต่เขากลับขมวดคิ้วแน่นราวกับกำลังครุ่นคิดอะไรบางอย่างอยู่","เมื่อเห็นคิ้วที่ขมวดมุ่นของลินน์ เควินก็เข้าใจในทันที และสีหน้าเสียดายปรากฏขึ้นบนใบหน้าของเขา จากนั้นจึงก้าวไปข้างหน้าเพื่อปลอบโยนพร้อมกับถอนหายใจ","“ท่านศาสตราจารย์ลินน์ การทะลวงขึ้นเป็นจอมเวทผู้ยิ่งใหญ่นั้นไม่ใช่เรื่องง่าย และท่านยังมีเวลาอีกมาก ความล้มเหลวเพียงชั่วคราวก็ไม่ใช่เรื่องใหญ่อะไร”","“เดี๋ยวนะ ใครบอกว่าข้าทะลวงระดับล้มเหลว?”","ลินน์ชะงักไปและเอ่ยถามด้วยความงุนงง","“ถ้าอย่างนั้นหมายความว่า ท่านทำสำเร็จแล้วหรือ?”","เควินถามด้วยความประหลาดใจ","“แน่นอนสิ!”","ลินน์พยักหน้าพร้อมกับรอยยิ้ม จากนั้นเมื่อเขารวบรวมความคิด พลังเวทในอาณาเขตก็แปรสภาพกลายเป็นธาตุเหล็กอย่างเป็นธรรมชาติ พวกมันรวมตัวกันในชั่วพริบตา และกลายเป็นดาบใหญ่ที่มีความยาวหลายเมตรลอยตระหง่านอยู่กลางอากาศ","พื้นที่สิบสองเมตรรอบกายล้วนอยู่ภายในอาณาเขตของเขา และเขาสามารถควบคุมพลังเวทเหล่านี้ให้เปลี่ยนแปลงและผสมผสานกันได้อย่างใจนึก","“ยอดเยี่ยมไปเลย ตอนนี้สถาบันอิเยตาก็มีจอมเวทผู้ยิ่งใหญ่แล้ว!”","เควินพูดอย่างตื่นเต้น โดยไร้ซึ่งความกังขาใดๆ ในใจ เพราะการเลียนแบบธาตุโลหะได้เช่นนี้ เป็นสิ่งที่จอมเวทผู้ยิ่งใหญ่เท่านั้นที่ทำได้จริงๆ!","พ่อมดคนอื่นๆ ในสถาบัน ต่างก็รู้สึกยินดีปรีดาเช่นกัน","นับตั้งแต่การจากไปของจอมเวทผู้ยิ่งใหญ่เฮลราม อิเยตาก็สูญเสียเสาหลักไป แม้ว่าทฤษฎีแปลกใหม่มากมายที่ลินน์นำเสนอจะโดดเด่นเจิดจรัสในงานสัมมนาวิชาการ จนทำให้ชื่อเสียงของสถาบันอิเยตาดังก้องไปทั่วดินแดนพ่อมด แต่ไม่ว่าอย่างไร จอมเวทผู้ยิ่งใหญ่ก็คือหลักประกันความแข็งแกร่งของสถาบันอย่างแท้จริง!","“เดี๋ยวก่อน ในเมื่อท่านทำสำเร็จแล้ว อาการคลุ้มคลั่งของพลังเวทเมื่อครู่นี้มันเกิดอะไรขึ้นกัน?”","เควินเพิ่งนึกเรื่องนี้ขึ้นมาได้ จึงเอ่ยถามอย่างสับสน","แต่ก่อนที่ลินน์จะได้ตอบคำถาม เดนนิสก็พูดแทรกขึ้นมาอย่างร้อนรน","“ท่านศาสตราจารย์ลินน์ เมื่อครู่นี้ท่านกำลังจะสร้างธาตุชนิดใหม่ขึ้นมาใช่หรือไม่?”","น้ำเสียงของเดนนิสเต็มไปด้วยความจริงจังอย่างที่สุด และเขายังใช้คำว่า ‘สร้าง’ เลยด้วยซ้ำ!","ธาตุในอดีตล้วนได้รับการอธิบายว่าเป็น ‘การค้นพบ’ เพราะพวกมันล้วนมีอยู่ในธรรมชาติแต่เดิม พวกเขาเพียงแค่ค้นพบธาตุชนิดนั้น และใช้เวทแยกแยะวัสดุเพื่อวิเคราะห์แล้วนำมันมาใช้งาน","แต่สิ่งที่ลินน์ทำนั้นแตกต่างออกไป แม้ในตอนแรก เดนนิสนั้นคิดว่าอีกฝ่ายเพียงแค่ใช้พลังเวทเพื่อเลียนแบบธาตุใหม่ที่ยังไม่มีใครรู้จัก แต่ในวินาทีที่ธาตุนั้นหลุดการควบคุม เขาก็ตระหนักได้ถึงความผิดปกติ เพราะลินน์กำลังสร้างบางสิ่งขึ้นมาจากความว่างเปล่าอย่างชัดเจน...มันคือธาตุชนิดใหม่!","แต่สิ่งนี้จะเป็นไปได้อย่างไร?","แม้แต่พ่อมดระดับตำนานยังไม่อาจทำเรื่องที่ฝืนกฎเกณฑ์เช่นนี้ได้ แต่ลินน์กลับเกือบจะทำมันสำเร็จเมื่อครู่นี้","“ไม่หรอก มันไม่ใช่การสร้างขึ้นใหม่ ข้าเพียงแค่ได้ยินปรมาจารย์แห่งสมาคมเวทมนตร์เร้นลับพูดถึงโครงสร้างและรูปแบบจำลองของธาตุพลูโทเนียม ดังนั้นข้าจึงอยากลองดูว่าจะสามารถจำลองมันขึ้นมาได้หรือไม่”","ลินน์ส่ายหัวและอธิบาย","“แต่น่าเสียดายที่ในท้ายที่สุดมันก็ยังล้มเหลว!”","ในความเห็นของเขา การใช้ธาตุของเหล่าพ่อมดนั้นสามารถเปรียบเทียบได้กับการเขียนโปรแกรม โดยสิ่งที่พวกเขาทั้งหมดต้องทำก็เพียงแค่ใช้พลังเวทเพื่อ ‘คัดลอก’ และ ‘วาง’ โค้ดที่สามารถรันได้สำเร็จ และตราบใดที่พวกเขาไม่ทำการสุ่มเปลี่ยนแปลงมั่วซั่ว มันก็ยังพอถูไถใช้งานต่อไปได้","ซึ่งสิ่งที่ลินน์ทำเมื่อครู่นี้ก็คือการคาดเดาว่าโค้ดนั้นเขียนมาด้วยอะไร จากนั้นก็เขียนตาม และพบ ‘บั๊ก’ ในระหว่างกระบวนการรันระบบ","อย่างไรก็ตาม เมื่อพิจารณาจากการสร้างธาตุตามปกติแล้ว รูปแบบจำลองธาตุพลูโทเนียมในฐานข้อมูลของสหพันธ์ก็ไม่ได้มีปัญหาแต่อย่างใด แต่มันกลับติดขัดอย่างกะทันหันในขณะที่กำลังเลียนแบบชั้นอิเล็กตรอน เพราะสิ่งนี้เกี่ยวข้องกับระดับควอนตัม ซึ่งเขายังไม่รู้วิธีที่จะทำให้เกิดการเปลี่ยนสถานะของอิเล็กตรอนที่อยู่รอบนอกนิวเคลียส รวมถึงวิธีทำให้พวกมันมีการกระจายตัวตามความน่าจะเป็น...","นั่นหมายความว่า เขาเพียงแค่คลำทางเขียนโค้ดชิ้นนี้ไปแบบมั่วๆ และผลลัพธ์ที่ได้ก็คือปัญหานั่นเอง..."]},{"n":312,"t":"อันที่จริงแล้ว เรือรบลำนี้พวกเราเอาไว้ใช้ตกปลา!","c":["“ธาตุพลูโทเนียม...รูปแบบจำลองธาตุ?!”","ในตอนแรกเดนนิสรู้สึกประหลาดใจที่ธาตุชนิดใหม่นี้มีอยู่จริง จากนั้นเขาก็ยิ่งรู้สึกประหลาดใจมากขึ้นไปอีกกับสิ่งที่เรียกว่ารูปแบบจำลองธาตุ","“หรือว่าท่านผู้ควบคุมธาตุอัลทอคจะพูดถูก และธาตุยังสามารถถูกแบ่งย่อยลงไปได้อีก?”","เดนนิสขมวดคิ้วโดยไม่รู้ตัว ทฤษฎีกระแสหลักในดินแดนพ่อมดปัจจุบันมีแนวโน้มไปทางที่ว่า ธาตุไม่สามารถแบ่งแยกได้ พวกมันคือรากฐานของโลก เพราะนี่คือขีดจำกัดของเวทแยกแยะวัสดุ และพวกเขาไม่สามารถแยกย่อยธาตุพื้นฐานลงไปได้อีกแล้ว","พ่อมดระดับตำนานอัลทอคได้เสนอทฤษฎีการแบ่งย่อยธาตุ แต่จู่ๆ เขาก็เกิดเสียสติไปก่อนที่จะพบหลักฐานใดๆ บันทึกที่เขาเขียนยังเปิดเผยถึงลัทธิวันสิ้นโลก ซึ่งเป็นกลุ่มคนวิกลจริตที่เชื่อว่าโลกกำลังจะก้าวเข้าสู่จุดจบ ดังนั้นมันจึงถูกมองว่าเป็นเพียงสมมติฐานที่ไม่น่าเชื่อถือเท่านั้น","“แน่นอน!”","ลินน์พยักหน้า","“ตามสมมติฐานของนักวิชาการบางคนในสมาคมเวทมนตร์เร้นลับ ธาตุประกอบด้วยนิวเคลียสของอะตอมและอิเล็กตรอนที่โคจรรอบนิวเคลียส”","เดนนิสรู้สึกสนใจในหัวข้อนี้เป็นอย่างมาก และรีบเอ่ยถามว่าสิ่งที่เรียกว่านิวเคลียสของอะตอมและอิเล็กตรอนคืออะไร","ลินน์ไม่ได้อธิบายอะไรมากนัก เขาเพียงบอกว่านี่เป็นเพียงทฤษฎีเวทมนตร์ และจำเป็นต้องมีการทดลองที่เกี่ยวข้องเพื่อพิสูจน์มัน","แม้ว่าจะมีรูปแบบจำลองธาตุมากกว่าหนึ่งร้อยชนิดอยู่ในฐานข้อมูลของสมองกล แต่ลินน์ก็สามารถยืนยันได้เพียงแค่ว่ารูปแบบจำลองของธาตุพลูโทเนียมน่าจะถูกต้อง และที่สำคัญไปกว่านั้น สำหรับเดนนิสที่ไม่เคยสัมผัสกับทฤษฎีควอนตัมมาก่อน เกรงว่ามันคงเป็นเรื่องยากที่จะทำความเข้าใจว่าอะตอมถูกสร้างขึ้นและทำงานอย่างไร","ท้ายที่สุดแล้ว เหล่าพ่อมดเชื่อว่าโลกทั้งใบขับเคลื่อนไปตามกฎเกณฑ์บางอย่าง และพ่อมดก็สามารถร่ายเวทมนตร์ได้โดยการทำความเข้าใจและใช้ประโยชน์จากกฎเกณฑ์เหล่านั้น เขายังสงสัยด้วยซ้ำว่าพ่อมดระดับตำนานที่เป็นที่รู้จักในนามผู้ควบคุมธาตุ อาจจะเคยสัมผัสกับโลกจุลภาคมาแล้ว และเป็นเพราะลักษณะเฉพาะของควอนตัมที่ไม่อาจยอมรับได้นั่นเองที่ทำให้เขาเกิดเสียสติไปอย่างกะทันหัน","“ท่านศาสตราจารย์ เรือเหาะที่เดินทางกลับมาจากอาณาจักรฮัดลาตามาถึงแล้วครับ”","ศิษย์ฝึกหัดหลายคนเดินเข้ามาทางประตู พร้อมกับโค้งคำนับและรายงานต่อลินน์","“ดูเหมือนว่าแขกของเราจะมาถึงแล้วนะ!”","รอยยิ้มปรากฏขึ้นบนใบหน้าของลินน์","“ออกไปดูด้วยกันเถอะ”","ในเวลาเดียวกัน เรือเหาะขนาดมหึมาก็เคลื่อนผ่านหมอกหนาทึบ มาถึงน่านฟ้าเหนือเมืองท่า และค่อยๆ ร่อนลงจอดที่ลานกว้างซึ่งถูกขยายออกเป็นพิเศษ","“นี่คือดินแดนพ่อมดงั้นหรือ? ข้าไม่คิดเลยว่าจะมีสถานที่ที่เจริญรุ่งเรืองเช่นนี้อยู่อีกฟากหนึ่งของท้องทะเล...”","ฟูล่าเดินตามธีโอดอร์และคนอื่นๆ ลงมาจากเรือเหาะ พร้อมกับมองไปรอบๆ อย่างไม่หยุดหย่อน","ทุกสิ่งที่ปรากฏอยู่ในเมืองท่าแห่งนี้ล้วนเป็นสิ่งแปลกใหม่สำหรับฟูล่า ซึ่งมันแตกต่างอย่างสิ้นเชิงจากเมืองใดๆ ในอาณาจักรฮัดลาตา แม้แต่เมืองหลวงที่เจริญรุ่งเรืองที่สุดก็ยังไม่อาจเทียบชั้นได้","อันที่จริงแล้ว นอกเหนือจากใจกลางเมือง พื้นที่ทั้งหมดของเมืองหลวงล้วนสกปรกและยุ่งเหยิง อีกทั้งมักจะมีกลิ่นเหม็นที่ไม่พึงประสงค์ลอยคละคลุ้งอยู่เสมอ","หลังจากใช้ชีวิตอยู่ที่นั่นมาเป็นเวลานาน ฟูล่าก็ไม่ได้คิดว่ามันมีอะไรผิดปกติ ทว่าหลังจากมาถึงอิเยตา นางถึงได้ตระหนักว่าเมืองเมืองหนึ่งสามารถสะอาดและเป็นระเบียบเรียบร้อยได้ถึงเพียงนี้","และเพียงชั่วครู่เดียว นางก็เห็นเรือเหาะเจ็ดลำบินอยู่เหนือเมืองแล้ว นอกเหนือจากรถม้าธรรมดาที่สัญจรไปมาบนท้องถนน ยังมีกล่องเหล็กรูปร่างแปลกประหลาด ซึ่งสามารถเคลื่อนที่ไปได้อย่างรวดเร็วโดยไม่ต้องอาศัยอูฐหรือม้ามาลากจูง","จากปล่องควันของโรงงานที่อยู่ไกลออกไป มีควันสีขาวพ่นออกมาเป็นจังหวะ ‘ฉึก-ฉัก’ ซึ่งเป็นสิ่งที่ไม่สามารถพบเห็นได้เลยในอาณาจักรฮัดลาตา","“นั่นมันอะไรกัน? ช่างเป็นเรือที่ลำใหญ่โตอะไรเช่นนี้?!”","สายตาของแอนโธนีจับจ้องไปยังเรือขนาดมหึมาที่จอดเทียบท่าอยู่บนทะเล","ความสูงของเรือลำยักษ์นี้สูงถึง 50 เมตร และมีความยาวมากกว่า 100 เมตร บนทั้งสองด้านของตัวเรือมีปืนใหญ่หน้าตาน่าเกรงขามเรียงรายอยู่เป็นแถว มันจอดตระหง่านอยู่บนท่าเรืออย่างโดดเด่นสะดุดตา ราวกับเป็นเกาะที่สามารถเคลื่อนที่ได้","“นี่คือเรือรบที่กำลังอยู่ระหว่างการก่อสร้าง ซึ่งทั้งหมดสร้างขึ้นจากเหล็กกล้า!”","ธีโอดอร์แนะนำให้ทุกคนรู้จักอย่างภาคภูมิใจ แม้ว่าเขาจะไม่ได้กลับมาที่อิเยตาเป็นเวลานานแล้ว แต่ก็มีโครงร่างทั่วไปของเรือรบลำนี้อยู่ก่อนที่เขาจะจากไป ดังนั้นเขาจึงไม่รู้สึกแปลกใจแต่อย่างใด","“เรือที่ทำจากเหล็กกล้าสามารถลอยน้ำได้ด้วยหรือ?”","แฮมม์ถามด้วยความประหลาดใจ","แม้แต่แอนโธนีก็ยังรู้สึกสนใจเป็นอย่างมาก หรือว่าจะมีใครร่ายเวทมนตร์อันทรงพลังบางอย่างใส่เรือเหล็กยักษ์ลำนี้? แต่เรือลำใหญ่ขนาดนี้มีน้ำหนักหลายร้อยตัน มันจะไม่กินพลังเวทจนไม่อาจประเมินได้เลยงั้นหรือ","“แน่นอนสิ!”","ธีโอดอร์เอ่ยอย่างภาคภูมิใจ","“ท่านศาสตราจารย์กล่าวว่า เหตุผลที่วัตถุลอยอยู่บนน้ำได้นั้น เป็นเพราะแรงโน้มถ่วงที่มันได้รับมีค่าน้อยกว่าแรงพยุงของน้ำ...”","ด้วยความรู้ที่เขาได้เรียนมาจากลินน์ ธีโอดอร์จึงอธิบายทฤษฎีบทของกลศาสตร์ให้ทุกคนที่อยู่ตรงหน้าฟัง—วัตถุที่จมอยู่ในของไหลสถิตจะได้รับแรงพยุงซึ่งมีค่าเท่ากับน้ำหนักของของไหลที่ถูกแทนที่ด้วยวัตถุนั้น","ดังนั้น เพียงแค่ใช้สูตรคำนวณความหนาแน่นโดยนำมวลมาหารด้วยปริมาตร ตราบใดที่มันมีค่าน้อยกว่าน้ำ มันก็จะสามารถลอยน้ำได้อย่างเป็นธรรมชาติ ยกตัวอย่างเช่น เรือรบเหล็กกล้าของพวกเขามีห้องโดยสารกลวงอยู่ที่ด้านล่าง ดังนั้นส่วนที่จมลงไปในน้ำจึงมีความหนาแน่นโดยรวมน้อยกว่าน้ำมาก","“ตราบใดที่เป็นไปตามเงื่อนไขนี้ ไม่ว่าสิ่งใดก็สามารถลอยบนน้ำได้ ท่านศาสตราจารย์ลินน์ยังได้คิดค้นคำศัพท์ใหม่ขึ้นมา เรียกว่า ระวางขับน้ำ! มันคือปริมาณน้ำที่เรือเข้าไปแทนที่ในน้ำ...”","ธีโอดอร์แนะนำอย่างฉะฉาน","“จะมีการสร้างเรือแบบนี้เพิ่มขึ้นอีกหลายลำ และเมื่อถึงเวลานั้น การออกเรือเพียงครั้งเดียวก็จะสามารถนำปลาทะเลกลับมาได้มากพอให้ผู้คนนับหมื่นกินไปได้ตลอดทั้งสัปดาห์!”","ตกปลาเนี่ยนะ?!","ทุกคนที่อยู่ตรงหน้าถึงกับตอบสนองไม่ทัน พวกเขาเพิ่งจะฟังธีโอดอร์โอ้อวดว่าเรือเหล็กยักษ์ลำนี้ทรงพลังเพียงใด แต่ตอนนี้กลับมาบอกพวกเขาว่าเจ้าสิ่งนี้มีไว้เพื่อใช้ตกปลา มันช่างเป็นเรื่องยากที่จะทำใจยอมรับได้ชั่วขณะ","ธีโอดอร์เบ้ปาก อันที่จริงแล้ว เขาก็รู้สึกเหมือนกันว่านี่มันเป็นการทำอะไรที่เกินกว่าเหตุไปสักหน่อย แต่ท่านศาสตราจารย์ลินน์กลับไม่คิดเช่นนั้นอย่างเห็นได้ชัด","ตามความเห็นของลินน์ ในเมื่อทุกสิ่งถูกสร้างขึ้นมาแล้ว จะปล่อยให้มันว่างเปล่าในช่วงที่ไม่มีสงครามไม่ได้ การตกปลาไม่เพียงแต่สร้างผลประโยชน์ และช่วยปรับปรุงเมนูอาหารของเมืองเท่านั้น แต่บางทีอาจจะได้ยิงสัตว์ทะเลเพิ่มอีกสักสองสามตัว เพื่อให้เหล่าพลปืนได้ฝึกฝนความแม่นยำของพวกเขาด้วย","เรย์เดลไม่ได้จับจ้องสายตาไปที่เรือหุ้มเกราะอันสง่างามเหมือนฟูล่าและคนอื่นๆ แต่เขากลับให้ความสนใจไปยังคนยากจนที่เดินผ่านไปมา ทุกคนล้วนแต่งกายด้วยเสื้อผ้าที่ดูดี เสื้อผ้าที่สวยงามเช่นนี้มักจะมีเพียงขุนนางเท่านั้นที่สามารถซื้อหามาสวมใส่ได้ แต่ตอนนี้มันกลับถูกสวมใส่โดยคนงานท่าเรือที่กำลังขนย้ายสินค้า...","“พวกเขาเต็มใจที่จะสวมเสื้อผ้าสวยงามเช่นนี้ในขณะที่กำลังขนย้ายสินค้าได้อย่างไร? แล้วถ้าหากมันขาดขึ้นมาล่ะ?”","แฮมม์เอ่ยด้วยความรู้สึกปวดใจเล็กน้อย","ธีโอดอร์ที่อยู่ด้านข้างตอบกลับด้วยน้ำเสียงขบขัน","“นี่ไม่ใช่เรื่องแปลกอะไรในอิเยตา ในทุกๆ วัน คนงานในโรงงานเวทมนตร์สามารถผลิตผ้าได้ยาวถึงหลายหมื่นเมตร และที่นี่ คุณสามารถซื้อเสื้อผ้าดีๆ ได้ในราคาเพียงห้าเหรียญทองแดงเท่านั้น”"]},{"n":313,"t":"คุณแน่ใจหรือว่าท่านศาสตราจารย์ไม่ใช่พ่อมดระดับตำนาน?","c":["“ผ้าหนึ่งหมื่นเมตรงั้นหรือ? เป็นไปได้ไหมว่ามันถูกสร้างขึ้นด้วยเวทมนตร์?”","แฮมม์ถามด้วยความไม่อยากจะเชื่อ","“มันเป็นสิ่งที่ท่านลินน์วิจัยขึ้นมา มีสิ่งหนึ่งที่เรียกว่าเครื่องทอผ้าและจักรเย็บผ้า มันไม่จำเป็นต้องพึ่งพาเวทมนตร์เลย แม้แต่คนธรรมดาก็สามารถควบคุมมันได้อย่างอิสระ หากมีวัตถุดิบเพียงพอ ผลผลิตก็สามารถเพิ่มขึ้นเป็นสองเท่าได้สบาย!”","น้ำเสียงของธีโอดอร์แฝงไปด้วยความรู้สึกเหนือกว่าอย่างชัดเจน และความเร็วในการพัฒนาของอิเยตานั้นก็รวดเร็วราวกับเปลี่ยนไปในทุกสัปดาห์!","ในขณะที่กำลังพูดคุยกัน รถแปรธาตุที่ถูกประดิษฐ์ขึ้นมาอย่างประณีตคันหนึ่งก็มาจอดเทียบข้างทุกคน","ธีโอดอร์เชิญแอนโธนีและคนอื่นๆ ให้ขึ้นไปนั่งบนนั้น","ในช่วงไม่กี่เดือนที่ผ่านมา เทคโนโลยีเครื่องยนต์สันดาปภายในค่อยๆ พัฒนาจนสมบูรณ์แบบ รถแปรธาตุประเภทนี้ยังถูกแบ่งออกเป็นหลากหลายประเภท บางคันใช้สำหรับการขนส่งแร่โดยเฉพาะ และบางคันก็ถูกใช้เป็นพาหนะสำหรับผู้คนในการเดินทางภายในเมือง","รถที่อยู่ตรงหน้าพวกเขาในตอนนี้เป็นประเภทหลังอย่างไม่ต้องสงสัย มันเป็นรถที่ถูกออกแบบมาเพื่อการท่องเที่ยวโดยเฉพาะ มีขนาดใหญ่กว่ารถแปรธาตุคันอื่นเกือบสองเท่า สามารถรองรับผู้โดยสารได้ถึงยี่สิบคน มีหลังคาสำหรับบังแดดบังฝน ใช้ยางแบบเติมลม ทำให้ไม่รู้สึกสั่นสะเทือนเหมือนแต่ก่อนอีกต่อไป","ข้อเสียเพียงอย่างเดียวคือความเร็วของมันไม่ได้เร็วนัก และเป็นไปไม่ได้เลยที่จะวิ่งทะยานไปทั่วทั้งเมือง แต่สำหรับเรย์เดลและคนอื่นๆ ที่เพิ่งเคยนั่งเป็นครั้งแรก มันก็ถือว่าเร็วมากแล้ว เพราะถึงอย่างไรรถคันนี้ก็ยังเร็วกว่ารถม้าอยู่มาก...","แฮมม์นั่งลงบนเบาะหนังนุ่มๆ อย่างระมัดระวัง เขารู้สึกราวกับว่าทุกสิ่งรอบตัวเปรียบเสมือนงานศิลปะอันวิจิตรบรรจง แม้แต่ขุนนางผู้สูงศักดิ์ก็ยังไม่เคยได้รับการปรนนิบัติเช่นนี้มาก่อน","ธีโอดอร์พาทุกคนตระเวนไปทั่วเมืองท่าและแนะนำให้พวกเขารู้จักกับโรงงานต่างๆ ที่กำลังปล่อยควันสีขาวพวยพุ่ง ก่อนหน้านี้เขาได้ยินมาว่าลินน์กำลังจะให้คนสร้างสิ่งที่เรียกว่า ‘รางรถไฟ‘ ซึ่งจะสามารถเชื่อมโยงทุกหนทุกแห่งในดินแดนพ่อมดเข้าด้วยกัน เมืองทั้งหมดจะเชื่อมต่อถึงกัน ทำให้ใช้เวลาเพียงไม่กี่ชั่วโมงในการเดินทางระหว่างสองเมือง ซึ่งจะสะดวกสบายอย่างมากในการขนส่งสินค้าหรือผู้คน","และสิ่งสุดท้ายคือการแนะนำให้รู้จักกับระบบการเมืองในดินแดนพ่อมดที่แตกต่างจากโลกภายนอกอย่างสิ้นเชิง นั่นคือ—ระบบรัฐสภาพ่อมด!","ที่นี่ไม่มีขุนนางหรือกษัตริย์ ทุกสิ่งทุกอย่างล้วนถูกควบคุมโดยพ่อมด!","เรย์เดลและคนอื่นๆ พยายามเก็บซ่อนความตื่นตะลึงไว้ในใจ หลังจากเดินทางมาถึงเมืองแห่งพ่อมดอันน่ามหัศจรรย์แห่งนี้ พวกเขาก็รู้สึกราวกับว่าทุกสิ่งที่ได้เห็นและได้ยินกำลังท้าทายขอบเขตความรู้ความเข้าใจของตนเอง","เรือเหล็กขนาดยักษ์ที่หนักนับร้อยตันแต่สามารถลอยอยู่บนทะเลได้ รถแปรธาตุที่สามารถเคลื่อนที่ได้เองโดยไม่ต้องพึ่งพาอูฐหรือม้าลากจูง และเครือข่ายทางรถไฟอันยิ่งใหญ่ที่เชื่อมต่อเมืองหลายสิบเมืองเข้าด้วยกัน ล้วนเป็นเรื่องที่เหลือเชื่อทั้งสิ้น","ชั่วขณะหนึ่ง เรย์เดลถึงกับสงสัยว่าเขายังคงอยู่ในความฝันหรือเปล่า","“ตามที่ท่านศาสตราจารย์กล่าวไว้ พลังของเวทมนตร์และเทคโนโลยีไม่เพียงแต่สามารถนำมาใช้ในการต่อสู้ได้เท่านั้น แต่ยังรวมถึงในชีวิตประจำวัน เพื่อมอบความสะดวกสบายให้กับทุกคนด้วย”","ธีโอดอร์กล่าวพร้อมกับรอยยิ้ม","“ท่านลินน์ช่างเป็นบุคคลที่น่าเหลือเชื่อจริงๆ...”","ฟูล่าอดไม่ได้ที่จะกล่าวชื่นชม จากคำพูดของธีโอดอร์ ไม่ยากเลยที่จะรับรู้ว่าเมืองท่าแห่งนี้ไม่ได้เป็นเช่นนี้มาตั้งแต่ต้น แต่การเปลี่ยนแปลงทั้งหมดในอิเยตานั้น เกิดขึ้นหลังจากที่ลินน์ก้าวขึ้นมาเป็นผู้นำของสถาบัน","“ในเมื่อดินแดนพ่อมดทั้งหมดถูกควบคุมโดยรัฐสภา เช่นนั้นท่านลินน์ก็น่าจะเป็นประธานที่ดูแลรัฐสภาใช่หรือไม่?”","ฟูล่าเอ่ยถามต่อ","“ไม่หรอก ท่านศาสตราจารย์เพิ่งเดินทางจากจักรวรรดิเซคัสมายังดินแดนพ่อมดเมื่อสองปีก่อน แม้ว่าทฤษฎีเวทมนตร์หลายข้อที่เขาเสนอจะเพียงพอที่จะเปลี่ยนแปลงระบบเวทมนตร์ที่มีอยู่เดิม แต่ตำแหน่งประธานรัฐสภาก็มักจะถูกครอบครองโดยพ่อมดระดับตำนานเสมอ”","ธีโอดอร์ส่ายหน้า ปฏิเสธข้อสันนิษฐานของฟูล่า ก่อนจะกล่าวเสริมว่า","“แน่นอนว่า พ่อมดทุกคนล้วนรู้ดีว่ามันเป็นเพียงเรื่องของเวลาเท่านั้น ก่อนที่ท่านศาสตราจารย์จะก้าวขึ้นเป็นประธานรัฐสภา”","‘นั่นหมายความว่า ท่านลินน์ไม่ใช่พ่อมดระดับตำนานอย่างนั้นหรือ?’","ฟูล่าและคนอื่นๆ รู้สึกประหลาดใจเล็กน้อย พวกเขาทุกคนต่างก็เคยเห็นอสนีบาตศักดิ์สิทธิ์ที่ฟาดฟันลงมาจากฟากฟ้าในคืนนั้น และคฤหาสน์ทั้งหลังก็ถูกทำลายลงในพริบตา พลังอำนาจเช่นนั้นย่อมต้องเกิดจากเวทมนตร์ระดับตำนานเท่านั้น","ด้วยความสับสนอย่างหนัก ฟูล่าจึงเอ่ยถามเรื่องราวเกี่ยวกับลินน์ต่อไปด้วยความอยากรู้อยากเห็น","ธีโอดอร์เองก็เริ่มมีท่าทีสนใจขึ้นมาทันที ลินน์เดินทางมาถึงอิเยตาได้ไม่นาน แต่ประสบการณ์ของเขากลับเต็มไปด้วยตำนานอันยิ่งใหญ่ เริ่มตั้งแต่การสร้างเรือเหาะ ไปจนถึงการสาธิตกฎการตกอย่างอิสระ การวัดพื้นที่ของดาวเคราะห์ และการเสนอกฎแรงโน้มถ่วงสากล เขาได้รับเกียรติยศสูงสุดทางวิชาการในโลกเวทมนตร์—นั่นคือเหรียญตราโคโรน่า","หากจะให้เล่ารายละเอียดจริงๆ เกรงว่าคงใช้เวลาหลายชั่วโมงก็ยังไม่จบ","ฟูล่าและคนอื่นๆ ต่างตกตะลึง ก่อนที่พวกเขาจะตั้งสติได้จากข่าวอันน่าตกใจที่ว่าทวีปใต้ฝ่าเท้าของพวกเขานั้นมีรูปทรงเป็นทรงกลม พวกเขาก็ต้องรับฟังข่าวที่ฟังดูไร้สาระยิ่งกว่านั้น ลินน์ที่ธีโอดอร์กำลังพูดถึง กลับเป็นเพียงพ่อมดระดับสามเท่านั้น","‘เรื่องนี้จะเป็นไปได้อย่างไร?’","ทุกคนที่อยู่ในเหตุการณ์ต่างตกตะลึง และถึงกับสงสัยว่าธีโอดอร์จงใจปั่นหัวพวกเขาเล่นหรือเปล่า","แม้แต่แอนโธนีเองก็ค่อนข้างประหลาดใจเช่นกัน แต่เมื่อนึกถึงรูปลักษณ์ที่ดูอ่อนเยาว์เป็นพิเศษของลินน์ สีหน้าครุ่นคิดก็ปรากฏขึ้นบนใบหน้าของเขาในไม่ช้า","ประมาณสิบห้านาทีต่อมา รถแปรธาตุก็มาจอดสนิทอยู่ที่หน้าประตูสถาบัน","ฟูล่า, แอนโธนี, เรย์เดล และคนอื่นๆ ก้าวลงจากรถ และเมื่อพวกเขาเงยหน้าขึ้นมอง ก็มองเห็นสิ่งก่อสร้างอันเป็นสัญลักษณ์สำคัญที่สุดของสถาบันอิเยตา—นั่นคือประติมากรรมรูปมือยักษ์คู่หนึ่งที่สลักจากหินอ่อนสีขาวบริสุทธิ์ บนฝ่ามือแต่ละข้างมีลูกบอลไม้และลูกเหล็กถูกชูขึ้นสู่ท้องฟ้า","กลุ่มนักเรียนฝึกหัดอย่างเอล็อคที่เดินทางกลับมายังสถาบันพร้อมกันอดไม่ได้ที่จะตัวสั่นสะท้าน เพราะมันทำให้พวกเขานึกถึงสูตรการตกอย่างอิสระ","ได้ยินมาจากท่านศาสตราจารย์ว่าพวกเขาจะต้องทำการสอบจบการศึกษาเมื่อเดินทางกลับมาในครั้งนี้ เนื้อหาของการสอบครั้งนี้แตกต่างจากครั้งที่ผ่านๆ มา สูตรและทฤษฎีที่เคยเรียนไปทั้งหมดล้วนอยู่ในขอบเขตของการสอบ ซึ่งมันเรียกได้ว่าเป็นฝันร้ายเลยทีเดียว","“ทุกท่าน ยินดีต้อนรับสู่อิเยตา!”","น้ำเสียงดังกังวานดังขึ้นในหูของทุกคนในเวลาต่อมา และเป็นลินน์นั่นเองที่เดินเข้ามาพร้อมกับกลุ่มพ่อมดแห่งสถาบัน","“ท่านศาสตราจารย์!”","เอล็อคและคนอื่นๆ รีบโค้งคำนับทำความเคารพ","ธีโอดอร์ก้าวเข้าไปข้างหน้าและสวมกอดเควินที่ไม่ได้พบกันมานานอย่างอบอุ่น","“ธีโอดอร์ นายไม่สังเกตเห็นหรือว่าท่านศาสตราจารย์เปลี่ยนไป?”","เควินเอ่ยถามด้วยรอยยิ้ม","“เปลี่ยนไป?!”","ธีโอดอร์ชะงักไปครู่หนึ่ง เขามองลินน์ด้วยความประหลาดใจ และไม่เห็นความแตกต่างใดๆ เป็นเวลานาน ก่อนจะนึกอะไรบางอย่างขึ้นมาได้ และเอ่ยขึ้นด้วยความตกตะลึง","“เป็นไปได้ไหมว่าท่านทะลวงขีดจำกัดและกลายเป็นจอมเวทผู้ยิ่งใหญ่แล้ว?”","ลินน์พยักหน้ารับอย่างไม่ใส่ใจนัก","เควินกล่าวด้วยสีหน้าเสียดาย","“เมื่อคืนนี้เอง น่าเสียดายที่นายพลาดช่วงเวลาสำคัญเช่นนี้ไป”","ธีโอดอร์เองก็รู้สึกหงุดหงิดเล็กน้อย เขาคงจะกลับมาเร็วกว่านี้สักวันหากรู้ล่วงหน้า","แอนโธนี ซึ่งเป็นจอมเวทผู้ยิ่งใหญ่เช่นกันไม่ได้รู้สึกประหลาดใจเลยแม้แต่น้อย เขาสังเกตเห็นการคงอยู่ของอาณาเขตตั้งแต่แรกเห็นลินน์แล้ว","สำหรับภาพฉายพลังเวทมนตร์ที่เขาเคยสัมผัสมาก่อนหน้านี้ เขาย่อมไม่สามารถประเมินมันได้อย่างชัดเจน แต่ตอนนี้เขาสามารถมั่นใจได้แล้วว่าลินน์คือจอมเวทผู้ยิ่งใหญ่เช่นเดียวกับเขา"]},{"n":314,"t":"แอนโธนี: เจ้าคิดว่าพ่อมดระดับสามวงแหวนจะสามารถเข้าใจทฤษฎีเวทมนตร์อันลึกซึ้งมากมายขนาดนั้นได้จริงๆ หรือ?","c":["“ท่านแอนโธนี ระหว่างทางมาที่นี่ ท่านน่าจะได้เห็นเมืองท่าแห่งนี้แล้ว ท่านรู้สึกอย่างไรบ้าง?”","ลินน์เชิญทุกคนเข้ามาในห้องประชุมอันกว้างขวางแล้วเอ่ยถาม","“ข้าคิดว่าไม่ว่าใครก็ตามที่เดินทางมาถึงเมืองพ่อมดแห่งนี้เป็นครั้งแรก ล้วนต้องรู้สึกตกตะลึงอย่างหาที่สุดไม่ได้...”","แอนโธนีตอบกลับด้วยความรู้สึกท่วมท้น คำพูดเหล่านี้ไม่ใช่การจงใจประจบสอพลอ แต่เป็นเสียงถอนหายใจที่ออกมาจากก้นบึ้งของหัวใจ มันช่างเข้ากับจินตนาการของอาณาจักรเวทมนตร์ได้อย่างสมบูรณ์แบบ","ไม่สิ ควรจะบอกว่ามันแปลกประหลาดยิ่งกว่าที่เขาจินตนาการไว้เสียอีก","“ข้าเชื่อว่าอีกไม่นาน อาณาจักรฮัดลาตาทั้งหมดก็จะได้รับการเปลี่ยนแปลงเฉกเช่นเมืองท่าแห่งนี้ และนี่จะเป็นกุญแจสำคัญสู่ชัยชนะเหนือจักรวรรดิของเราด้วย!”","ลินน์กล่าวพร้อมกับรอยยิ้ม","“ข้าไม่มีข้อสงสัยในเรื่องนี้เลย แต่เหล่าขุนนางของอาณาจักรและฝ่าบาท กษัตริย์องค์ใหม่ของเรา อาจจะไม่ทรงพอพระทัยนัก...”","สีหน้าของแอนโธนีดูเคร่งขรึมขึ้นเล็กน้อย","ระหว่างทางมายังสถาบัน เขาได้ยินเรื่องราวมากมายจากธีโอดอร์เกี่ยวกับการเปลี่ยนแปลงของเมืองท่าแห่งนี้ ชาวเมืองเกือบร้อยละหกสิบได้เข้าไปทำงานในโรงงาน และพวกเขาสามารถรับค่าจ้างที่สูงมากในทุกๆ เดือน ด้วยเหตุนี้เอง จึงไม่มีใครในอิเยตาทั้งเมืองต้องทนหิวโหย และทุกคนยังสามารถกินขนมปังขาวที่อดีตมีเพียงขุนนางเท่านั้นที่จะได้ลิ้มรส","การดำเนินนโยบายเช่นนี้ย่อมไม่มีปัญหาในดินแดนพ่อมด เพราะที่นี่ไม่มีขุนนางหรือราชวงศ์ และบรรดาพ่อมดก็ไม่ได้ใส่ใจกับชะตากรรมของประชาชนมากนัก ประกอบกับการยอมรับอย่างเงียบๆ ของรัฐสภา ภายในเวลาเพียงสองปี ประชากรของอิเยตาก็พุ่งทะลุหนึ่งแสนคนไปแล้ว","แต่มันไม่ง่ายเลยที่จะนำนโยบายนี้ไปปรับใช้ในอาณาจักร เพราะท้ายที่สุดแล้ว ประชาชนคือทรัพย์สินที่มีค่าที่สุดของเหล่าขุนนาง และยังเป็นสัญลักษณ์ของสิทธิอำนาจทั้งมวล!","ลินน์เข้าใจความกังวลของแอนโธนีเป็นอย่างดี แต่เขาไม่ได้รู้สึกหนักใจอะไรนัก จึงเอ่ยด้วยรอยยิ้ม","“ไม่มีใครสามารถหยุดยั้งความก้าวหน้าของยุคสมัยได้ หากพวกเขากล้าที่จะยกแขนขึ้นมาขวางทางรถ พวกเขาก็มีแต่จะถูกกงล้อแห่งยุคสมัยบดขยี้!”","เหตุผลที่เขาเลือกจะร่วมมือกับองค์ชายรองและรักษาฐานะของราชวงศ์เอาไว้ชั่วคราว ก็เพื่อใช้การควบคุมระดับรากหญ้าของราชวงศ์และเหล่าขุนนางมากดทับอิทธิพลของศาสนจักร","ตราบใดที่ช่วงเวลาอันยากลำบากที่สุดนี้ผ่านพ้นไป และผู้ยากไร้เหล่านั้นได้เห็นผลประโยชน์ที่เป็นรูปธรรม เมื่อนั้นเหล่าขุนนางก็จะหมดประโยชน์ไปโดยปริยาย!","“ท่านลินน์ ในเมื่อชาวเมืองส่วนใหญ่เข้าไปทำงานในโรงงาน แล้วพื้นที่เกษตรกรรมที่ถูกทิ้งร้างล่ะครับ?”","เรย์เดลเอ่ยถามด้วยความสับสน","“ข้าได้ยินจากท่านธีโอดอร์ว่า อิเยตามีอุปกรณ์แปรธาตุที่ทำให้ผู้คนสามารถเพาะปลูกบนที่ดินขนาดสิบกิโลเมตรได้ภายในหนึ่งชั่วโมง เรื่องนั้นเป็นความจริงหรือครับ?”","นี่เป็นสิ่งที่เรย์เดลให้ความสนใจมากที่สุด เพราะอีกไม่นานก็จะถึงช่วงฤดูเก็บเกี่ยวข้าวสาลีในฤดูร้อนประจำปี ซึ่งตามมาด้วยการเพาะปลูกในฤดูใบไม้ร่วง","“แน่นอนว่าเป็นความจริง แต่ไม่ต้องกังวลไปหรอก อีกไม่กี่วันพวกเจ้าก็จะได้รู้เอง!”","ลินน์กล่าวด้วยน้ำเสียงหนักแน่น รถเกี่ยวข้าวรุ่นแรกของโรงงานแปรธาตุได้ถูกผลิตขึ้นมาแล้ว และเขาเชื่อว่าจะได้เห็นผลลัพธ์ในเร็วๆ นี้","เมื่อเห็นว่าแอนโธนีและคนอื่นๆ ต้องเดินทางข้ามดินแดนทั้งสองแห่งด้วยเรือเหาะมาตลอดทั้งวัน ลินน์จึงไม่ได้พูดคุยกับพวกเขาให้ยืดเยื้อ และรีบเรียกให้ผู้ติดตามพาทุกคนไปพักผ่อน","หลังจากเดินออกจากห้องรับรอง ฟูล่าก็ไม่อาจเก็บงำคำพูดที่อัดอั้นอยู่ในใจได้อีกต่อไป","“ท่านอาจารย์ ดูเหมือนว่าการคาดเดาก่อนหน้านี้ของท่านจะผิดพลาดนะคะ ท่านลินน์ไม่ได้เป็นพ่อมดระดับตำนาน และตอนที่เขาพบกับพวกเรา เขาก็เป็นเพียงพ่อมดระดับสามวงแหวนเท่านั้น”","“เจ้าคิดว่าพ่อมดระดับสามวงแหวนจะสามารถเข้าใจทฤษฎีเวทมนตร์อันลึกซึ้งมากมายขนาดนั้นได้จริงๆ หรืองั้นหรือ? ทั้งแรงโน้มถ่วง อวกาศ และแรงแม่เหล็กไฟฟ้า... ทฤษฎีเหล่านี้ ต่อให้จอมเวทผู้ยิ่งใหญ่ใช้เวลาทั้งชีวิตเพื่อศึกษามัน ก็อาจจะยังไม่ลึกซึ้งเท่าเขาเลยด้วยซ้ำ”","แอนโธนีส่ายหน้าและปฏิเสธข้อสันนิษฐานของฟูล่า","“แต่ว่า บรรดาพ่อมดแห่งสถาบันอิเยตาก็ไม่มีความจำเป็นที่จะต้องโกหกพวกเรานี่คะ ท่านลินน์เพิ่งจะผ่านพิธีเลื่อนระดับเมื่อคืนนี้เอง...”","ฟูล่ากล่าวด้วยความสับสน ก่อนจะคาดเดาต่อว่า","“บางทีที่เขารู้มากขนาดนี้ อาจเป็นเพราะเขาได้เรียนรู้ทฤษฎีเวทมนตร์ขั้นสูงมากมายจาก [สมาคมเวทมนตร์เร้นลับ] แห่งนั้นก็ได้”","ดังนั้นพวกเขาก็น่าจะถูกอีกฝ่ายหลอกลวงมาก่อนหน้านี้ และนางกลับต้องมาทำความเคารพเด็กหนุ่มที่มีอายุไม่ถึงครึ่งหนึ่งของนาง แถมยังเป็นเพียงพ่อมดระดับทางการเท่านั้น","แอนโธนียิ้มและไม่ได้พูดอะไร เขาเคยติดต่อกับลินน์มาแล้วหลายครั้งในด้านพลังเวทมนตร์ และเขาได้เรียนรู้ความรู้ที่หลากหลายจากอีกฝ่าย แต่ไม่ว่าจะเป็นด้านไหน ลินน์ก็สามารถตอบคำถามได้โดยไม่ต้องหยุดคิดเลยด้วยซ้ำ","บางครั้งเขาก็อดสงสัยไม่ได้ว่า จะมีปัญหาใดบนโลกใบนี้ที่สามารถทำให้อีกฝ่ายจนมุมได้บ้างหรือไม่","คลังความรู้เป็นสิ่งที่ไม่สามารถเสแสร้งแกล้งทำได้ และไม่มีพ่อมดคนไหนที่จะถ่ายทอดความรู้ที่พวกเขาอุตส่าห์ศึกษาและสรุปมาให้กับคนอื่นอย่างหมดเปลือกโดยไม่มีเหตุผล อย่างน้อยมันก็ต้องเป็นการแลกเปลี่ยนที่อยู่ในระดับเดียวกัน","เช่นนั้นมันก็เหลือความเป็นไปได้เพียงอย่างเดียว...","จู่ๆ แอนโธนีก็คลับคล้ายคลับคลาถึงข่าวลือหนึ่ง ว่ากันว่าเมื่อหลายร้อยปีก่อน ในยุคที่อำนาจของศาสนจักรยังไม่ได้แผ่ขยายไปทั่วทั้งทวีป เคยมีจอมเวทผู้ยิ่งใหญ่และแม้แต่พ่อมดระดับตำนานนับไม่ถ้วนเฉกเช่นเดียวกับพวกเขา ทว่าคนเหล่านี้กลับล้มตายและบาดเจ็บเป็นจำนวนมากในสงครามอันยาวนานที่นำมาซึ่งหายนะ ซึ่งอาจเรียกได้ว่าเป็นมหาสงครามแห่งเวทมนตร์","แอนโธนีอดสงสัยไม่ได้ว่า แท้จริงแล้วลินน์เคยเป็นพ่อมดระดับตำนานมาก่อน ทว่ากลับร่วงหล่นลงมาด้วยเหตุผลที่ไม่ทราบแน่ชัด และตอนนี้เขาก็ได้ถือกำเนิดใหม่ ไม่ว่าจะเป็นการยึดร่าง หรือการใช้วิชาเวทมนตร์บางอย่างก็ตาม","แม้ว่าความรู้จะยังคงอยู่ แต่มันก็ยังต้องการการสั่งสมพลังอีกเล็กน้อยเพื่อหวนคืนสู่ขอบเขตระดับตำนาน เขายังจำเป็นต้องใช้ค่ายกลเล่นแร่แปรธาตุหรือความช่วยเหลือจากคนอื่นๆ เพื่อให้สามารถร่ายเวทมนตร์ระดับตำนานที่เคยสร้างขึ้นมาในอดีตได้!","ยิ่งแอนโธนีคิดเกี่ยวกับเรื่องนี้มากเท่าไหร่ มันก็ยิ่งมีความเป็นไปได้มากเท่านั้น จากการติดต่อเมื่อครู่นี้ จะเห็นได้ว่าอาณาเขตที่ลินน์สร้างขึ้นนั้นมีความเสถียรเป็นอย่างมาก และเขายังทำให้ทะเลแห่งธาตุสมบูรณ์แบบได้อีกด้วย มันดูไม่เหมือนกับจอมเวทผู้ยิ่งใหญ่ที่เพิ่งได้รับการเลื่อนระดับเลยสักนิด","แต่ไม่ว่าเขาจะแน่ใจแค่ไหน ท้ายที่สุดแล้วนี่ก็เป็นเพียงการคาดเดา แอนโธนีไม่ได้ตั้งใจจะพูดมันออกมา เขาเพียงแค่เตือนฟูล่าและคนอื่นๆ ว่าท่านลินน์ไม่ใช่คนธรรมดาทั่วไป พวกเขาแค่ต้องปฏิบัติต่ออีกฝ่ายในฐานะพ่อมดระดับตำนาน... นั่นคือสิ่งที่ถูกต้องที่สุดแล้ว","เมื่อเทียบกับเรย์เดลและคนอื่นๆ ที่กำลังท่องเที่ยวอยู่ในอิเยตา เอล็อคที่เพิ่งมาถึงสถาบันได้อุทิศตนให้กับการทบทวนบทเรียนไปเป็นที่เรียบร้อยแล้ว","เนื่องจากสงครามกับจักรวรรดิอาจจะเริ่มต้นขึ้นเมื่อใดก็ได้ ลินน์จึงจัดตารางเวลาอย่างรัดกุม โดยปล่อยให้พวกเขามีเวลาทบทวนบทเรียนเพียงแค่ครึ่งวันเท่านั้น","การสอบจบการศึกษามีเพียงปีละครั้งเท่านั้น หากพวกเขาสอบตกในครั้งนี้ ก็จะต้องรอไปอีกหนึ่งปีเต็ม!","หลังจากอยู่ในอาณาจักรฮัดลาตามานานกว่าหนึ่งเดือน เพียร์ซก็แทบจะลืมสูตรที่เขาเคยเรียนไปก่อนหน้านี้จนหมดสิ้น เมื่อมองไปที่สมุดจดบันทึกที่เขาเขียนไว้ในวันธรรมดา เขาก็รู้สึกหน้ามืดตาลาย และไม่รู้ว่าจะต้องทำอย่างไรดี เขาจำไม่ได้ด้วยซ้ำว่าสัญลักษณ์แต่ละตัวหมายถึงอะไร","“เร็วเข้า เร็วเข้า ใครบอกฉันทีว่าความเร่งโน้มถ่วงคืออะไร?”","“แล้วสูตรปริมาตรของทรงกระบอกล่ะ? ค่าพายคืออะไร?”","“ใครจำความหนาแน่นของน้ำได้บ้าง?”","เสียงตะโกนในทำนองเดียวกันดังขึ้นจากทุกมุมของสถาบัน เห็นได้ชัดว่าในช่วงเวลากว่าหนึ่งเดือนที่ผ่านมา มีน้อยคนนักที่จะยอมอ่านหนังสือในเวลาว่าง คืนนี้คงถูกกำหนดให้เป็นค่ำคืนที่ไม่ได้หลับไม่ได้นอนเสียแล้ว..."]},{"n":315,"t":"จุดประสงค์ของเราคือการสำรวจว่าเวทมนตร์มาจากไหน!","c":["เช้าตรู่ของวันรุ่งขึ้น กลุ่มพ่อมดฝึกหัดได้ก้าวเข้าสู่ห้องสอบด้วยความรู้สึกวิตกกังวล หลังจากได้รับกระดาษข้อสอบของตัวเองแล้ว พวกเขาก็รีบนับจำนวนข้อสอบด้วยใบหน้าที่ขมวดคิ้วมุ่น","เพียร์ซไม่กล้าชักช้าและรีบเปิดไปที่คำถามข้อแรก","[A และ B เดินเข้าหากันจากสองสถานที่ในเวลาเดียวกัน หลังจากผ่านไปสี่ชั่วโมง พวกเขาจะพบกันที่ระยะห่าง 5 กิโลเมตรจากจุดกึ่งกลาง เป็นที่ทราบกันดีว่า A เร็วกว่า B จงหาว่าในหนึ่งชั่วโมง A เดินเร็วกว่า B กี่กิโลเมตร?]","จู่ๆ เพียร์ซก็ขมวดคิ้ว นี่น่าจะเป็นโจทย์คณิตศาสตร์ที่ต้องการหาค่าตัวแปรที่ไม่ทราบค่า แต่เงื่อนไขที่ให้มานั้นมีไม่มากนัก หลังจากครุ่นคิดอยู่ครู่หนึ่ง ในที่สุดเขาก็ได้แนวคิดในการแก้ปัญหาและเริ่มวาดแผนภาพเส้น","อีกด้านหนึ่งของห้องสอบ บรรดาพ่อมดหลายคนที่รับผิดชอบในการคุมสอบต่างก็กำลังมองดูกระดาษข้อสอบในมือของพวกเขาเช่นกัน","ฟูล่าและคนอื่นๆ ให้ความสนใจกับการสอบจบการศึกษาของสถาบันอิเยตาเป็นอย่างมาก ดังนั้นพวกเขาจึงเสนอตัวที่จะมาช่วยคุมสอบนักเรียน และในขณะเดียวกันก็เริ่มรู้สึกสนใจที่จะลองทำข้อสอบเหล่านี้ดูบ้าง","ในตอนแรกฟูล่าคิดว่าคำถามเหล่านี้ถูกเตรียมไว้สำหรับเด็กฝึกหัด มันจึงไม่น่าจะยากอะไรสำหรับพ่อมดเต็มตัวอย่างนาง แต่หลังจากอ่านคำถามติดต่อกันสองสามข้อ นางก็ถึงกับต้องเบิกตาโพลงด้วยความตกตะลึง","“สถาบันอิเยตาสอนเรื่องพวกนี้ด้วยเหรอ?”","พ่อมดคนหนึ่งเอ่ยถามด้วยความสับสน เพราะเขาคิดว่า เนื้อหาของการสอบจะเป็นความรู้เกี่ยวกับธาตุ สมุนไพร การเล่นแร่แปรธาตุ และเวทมนตร์สายแปรสภาพเสียอีก","“ไม่ผิด!”","ลินน์พยักหน้า เขามองไปที่ฟูล่าและคนอื่นๆ ก่อนจะกล่าวว่า","“โดยทั่วไปแล้วจะประกอบไปด้วยสามวิชา ได้แก่ คณิตศาสตร์ เคมี และฟิสิกส์...ส่วนชีววิทยาก็อาจจะถูกเพิ่มเข้ามาในอนาคต”","“แต่เรียนเรื่องพวกนี้ไปแล้วมันจะได้ประโยชน์อะไรล่ะ? เอาเวลาไปเรียนรู้เวทมนตร์ให้มากขึ้นยังจะดีกว่าเสียอีก...”","ฟูล่าเบ้ปาก","ลินน์เปลี่ยนสีหน้าให้จริงจังขึ้น","“คณิตศาสตร์คือรากฐานของวิทยาศาสตร์ธรรมชาติทั้งหมด เคมีคือศาสตร์ที่ศึกษาองค์ประกอบ โครงสร้าง และการเปลี่ยนแปลงของธาตุเวทมนตร์ ส่วนฟิสิกส์ก็คือการสำรวจกฎเกณฑ์การทำงานของโลกใบนี้...”","“จุดประสงค์ของการศึกษาหลักสูตรเหล่านี้ก็เพื่อสำรวจว่า เวทมนตร์มาจากไหน!”","ลินน์กล่าวด้วยน้ำเสียงหนักแน่น","เวทมนตร์มาจากไหน?","เมื่อได้ยินเช่นนี้ หัวใจของผู้ที่อยู่ในเหตุการณ์ทั้งหมดก็ถึงกับสั่นสะท้าน แม้ว่าพวกเขาจะศึกษาเวทมนตร์มาโดยตลอด แต่ก็แทบจะไม่เคยคิดทบทวนอย่างลึกซึ้งเกี่ยวกับปัญหานี้เลย","ลินน์ยังคงพูดต่อไปว่า","“ส่วนเรื่องประโยชน์ของมัน ข้าคิดว่าพวกท่านก็น่าจะได้เห็นกันแล้วไม่ใช่หรือ? มันอยู่ทุกแห่งทั่วทั้งเมือง! พวกท่านได้เห็นทั้งกระจก กระดาษ เรือเหาะ เรือเดินสมุทร หรือแม้กระทั่งปืนใหญ่แม่เหล็กไฟฟ้า...ทุกสิ่งทุกอย่างล้วนสามารถจัดอยู่ในศาสตร์ทั้งสามแขนงนี้ได้ทั้งสิ้น!”","เมื่อนึกถึงสิ่งที่ตนได้เห็นและได้ยินนับตั้งแต่เข้ามาในอิเยตา ฟูล่าก็เก็บงำความคิดดูถูกเหยียดหยามของตนไปจนหมดสิ้น และเริ่มพิจารณาแต่ละโจทย์ปัญหาอย่างจริงจัง","เพียงแต่นางไม่เคยศึกษาคณิตศาสตร์อย่างเป็นระบบมาก่อน ดังนั้นนางจึงไม่รู้จริงๆ ว่าจะเริ่มแก้สมการเหล่านี้จากตรงไหน ทำให้นางทำได้เพียงหันไปมองลินน์เพื่อขอความช่วยเหลือ","ลินน์ยกมือขึ้นแล้วเคาะเบาๆ เพื่อสร้างบาเรียตัดเสียงรบกวนในบริเวณใกล้เคียง ก่อนจะอธิบายให้ฟังว่า","“คำถามข้อนี้จริงๆ แล้วคำนวณได้ง่ายมาก เพียงแต่มันมีลูกเล่นซ่อนอยู่นิดหน่อย หาก A และ B มีความเร็วเท่ากัน พวกเขาก็ย่อมต้องเดินทางไปถึงจุดกึ่งกลางในเวลาเดียวกันอย่างแน่นอน แต่พวกเขากลับพบกันที่ระยะห่างจากจุดกึ่งกลางห้ากิโลเมตร ดังนั้นคนที่มีความเร็วกว่าอย่าง A ย่อมต้องเดินไปไกลกว่า B ถึงสองเท่า ซึ่งก็คือ 10 กิโลเมตร”","“ทั้งสองคนพบกันหลังจากผ่านไปสี่ชั่วโมง นั่นหมายความว่าทั้ง A และ B ต่างก็ใช้เวลาเดิน 4 ชั่วโมง ดังนั้นจึงใช้แค่การหารแบบง่ายๆ ก็สรุปได้แล้วว่าความเร็วของ A นั้นเร็วกว่า B 2.5 กิโลเมตรต่อชั่วโมง!”","ลินน์อธิบายแนวคิดในการแก้ปัญหาให้กระชับที่สุดเท่าที่จะทำได้ โจทย์ข้อนี้ไม่ได้ยากจริงๆ และมันสามารถแก้ได้ด้วยการใช้ความคิดเพียงเล็กน้อย","กระดาษข้อสอบที่เขาให้ไปนั้นมีทั้งหมด 50 ข้อ ข้อละ 2 คะแนน รวมคะแนนเต็ม 100 คะแนน การได้ 60 คะแนนจะถือว่าสอบผ่าน นั่นก็หมายความว่าพวกเขาจำเป็นต้องตอบคำถามให้ถูกต้องเพียง 30 ข้อเท่านั้น!","และระดับความยากของคำถามเหล่านี้ ยังได้รับการออกแบบมาอย่างรอบคอบโดยลินน์ ซึ่งมีคำถามแจกคะแนนแบบนี้อยู่ยี่สิบห้าข้อ คำถามระดับง่ายยี่สิบข้อ และคำถามค่อนข้างยากอีกห้าข้อ","ตามการคาดเดาของเขา หากเอล็อคและคนอื่นๆ จดบันทึกอย่างระมัดระวัง มันก็ควรจะเป็นเรื่องง่ายสำหรับพวกเขาที่จะทำคะแนนจากคำถามแจกคะแนนทั้งหมด และหลังจากนั้นพวกเขาก็แค่ต้องทำคำถามระดับง่ายให้ถูกต้องอีกเพียงห้าข้อเพื่อให้สอบผ่าน","แต่นี่เป็นเพียงแค่เกณฑ์สอบผ่านเท่านั้น เพราะลินน์นั้นหวังไว้ว่า จะมีนักเรียนที่ได้เกรดดีเยี่ยมสองสามคนเพื่อให้ความสำคัญกับการฝึกฝน ซึ่งล้วนเป็นบุคลากรที่มีความสามารถด้านการวิจัยทางวิทยาศาสตร์","แน่นอนว่านอกเหนือจากการสอบภาคทฤษฎีแล้ว นักเรียนเหล่านี้จะต้องเข้าสอบในหลักสูตรภาคปฏิบัติเพื่อทดสอบการต่อสู้จริงและความสามารถในการร่ายเวทมนตร์ขั้นพื้นฐานด้วย โดยจะนำคะแนนเฉลี่ยจากทั้งสองส่วนมาใช้เพื่อตัดสินว่าพ่อมดฝึกหัดคนนั้นมีคุณสมบัติพอที่จะกลายเป็นพ่อมดเต็มตัวได้หรือไม่ นี่ถือเป็นโอกาสพิเศษสำหรับนักเรียนบางคนที่มีความถนัดเพียงด้านใดด้านหนึ่ง","หลังจากที่ลินน์วิเคราะห์โจทย์คณิตศาสตร์ไปสองสามข้อ ฟูล่าและคนอื่นๆ ก็ได้สัมผัสกับความสนุกสนานในการทำข้อสอบอย่างรวดเร็ว และพวกเขาก็เริ่มหยิบปากกาขึ้นมาครุ่นคิดทีละข้อๆ จนลืมไปเสียสนิแต่พวกเขามาที่นี่เพื่อคุมสอบบรรดานักเรียนเหล่านั้น","สำหรับธีโอดอร์แล้ว คำถามแจกคะแนนเหล่านี้ไม่ได้มีความหมายอะไรเลย หลังจากมองปราดเดียว เขาก็หันไปสนใจคำถามที่ลินน์ทำเครื่องหมายไว้ว่าเป็นระดับง่ายบนกระดาษข้อสอบแทน","[พ่อมดคนหนึ่งซึ่งกำลังขับเรือเหาะได้ประสบอุบัติเหตุทางอากาศ ซึ่งทำให้เขาต้องกระโดดลงมาจากความสูง 480 เมตร หลังจากตกอย่างอิสระเป็นระยะทางหนึ่ง เขาก็ได้ร่ายเวทชะลอการตกด้วยความหน่วงคงที่ซึ่งมีความเร่ง 2 เมตรต่อวินาทีจนกระทั่งถึงพื้น เมื่อความเร็วเท่ากับศูนย์พอดี โดยไม่ต้องคำนึงถึงแรงต้านของอากาศ จงหาเวลาทั้งหมดของการตกลงมาและระยะทางของการตกอย่างอิสระ...]","เอาล่ะ นี่ก็น่าจะเป็นโจทย์สมการด้วยเช่นกัน","ธีโอดอร์ครุ่นคิดเกี่ยวกับมัน เขาจำได้ว่าลินน์เคยบอกไว้ว่าการตกอย่างอิสระคือการเคลื่อนที่ในแนวตรงด้วยความเร่งคงที่โดยมีความเร็วต้นเท่ากับ 0 สูตรของมันคือ v=gt และ g คือความเร่งเนื่องจากแรงโน้มถ่วง ซึ่งดูเหมือนว่าจะเป็น 10 เมตรต่อวินาที? แล้วเจ้า t ตัวนี้ล่ะ มันควรจะเป็นเวลาใช่ไหม?","แต่การตกลงมาของร่างกายถูกแบ่งออกเป็นสองส่วน ทั้งเวลาและระยะทางของการตกต่างก็เป็นสิ่งที่ไม่รู้ค่า และมันก็คือคำตอบที่จำเป็นต้องหา การนำสูตรนี้ไปใช้ตรงๆ ย่อมไม่เกิดผลอย่างแน่นอน...","ธีโอดอร์ครุ่นคิดอย่างหนักเป็นเวลานานจนเหงื่อเย็นผุดพรายขึ้นบนหน้าผาก","และเขาก็พบว่า เขา...ทำไม่ได้!","“ท่านศาสตราจารย์ลินน์ คำถามพวกนี้มันไม่ยากเกินไปหน่อยหรือครับ?”","ธีโอดอร์อดไม่ได้ที่จะเอ่ยเตือน ท่านเรียกคำถามพวกนี้ว่าระดับง่ายงั้นเหรอ?!","นี่เป็นคำถามที่เด็กฝึกหัดควรจะทำจริงๆ อย่างนั้นหรือ? เขาไม่คิดว่าเรื่องนี้มันออกจะเกินเหตุไปหน่อยหรือไง?","“นี่มันยากเหรอ?”","ลินน์มองไปที่ธีโอดอร์ด้วยสายตาแปลกๆ เพราะเขาจำได้ว่าเขาเคยอธิบายสูตรที่เกี่ยวข้องและตีพิมพ์ลงใน [เมจิกเดลี่] ไปแล้ว เพื่อให้บรรดาพ่อมดหรือแม้กระทั่งชาวเมืองที่สนใจศึกษาการคำนวณได้เรียนรู้เพิ่มเติมเกี่ยวกับเรื่องนี้","ยิ่งไปกว่านั้น พ่อมดทุกคนก็เปรียบเสมือนคอมพิวเตอร์รูปร่างมนุษย์ แม้แต่เด็กฝึกหัดก็ยังมีพลังในการคำนวณที่แข็งแกร่งกว่าคนธรรมดามาก และโจทย์ปัญหาเหล่านี้ก็ควรจะอยู่ในขอบเขตที่รับได้","ในขณะที่ลินน์กำลังจะอธิบาย จู่ๆ สีหน้าของเขาก็เปลี่ยนไป เขายื่นมือออกไปและดีดนิ้ว พลังเวทมนตร์พลุ่งพล่านขึ้นในบริเวณรอบตัวเขา ในชั่วพริบตา ตะปูทองแดงก็ลอยพุ่งออกไปตอกตรึงปากกาขนนกและกระดาษข้อสอบในมือของพ่อมดฝึกหัดคนหนึ่งด้วยความรวดเร็วดุจสายฟ้าแลบ..."]},{"n":316,"t":"ข้าอยากจะยัดกระดาษข้อสอบใส่ปากท่านศาสตราจารย์จริงๆ!","c":["อาร์พาดเป็นเพียงพ่อมดฝึกหัดธรรมดาคนหนึ่งในสถาบันอิเยตา ซึ่งรู้ดีว่าความฉลาดและพลังในการคำนวณของเขานั้นด้อยกว่าพวกนักเรียนที่ได้เข้าร่วมชั้นเรียนหัวกะทิเป็นอย่างมาก และหากเขาต้องการสอบผ่านการจบการศึกษาในครั้งนี้ หรือแม้กระทั่งอยากจะโดดเด่นจนได้รับการยอมรับจากท่านศาสตราจารย์ เขาก็จำเป็นต้องใช้วิธีการที่ไม่ธรรมดา!","ตัวอย่างเช่น เมื่อคืนที่ผ่านมา เขานั้นยอมจ่ายในราคาสูงลิ่วเพื่อซื้อผงแปรธาตุสูตรพิเศษมาจากนักสมุนไพรผู้เก่งกาจ และนำมันมาผสมลงในหมึกเพื่อเขียนโพยโกงข้อสอบ โดยข้อความที่เขียนด้วยหมึกชนิดนี้จะสามารถมองเห็นได้ก็ต่อเมื่อใช้เวทมนตร์เฉพาะทางเท่านั้น","ดังนั้น อาร์พาดจึงกล้าวางกระดาษหนังที่เต็มไปด้วยสูตรและตัวอย่างคำถามลงบนโต๊ะอย่างสง่าผ่าเผย ในขณะที่แสร้งทำเป็นกำลังแก้โจทย์ปัญหาบนกระดาษ เขาก็แอบมองดูตัวอย่างเหล่านั้นผ่านเวทสำแดงรูปลักษณ์","‘ดีมาก...ท่านศาสตราจารย์เคยอธิบายคำถามพวกนี้ไปแล้ว และมันสามารถคำนวณได้ตราบใดที่ตัวเลขถูกแทนค่ากลับเข้าไป’","อาร์พาดทำการคำนวณบนกระดาษอย่างผู้มีชัย และภายในเวลาเพียงไม่กี่นาที เขาก็สามารถทำคำถามห้าข้อแรกเสร็จสิ้น แต่ไม่นานเขาก็พบว่าวิธีเทียบเคียงกับคำถามตัวอย่างนี้ไม่ได้ผลเสมอไป นั่นเป็นเพราะคำถามหลายข้อในกระดาษข้อสอบเป็นรูปแบบคำถามที่ไม่เคยเห็นมาก่อน และการเพียงแค่แทนค่าลงในสูตรสลับกับการดำเนินการตัวเลขก็ไม่สามารถช่วยอะไรได้เลย","อาร์พาดครุ่นคิดอย่างหนัก จากนั้นจึงตัดสินใจร่ายเวทอีกครั้งเพื่อเปิดเผยโพยข้อสอบบนกระดาษ และไล่อ่านมันไปทีละบรรทัด โดยพยายามค้นหาว่าเขาได้พลาดสูตรไหนไปบ้างหรือไม่","ในขณะนั้นเอง เสียงแหวกอากาศก็ดังขึ้นที่ข้างหูของเขาอย่างกะทันหัน และก่อนที่อาร์พาดจะทันได้ตอบสนอง ตะปูทองแดงก็ลอยพุ่งผ่านไปและตอกตรึงปากกาขนนกกับกระดาษข้อสอบในมือของเขาเอาไว้...ส่วนกระดาษตรงหน้าเขาก็ค่อยๆ ลอยขึ้นมาและพุ่งตรงไปยังโต๊ะของผู้คุมสอบอย่างเป็นธรรมชาติ","“ท่านศาสตราจารย์...”","อาร์พาดสะดุ้งโหยง และผุดลุกขึ้นจากที่นั่งอย่างกะทันหัน","ลินน์ยื่นมือออกไป และกระดาษแผ่นนั้นก็ร่วงหล่นลงมาบนฝ่ามือของเขา","อาร์พาดพยายามอย่างเต็มที่ที่จะรักษาความสงบเยือกเย็นไว้บนใบหน้า เขาพยายามกดข่มความหวาดกลัวและความวิตกกังวลในใจเอาไว้ และคอยปลอบประโลมตัวเองอยู่เสมอว่าหมึกล่องหนชนิดพิเศษนั้นถูกซ่อนเอาไว้อย่างมิดชิดและไม่มีทางที่จะถูกค้นพบได้","ธีโอดอร์และฟูล่าที่กำลังครุ่นคิดเกี่ยวกับคำถามในข้อสอบ เพิ่งจะนึกถึงความรับผิดชอบของตนในฐานะผู้คุมสอบขึ้นมาได้ และรีบเดินเข้ามาหาทันที แต่บนกระดาษแผ่นนั้นมีรอยขีดเขียนร่างข้อความที่ดูยุ่งเหยิงอยู่บ้าง ซึ่งก็ไม่ได้ดูพิเศษอะไร","แต่หลายคนต่างก็เข้าใจดีว่า นี่จะต้องเป็นวิธีการโกงข้อสอบรูปแบบหนึ่งอย่างแน่นอน มิฉะนั้นท่านศาสตราจารย์ก็คงไม่รู้สึกประหลาดใจและลงมืออย่างกะทันหันเช่นนี้","ลินน์ปรายตามองอาร์พาดด้วยสายตาขี้เล่น และคาดเดาได้ในทันทีว่านี่น่าจะเป็นหมึกล่องหน","เห็นได้ชัดว่าอีกฝ่ายคิดตื้นเกินไปที่จะเอาลูกไม้เล็กๆ น้อยๆ แบบนี้มาซ่อนจากสายตาของเขา","สิ่งที่เรียกว่าหมึกล่องหนก็ไม่มีอะไรมากไปกว่าสเปกตรัมที่มองไม่เห็น ดังนั้น...พลังเวทมนตร์ของลินน์จึงสร้างปริซึมขึ้นมาในทันทีเพื่อแยกองค์ประกอบของแสงอาทิตย์ที่สาดส่องเข้ามาทางหน้าต่าง และรังสีอัลตราไวโอเลตซึ่งเป็นสิ่งที่มองไม่เห็นด้วยตาเปล่าเช่นกัน มารวมตัวกันและหักเหแสงลงบนกระดาษหนังแผ่นนั้น ในชั่วพริบตา ข้อความที่ล่องหนอยู่ก็ปรากฏขึ้นมาให้เห็นทันที","ใบหน้าของอาร์พาดซีดเผือดลง เขาแอบก่นด่านักสมุนไพรเฮงซวยคนนั้นในใจอย่างเงียบๆ ไหนบอกว่าของสิ่งนี้มันซ่อนเร้นได้มิดชิดจนแม้แต่พ่อมดเต็มตัวก็มองไม่เห็นยังไงล่ะ?","“อาร์พาด ข้าน่าจะเคยบอกไปแล้วนะว่าจุดจบของการโกงข้อสอบคืออะไร เจ้ากลับไปได้แล้ว!”","ลินน์โยนกระดาษกลับไปและเอ่ยด้วยน้ำเสียงเฉยชา","“ท่านศาสตราจารย์ ได้โปรดให้โอกาสข้าอีกสักครั้งเถิด...”","อาร์พาดอ้อนวอนด้วยความหวาดกลัว ปีนี้เขาอายุยี่สิบเก้าปีแล้ว หากเขาไม่สามารถเลื่อนขั้นเป็นพ่อมดระดับทางการได้ เขาก็จะถูกตัดสินว่าเป็นผู้ไร้ศักยภาพและถูกไล่ออกจากสถาบัน","ลินน์ยังคงไม่หวั่นไหว ในเมื่อเขาเลือกที่จะใช้ทางลัด เขาก็ต้องยอมรับความเสี่ยงที่จะตามมา หากเขาไม่ถูกลงโทษ มันก็จะไม่ยุติธรรมต่อคนที่ตั้งใจเรียนอย่างหนัก...","ดังนั้น ไม่ว่าอาร์พาดจะร้องไห้และอ้อนวอนมากเพียงใด ลินน์ก็ทำเพียงแค่โบกมือและขอให้ธีโอดอร์พานำตัวเขาออกไป เพื่อที่จะได้ไม่เป็นการรบกวนนักเรียนคนอื่นๆ ที่กำลังทำข้อสอบอยู่","แม้ว่าจะมีบทเรียนให้เห็นเป็นตัวอย่างแล้ว แต่ก็ยังมีนักเรียนอีกไม่น้อยที่พยายามจะโกงการสอบในครั้งนี้ โดยที่ทุกคนต่างก็เชื่อมั่น ว่าพวกเขาจะไม่มีทางถูกจับได้","สำหรับวิธีการโกงข้อสอบนั้น มีหลากหลายวิธีที่ยากจะบรรยายให้ครบถ้วน พวกที่โง่หน่อยก็เขียนลงบนมือหรือแขนเสื้อของตัวเองโดยตรง และแอบชำเลืองมองมันเมื่อไม่มีใครสังเกตเห็น","ส่วนพวกที่ฉลาดหน่อย ตัวอย่างเช่น มีพ่อมดฝึกหัดคนหนึ่งครอบครองเวทมนตร์ประเภทหนึ่งที่สามารถแอบดูคำตอบของคนอื่นผ่านการสะท้อนของแสงได้โดยที่ไม่มีใครสังเกตเห็น และเกือบจะตบตาอีกฝ่ายได้สำเร็จ","นอกจากนี้ยังมีวิธีการอย่างเช่นการใช้เวทเนตรส่องไกลเพื่อแอบดู โชคดีที่ลินน์นั้นมีประสบการณ์จากการผ่านสมรภูมิมาอย่างโชกโชน แน่นอนว่าในชาติก่อนของเขาไม่มีเวทมนตร์ แต่วิธีการโกงข้อสอบด้วยเทคโนโลยีขั้นสูงอันหลากหลายก็ไม่ได้ด้อยไปกว่าเวทมนตร์เลย ดังนั้นภายในเวลาไม่กี่นาที คนพวกนี้จึงถูกคัดแยกตัวออกมาทีละคนๆ","ห้องสอบเต็มไปด้วยเสียงคร่ำครวญ ในบรรดาพ่อมดฝึกหัดสองร้อยสามสิบคนที่เข้าสอบในครั้งนี้ มีจำนวนถึงสามสิบเจ็ดคนที่พยายามจะโกงข้อสอบด้วยวิธีการต่างๆ และทั้งหมดก็ถูกไล่ออกจากห้องสอบ พร้อมกับถูกตัดสินให้คะแนนเป็นโมฆะในทันที","เอล็อคมองดูบรรดาพ่อมดฝึกหัดที่ถูกตัดสิทธิ์จากการสอบเดินผ่านเขาไปด้วยสีหน้าอมทุกข์ แถมพวกเขายังต้องเผชิญกับบทลงโทษที่รุนแรง เขาจึงอดไม่ได้ที่จะกลืนน้ำลายลงคอ อันที่จริงเขาก็เตรียมโพยข้อสอบมาเหมือนกัน เพียงแต่เขาเอาแต่นั่งดิ้นรนต่อสู้กับจิตใจของตัวเองและไม่มีความกล้าพอที่จะหยิบมันออกมา","ท้ายที่สุดแล้ว ท่านศาสตราจารย์ก็เคยสร้างฝันร้ายทางจิตใจให้กับเขามาก่อนหน้านี้ แต่เขาก็ไม่ได้อยากจะหลบหนีจากหายนะ ในขณะที่แอบลอบยินดีอยู่ในใจ เขาก็ทำได้เพียงเค้นสมองและทำข้อสอบต่อไป","ถึงแม้ว่าคะแนนสอบภาคทฤษฎีจะแย่ลงมาสักหน่อย แต่หลังจากนี้ก็จะยังมีการสอบภาคปฏิบัติอยู่อีก ตราบใดที่เขาทำผลงานได้อย่างโดดเด่น มันก็ไม่ใช่ปัญหาเลยที่จะได้รับคะแนนดีๆ","ลิเดียที่อยู่ในห้องสอบเช่นเดียวกันกลับมีความคิดที่ตรงกันข้ามกับเอล็อคอย่างสิ้นเชิง","ในฐานะฮาล์ฟลิงที่ไม่มีพรสวรรค์ทางด้านเวทมนตร์ การที่นางได้รับอนุญาตให้เข้าสอบในครั้งนี้ได้ถือเป็นการอนุมัติกรณีพิเศษจากลินน์ แต่ท่านศาสตราจารย์จะไม่มีทางยอมยกเว้นให้นางอย่างแน่นอน","นั่นหมายความว่า นางถูกกำหนดมาแล้วว่าจะไม่ได้รับคะแนนใดๆ เลยในภาคปฏิบัติ ดังนั้นนางจึงทำได้เพียงทำงานให้หนักขึ้นอีกหน่อยในวิชาเล่นแร่แปรธาตุและสมุนไพรศาสตร์ ซึ่งประเมินดูแล้วว่ามันคงจะผ่านได้ยาก","และหากนางต้องการสอบผ่านอย่างราบรื่น นางก็จะต้องทำคะแนนภาคทฤษฎีให้ดีเยี่ยมแบบสุดๆ...","ลิเดียจึงต้องพยายามอย่างหนักเป็นพิเศษ ในฐานะผู้สร้างและนักบินเรือเหาะ นางคุ้นเคยกับการคำนวณพื้นที่และปริมาตรของรูปทรงเรขาคณิต รวมถึงสูตรสำหรับการตกอย่างอิสระหลายสูตร ดังนั้นคำถามพื้นฐานก่อนหน้านี้จึงถูกนางทำเสร็จสิ้นลงภายในเวลาเพียงหนึ่งชั่วโมงครึ่งเท่านั้น","แต่พอนางต้องมาทำคำถามอีกสิบกว่าข้อถัดไป นางก็ถึงกับต้องจนปัญญา เพราะคำถามเหล่านี้ถ้าไม่เกี่ยวข้องกับการเคลื่อนที่ของวัตถุบนท้องฟ้า ก็เกี่ยวข้องกับฟังก์ชัน แม้แต่คำถามที่ง่ายที่สุดก็ยังเกี่ยวข้องกับการคำนวณทางเรขาคณิตที่ซับซ้อนสุดๆ จนทำให้นางรู้สึกปวดหัวขึ้นมาเลยทีเดียว","ตัวอย่างเช่น หนึ่งในคำถามก็คือ...","[A B และ C คือตำแหน่งฐานยิงปืนใหญ่ทั้งสามแห่งของเรา A อยู่ทางทิศตะวันออกของ B ห่างออกไป 6,000 เมตร และ C อยู่ทางทิศตะวันตกเฉียงเหนือทำมุม 30 องศาจาก B ด้วยระยะทาง 5,000 เมตร P คือตำแหน่งของกองทหารนักบวชฝ่ายศัตรู ฝ่ายเราตรวจพบบิชอปคนหนึ่งที่กำลังใช้เวทมนตร์สื่อสาร เนื่องจากสถานที่ B และ C อยู่ห่างจากจุด P มากกว่าสถานที่ A จึงไม่พบร่องรอยของเวทมนตร์สื่อสารจนกระทั่งผ่านไปแล้วสามวินาที เป็นที่ทราบกันดีว่าความเร็วของเวทมนตร์สื่อสารคือ 1,000 เมตรต่อวินาที จงหามุมทิศที่ฐานยิง A จะต้องใช้เพื่อระดมยิงใส่ตำแหน่งของกองทหารนักบวช...]","มันยากมาก...","ลิเดียทำหน้าขมขื่น ขีดเขียนและวาดรูปบนกระดาษทด นางรู้สึกอยากจะยัดกระดาษข้อสอบทั้งหมดนี้เข้าไปในปากของท่านศาสตราจารย์เสียเหลือเกิน ท่านจะออกคำถามง่ายๆ กว่านี้สักหน่อยไม่ได้หรือไง?"]},{"n":317,"t":"เรื่องนี้มันน่าเหลือเชื่อยิ่งกว่าดวงอาทิตย์ร่วงหล่นลงมาจากฟากฟ้าเสียอีก!","c":["การสอบลากยาวมาตลอดทั้งช่วงเช้า และการสอบที่กินเวลาถึงสามชั่วโมงก็สิ้นสุดลงในที่สุด ทันทีที่เอล็อคและคนอื่นๆ เดินออกจากประตูห้องสอบ พวกเขาก็อดไม่ได้ที่จะถอนหายใจด้วยความโล่งอก จากนั้นพวกเขาก็เริ่มประหม่าและวิตกกังวลเมื่อต้องมาจับกลุ่มเทียบคำตอบของกันและกัน และในไม่ช้าแต่ละคนก็เริ่มหน้าดำหน้าแดงทุ่มเถียงกัน","“เป็นไปไม่ได้ ข้าตรวจทานตั้งหลายรอบแล้ว พ่อมดที่ประสบอุบัติเหตุทางอากาศและตกลงมา ควรจะตกถึงพื้นในวินาทีที่สามสิบเอ็ดสิ”","เอล็อคเอ่ยด้วยความมั่นใจ","“ถ้าอย่างนั้นเจ้าก็ต้องคำนวณผิดแล้วล่ะ สูตรสำหรับข้อนี้ควรจะเป็นระยะทาง S = ความเร็วต้น V * เวลา t + 1/2at^2 เจ้าต้องกำหนดให้เวลาของการตกอย่างอิสระเป็น t1...และในท้ายที่สุดก็จะได้เวลาของการตกรวมทั้งหมดคือยี่สิบสี่วินาที และระยะทางของการตกอย่างอิสระคือแปดสิบเมตร!”","พ่อมดฝึกหัดคนหนึ่งแย้งขึ้นมา","เอล็อคตรวจสอบการคำนวณในหัวของเขาอย่างรวดเร็ว และใบหน้าของเขาก็พลันดูไม่ได้ขึ้นมาทันที","จบเห่แล้ว นี่เขาทำผิดไปอีกข้อแล้วหรือเนี่ย","เพียร์ซที่อยู่ด้านข้างลอบถอนหายใจด้วยความโล่งอก โชคดีที่เมื่อคืนนี้เขาได้ทบทวนสูตรเกี่ยวกับการตกอย่างอิสระหลายสูตรอย่างเร่งด่วน มิฉะนั้นวันนี้เขาคงจะจบสิ้นของจริงอย่างแน่นอน","ภายในห้องสอบ ลินน์กำลังมองดูกระดาษคำตอบที่ถูกรวบรวมมา ซึ่งกำลังถูกตรวจให้คะแนนโดยธีโอดอร์และคนอื่นๆ","แม้ว่าพวกเขาอาจจะไม่สามารถทำข้อสอบพวกนี้ได้ด้วยตัวเอง แต่การมีเฉลยให้เทียบคำตอบนั้นก็ไม่ใช่ปัญหาเลยสำหรับพวกเขา","“ท่านศาสตราจารย์ลินน์ ดูเหมือนว่าในครั้งนี้จะมีคนสอบผ่านไม่มากนักนะขอรับ...”","ธีโอดอร์ส่ายหน้าหลังจากพลิกดูกระดาษข้อสอบกว่าสิบชุด ดูเหมือนว่าจะมีเพียงสามสิบเปอร์เซ็นต์เท่านั้นที่น่าจะสอบผ่านภาคทฤษฎี","มันยากขนาดนั้นเลยหรือ?","ลินน์เองก็รู้สึกแปลกใจเล็กน้อย สมองของบรรดาพ่อมดฝึกหัดควรจะยังคงใช้งานได้ดีสิ ไม่ต้องพูดถึงพวกที่เป็นอัจฉริยะ อย่างน้อยพวกเขาก็ต้องฉลาดกว่าคนทั่วไปอยู่แล้ว","แต่หลังจากที่ลองคิดดูให้ดีแล้ว ลินน์ก็ตระหนักถึงปัญหาได้อย่างรวดเร็ว","แม้ว่าคำถามที่เขาตั้งขึ้นในครั้งนี้จะไม่ยากนัก แต่ถ้าเทียบกันแล้ว พ่อมดฝึกหัดเหล่านี้ไม่ได้เรียนมาเป็นเวลานานนัก และเวลารวมทั้งหมดก็มีเพียงแค่ปีกว่าๆ เท่านั้น แถมยังมีเนื้อหาอีกมากมายที่พวกเขาต้องทำความเข้าใจ การที่เขายัดเยียดความรู้ด้านฟิสิกส์และเคมีในระดับประถมและมัธยมต้น หรือแม้แต่จุดที่ต้องทำความเข้าใจในระดับมัธยมปลายบางส่วนให้กับพวกเขาจนหมด","เมื่อรวมเข้ากับความจริงที่ว่าพวกเขาโดดเรียนอยู่เป็นครั้งคราวเพื่อไปจัดการกับธุระส่วนตัว หรือไม่ก็ไปเข้าร่วมงานสัมมนาทางวิชาการและสงครามระหว่างอาณาจักร พวกเขาจึงต้องใช้เวลาส่วนใหญ่ไปกับการศึกษาด้วยตนเองเสียมากกว่า","พอมองดูกระดาษข้อสอบในครั้งนี้แล้ว ดูเหมือนว่า...มันดูเหมือนว่า...อาจจะยากเกินไปหน่อยจริงๆ?","ลินน์ลูบคางของตนเอง และหลังจากที่ได้เห็นกระดาษข้อสอบที่ได้คะแนนสูงหลายฉบับ เขาก็ปัดความคิดนี้ทิ้งไปในทันที","ในเมื่อยังมีคนที่สามารถทำคะแนนสูงๆ ได้ นั่นก็หมายความว่าคำถามในข้อสอบที่เขาให้ไปนั้นไม่ได้ยากเกินความสามารถเลย...","ในหมู่พวกเขา จอห์นนี่คือคนที่ทำผลงานได้ดีที่สุดอย่างไม่ต้องสงสัย นอกเหนือจากคำถามที่ยากที่สุด ห้าข้อสุดท้ายที่เขาจงใจเตรียมเอาไว้ ซึ่งจอห์นนี่ทำผิดไปสามข้อ ส่วนข้ออื่นๆ นั้นก็ทำได้ถูกต้องทั้งหมด!","นอกเหนือจากการที่เป็นพ่อมดเต็มตัว ซึ่งมีพลังในการคำนวณแข็งแกร่งกว่าพวกพ่อมดฝึกหัดแล้ว เห็นได้ชัดเลยว่านางจะต้องตั้งใจเรียนอย่างหนักในช่วงวันธรรมดาด้วย","สิ่งที่ทำให้ลินน์ประหลาดใจมากที่สุดก็คือลิเดีย เพราะนางสามารถทำคะแนนสอบได้ถึงแปดสิบแปดคะแนน และข้อผิดพลาดทั้งหมดของนางก็ล้วนแล้วแต่เกี่ยวข้องกับคุณสมบัติของธาตุเวทมนตร์ทั้งสิ้น และนางถึงกับสามารถแก้โจทย์ปัญหาสำคัญทั้งหมดที่เขาเตรียมมาเป็นพิเศษได้เลยด้วยซ้ำ","“นางเป็นอัจฉริยะด้านวิศวกรรมจริงๆ!”","ลินน์เอ่ยด้วยความชื่นชม","“ท่านศาสตราจารย์ ท่านไม่ควรให้ลิเดียเข้าร่วมการประเมินในครั้งนี้เลยนะขอรับ จะเป็นอย่างไรหากนางสอบผ่านจริงๆ? ท่านจะมอบเหรียญตราพ่อมดให้กับฮาล์ฟลิงที่ใช้เวทมนตร์ไม่เป็นอย่างนั้นหรือขอรับ?”","ธีโอดอร์กล่าวด้วยความลังเล","“แน่นอน ตราบใดที่นางสามารถสอบผ่านได้สำเร็จ การได้กลายเป็นพ่อมดมันก็ไม่ใช่เรื่องใหญ่หรอก”","ลินน์กล่าวอย่างใจเย็น","“แต่ถ้าทำแบบนี้ ลิเดียอาจจะกลายเป็นตัวตลกของบรรดาพ่อมด และอาจจะมีบางคนพุ่งเป้าไปที่นาง โดยคิดว่านางดูหมิ่นสถานะอันสูงส่งของพ่อมด...”","ธีโอดอร์ดูเป็นกังวล เขารู้สึกว่าท่านศาสตราจารย์นั้นคิดตื้นเกินไปจริงๆ พ่อมดที่ใช้เวทมนตร์ไม่เป็น การมีเพียงแค่ชื่อมันจะมีประโยชน์อะไรเล่า?","“ถึงแม้นางจะร่ายเวทมนตร์ไม่ได้ แต่ลิเดียก็สามารถกลายเป็นนักเล่นแร่แปรธาตุได้ไม่ใช่หรือ? นางสร้างเรือเหาะขึ้นมาด้วยตัวเอง และนางยังมีส่วนสนับสนุนอย่างมากในการวิจัยเครื่องยนต์สันดาปภายในและปืนใหญ่แม่เหล็กไฟฟ้าด้วย”","ลินน์เอ่ยเตือนความจำ","ธีโอดอร์สำลักคำพูดไปชั่วขณะ หากมองจากมุมนี้ มันก็ไม่ใช่ปัญหาเลยที่จะเรียกเด็กสาวเผ่าฮาล์ฟลิงคนนี้ว่าเป็นนักเล่นแร่แปรธาตุ","แต่พ่อมดที่ใช้เวทมนตร์ไม่เป็น ไม่ว่าเขาจะคิดอย่างไรมันก็ยังคงเป็นเรื่องแปลกประหลาดอยู่ดี","ในขณะที่เขากำลังดิ้นรนหาคำพูดอยู่นั้น ลินน์ก็ยิ้มและพูดต่อ","“แล้วใครบอกเจ้ากันล่ะว่าลิเดียใช้เวทมนตร์ไม่ได้?”","ธีโอดอร์มีสีหน้างุนงง มันเป็นสามัญสำนึกในดินแดนพ่อมดอยู่แล้วที่ว่าฮาล์ฟลิงนั้นไม่มีพรสวรรค์ทางด้านเวทมนตร์ และยังไม่เคยมีใครทำลายกฎนี้ลงได้มาก่อนเลย","ลิเดียเองก็เป็นพ่อมดฝึกหัดมานานกว่าหนึ่งปีแล้ว แต่ผลก็คือนางไม่สามารถเรียนรู้ได้แม้กระทั่ง เวทรวบรวมน้ำ และ เวทแยกแยะวัสดุพื้นฐาน ซึ่งเป็นเวทมนตร์พื้นฐานที่สุด","หรือว่าท่านศาสตราจารย์จะสามารถทำให้คนที่ไร้พรสวรรค์สามารถเรียนรู้เวทมนตร์และกลายเป็นพ่อมดได้สำเร็จอย่างนั้นหรือ?!","เรื่องนี้มันน่าเหลือเชื่อยิ่งกว่าดวงอาทิตย์ร่วงหล่นลงมาจากฟากฟ้าเสียอีก!","ลินน์เก็บเป็นความลับและไม่ได้อธิบายอะไร เขาเพียงแค่บอกกับธีโอดอร์ว่า อีกเดี๋ยวในอีกไม่กี่วันข้างหน้าเจ้าก็จะได้รู้เอง","ในช่วงบ่าย กลุ่มพ่อมดฝึกหัดที่ถูกทรมานในการสอบภาคทฤษฎีในที่สุดก็ต้องมาเผชิญหน้ากับการสอบภาคปฏิบัติที่แสนจะคุ้นเคย","ธาตุเวทมนตร์ เวทแปรสภาพ การเล่นแร่แปรธาตุ ปรุงยา และบวกกับการฝึกซ้อมรบจริง รวมทั้งหมดห้าวิชา ซึ่งจะถูกแบ่งออกเป็นสองวัน...","เป็นเวลากว่าหนึ่งปีที่นักเรียนพ่อมดของอิเยตาได้เพิ่มหลักสูตรหนักๆ เข้ามามากมาย แต่หลายๆ อย่างก็มีความเกี่ยวโยงซึ่งกันและกัน","ตัวอย่างเช่น วิชาเคมีที่เกี่ยวข้องกับคุณสมบัติและการเปลี่ยนแปลงของธาตุเวทมนตร์ ดังนั้น วิชาพื้นฐานเหล่านี้จึงไม่ได้ถูกทิ้งไว้ข้างหลังเลย และการทำแบบฝึกหัดโจทย์ปัญหาคณิตศาสตร์เพื่อเพิ่มพลังในการคำนวณก็ยังทำให้ปริมาณพลังเวทที่พวกเขากักเก็บเอาไว้เข้าใกล้ขีดจำกัดสูงสุดด้วย ดังนั้น ในครั้งนี้จึงมีนักเรียนที่ยื่นขอเข้าสอบจบการศึกษามากกว่าปีก่อนๆ อยู่ไม่น้อยเลยทีเดียว","เมื่อรู้ตัวดีว่าตนเองนั้นทำคะแนนในการสอบภาคทฤษฎีช่วงเช้าได้ไม่ดีนัก เพียร์ซจึงพยายามอย่างหนักเป็นพิเศษ ซึ่งทำผลงานได้อย่างยอดเยี่ยมและสอบผ่านทั้งสี่วิชาแรกด้วยคะแนนระดับเกียรตินิยม","สำหรับการฝึกซ้อมรบจริงในช่วงสุดท้าย ถือว่าเป็นการสอบที่ง่ายที่สุดแล้ว โดยคู่ต่อสู้ของพวกเขาคือหุ่นเชิดเวทมนตร์สามตัว ซึ่งมีพลังการต่อสู้เทียบเท่ากับทหารยามที่ติดอาวุธครบมือเท่านั้น","แม้แต่ลิเดียเองก็ยังสามารถจัดการสังหารหุ่นเชิดเหล่านี้ทีละตัวๆ ด้วยปืนคาบศิลาลำกล้องสั้นที่ถูกสร้างขึ้นมาอย่างประณีต","ในเช้าของวันที่สาม ซึ่งเป็นเวลาของการประกาศผลคะแนนสอบ นักเรียนของสถาบันเวทมนตร์ทั้งหมดต่างก็มารวมตัวกัน พวกเขารอคอยด้วยความรู้สึกทุกข์ทรมานและวิตกกังวล","เมื่อได้รับใบแจ้งผลคะแนนและเห็นว่าสอบผ่านการประเมินสำเร็จ พวกเขาก็จะรู้สึกปีติยินดีขึ้นมาในทันที แต่เห็นได้ชัดว่ามีคนที่สอบตกมากกว่า","ในกรณีที่ต้องเอาคะแนนเฉลี่ยมาคำนวณรวมกันแล้ว มีไม่ถึงสี่สิบเปอร์เซ็นต์ด้วยซ้ำที่สอบผ่านการสอบจบการศึกษา","“บ้าเอ๊ย อีกแค่นิดเดียวแท้ๆ!”","เดบร้ามองดูตัวเลขห้าสิบแปดคะแนนอันโดดเด่นบนกระดาษด้วยความรู้สึกหงุดหงิดใจเป็นอย่างมาก หากนางทบทวนตำราอีกสักสองสามรอบ หรือถ้าท่านศาสตราจารย์ยอมผ่อนปรนให้อีกสักนิด นางก็คงจะสามารถสอบผ่านไปได้แล้ว","แต่ผลก็คือ ตอนนี้นางต้องรอไปอีกหนึ่งปีเต็ม...","เดบร้าแอบทบทวนความผิดพลาดของตนเองอยู่ในใจ และในขณะเดียวกัน เสียงโห่ร้องด้วยความดีใจก็ดังขึ้นที่ข้างตัวนาง","“เยี่ยมไปเลย...ข้าสอบผ่านแล้ว!”"]},{"n":318,"t":"หากแม้แต่เจ้ายังสามารถเรียนรู้เวทมนตร์ได้ แล้วแบบนี้มิใช่ว่าทุกคนสามารถกลายเป็นพ่อมดได้หรอกหรือ?","c":["ลิเดียถือกระดาษข้อสอบของนางเอาไว้ด้วยความปิติยินดีอย่างยิ่ง และตะโกนออกมาด้วยความตื่นเต้น นางไม่คาดคิดเลยว่านางจะสามารถสอบผ่านการสอบจบการศึกษาได้สำเร็จจริงๆ แถมคะแนนของนางก็ยังไม่ต่ำเลยด้วย!","แม้ว่านางจะได้ศูนย์คะแนนในวิชาแปรสภาพ ส่วนคะแนนของวิชาธาตุและวิชาสมุนไพรนั้นก็ถือว่าย่ำแย่มาก แต่เป็นเพราะนางได้คะแนนสูงมากในวิชาการต่อสู้และวิชาการเล่นแร่แปรธาตุ นางจึงสามารถสอบผ่านภาคปฏิบัติมาได้อย่างเฉียดฉิว","เมื่อนำมารวมกับผลคะแนนอันยอดเยี่ยมที่ได้รับจากการสอบภาคทฤษฎีแล้ว คะแนนเฉลี่ยของนางจึงอยู่ที่ 74 คะแนน ซึ่งถือได้ว่าเป็นคะแนนที่อยู่ในกลุ่มที่ดีที่สุดในบรรดาพ่อมดฝึกหัดแล้ว!","ผู้ที่รู้สึกตื่นเต้นยิ่งกว่าลิเดียก็คือดาร์เรนและคนอื่นๆ โดยพวกเขาแอบตามลิเดียเข้ามาในสถาบันตั้งแต่เช้าตรู่ เพียงเพื่อรอคอยช่วงเวลาที่จะมีการประกาศผลการสอบเท่านั้น","“ยอดเยี่ยมไปเลย ลิเดีย ดูเหมือนว่าเจ้ากำลังจะกลายเป็นฮาล์ฟลิงตนแรกที่เป็นพ่อมดแล้วนะ!”","“ข้าว่าแล้วว่าเจ้าต้องทำได้!”","เหล่าฮาล์ฟลิงที่อยู่ที่นั่นต่างก็เอ่ยออกมาด้วยความตื่นเต้น และพวกเขาทุกคนต่างก็เป็นประจักษ์พยานด้วยตาของตนเองว่าลิเดียสามารถก้าวมาถึงจุดนี้ในทุกวันนี้ได้อย่างไร","มันเป็นฉันทามติของดินแดนพ่อมดทั้งหมดว่าฮาล์ฟลิงนั้นไม่มีพรสวรรค์ทางด้านเวทมนตร์ แต่ลิเดียกลับไม่ยอมจำนนต่อโชคชะตา และนางก็ต้องการที่จะเข้าร่วมสถาบันอิเยตาเพื่อเรียนรู้เวทมนตร์และกลายเป็นนักเล่นแร่แปรธาตุที่แท้จริง!","ในสายตาของคนอื่นๆ นี่เป็นเรื่องที่เพ้อฝันอย่างไม่ต้องสงสัย และอาจถึงขั้นถูกตราหน้าว่าดื้อรั้นและโง่เขลา","ไม่ว่าอูฐที่ลากเกวียนอยู่บนพื้นดินจะพยายามอย่างหนักสักแค่ไหน มันก็ไม่สามารถบินขึ้นไปบนท้องฟ้าได้เหมือนกับกริฟฟอน ด้วยพรสวรรค์ทางด้านเวทมนตร์นั้นเป็นสิ่งที่มีมาตั้งแต่กำเนิด และช่องว่างระหว่างผู้มีพลังพิเศษกับคนธรรมดาสามัญนั้นถูกแบ่งแยกเอาไว้อย่างชัดเจนมาตั้งนานแล้ว!","แม้ว่านางจะไม่ได้รับการยอมรับ และยังคงถูกตั้งคำถามรวมไปถึงถูกเยาะเย้ยถากถาง แต่ลิเดียก็ไม่เคยคิดที่จะยอมแพ้ นางทำงานเป็นผู้ช่วยนักเล่นแร่แปรธาตุ และยังสร้างเครื่องจักรที่บินได้มากมายหลายชนิดเพื่อที่จะได้รับโอกาสสัมผัสกับเวทมนตร์!","ซึ่งความพยายามเหล่านี้ก็ล้มเหลวลงอย่างไม่ต้องสงสัย แต่ยังโชคดี ที่นางยังมีโชคอยู่บ้าง ซึ่งบังเอิญว่านางได้รับความชื่นชมจากท่านศาสตราจารย์ลินน์ และได้เข้าร่วมในการสร้างเรือเหาะ ด้วยเหตุนี้ นางจึงสามารถบรรลุข้อตกลงกับจอมเวทผู้ยิ่งใหญ่เฮลรามและเข้าร่วมกับสถาบันอิเยตาได้สำเร็จ","นับจนถึงตอนที่นางสอบผ่านการประเมิน เวลาก็ล่วงเลยมาถึงสองปีเต็มแล้ว ซึ่งนั่นก็หมายความว่า ในที่สุดเผ่าฮาล์ฟลิงก็จะมีพ่อมดที่แท้จริงถือกำเนิดขึ้นเสียที!","“มันยังเร็วเกินไปที่พวกเจ้าจะมาดีใจ การสอบผ่านในครั้งนี้มันเป็นเพียงแค่การได้รับคุณสมบัติในการดื่มต้นกำเนิดเวทมนตร์เท่านั้น มันไม่ได้หมายความว่าเจ้าจะสามารถกลายเป็นพ่อมดเต็มตัวได้หรอกนะ...”","เดบร้าพูดขัดจังหวะลิเดียและคนอื่นๆ ที่กำลังตื่นเต้นด้วยน้ำเสียงที่ค่อนข้างเบื่อหน่าย จากนั้นนางก็พูดต่อด้วยรอยยิ้มเยาะ","“ด้วยพรสวรรค์ทางด้านเวทมนตร์ของเจ้า แม้แต่การดื่มต้นกำเนิดเวทมนตร์ก็เป็นเพียงแค่ความสูญเปล่าเท่านั้น และมันก็ไม่มีความเป็นไปได้เลยสักนิดที่เจ้าจะกลายเป็นพ่อมดได้”","คำพูดอันแหลมคมของเดบร้าเปรียบเสมือนน้ำเย็นจัด ที่สาดลงมาดับความกระตือรือร้นของบรรดาฮาล์ฟลิง และบรรยากาศที่เคยคึกคักก็พลันเงียบสงัดลงในทันที...","เอล็อคและคนอื่นๆ ขมวดคิ้ว แต่พวกเขาก็ไม่สามารถหาคำพูดใดมาโต้แย้งได้เลย ท้ายที่สุดแล้ว ไม่ว่าคำพูดของเดบร้าจะฟังดูไม่น่ารื่นหูสักแค่ไหน แต่มันก็คือความจริง!","และพ่อมดฝึกหัดเหล่านี้ที่สอบผ่านการประเมิน ก็ยังมีอีกหนึ่งอุปสรรคที่ต้องก้าวผ่านไปให้ได้ นั่นก็คือพิธีเลื่อนระดับในขั้นตอนสุดท้าย!","ตามธรรมเนียมปฏิบัติในปีก่อนๆ จะมีเพียงครึ่งเดียวเท่านั้นที่สามารถเลื่อนระดับได้สำเร็จ และลิเดียก็ยังไม่สามารถเรียนรู้ได้แม้กระทั่งเวทมนตร์ระดับศูนย์วงแหวนจนถึงตอนนี้ ดังนั้น ความเป็นไปได้ที่นางจะกลายเป็นพ่อมดเต็มตัวจึงมีความหวังที่ริบหรี่มาก","เมื่อคิดได้เช่นนี้ เหล่านักเรียนที่สอบไม่ผ่านก็มองไปที่ลิเดียด้วยสายตาที่แฝงไปด้วยความเย้ยหยัน","แล้วจะทำไมล่ะถ้านางสอบผ่านการประเมินมาได้ด้วยความโชคดี?","การที่คนๆ หนึ่งจะกลายเป็นพ่อมดได้หรือไม่นั้น มันถูกกำหนดเอาไว้ตั้งแต่ตอนที่เขาเกิดมาแล้ว!","แม้ว่าปีนี้พวกเขาจะสอบตก แต่ปีหน้าหรือปีถัดๆ ไปก็จะยังมีการสอบอยู่อีก อย่างน้อยพวกเขาก็ยังมีความหวังที่จะได้รับการเลื่อนระดับให้เป็นพ่อมดเต็มตัว!","จอห์นนี่เห็นว่าลิเดียรู้สึกหดหู่เล็กน้อยจากคำพูดไม่กี่คำของเดบร้า นางจึงเอ่ยด้วยน้ำเสียงทุ้มต่ำ","“ในเมื่อท่านศาสตราจารย์ลินน์ไม่ได้ห้ามไม่ให้เจ้าเข้าร่วมการสอบจบการศึกษา บางทีเขาอาจจะมีวิธีที่จะทำให้เจ้ากลายเป็นพ่อมดก็ได้นะ!”","นางรู้สึกว่าท่านศาสตราจารย์ไม่น่าจะโหดร้ายถึงขนาดที่มอบความหวังให้กับผู้คนแล้วก็ทำลายมันทิ้งไปในเวลาเดียวกัน","ทันใดนั้นลิเดียก็รู้สึกว่าดวงตาของนางเปล่งประกายขึ้นมา หากเป็นคนอื่นที่มีวิธีทำให้นางกลายเป็นพ่อมด นางคงอดไม่ได้ที่จะรู้สึกสงสัย แต่ถ้าเป็นท่านศาสตราจารย์ลินน์ล่ะก็ มันจะต้องแตกต่างออกไปอย่างแน่นอน!","เดบร้าเบ้ปากและไม่เห็นด้วยกับคำพูดของจอห์นนี่ หากฮาล์ฟลิงยังสามารถเรียนรู้เวทมนตร์ได้ แล้วแบบนี้มิใช่ว่าทุกคนสามารถกลายเป็นพ่อมดได้หรอกหรือ?","แต่ก่อนที่นางจะได้พูดอะไรออกมาอีก ธีโอดอร์ก็เดินเข้ามาหา และเรียกให้นักเรียนที่สอบผ่านการประเมินเดินเข้าไปในหอคอยวิสลิ่งเพื่อเข้าร่วมพิธีเลื่อนระดับทีละคน","หลังจากที่เส้นทางการขนส่งทางอากาศถูกสร้างขึ้น กระบวนการเลื่อนระดับทั้งหมดก็รวดเร็วเป็นมาก หลังจากที่ยืนยันผลสอบของนักเรียนแต่ละคนเมื่อวานนี้ ลินน์ก็ได้ส่งคนไปรายงานต่อสภาเวทมนตร์ผ่านทางเรือเหาะ จากนั้นก็นำเอาต้นกำเนิดเวทมนตร์กลับมา ซึ่งกระบวนการไปกลับทั้งหมดนี้ ใช้เวลาเพียงแค่ครึ่งวันเท่านั้น และไม่จำเป็นต้องรอเป็นเวลาหนึ่งหรือสองสัปดาห์เหมือนอย่างแต่ก่อน","เดบร้าและคนอื่นๆ มองดูพ่อมดฝึกหัดที่ถูกขานชื่อและเดินเข้าไปในหอคอยสูงตระหง่านด้วยความอิจฉา ซึ่งพวกเขาก็ทำได้เพียงแค่รออยู่ข้างนอกเท่านั้น","เพียร์ซคือคนแรกที่ถูกเรียกชื่อ เขาเดินเข้าไปในหอคอยวิสลิ่งด้วยความวิตกกังวล และเมื่อเขาเห็นลินน์ เขาก็โค้งคำนับทำความเคารพอย่างนอบน้อม","“ท่านศาสตราจารย์ลินน์!”","“เพียร์ซ เกรดของเจ้าในครั้งนี้ถือว่าไม่เลวเลย แม้ว่าการสอบภาคทฤษฎีจะย่ำแย่ไปสักหน่อย แต่เจ้าก็สามารถทำความเข้าใจวิชาธาตุ วิชาแปรสภาพ และวิชาสมุนไพรได้เป็นอย่างดี...”","ลินน์ยิ้มและส่งขวดยาสีฟ้าขวดหนึ่งไปให้","เพียร์ซรับยาขวดนั้นมาด้วยความตื่นเต้น และเขาก็เกือบจะทำยาอันล้ำค่าหกเลอะเทอะด้วยมือที่สั่นเทา","ลินน์รู้สึกขบขันเมื่อเห็นเช่นนั้น และเขาก็เอ่ยเตือนเพียร์ซว่า เขาจะไม่สามารถเลื่อนระดับได้อย่างสมบูรณ์หากยังอยู่ในสภาพที่ย่ำแย่เช่นนี้","เพียร์ซสูดหายใจเข้าลึกๆ อยู่ครู่หนึ่งก่อนที่จะสงบสติอารมณ์ลงได้ จากนั้นเขาก็ดื่มต้นกำเนิดเวทมนตร์เข้าไปด้วยความขึงขัง","ความหนาวเหน็บอันเสียดแทงทะยานขึ้นมาจากช่องท้อง และพลังของยาก็พุ่งพล่านไปทั่วทั้งร่างกายอย่างรวดเร็ว ในท้ายที่สุดมันก็ไหลไปรวมกันอยู่ที่สมอง จากนั้นก็เกิดความรู้สึกคันยุกยิกแปลกๆ ที่ราวกับว่ามันเล็ดลอดออกมาจากกระดูก เซลล์ทุกเซลล์ในร่างกายราวกับว่าพวกมันกำลังถูกฉีกกระชากและจัดเรียงตัวใหม่ นั่นคือความเจ็บปวดที่หยั่งรากลึกลงไปในจิตวิญญาณ...","หยาดเหงื่อเม็ดโป้งไหลหยดลงมาจากหน้าผากของเพียร์ซ","ใบหน้าของเขาค่อยๆ เปลี่ยนเป็นสีม่วงคล้ำ ราวกับว่าเลือดในกายของเขาได้ถูกสูบออกไปจนหมด ซึ่งมันทำให้เขาดูน่าสะพรึงกลัวเป็นอย่างมาก","กระบวนการทั้งหมดกินเวลาประมาณสิบนาที และในไม่ช้าคลื่นพลังเวทอันแข็งแกร่งก็แผ่กระจายออกมาจากร่างของเพียร์ซ","ทันใดนั้น ลูกไฟที่ร้อนระอุพลันปรากฏขึ้นกลางอากาศ และเพียร์ซก็ลืมตาขึ้นในทันทีพร้อมกับสีหน้าที่เต็มไปด้วยความปีติยินดี การร่ายเวทมนตร์โดยไม่ต้องใช้วัสดุในการร่ายและสามารถจำลองธาตุต่างๆ ด้วยพลังเวทได้ นั่นล้วนแต่เป็นสัญลักษณ์ของพ่อมดเต็มตัว!","“ดูเหมือนว่าจะสำเร็จแล้วนะ!”","ลินน์พยักหน้าพร้อมกับรอยยิ้ม","“ขอบพระคุณมากขอรับท่านศาสตราจารย์ หากไม่ใช่เพราะท่าน ข้าเกรงว่าชีวิตนี้ข้าคงเป็นได้แค่พ่อมดฝึกหัดเท่านั้น”","เพียร์ซโค้งคำนับอย่างสุดซึ้งและกล่าวขอบคุณ","นับตั้งแต่ที่เขาเข้าเรียนที่สถาบันอิเยตาตอนอายุสิบสองปี เขาก็เป็นพ่อมดฝึกหัดมานานถึงสิบหกปีแล้ว และปีนี้เขาก็มีอายุเกือบจะสามสิบปีแล้วด้วย","เนื่องจากขาดพรสวรรค์ เขาจึงไม่สามารถกักเก็บพลังเวทได้เป็นเวลานาน จนกระทั่งลินน์ได้กลายมาเป็นศาสตราจารย์ของอิเยตา ซึ่งนำเอาหลักสูตรคณิตศาสตร์ที่แปลกใหม่และสามารถฝึกฝนพลังในการคำนวณมาสอน","ดังนั้น เพียร์ซจึงรู้สึกซาบซึ้งใจต่อท่านศาสตราจารย์เป็นอย่างมากอย่างไม่ต้องสงสัย..."]},{"n":319,"t":"โลกที่ทุกคนสามารถกลายเป็นผู้ใช้เวทมนตร์ได้!","c":["“ข้าก็แค่ให้โอกาสพวกเจ้าได้เลือก ส่วนการเลื่อนระดับนั้นขึ้นอยู่กับความพยายามของตัวเจ้าเอง”","ลินน์หยิบเหรียญตราพ่อมดที่เตรียมเอาไว้ออกมา และประดับมันลงบนหน้าอกของเพียร์ซด้วยมือของเขาเอง","“ตั้งแต่วันนี้เป็นต้นไป เจ้าคือพ่อมดเต็มตัวแล้ว!”","“ขอบพระคุณมากขอรับท่านศาสตราจารย์...”","น้ำเสียงของเพียร์ซสั่นเครือเล็กน้อย","ลินน์โบกมือเป็นเชิงบอกให้เพียร์ซกลับไปได้ จากนั้นเขาก็เรียกพ่อมดฝึกหัดคนต่อไปเข้ามา","เพียร์ซทำความเคารพอีกครั้งก่อนที่จะเดินออกจากหอคอยวิสลิ่ง","ประมาณสามนาทีต่อมา จอห์นนี่ก็เปิดประตูแล้วเดินเข้ามา ทั้งสองคนส่งยิ้มให้กัน และลินน์ก็ชี้ไปที่เก้าอี้ตรงหน้าเขา","“อยู่ตรงนี้สักสองสามนาทีก่อนค่อยออกไปก็แล้วกัน เผื่อว่าพวกเขาจะสังเกตเห็นถึงความผิดปกติ...”","เด็กสาวพยักหน้า อันที่จริงแล้วในช่วงเวลาที่ผ่านมานี้ เอล็อคและคนอื่นๆ ก็เริ่มสงสัยในตัวนางอยู่หลายครั้ง เพราะท้ายที่สุด นางก็มักจะร่ายเวทมนตร์ให้เห็นอยู่เสมอ แต่ทุกครั้งนางก็จะใช้ข้ออ้างว่านางใช้ไอเทมเวทมนตร์อย่าง ถุงมือเวท เพื่อบ่ายเบี่ยง","แต่ตอนนี้ นางก็ไม่ต้องคอยหลบๆ ซ่อนๆ อีกต่อไปแล้ว","และช่วงเวลาสิบนาทีนี้ก็ไม่ได้สูญเปล่าแต่อย่างใด จอห์นนี่หยิบกระดาษข้อสอบขึ้นมาและขอคำแนะนำจากลินน์เกี่ยวกับคำถามสองสามข้อสุดท้ายที่นางทำผิด...","ในช่วงไม่กี่ชั่วโมงต่อมา ลินน์ก็แจกเหรียญตราพ่อมดให้กับนักเรียนทุกคนที่เลื่อนระดับได้สำเร็จภายในหอคอยวิสลิ่ง หรือไม่ก็กล่าวปลอบใจผู้ที่ล้มเหลวให้พยายามต่อไป และพวกเขาอาจจะมีโอกาสอีกครั้งในปีหน้า","บางทีอาจเป็นเพราะการถูกทรมานด้วยข้อสอบจำนวนมหาศาลและการเพิ่มขึ้นของพลังในการคำนวณ อัตราการเลื่อนระดับในปีนี้จึงสูงกว่าเมื่อก่อนมาก โดยสูงถึง 60% เลยทีเดียว","นั่นก็หมายความว่า จะมีพ่อมดเต็มตัวหน้าใหม่เพิ่มขึ้นมาถึงสี่หรือห้าสิบคนในปีนี้","ลินน์มองดูกระดาษในมืออย่างครุ่นคิด ซึ่งมันได้บันทึกข้อมูลของนักเรียนแต่ละคนเอาไว้ และเขาก็วางแผนที่จะกำหนดตำแหน่งให้กับพวกเขาแต่ละคนตามผลคะแนนของพวกเขา","ผู้ที่มีผลคะแนนภาคทฤษฎีย่ำแย่แต่เชี่ยวชาญในการต่อสู้จริงจะกลายเป็นพ่อมดสายต่อสู้และเข้าร่วมสงครามกับจักรวรรดิ แต่ถ้าหากเป็นในทางกลับกัน พวกเขาก็จะกลายเป็นนักวิจัยทางวิทยาศาสตร์และมีส่วนร่วมในการพัฒนาอาวุธชนิดใหม่และเวทมนตร์บทใหม่","ในขณะที่กำลังครุ่นคิด ประตูก็ถูกผลักให้เปิดออกอีกครั้ง และคราวนี้ผู้ที่เดินเข้ามาก็คือ ลิเดีย","ทันทีที่เด็กสาวเผ่าฮาล์ฟลิงเดินเข้ามาในประตู นางก็เกาะขอบโต๊ะยาวเอาไว้และเอ่ยถามอย่างร้อนรน","“ท่านศาสตราจารย์ลินน์ ข้าสามารถกลายเป็นพ่อมดได้ด้วยหรือไม่คะ?”","ลินน์ได้สติกลับมาและหันไปถามนาง","“นั่นก็ขึ้นอยู่กับว่าเจ้าต้องการที่จะเป็นพ่อมดแบบไหน”","“แน่นอนว่าต้องเป็นพ่อมดที่สามารถร่ายเวทมนตร์ได้สิคะ!”","ลิเดียเอ่ยตอบโดยไม่ลังเล จากนั้นนางก็มองดูท่านศาสตราจารย์ด้วยความคาดหวัง ดวงตาของนางแทบจะเปล่งประกายออกมา","“ถ้าแค่ร่ายเวทมนตร์ได้ มันก็ไม่ใช่เรื่องยากอะไรหรอกนะ”","ลินน์เอ่ยพร้อมกับรอยยิ้ม","“จริงหรือคะ? ข้าก็สามารถใช้เวทมนตร์ได้ด้วยเช่นนั้นหรือ?”","ลิเดียตะโกนออกมาด้วยความประหลาดใจ แม้ว่าจอห์นนี่จะเคยพูดเรื่องนี้กับนางมาก่อน แต่มันก็เป็นเพียงแค่การคาดเดาเท่านั้น แต่ในตอนนี้มันได้รับการยืนยันจากท่านศาสตราจารย์ด้วยตัวเองแล้ว","“สวมสิ่งนี้เอาไว้ก่อนสิ!”","ลินน์ยื่นสร้อยข้อมือแบบพิเศษให้ ซึ่งมันก็เหมือนกับ แหวนแห่งศาสตร์เร้นลับ ที่ถูกใช้เพื่อสื่อสารกับเครือข่ายเวทมนตร์ และรูปลักษณ์ของมันก็ถูกปรับเปลี่ยนเพื่อสร้างความแตกต่าง","ลิเดียแทบจะรอไม่ไหวที่จะสวมมันไว้ที่ข้อมือของนาง และเอ่ยถามอย่างกระตือรือร้น","“แล้วตอนนี้ข้าก็สามารถใช้เวทมนตร์ได้แล้วใช่ไหมคะ?”","“แน่นอนว่าไม่!”","ลินน์ส่ายหัวอย่างขบขัน","“หลับตาลงก่อนแล้วก็ทำตัวตามสบาย!”","ลิเดียทำตามในทันทีและหลับตาปี๋ แต่นางก็ไม่สามารถผ่อนคลายได้เลยแม้แต่น้อย","ลินน์แอบสั่งให้ปัญญาประดิษฐ์สนับสนุนเชื่อมต่อเข้ากับสมองของเด็กสาวฮาล์ฟลิง ด้วยตัวอย่างของเรย์เดล และความไว้วางใจอย่างสูงที่ลิเดียมีต่อเขา ในครั้งนี้มันจึงดำเนินไปอย่างราบรื่นมาก และเด็กสาวฮาล์ฟลิงก็ไม่ต้องทนทุกข์ทรมานมากนัก หลังจากที่รู้สึกเจ็บปวดอยู่พักหนึ่ง การเชื่อมต่อกับเครือข่ายเวทมนตร์ก็เสร็จสมบูรณ์","ในไม่ช้าลิเดียก็พบว่านางได้เข้ามาอยู่ในสถานที่ที่แสนจะมหัศจรรย์ ท่ามกลางความว่างเปล่าของห้วงมิติ มีอักษรรูนสีเทานับไม่ถ้วนล่องลอยอยู่ และห้าตัวในนั้นก็ลอยเข้ามาหานาง พวกมันบินวนรอบตัวนางราวกับเด็กซุกซน ก่อนที่จู่ๆ พวกมันจะบินเข้าไปในหัวของนาง","[เวทแยกแยะวัสดุพื้นฐาน], [เวทควบแน่นน้ำ], [หัตถ์เวท], [เวทลูกไฟ], [เวทใบมีดน้ำแข็ง]...","ช่องสำหรับใส่เวทมนตร์ทั้งหมดห้าช่องปรากฏขึ้นในสมองของลิเดีย และเสียงของลินน์ก็ดังก้องขึ้นในหูของนางในเวลาเดียวกัน","“ตอนนี้เจ้าลองร่ายเวทมนตร์ดูสิ!”","ลิเดียลืมตาขึ้น และยื่นฝ่ามือออกไปด้วยความประหม่า นางกระตุ้นช่องเวทมนตร์ที่อยู่ภายในหัว ภายใต้การพุ่งพล่านของธาตุ ใบมีดน้ำแข็งที่ใสกระจ่างราวกับคริสตัลก็ปรากฏขึ้น มันแผ่ไอเย็นอันเย็นยะเยือกออกมา ทำให้ทุกคนที่อยู่รอบตัวนางรู้สึกหนาวสั่น พร้อมกับอุณหภูมิโดยรอบลดต่ำลงในทันที","“มันคือเวทมนตร์จริงๆ ด้วย!”","ลิเดียตะโกนออกมาอย่างมีความสุข จากนั้นนางก็ลองใช้เวทลูกไฟ ทำให้พลังแห่งน้ำแข็งและเปลวเพลิงไหลเวียนอยู่ในฝ่ามือของนางอย่างต่อเนื่อง และนางก็เล่นสนุกอยู่กับมันอย่างเพลิดเพลิน","แม้ว่าเวทเหล่านี้จะเป็นเพียงแค่เวทมนตร์ขั้นพื้นฐาน แต่มันก็ทำให้นางรู้สึกพึงพอใจเป็นอย่างมากแล้วสำหรับเด็กสาวฮาล์ฟลิงที่ไม่เคยแม้แต่จะสามารถใช้เวทมนตร์ได้เลย","“ท่านศาสตราจารย์ ท่านยอดเยี่ยมที่สุดเลยค่ะ!”","ลิเดียกระโดดโลดเต้นด้วยความตื่นเต้นไปตรงหน้าลินน์ และจูบลงบนแก้มของเขาแรงๆ สองสามครั้งเพื่อแสดงถึงความตื่นเต้นของนาง","ลินน์เช็ดน้ำลายบนใบหน้าของเขาด้วยความรังเกียจ และเอ่ยเตือนนาง","“จำเอาไว้ พลังจิตของเจ้ามีอยู่อย่างจำกัด ดังนั้นในหนึ่งวัน เจ้าจึงสามารถร่ายเวทมนตร์ระดับศูนย์วงแหวนได้เพียงห้าครั้ง และเวทมนตร์ระดับหนึ่งวงแหวนได้เพียงสามครั้งเท่านั้น”","ลิเดียพยักหน้ารับอย่างรวดเร็ว และนางก็ไม่ได้สนใจข้อจำกัดเหล่านั้นเลยแม้แต่น้อย อย่างน้อยตอนนี้นางก็เป็นพ่อมดจริงๆ แล้ว!","นางอยากจะเห็นนักว่าจะมีใครกล้าพูดว่านางไม่ใช่พ่อมดอีก...","ลิเดียแทบจะรอไม่ไหวที่จะออกไปอวดเบ่ง แต่ก่อนที่นางจะได้เดินออกไป ลินน์ก็หยุดนางเอาไว้เสียก่อน","“เจ้าไม่อยากได้เหรียญตราพ่อมดของเจ้าแล้วหรือ?”","ลินน์เอ่ยถามอย่างจนปัญญา","“อยากได้สิคะ อยากได้ค่ะ!”","ลิเดียรีบวิ่งกลับมาอย่างลนลาน นางรอคอยอย่างอดทนให้ท่านศาสตราจารย์ติดเหรียญตราให้กับนาง จากนั้นนางก็วิ่งออกไปอย่างมีความสุข","เมื่อมองดูท่าทางกระโดดโลดเต้นของลิเดีย ลินน์ก็อดไม่ได้ที่จะยิ้มออกมา จากนั้นเขาก็เริ่มสำรวจปัญหาเกี่ยวกับการสูญเสียพลังเวทของปัญญาประดิษฐ์สนับสนุน","เพาะมันไม่ได้มาเปล่าๆ ในการที่คนที่ไม่มีความรู้เรื่องเวทมนตร์จะสามารถร่ายเวทมนตร์ได้สำเร็จ และพลังเวทนั้นก็ไม่ได้ถูกสร้างขึ้นมาจากความว่างเปล่า แต่มันดึงมาจากเครือข่ายเวทมนตร์ของเขาเท่านั้น","นี่คือความพยายามครั้งที่สองของลินน์ในการทำลายทฤษฎีพรสวรรค์ทางด้านเวทมนตร์ที่มีมาตั้งแต่กำเนิด ซึ่งในตอนนี้มันก็ดูเหมือนว่าจะประสบความสำเร็จแล้ว แต่ก็ยังมีปัญหาอีกมากมายที่ต้องรอการแก้ไข","ยกตัวอย่างเช่น เรื่องการจัดหาพลังเวท เพราะพลังเวทที่สูญเสียไปนั้นจะต้องไม่ให้ปัญญาประดิษฐ์สนับสนุนเป็นผู้รับภาระทั้งหมด และวิธีที่ดีที่สุด ก็คือการสร้างเตาปฏิกรณ์พลังเวทขึ้นมา โดยคล้ายกับการสร้างโรงไฟฟ้า จากนั้นก็เชื่อมต่อมันเข้ากับ เครือข่ายเวทมนตร์ขนาดใหญ่ เพื่อคอยจ่ายพลังเวทที่จำเป็นสำหรับการร่ายเวทมนตร์ให้แก่พ่อมดหน้าใหม่เหล่านี้","ตามวิสัยทัศน์ของเขาแล้ว ในอาณาจักรเวทมนตร์แห่งอนาคต ไม่ว่าทุกคนจะมีพรสวรรค์ในการเป็นพ่อมดหรือไม่ก็ตาม ตราบใดที่พวกเขาได้เรียนรู้หลักการของเวทมนตร์และมีพลังในการคำนวณมากพอ พวกเขาก็จะสามารถใช้เครือข่ายเวทมนตร์เพื่อร่ายเวทมนตร์ที่สอดคล้องกันได้!","แทนที่จะเป็นเหมือนอย่างในปัจจุบัน ที่ชาติกำเนิดเป็นตัวกำหนดว่าสามัญชนจะสามารถกลายเป็นพ่อมดได้หรือไม่","โลกที่ทุกคนสามารถกลายเป็นผู้ใช้เวทมนตร์ได้ บางทีมันอาจจะสามารถก้าวข้ามสหพันธรัฐในชาติก่อน และผลักดันเวทมนตร์ให้ก้าวไปสู่ระดับใหม่ได้อย่างแท้จริง"]},{"n":320,"t":"หรือว่าเจ้าหมกมุ่นอยู่กับการใช้เวทมนตร์มากเกินไปจนเกิดภาพหลอนกันล่ะ?","c":["ภายนอกหอคอยวิสลิ่ง กลุ่มนักเรียนกำลังรวมตัวกันอยู่ที่หน้าประตู เพื่อรอคอยผลลัพธ์ของพิธีเลื่อนระดับ","เป็นระยะๆ ที่จะมีคนเดินออกมาจากหอคอยด้วยความปีติยินดี และได้รับสายตาที่อิจฉาริษยา แต่ก็มีคนจำนวนไม่น้อยที่ล้มเหลวและต้องเดินคอตกกลับไป","ดาร์เรนและคนอื่นๆ มองดูลิเดียเดินเข้าไปในหอคอย โดยพวกเขาก็รอคอยอย่างกระวนกระวายใจ และภายในเวลาไม่ถึงสองนาที พวกเขาก็เห็นประตูของหอคอยเปิดออกอีกครั้ง","เร็วขนาดนี้เลยหรือ?","ดาร์เรนลอบกังวลอยู่ในใจ เพราะนักเรียนที่เลื่อนระดับได้สำเร็จก่อนหน้านี้ ก็บอกไว้อย่างชัดเจนว่า มันต้องใช้เวลาในการที่ยาจะปรับเปลี่ยนสภาพร่างกาย ซึ่งมันก็อาจจะเร็วหรือช้าแตกต่างกันไป แต่โดยทั่วไปแล้ว มันจะใช้เวลาประมาณสิบนาที...","หรือว่าการเลื่อนระดับจะล้มเหลวกัน?","เขาเพิ่งจะคิดเรื่องนี้อยู่ได้ไม่นาน แต่ในวินาทีต่อมา ดาร์เรนก็ปฏิเสธข้อสันนิษฐานนี้ไปในทันที เพราะลิเดียที่เพิ่งเดินออกมาจากหอคอยนั้นมีเหรียญตราพ่อมดที่ส่องแสงระยิบระยับประดับอยู่บนหน้าอก ซึ่งมันดูเจิดจ้ามากเมื่ออยู่ภายใต้แสงแดด","สายตาของทุกคนถูกดึงดูดไปที่นั่น ซึ่งนั่นหมายความว่าสถาบันอิเยตา...ไม่สิ ต้องบอกว่าดินแดนพ่อมดทั้งหมดกำลังจะมีฮาล์ฟลิงตนแรกที่เป็นพ่อมด!","“ขอแสดงความยินดีด้วยนะลิเดีย เจ้าได้สร้างประวัติศาสตร์หน้าใหม่ให้กับเผ่าฮาล์ฟลิงแล้ว!”","จอห์นนี่กล่าวแสดงความยินดีอย่างมีความสุข","เอล็อคและคนอื่นๆ ที่คุ้นเคยกับเด็กสาวต่างก็ก้าวไปข้างหน้าเพื่อแสดงความยินดี โดยพวกเขาก็รู้สึกดีใจกับนางอย่างแท้จริง","ลิเดียยืดอกขึ้นอย่างภาคภูมิใจภายใต้สายตาของทุกคน ตั้งแต่วันนี้เป็นต้นไป นางคือพ่อมดเต็มตัวแล้ว","“ข้าไม่คิดเลยว่าท่านศาสตราจารย์จะอนุญาตให้คนที่ไม่รู้จักเวทมนตร์กลายเป็นพ่อมดได้จริงๆ!”","เดบร้าเอ่ยด้วยความอิจฉาริษยา","พ่อมดฝึกหัดที่ดื่มยาเข้าไปแต่ไม่สามารถเลื่อนระดับได้สำเร็จ ต่างก็มองไปที่เด็กสาวฮาล์ฟลิงด้วยความรู้สึกไม่พอใจมากยิ่งขึ้น","เช่นเดียวกับลิเดีย พวกเขาต่างก็สอบผ่านการสอบข้อเขียนและการสอบภาคปฏิบัติมาแล้วทั้งคู่ แต่ท่านศาสตราจารย์กลับไม่มอบสถานะพ่อมดให้กับพวกเขา แต่กลับมอบเกียรตินี้ให้กับฮาล์ฟลิงที่แม้แต่เวทมนตร์ก็ยังใช้ไม่เป็น ซึ่งมันทำให้พวกเขาอดไม่ได้ที่จะแอบบ่นถึงความลำเอียงของท่านศาสตราจารย์ลินน์อยู่ในใจ","“ใครบอกว่าข้าใช้เวทมนตร์ไม่เป็นกัน?”","ลิเดียยื่นมือออกไปอย่างภาคภูมิใจ และเตรียมพร้อมที่จะร่ายเวทลูกไฟอย่างใจเย็น เพื่อเบิกเนตรให้ทุกคนได้เห็น","บรรดาพ่อมดฝึกหัดและพ่อมดเต็มตัวที่อยู่ที่นั่นต่างก็มองดูด้วยความสงสัย โดยรู้ดีว่า ลิเดียนั้นใช้เวลาถึงสองปีเต็มในสถาบันอิเยตาแต่ก็ไม่สามารถเรียนรู้เวทมนตร์ได้","ลิเดียจดจ่ออยู่กับการสื่อสารกับเครือข่ายเวทมนตร์ และพยายามกระตุ้นช่องเวทมนตร์ที่อยู่ในหัวของนาง แต่หลังจากที่พยายามอยู่นาน มันก็ไม่มีการตอบสนองใดๆ เลย","“เอ๊ะ ทำไมมันถึงใช้ไม่ได้ล่ะ?”","ลิเดียลืมตาขึ้นและเอ่ยออกมาอย่างว่างเปล่า","“หรือว่าเจ้าหมกมุ่นอยู่กับการใช้เวทมนตร์มากเกินไปจนเกิดภาพหลอนกันล่ะ?”","เดบร้าเอ่ยด้วยรอยยิ้มเยาะ","ลิเดียเบ้ปาก จากนั้นนางก็พลันนึกขึ้นได้ว่าท่านศาสตราจารย์บอกว่าด้วยพลังในการคำนวณของนาง นางสามารถใช้เวทมนตร์ระดับหนึ่งวงแหวนได้เพียงวันละสามครั้งเท่านั้น เมื่อกี้ตอนที่อยู่ในหอคอยวิสลิ่ง นางตื่นเต้นมากเกินไป และดูเหมือนว่านางจะใช้มันจนหมดโควตาไปแล้ว!","ถ้างั้นก็คงต้องเปลี่ยนไปใช้เวทมนตร์ระดับศูนย์วงแหวนแทน...ซึ่งนางจำได้ว่านางยังใช้มันไม่หมด","เมื่อคิดได้เช่นนั้น ลิเดียก็ร่ายหัตถ์เวทในทันที จากนั้นกระดาษข้อสอบที่อยู่ในมือของทุกคนก็สั่นไหวอย่างกะทันหัน ก่อนที่พวกมันจะลอยขึ้นไปในอากาศ บินวนรอบตัวนาง แล้วก็ไปกองรวมกันอยู่ในมือของนาง","“นี่...นี่มัน หัตถ์เวท”","ดวงตาของเดบร้าเบิกกว้าง ใบหน้าของนางเต็มไปด้วยความประหลาดใจ และนางก็ต้องใช้เวลาอยู่ครู่หนึ่งเพื่อยืนยันว่าไม่ได้มีใครกลั่นแกล้งนาง","คนที่ร่ายเวทเมื่อครู่นี้ก็คือลิเดีย!","“เจ้าเรียนรู้เวทมนตร์ได้จริงๆ ด้วย ลิเดีย!”","ดาร์เรนวางมือลงบนไหล่ของลิเดียด้วยความตื่นเต้นและเขย่าไปมา","แม้ว่านี่จะเป็นเพียงแค่เวทมนตร์ระดับศูนย์วงแหวนขั้นพื้นฐานที่สุด แต่มันก็หมายความว่าอีกฝ่ายได้ครอบครองปาฏิหาริย์ที่เรียกว่าเวทมนตร์แล้ว!","“แน่นอนสิ! ข้ายังสามารถร่าย เวทลูกไฟกับเวทใบมีดน้ำแข็งได้ด้วยนะ แต่เมื่อกี้ข้าเผลอใช้มันไปหลายครั้ง ตอนนี้ข้าเลยต้องรอจนถึงพรุ่งนี้ถึงจะใช้มันได้อีก...”","ลิเดียเอ่ยอย่างภาคภูมิใจ และในขณะเดียวกันนางก็รู้สึกรำคาญตัวเองเล็กน้อย ถ้ารู้อย่างนี้ นางน่าจะเก็บช่องเวทมนตร์ระดับหนึ่งวงแหวนเอาไว้สักช่อง เพื่อเอามาโชว์ให้ทุกคนได้เห็นชัดๆ","อย่างไรก็ตาม เมื่อเห็นว่าลิเดียสามารถร่ายเวทมนตร์ได้สำเร็จ ก็ไม่มีใครตั้งคำถามกับคำพูดของนางอีก ท้ายที่สุดแล้ว พลังเวทและพลังจิตของทุกคนล้วนมีขีดจำกัด การตกอยู่ในสภาวะที่พลังเวทเหือดแห้งนั้นเป็นเรื่องปกติ","กล่าวอีกนัยหนึ่งก็คือ เด็กสาวฮาล์ฟลิงที่อยู่ตรงหน้านี้ได้กลายเป็นพ่อมดจริงๆ แล้ว!","แต่ว่า...ท่านศาสตราจารย์ทำมันได้อย่างไรกัน?","ฮาล์ฟลิงไม่มีพรสวรรค์ทางเวทมนตร์ ซึ่งเป็นฉันทามติของดินแดนพ่อมดแห่งนี้ที่ไม่เคยมีใครทำลายได้มาก่อน หรือว่าลิเดียจะเป็นกรณีพิเศษ ที่หลังจากดื่มต้นกำเนิดเวทมนตร์เข้าไปแล้ว นางก็สามารถทำลายพันธนาการของเผ่าพันธุ์และได้รับความสามารถในการร่ายเวทมนตร์มา?","ท่านศาสตราจารย์อาจจะมองเห็นพรสวรรค์ในการเป็นพ่อมดของนาง เขาถึงยอมให้ลิเดียเข้ามาเรียนที่สถาบันอิเยตา...","เอล็อคและคนอื่นๆ ต่างก็ครุ่นคิดด้วยความสับสน แต่พวกเขาไม่ได้คิดไปในทิศทางที่สุดโต่งมากนัก ท้ายที่สุดแล้ว หากท่านศาสตราจารย์มีวิธีที่จะทำให้ใครๆ ก็สามารถกลายเป็นพ่อมดเต็มตัวได้จริงๆ มันคงจะเป็นเรื่องที่น่าเหลือเชื่อมากเกินไป และการคาดเดาว่าฮาล์ฟลิงตนนี้มีพรสวรรค์ทางด้านเวทมนตร์นั้นดูเป็นไปได้มากกว่าการคาดเดาที่เหลือเชื่อแบบนั้นเป็นร้อยเท่า!","การสอบจบการศึกษาของสถาบันอิเยตากินเวลานานถึงสี่วันเต็มก่อนที่มันจะสิ้นสุดลง และเอล็อคกับคนอื่นๆ ที่บอกลาสถานะพ่อมดฝึกหัดของตนเอง ก็ถูกส่งตัวไปประจำการตามหน่วยงานต่างๆ อย่างรวดเร็ว","อย่างไรก็ตาม ในทุกๆ ด้านต่างก็ต้องการกำลังคน โดยเฉพาะพ่อมดที่เชี่ยวชาญในด้านการแปรสภาพ ตั้งแต่การปรับปรุงเครื่องยนต์สันดาปภายใน การสร้างเรือรบหุ้มเกราะ ไปจนถึงการปรับปรุงปืนคาบศิลาและปืนใหญ่ ผู้สำเร็จการศึกษาทั้ง 47 คนล้วนแต่เป็นพ่อมดที่จบมาเพื่อการนี้","ในช่วงไม่กี่วันที่ผ่านมา เรย์เดลและแฮมม์ก็ไม่ได้อยู่นิ่งๆ เลย พวกเขาได้เรียนรู้เกี่ยวกับทุกแง่มุมของเมืองพ่อมดแห่งนี้ และยังได้ไปยังโรงงานต่างๆ เพื่อสัมผัสกับมันด้วยตัวเอง","งานเหล่านี้เป็นงานที่เหนื่อยมากจริงๆ โดยต้องทำงานวันละสิบสี่ชั่วโมง แต่เงินเดือนในแต่ละเดือนก็มากพอที่จะทำให้ทุกคนลืมความเจ็บปวดทางร่างกายไปได้จนหมดสิ้น และทุกคนต่างก็หวงแหนชีวิตในปัจจุบันของตนเองเป็นอย่างมาก พวกเขาไม่จำเป็นต้องมีผู้คุมคอยจับตามองด้วยซ้ำ","นั่นก็เป็นเพราะพ่อมดที่ดูแลสถานที่แห่งนั้นบอกกับพวกเขาว่า สิ่งของส่วนใหญ่ที่ผลิตในโรงงานแห่งนี้ถูกเตรียมเอาไว้เพื่อทำสงคราม ซึ่งมันจะเป็นตัวตัดสินความสำเร็จหรือความพ่ายแพ้ของสงครามในครั้งนี้เป็นอย่างมาก","และเมื่อใดก็ตามที่สภาเวทมนตร์พ่ายแพ้ จักรวรรดิก็จะเข้ายึดครองสถานที่แห่งนี้ และพวกเขาก็จะต้องกลับไปใช้ชีวิตแบบเดิมๆ ที่กินข้าวมื้อนี้โดยไม่รู้ว่าจะมีมื้อหน้าให้กินหรือไม่ ซึ่งมันอาจจะเลวร้ายยิ่งกว่านั้นด้วยซ้ำ","ข้าได้ยินมาว่าพวกขุนนางและศาสนจักรที่อยู่ภายนอกดินแดนพ่อมดนั้นโหดเหี้ยมมาก พวกเขาจะไม่ลังเลเลยที่จะสังหารหมู่ผู้คนทั้งเมือง ปล้นชิงทรัพย์สิน สังหารทุกคนที่ไม่ศรัทธาในพระเจ้า หรือไม่ก็จับพวกเขาไปขายเป็นทาสในดินแดนอันแห้งแล้ง","ด้วยเหตุนี้ คนงานจึงยอมทำงานล่วงเวลาด้วยความสมัครใจ และทำงานด้วยความกระตือรือร้นอย่างเต็มเปี่ยม เพื่อรักษาชีวิตในปัจจุบันของพวกเขาเอาไว้...","หลังจากที่อยู่ในโรงงานมาเป็นเวลาห้าวัน ในที่สุดเรย์เดลก็ต้องจำใจเดินทางไปยังพื้นที่เพาะปลูกธัญพืชที่พวกพ่อมดบุกเบิกเอาไว้ตามคำเชิญของลินน์ เพราะวันนี้คือวันสำหรับการเก็บเกี่ยวในฤดูร้อน!","และสิ่งที่ปรากฏอยู่ตรงหน้าของเรย์เดลก็คือ ภาพที่งดงามตระการตาเป็นอย่างยิ่ง มีทุ่งข้าวสาลีสีทองทอดยาวไปไกลสุดลูกหูลูกตา กินอาณาบริเวณไปจนสุดขอบฟ้า ซึ่งดูงดงามตระการตาราวกับมหาสมุทรสีทองก็ไม่ปาน"]},{"n":321,"t":"แนวคิดของการระเบิดนิวเคลียร์!","c":["เดิมทีที่นี่เคยเป็นผืนดินที่แห้งแล้ง ซึ่งเป็นดินเค็มที่หลงเหลืออยู่หลังจากที่น้ำทะเลลดลง แต่ในตอนนี้ มันกลับกลายเป็นผืนดินที่อุดมสมบูรณ์ภายใต้อำนาจอันยิ่งใหญ่ของเวทมนตร์","สิ่งที่ดึงดูดความสนใจของเรย์เดลและคนอื่นๆ ก็คือ พ่อมดจากสถาบันวิจัยการแปรธาตุกำลังปรับแต่งขั้นตอนสุดท้ายให้กับเครื่องเก็บเกี่ยวที่มีรูปร่างหน้าตาประหลาดเหล่านั้น","“ท่านพ่อมด เครื่องนี้มันสามารถเปลี่ยนรวงข้าวสาลีให้กลายเป็นเมล็ดข้าวได้โดยอัตโนมัติเลยจริงๆ หรือขอรับ?”","ชายวัยสามสิบเศษคนหนึ่งชะโงกหน้าไปที่ด้านหน้าของเครื่องจักร เขามองดูพวกพ่อมดสตาร์ทเครื่องจักร และอดไม่ได้ที่จะเอ่ยถามออกมา","เบียต เป็นชาวนาของที่นี่ เนื่องจากการรับสมัครคนงานจำนวนมหาศาลในโรงงาน ทำให้คนยากคนจนที่เคยหาเลี้ยงชีพด้วยการทำนาต่างก็พากันเปลี่ยนงาน แต่เพื่อป้องกันไม่ให้ที่ดินเหล่านี้ถูกทิ้งร้าง ลินน์จึงถือโอกาสนี้นำนโยบายการทำสัญญาเช่าที่ดินมาใช้ เพื่อเตรียมพร้อมสำหรับการทำฟาร์มขนาดใหญ่ที่ใช้เครื่องจักรกลอย่างเต็มรูปแบบ","เบียต เลยใช้ประโยชน์จากโอกาสทองนี้ ยอมทุบกระปุกเอาเงินเก็บทั้งหมดของเขาออกมาเช่าที่ดินโดยรอบ!","นี่คือผลลัพธ์จากการทำงานหนักมานานกว่าครึ่งปีของเขา ทุ่งข้าวสาลีแห่งนี้มีค่ามากกว่าลูกชายแท้ๆ ของเขาเสียอีก!","“แน่นอน ไม่มีปัญหาอยู่แล้ว!”","ฟิลิปเอ่ยอย่างมั่นใจ","เพื่อที่จะสร้างแบบแปลนที่ท่านศาสตราจารย์มอบให้ พวกเขาต้องใช้ความพยายามอย่างมาก และสูญเสียเซลล์สมองไปนับไม่ถ้วนก่อนที่จะสร้างสิ่งนี้ขึ้นมาได้สำเร็จ แม้ว่าพวกเขาจะยังไม่ได้ลองใช้มัน แต่ฟิลิปก็มีความมั่นใจอย่างเต็มเปี่ยม","เขาแค่ไม่รู้ว่าปรมาจารย์ท่านไหนเป็นคนประดิษฐ์เครื่องเก็บเกี่ยวเครื่องนี้ขึ้นมา?","ถึงสามารถคิดค้นสิ่งประดิษฐ์ที่ประณีตเช่นนี้ขึ้นมาได้...","“ท่านศาสตราจารย์ลินน์ พวกเราเริ่มกันได้เลยหรือยังครับ?”","ฟิลิปหันไปมองลินน์และเอ่ยถามด้วยความคาดหวัง","ลินน์พยักหน้าพร้อมกับรอยยิ้ม เขาก็อยากรู้เหมือนกันว่าเครื่องเก็บเกี่ยวที่สถาบันวิจัยการแปรธาตุสร้างขึ้นมาจะมีประสิทธิภาพมากแค่ไหน","เมื่อได้รับอนุญาต ฟิลิปก็ปล่อยให้เพื่อนร่วมงานที่กระตือรือร้นหลายคนขึ้นไปบนเครื่องเก็บเกี่ยว","ฉึกฉัก","เมื่อคันโยกถูกดึง เครื่องจักรประหลาดเหล่านี้ก็ส่งเสียงออกมาในทันที","ภายใต้สายตาอันตึงเครียดของทุกคน เครื่องเก็บเกี่ยวก็แล่นตรงไปที่ทุ่งข้าวสาลี ส่วนที่รองรับเมล็ดพืชที่ด้านล่างก็ถูกสอดเข้าไปในต้นพืช กวาดรวบรวงข้าวสาลีเข้าสู่ตัวเครื่อง จากนั้นอุปกรณ์ตัดที่อยู่ภายในก็ตัดและลำเลียงพวกมันเข้าไปในถังนวดข้าวของเครื่องเก็บเกี่ยว โดยเมล็ดข้าวสาลีจะถูกคัดแยกผ่านรูตะแกรงในขั้นตอนสุดท้าย และเมล็ดข้าวสาลีที่แยกออกมาก็จะถูกเก็บไว้ในกล่องเก็บของที่อยู่ด้านหลัง","กระบวนการนี้ฟังดูซับซ้อน แต่มันก็ทำงานโดยอัตโนมัติด้วยเครื่องจักรทั้งหมด สิ่งที่พวกเขาต้องทำก็มีเพียงแค่การขับเครื่องเก็บเกี่ยวและแล่นตรงไปในทุ่งข้าวสาลีอันกว้างใหญ่!","เพียงเวลาสั้นๆ พื้นที่หลายพันตารางเมตรก็ถูกเก็บเกี่ยวจนหมด...","ฟิลิปภูมิใจเป็นอย่างมากที่ได้แนะนำวิธีการทำงานและหลักการของเครื่องเก็บเกี่ยวให้เบียต เรย์เดล และคนอื่นๆ ได้ฟัง นอกจากเครื่องเก็บเกี่ยวแล้ว สถาบันวิจัยการแปรธาตุก็ยังได้ผลิตเครื่องจักรที่ใช้สำหรับการไถและหว่านเมล็ดโดยเฉพาะอีกด้วย","การใช้เครื่องจักรทั้งหมดนี้คือกระบวนการสามประการของการไถ หว่าน และเก็บเกี่ยว ซึ่งมีแค่พ่อมดที่เชี่ยวชาญในด้านธาตุจะร่ายเวทมนตร์เพื่อใส่ปุ๋ยให้กับดิน ใช้เพียงแค่ไม่กี่คนก็สามารถดูแลที่ดินผืนใหญ่ได้แล้ว!","“นี่มันเหมือนกับอาณาจักรของพระเจ้าที่บรรยายเอาไว้ในพระคัมภีร์เลย...”","แฮมม์พึมพำ","มีข่าวลือว่าในอาณาจักรของพระเจ้า มีแม่น้ำสายใหญ่ที่เต็มไปด้วยไวน์รสเลิศ ทุ่งข้าวสาลีจะออกรวงเต็มต้นโดยไม่ต้องเพาะปลูก และกิ่งก้านของต้นไม้ทุกต้นก็เต็มไปด้วยสเต็กเนื้อนุ่มฉ่ำ...","แม้ว่าเขาจะไม่เคยเห็นแม่น้ำที่เต็มไปด้วยไวน์ชั้นดี และสเต็กที่งอกออกมาจากต้นไม้ แต่ทุ่งข้าวสาลีที่นี่สามารถเพาะปลูกและเก็บเกี่ยวได้โดยอัตโนมัติ แถมยังมีเครื่องมือเล่นแร่แปรธาตุที่สามารถผลิตผ้าได้หลายหมื่นเมตรต่อวัน...","ความงดงามในพระคัมภีร์นั้นมีอยู่เพียงแค่ในจินตนาการ แต่เขาได้เห็นปาฏิหาริย์ของสถาบันอิเยตาด้วยตาของเขาเอง!","“ท่านลินน์ เครื่องจักรเล่นแร่แปรธาตุพวกนี้สามารถนำไปใช้ในอาณาจักรได้หรือไม่ขอรับ?”","เรย์เดลรีบเอ่ยถาม เพราะในตอนนี้อาณาจักรฮัดลาตา ก็อยู่ในช่วงฤดูเก็บเกี่ยวเช่นเดียวกัน ถ้ามีเครื่องเก็บเกี่ยวแบบนี้ พวกเขาก็ไม่จำเป็นต้องทำงานหลังขดหลังแข็งฝังตัวอยู่ในดินทั้งวันอีกต่อไป","“ตอนนี้เกรงว่าจะสายเกินไปแล้วล่ะ เครื่องเก็บเกี่ยวมีจำนวนจำกัด เมื่อสถาบันอิเยตาใช้จนหมด ข้าก็ต้องเป็นคนจัดการให้กับเมืองอื่นๆ ในดินแดนพ่อมดต่อ แต่เมื่อถึงฤดูเพาะปลูกในฤดูใบไม้ร่วง ข้าสามารถส่งเครื่องจักรพรวนดินไปที่อาณาจักรได้บ้าง...”","ลินน์เอ่ยอย่างครุ่นคิด","“ถ้าคนอื่นๆ ได้เห็นภาพแบบนี้ พวกเขาคงจะต้องตกใจมากแน่ๆ...”","แฮมม์พึมพำ หากพวกเขาไม่ได้เห็นมันด้วยตาตัวเอง คงไม่มีใครเชื่อว่าการเพาะปลูกและการเก็บเกี่ยวมันจะง่ายดายถึงเพียงนี้","หลังจากที่ขับเครื่องเก็บเกี่ยวไปรอบๆ พ่อมดแห่งสถาบันวิจัยการแปรธาตุก็กระโดดลงมาจากเครื่องจักรด้วยความตื่นเต้นที่ยังไม่จางหาย และหันไปหาเรย์เดลกับคนอื่นๆ เพื่อให้พวกเขาได้ลองสัมผัสประสบการณ์นี้ดูบ้าง","โดยเฉพาะเบียต เขาเป็นชาวนาของที่นี่!","ในครั้งนี้ มันเป็นการทดสอบประสิทธิภาพของเครื่องเก็บเกี่ยว และพวกพ่อมดก็ต้องลงสนามเพื่อสาธิตให้พวกเขาดูด้วยตัวเอง ในอนาคต มันก็ต้องพึ่งพาเบียตในการควบคุมมันด้วยตัวเขาเอง","พวกเขายุ่งอยู่จนกระทั่งถึงตอนเย็น ทุ่งข้าวสาลีที่แต่เดิมกว้างใหญ่สุดลูกหูลูกตา บัดนี้เหลือเพียงแค่ต้นข้าวสาลีครึ่งหนึ่งที่ติดอยู่กับรากเท่านั้น และงานเก็บเกี่ยวก็เสร็จสมบูรณ์ไปอย่างราบรื่น!","หากต้องทำด้วยมือล้วนๆ มันต้องใช้คนมากกว่า 30 คน ทำงานห้าถึงหกวัน แต่ตอนนี้เครื่องเก็บเกี่ยวห้าเครื่องสามารถทำงานของคนหลายสิบคนในอดีตให้เสร็จได้ภายในครึ่งวัน ที่สำคัญที่สุดก็คือ พวกเขาไม่เหนื่อยเลยสักนิด และมันยังแยกเมล็ดข้าวสาลีออกมาโดยตรง ซึ่งช่วยประหยัดเวลาไปได้มาก","เบียตที่รู้สึกซาบซึ้งใจเป็นอย่างมาก ได้กระตือรือร้นที่จะอยู่กับฝูงชน และถึงกับเชือดอูฐเพียงตัวเดียวในครอบครัวเพื่อเฉลิมฉลองอย่างยิ่งใหญ่","มันเป็นเวลากลางคืนแล้วตอนที่ลินน์และคนอื่นๆ กลับมาที่สถาบัน และบัตรเชิญเข้าร่วมงานสัมมนาวิชาการก็ถูกส่งมาให้ในเวลาเดียวกัน","เมื่อพิจารณาว่าสงครามกับศาสนจักรอาจจะยืดเยื้อออกไปเป็นเวลานาน งานสัมมนาวิชาการในปีนี้จึงถูกเลื่อนให้เร็วขึ้นมาหนึ่งเดือนก็ไม่ใช่เรื่องแปลกอะไร","ลินน์ยังคงให้ความสนใจกับงานสัมมนานี้มาก นับตั้งแต่ที่เขาสร้างผลิตภัณฑ์แก้วขึ้นมา เหล่าพ่อมดก็เร่งทำความเข้าใจและมีความคืบหน้าในการวิจัยในระดับจุลภาค และดาราศาสตร์ก็ก้าวหน้าไปอย่างก้าวกระโดด","พ่อมดบางคนจากสถาบันพยากรณ์ได้สร้างกล้องโทรทรรศน์ดาราศาสตร์ขนาดใหญ่ขึ้นมาแล้ว และกำลังเตรียมพร้อมที่จะปรับปรุงแผนที่ดวงดาวต่อไป ซึ่งเขาก็ได้เห็นรายงานที่เกี่ยวข้องหลายครั้งใน วารสารเวทมนตร์รายวัน","ในช่วงเวลาที่เขาใช้เวทจำลองร่างเพื่อจัดการเรื่องราวในอาณาจักร ลินน์เองก็ไม่ได้อยู่เฉยๆ เช่นกัน เขาได้ตีพิมพ์ทฤษฎีเกี่ยวกับแม่เหล็กไฟฟ้าออกมามากมาย ซึ่งได้รับทั้งคำชมเชยและความสงสัยจากผู้คนจำนวนมาก","อย่างไรก็ตาม ลินน์ยังคิดไม่ออกว่าในครั้งนี้เขาจะนำเสนอทฤษฎีอะไร แต่มีสิ่งที่เขาต้องการ ทำให้มันสมบูรณ์แบบมากที่สุดก็คือ แบบจำลองธาตุ","ตราบใดที่คุณสามารถหาวิธีที่จะสร้างธาตุที่หายากเหล่านั้นขึ้นมาได้ เทคโนโลยีอันทรงพลังมากมายก็จะสามารถเปลี่ยนให้กลายเป็นเวทมนตร์ได้ อย่างเช่น ระเบิดนิวเคลียร์หรืออะไรทำนองนั้น และกองทัพของศาสนจักรก็จะลอยขึ้นสู่สรวงสวรรค์ในทันทีที่มันถูกปล่อยออกมา","ไม่สิ บางทีพวกเขาอาจจะไม่มีโอกาสได้ขึ้นสวรรค์ด้วยซ้ำ","ถ้างั้นก็ไม่มีความจำเป็นที่จะต้องทำสงคราม...","ลินน์จินตนาการถึงฉากของการระเบิดของนิวเคลียร์ในหัวของเขา แต่ลึกๆ ในใจเขาก็รู้ดีว่า แม้ว่าเขาจะสามารถสร้างเวทมนตร์ที่ทรงพลังเช่นนี้ขึ้นมาได้สำเร็จ เขาก็อาจจะไม่ได้เป็นฝ่ายชนะสงครามในทันที","ด้วยพลังของพระเจ้าที่อยู่เหนือระดับตำนาน แค่เพียงร่างอวตารก็แสดงให้เห็นถึงความสามารถในการบิดเบือนมิติเวลาแล้ว ซึ่งนั่นไม่ใช่เรื่องง่ายเลยที่จะรับมือ..."]},{"n":322,"t":"นี่มันกำลังเอาข้าไปนั่งอยู่บนปากปล่องภูเขาไฟชัดๆ!","c":["ในเดือนกรกฎาคม ดวงอาทิตย์ที่แผดเผาได้แขวนตัวลอยเด่นอยู่เหนือหัว แต่นครพ่อมด กรีนรีลกลับคึกคักเป็นอย่างยิ่ง ราวกับจะกวาดล้างเงามืดที่ลัทธิวันสิ้นโลกทิ้งเอาไว้ไปหมดสิ้น","และสงครามในเมืองหลวงที่เกิดขึ้นในอาณาจักรฮัดลาตา ก็กลายเป็นที่รู้จักกันอย่างแพร่หลายไปพร้อมๆ กับการเผยแพร่ของวารสารเวทมนตร์รายวัน สภาเวทมนตร์ถึงกับนำไปประกาศอย่างเปิดเผย โดยคิดว่านี่คือการต่อสู้ครั้งแรกของพ่อมดกับศาสนจักร และมันก็ยังเป็นชัยชนะที่น่าตื่นเต้นเป็นอย่างยิ่งด้วย!","นั่นก็หมายความว่านับตั้งแต่นี้เป็นต้นไป พ่อมดทุกคนไม่จำเป็นต้องอาศัยอยู่บนเกาะแห่งนี้อีกต่อไป และยังมีโลกที่กว้างใหญ่ไพศาลรออยู่ภายนอกนั่น!","ท่ามกลางบรรยากาศอันน่าตื่นเต้นเช่นนี้ งานสัมมนาวิชาการในปีนี้ก็ถูกจัดขึ้นตามปกติ และเรือเหาะลำยักษ์ก็ค่อยๆ ร่อนลงมาจากฟากฟ้า แล้วลงจอดที่จัตุรัสหน้าสภาเวทมนตร์","การใช้เรือเหาะในการเดินทางกลายมาเป็นกระแสนิยมในดินแดนพ่อมดไปแล้ว สถาบันเวทมนตร์ทุกแห่งยอมทุ่มเงินก้อนโตเพื่อซื้อเรือเหาะ ไม่ว่ามันจะเป็นเพื่อความสะดวกสบายในการเดินทางหรือเพื่อรักษาหน้าตาของสถาบันก็ตาม","บรรดาพ่อมดและชาวเมืองในนครพ่อมดกรีนรีลต่างก็คุ้นเคยกับภาพตรงหน้านี้เป็นอย่างดี ซึ่งเป็นเวลากว่าหนึ่งปีแล้วที่พวกเขาได้เห็นเรือเหาะหลายสิบลำบินเข้าบินออกเกือบทุกวัน จากความตกใจในตอนแรกจนกลายมาเป็นความเคยชินในปัจจุบัน...","ในฐานะเจ้าภาพของงานสัมมนาในครั้งนี้ ราฟาเอลจึงเป็นผู้นำพาผู้คนมายืนรออยู่ที่ประตูแต่เนิ่นๆ เพื่อต้อนรับพ่อมดจากสถาบันต่างๆ ที่เดินทางมาถึงกรีนรีล","เนื่องจากลินน์เพิ่งจะทำการทดลองเพื่อวัดเส้นรอบวงของดาวเคราะห์และตรวจสอบแรงดึงดูดของโลกเสร็จสิ้นในงานสัมมนาครั้งที่แล้ว เหล่าพ่อมดที่ได้รับข่าวแต่ไม่สามารถเดินทางมาเป็นสักขีพยานในผลการทดลองได้ทันเวลาต่างก็รู้สึกเสียดายเป็นอย่างมาก","ดังนั้น ในครั้งนี้จึงมีผู้คนมาร่วมงานเป็นจำนวนมาก หรือจะพูดให้ถูกก็คือ พ่อมดเต็มตัวที่ยังมีชีวิตอยู่แทบทุกคนในดินแดนพ่อมดต่างก็มารวมตัวกันที่นี่ จนทำให้พื้นที่ที่สภาเวทมนตร์ขยายเอาไว้เพื่อใช้สำหรับจอดเรือเหาะเป็นการเฉพาะนั้นไม่เพียงพอ","ราฟาเอลเพิ่งจะทักทายสหายเก่าของเขาเสร็จ เมื่อเขาได้ยินพ่อมดฝึกหัดที่อยู่ข้างๆ กระซิบที่ข้างหูของเขา","“ท่านอาจารย์ ดูเหมือนว่านั่นจะเป็นธงของสมาคมเวทมนตร์เร้นลับ นะขอรับ!”","ราฟาเอลหันขวับไปมองในทันที ซึ่งมีเรือเหาะลำยักษ์กำลังลอยลำอยู่เหนือสภาเวทมนตร์ โดยถุงลมนิรภัยขนาดใหญ่ทั้งสองด้าน มีลวดลายที่โดดเด่นและเป็นเอกลักษณ์วาดเอาไว้ นั่นคือสัญลักษณ์ของสมาคมเวทมนตร์เร้นลับ ซึ่งตอนนี้ทุกคนในดินแดนพ่อมดต่างก็รู้จักมันเป็นอย่างดี...","“ยินดีต้อนรับ ท่านลินน์ ข้าไม่ได้พบท่านมาสักพักแล้วนะ!”","ราฟาเอลก้าวไปข้างหน้าอย่างรวดเร็ว และสวมกอดลินน์ที่เพิ่งจะลงมาจากเรือเหาะอย่างกระตือรือร้น จากนั้นเขาก็เอ่ยด้วยความประหลาดใจราวกับเพิ่งจะค้นพบอะไรบางอย่าง","“นี่ท่านทะลวงผ่านแล้วงั้นหรือ?”","ราฟาเอล ซึ่งเป็นจอมเวทผู้ยิ่งใหญ่เช่นเดียวกัน ย่อมสัมผัสได้ถึงการมีอยู่ของอาณาเขตเวทมนตร์ เขาจึงยืนยันได้ในทันทีว่าพ่อมดหนุ่มที่อยู่ตรงหน้าเขาผู้นี้ได้ก้าวข้ามผ่านระดับแล้ว!","“มันก็แค่ความโชคดีน่ะครับ เพิ่งจะทะลวงผ่านไปได้เมื่อสัปดาห์ก่อนนี่เอง”","ลินน์ตอบกลับพร้อมกับรอยยิ้ม","“ดูเหมือนว่าต่อไปนี้ข้าคงจะต้องเรียกท่านว่าปรมาจารย์ลินน์แล้วล่ะ!”","ราฟาเอลเอ่ยด้วยความรู้สึกหลากหลาย แม้ว่าเขาจะรู้ดีว่าด้วยพรสวรรค์ของลินน์ มันก็เป็นเพียงแค่เรื่องของเวลาก่อนที่เขาจะสามารถทะลวงผ่านไปสู่ระดับของจอมเวทผู้ยิ่งใหญ่ได้ แต่ก็ไม่คิดเลยว่ามันจะเร็วถึงเพียงนี้","นี่มันเพิ่งจะผ่านไปแค่ปีเดียวเองนะตั้งแต่ที่พวกเราเจอกัน...","ดูเหมือนว่าสถิติของจอมเวทผู้ยิ่งใหญ่ที่อายุน้อยที่สุดในดินแดนพ่อมดกำลังจะถูกทำลายลงอีกครั้งแล้ว!","ราฟาเอลรู้สึกประหลาดใจ แต่เขาก็ไม่ลืมหน้าที่ของตนเอง โดยร่างอีกร่างหนึ่งที่อยู่ข้างๆ ลินน์ก็ดึงดูดความสนใจของเขาอย่างรวดเร็ว","“ไม่ทราบว่าท่านผู้นี้คือ?”","“แอนโธนี จากอาณาจักรฮัดลาตา เขาเป็นสมาชิกของสมาคมเวทมนตร์เร้นลับ เช่นเดียวกัน!”","ลินน์เป็นฝ่ายแนะนำให้รู้จักก่อน","สีหน้าของราฟาเอลเปลี่ยนเป็นจริงจังในทันที เขาเคยอ่านวารสารเวทมนตร์รายวันมาก่อน และชื่อนี้ก็ถูกกล่าวถึงในรายงานเกี่ยวกับสงครามในเมืองหลวง ดังนั้น เขาจึงรู้ดีว่าอีกฝ่ายคือปรมาจารย์ระดับหกวงแหวนที่เชี่ยวชาญในด้านแม่เหล็กไฟฟ้า","เมื่อคิดได้เช่นนั้น ราฟาเอลก็รีบเชิญทุกคนเข้าไปข้างในอย่างกระตือรือร้น และแอบสอบถามข้อมูลเกี่ยวกับจอมเวทผู้ยิ่งใหญ่ที่แปลกหน้าผู้นี้ไปตลอดทาง","แอนโธนีผู้มากประสบการณ์สามารถรับมือกับคำถามเหล่านั้นได้อย่างเป็นธรรมชาติ แม้ว่าเขาจะมีความปรารถนาอันแรงกล้าต่อดินแดนพ่อมดแห่งนี้ แต่เขาก็ยังไม่ได้สร้างความไว้วางใจให้กับใครเลย","ราฟาเอลพยายามตะล่อมถามอยู่นานแต่ก็ไม่สามารถเค้นข้อมูลที่เป็นประโยชน์ออกมาได้เลย แต่มีสิ่งหนึ่งที่ทำให้เขารู้สึกประหลาดใจ เพราะจอมเวทผู้ยิ่งใหญ่ระดับหกวงแหวนที่อยู่ห่างจากระดับตำนานเพียงก้าวเดียวผู้นี้ กลับทำตัวเป็นเหมือนผู้ติดตามของลินน์เสียอย่างนั้น","เมื่อถึงเวลาที่ต้องประเมินว่าควรจะตอบคำถามบางข้อหรือไม่ แอนโธนีมักจะหันไปมองหน้าลินน์ก่อนเสมอ และเมื่อเห็นว่าอีกฝ่ายไม่ได้คัดค้านอะไร เขาถึงจะยอมตอบ","ราฟาเอลตระหนักได้ในทันทีว่า ตัวตนของลินน์ในสมาคมเวทมนตร์เร้นลับ นั้นไม่ได้เรียบง่ายเหมือนกับนักวิชาการธรรมดาๆ อย่างที่เขาพูด","หรือว่าเขาจะเป็นพ่อมดระดับตำนาน หรือไม่ก็เป็นศิษย์ของผู้ก่อตั้งกันแน่?","ราฟาเอลคิดในใจ แต่ใบหน้าของเขาก็ยังคงประดับไปด้วยรอยยิ้มเช่นเดิม ขณะที่เขานำทางทุกคนเข้าไปในหอประชุมอย่างรวดเร็ว","ทันทีที่ลินน์และคนอื่นๆ เดินผ่านประตูเข้าไป บรรดาพ่อมดที่กำลังพูดคุยและปรึกษาหารือกันอยู่ในหอประชุมก็พากันเข้ามาห้อมล้อมเขาในทันที หลังจากที่เขาได้สร้างความตื่นตะลึงในงานสัมมนาครั้งที่แล้ว เขาก็กลายเป็นดาวรุ่งแห่งวงการเวทมนตร์ที่ฮอตที่สุดในดินแดนพ่อมดไปเสียแล้ว!","โดยเฉพาะอย่างยิ่งหลังจากที่ได้รู้ว่าลินน์ได้ทะลวงผ่านจนกลายมาเป็นจอมเวทผู้ยิ่งใหญ่แล้ว เสียงยกย่องสรรเสริญต่างๆ นานาก็ดังก้องไปทั่วทั้งหอประชุม","ลินน์ตอบรับพ่อมดที่กระตือรือร้นเหล่านั้นทีละคนด้วยรอยยิ้มบนใบหน้า หลังจากผ่านไปครึ่งชั่วโมง รอยยิ้มของเขาก็เริ่มแข็งค้าง และหูของเขาก็เริ่มชาจากการได้ยินคำเยินยอต่างๆ นานา แต่เขาก็ยังคงต้องรับมือกับมันต่อไป มิฉะนั้นในวันพรุ่งนี้ ข่าวลือเรื่องที่เขาซึ่งเป็นดาวรุ่งแห่งวงการเวทมนตร์ทำตัวหยิ่งยโสและไม่เห็นหัวใครก็คงจะแพร่สะพัดไปทั่วดินแดนพ่อมดอย่างแน่นอน","พูดได้คำเดียวเลยว่า การมีชื่อเสียงโด่งดังมันก็ไม่ได้มีแต่เรื่องดีเสมอไป...","ลินน์คิดด้วยความรู้สึกสะท้อนใจ จนกระทั่งงานสัมมนาใกล้จะเริ่มขึ้น ในที่สุดเขาก็สามารถหลุดพ้นจากการถูกห้อมล้อมของฝูงชนมาได้ และเดินทางไปที่นั่งของสถาบันอิเยตาภายใต้การนำทางของราฟาเอล","ลินน์ตระหนักได้อย่างชัดเจนว่าตำแหน่งที่นั่งของพวกเขาในครั้งนี้สูงกว่าครั้งที่แล้วอย่างเห็นได้ชัด ซึ่งเป็นรองเพียงแค่องค์กรที่ก่อตั้งโดยประธานสภาอย่างสถาบันพยากรณ์และสมาคมการเล่นแร่แปรธาตุเท่านั้น...","แน่นอนว่านี่ถือเป็นเกียรติอย่างหนึ่ง แต่มันก็เทียบเท่ากับการเอาตัวเองไปนั่งอยู่บนปากปล่องภูเขาไฟเช่นเดียวกัน หากผลงานของสถาบันอิเยตาในครั้งนี้ไม่เป็นที่น่าพอใจ เขาก็เกรงว่าจะมีคนเอาไปนินทาลับหลังอย่างแน่นอน","“ทุกคน โปรดอยู่ในความสงบ!”","บนแท่นสูงของหอประชุม จอมเวทผู้ยิ่งใหญ่ซานเชซกระแอมในลำคอ และใช้เวทขยายเสียงเพื่อส่งเสียงของเขาให้ดังก้องไปทั่วทุกมุมของหอประชุม เพื่อระงับเสียงพูดคุยที่ดังอื้ออึง","“ยินดีต้อนรับสู่กรีนรีลเพื่อเข้าร่วมงานสัมมนาวิชาการในครั้งนี้!”","“ในช่วงสัปดาห์ที่ผ่านมา สภาเวทมนตร์ได้รับข้อเสนอเกี่ยวกับทฤษฎีเวทมนตร์มากกว่าเจ็ดสิบเรื่อง ซึ่งมากกว่าปกติหลายเท่า ดังนั้น งานสัมมนาทั้งหมดจะใช้เวลาสามวัน โดยแบ่งออกเป็นสามช่วง ซึ่งทั้งหมดจะจัดขึ้นในตอนเที่ยงของทุกวัน...”","ซานเชซอธิบายสั้นๆ เกี่ยวกับขั้นตอนและการเปลี่ยนแปลงของการประชุม หลังจากที่หยุดชะงักไปครู่หนึ่ง จู่ๆ เขาก็มองมาที่ลินน์ เน้นเสียงของเขา และเอ่ยขึ้นอีกครั้ง","“นอกจากนี้ งานสัมมนาวิชาการในปีนี้จำเป็นจะต้องเพิ่มคณะกรรมการตัดสินเข้าไปอีกหนึ่งคน...และคนผู้นั้นก็คือ ปรมาจารย์ลินน์แห่งสถาบันอิเยตา!”"]},{"n":323,"t":"ทฤษฎีสุดโต่งของลินน์ สีไม่มีอยู่จริงงั้นหรือ?","c":["เมื่อสิ้นเสียงของซานเชซ สายตานับพันคู่ในหอประชุมก็หันขวับไปมองที่สถาบันอิเยตาในทันที","ลินน์ขมวดคิ้วอย่างอดไม่ได้ ก่อนหน้านี้ราฟาเอลก็ไม่เคยพูดถึงเรื่องนี้กับเขามาก่อนเลย แต่ก่อนที่เขาจะทันได้ทำความเข้าใจ เสียงปรบมือก็ดังก้องไปทั่วทั้งหอประชุมอย่างกระตือรือร้น","ภายใต้สายตาที่จับจ้องของทุกคน ลินน์ไม่มีทางเลือกอื่นนอกจากลุกขึ้นยืนแล้วเดินขึ้นไปบนแท่นสูง จากนั้นก็นั่งลงบนที่นั่งของคณะกรรมการตัดสิน ก่อนจะหันไปมองราฟาเอลที่อยู่ข้างๆ แล้วเอ่ยถามด้วยความไม่พอใจเล็กน้อย","“ข้าไม่เคยไปล่วงเกินท่านเลยนะ ท่านปรมาจารย์?”","แม้ว่าการได้เป็นกรรมการตัดสินในงานสัมมนาจะไม่ใช่เรื่องแย่ แต่สถานการณ์ที่เกิดขึ้นอย่างกะทันหันเช่นนี้ก็ทำให้ลินน์เกิดการคาดเดาในแง่ร้ายบางอย่างขึ้นมา","ในช่วงเวลาสั้นๆ เพียงหนึ่งชั่วโมงที่เดินทางมาถึงกรีนรีล สถาบันอิเยตากลับได้รับการต้อนรับพร้อมเกียรติยศมากจนเกินไป และลินน์ก็รู้ซึ้งถึงสัจธรรมข้อหนึ่งเป็นอย่างดี นั่นก็คือ ยิ่งยืนอยู่สูงเท่าไหร่ เวลาตกลงมาก็จะยิ่งเจ็บหนักมากเท่านั้น...","“แน่นอนว่าไม่ ทำไมท่านถึงคิดเช่นนั้นล่ะ?”","ราฟาเอลถามด้วยความขบขัน","“อย่างน้อยท่านก็ควรจะถามความเห็นของข้าในเรื่องนี้ก่อนที่จะตัดสินใจนะ”","ลินน์เอ่ยด้วยความไม่พอใจเล็กน้อย","“นั่นเป็นความผิดพลาดของข้าเอง...”","ราฟาเอลตบหน้าผากของตัวเองและอธิบายด้วยความรู้สึกผิด","“ข้อเสนอจำนวนมากที่สภาเวทมนตร์ได้รับในครั้งนี้ ล้วนแต่เป็นเรื่องเกี่ยวกับอุปกรณ์ที่ทำจากแก้วแบบใหม่ ซึ่งข้าคิดว่าท่านน่าจะรู้ดีกว่าพวกเรา ดังนั้น พวกเราจึงได้หารือกันและตัดสินใจเพิ่มที่นั่งของคณะกรรมการตัดสินเข้าไปชั่วคราว...”","ก่อนหน้านี้ พวกเขาก็ไม่ได้จัดการเช่นนี้ เพราะพวกเขายังไม่รู้ข้อมูลเกี่ยวกับการเลื่อนระดับของลินน์จนกลายมาเป็นจอมเวทผู้ยิ่งใหญ่","โดยธรรมชาติแล้ว พ่อมดระดับสามวงแหวนย่อมไม่มีคุณสมบัติมากพอที่จะตัดสินผลงานวิจัยของสถาบันใดๆ ได้ตามอำเภอใจ แต่ในตอนนี้ลินน์ได้ก้าวข้ามผ่านระดับไปแล้ว แน่นอนว่าเขาย่อมไม่ต้องกังวลในเรื่องนี้อีกต่อไป...","และการที่พวกเขาปรับที่นั่งให้กับเขาเสียใหม่ ก็เพื่อแสดงให้เห็นว่าพวกเขาให้ความสำคัญกับลินน์และสมาคมเวทมนตร์เร้นลับมากเพียงใด","เมื่อพูดถึงเรื่องนี้ ราฟาเอลก็รู้สึกพูดไม่ออกเล็กน้อย โดยทั่วไปแล้ว พ่อมดที่อยู่ในวัยเดียวกับลินน์มักจะกระตือรือร้นที่จะได้แสดงตัวตนและได้รับความสนใจ แต่ทำไมเขาถึงได้เป็นคนขี้ระแวงเช่นนี้กันล่ะ","จากคำอธิบายของราฟาเอล ลินน์ก็ตระหนักได้ว่าเขาเข้าใจผิดไปเอง และไม่ได้มีใครตั้งใจจะพุ่งเป้ามาที่เขา...","บนแท่นสูงในเวลานี้ ซานเชซเพิ่งจะกล่าวเปิดงานอันยืดยาวจบลง โดยประกาศถึงการเริ่มต้นของงานสัมมนาวิชาการในปีนี้อย่างเป็นทางการ ก่อนจะเดินลงจากแท่นสูงไปเพื่อเปิดพื้นที่ให้กับคนอื่นๆ","ซึ่งก็มีพ่อมดแม่มดหนุ่มสาวหลายคนอดใจรอไม่ไหวที่จะก้าวขึ้นมา และหลังจากทำความเคารพลินน์และคนอื่นๆ แล้ว พวกเขาก็หยิบเอาลูกบาศก์แก้วที่มีรูปร่างแปลกประหลาดออกมาแสดงให้ทุกคนดู และเอ่ยเสียงดัง","“นี่คืออุปกรณ์แยกแสงที่พวกเราเป็นคนพัฒนาขึ้นมา!”","“นั่นมันก็แค่ปริซึมไม่ใช่หรือไง?”","เอล็อคที่นั่งอยู่ท่ามกลางผู้ชมพึมพำเบาๆ ขณะที่พ่อมดจากสถาบันอิเยตาที่อยู่ข้างๆ เขาก็พยักหน้าอย่างพร้อมเพรียงกัน พวกเขาเคยสาธิตมันมาแล้ว เพียงแต่ยังไม่ได้ประกาศให้ใครรู้เท่านั้น","ในความเป็นจริง พวกเขาก็กำลังทำการวิจัยเกี่ยวกับแสงอยู่เช่นกัน แต่พวกเขายังไม่สามารถสร้างผลงานชิ้นสำคัญใดๆ ออกมาได้ เนื่องจากมีเวลาที่สั้นจนเกินไป","และก็เป็นไปตามคาด พ่อมดแม่มดบนเวทีก็ได้สาธิตการทดลองแยกแสงด้วยปริซึม แต่เห็นได้ชัดว่าการวิจัยของคนกลุ่มนี้มีมากกว่านั้น และยังมีบางสิ่งที่พวกเขาเองก็ยังไม่เข้าใจ...","“พวกเรายังพบอีกว่า ในบรรดาสีทั้งเจ็ดสีนั้น สีแดง สีเขียว และสีน้ำเงิน มีความสำคัญเป็นอย่างยิ่ง หรืออาจกล่าวได้ว่า สีอื่นๆ ทั้งหมดล้วนแล้วแต่ถือกำเนิดมาจากสีทั้งสามนี้”","พ่อมดผู้เป็นผู้นำที่ชื่อว่าเกล็นเอ่ยด้วยความภาคภูมิใจ","“ข้าเรียกพวกมันว่าแม่สี ซึ่งอาจกล่าวได้ว่ามันคือสีที่แท้จริงของแสง โดยทุกสิ่งทุกอย่างล้วนประกอบขึ้นจากสีทั้งสาม นั่นคือ สีแดง สีเขียว และสีน้ำเงิน มันเป็นเพียงแค่ความเข้มข้นของแม่สีแต่ละสีที่พัฒนาไปเป็นสีที่เรามองเห็น ทั้งสีอื่นๆ เช่น สีเหลือง สีม่วง สีฟ้า ฯลฯ และเมื่อนำทั้งสามสีมารวมกันในความเข้มข้นที่เท่ากัน มันก็จะกลายเป็นแสงสีขาว!”","เมื่อปรับมุมของอุปกรณ์แยกแสง สีสันที่ปรากฏออกมาก็เปลี่ยนไปตามนั้นเช่นกัน","ราฟาเอลและคนอื่นๆ ต่างก็จดจ่ออยู่กับการแสดงตรงหน้า และพวกเขาก็รู้สึกสนใจสิ่งที่ชายหนุ่มพูดเกี่ยวกับแม่สีเป็นอย่างมาก นี่ถือเป็นการค้นพบครั้งยิ่งใหญ่เลยทีเดียว!","แสงเป็นสิ่งที่พบเห็นได้ทั่วไป แต่ก่อนหน้านี้ แม้แต่พ่อมดระดับตำนานก็ยังไม่สามารถรับรู้ถึงสิ่งที่เรียกว่าธาตุแสงได้ พวกเขาทำได้เพียงแค่พัฒนาเวทมนตร์โดยอิงจากคุณสมบัติของแสง และตระหนักถึงการใช้ประโยชน์จากแสงในอีกระดับหนึ่งเท่านั้น","การค้นพบของคนกลุ่มนี้ ทำให้พวกเขามีความเข้าใจเกี่ยวกับแสงในเบื้องต้นอย่างไม่ต้องสงสัย ว่าแสงสีขาวนั้นแท้จริงแล้วประกอบไปด้วยแสงสีที่แตกต่างกันสามสี ได้แก่ สีแดง สีเขียว และสีน้ำเงิน...","เสียงพูดคุยปรึกษาหารือกันในหอประชุมเริ่มดังขึ้นเรื่อยๆ และทุกคนต่างก็กำลังพูดคุยเกี่ยวกับการค้นพบอันน่าประหลาดใจนี้","พ่อมดแม่มดบนแท่นสูงต่างก็ชูอุปกรณ์แยกแสงในมือขึ้นสูง เพื่อรับการตรวจสอบจากฝูงชน และพวกเขาก็รู้สึกตื่นเต้นเป็นอย่างยิ่ง เพราะอย่างน้อย การวิจัยของพวกเขาก็สามารถคว้ารางวัลเหรียญตราจันทร์สีเงินมาครองได้!","เกล็น ถึงกับเริ่มคิดแล้วว่าเขาควรจะเปลี่ยนชื่อสถาบันของเขาดีหรือไม่ ซึ่งคิดเอาไว้แล้วว่ามันจะใช้ชื่อว่า สถาบันรุ่งอรุณและแม่สี...","“ข้าคิดว่างานวิจัยนี้มีคุณค่าเป็นอย่างมาก!”","ซานเชซเป็นคนแรกที่เอ่ยปากชื่นชม","ราฟาเอลและคนอื่นๆ ต่างก็เห็นด้วยกับเรื่องนี้เป็นอย่างมาก และพวกเขาก็กล่าวชื่นชมผลงานการวิจัยของเกล็นเช่นเดียวกัน","ใบหน้าของเกล็นเต็มไปด้วยความพึงพอใจ จากนั้นเขาก็หันหน้าไปมองลินน์ที่ยังไม่ได้พูดอะไรออกมาเลย","สำหรับดาวรุ่งแห่งวงการเวทมนตร์ผู้โด่งดังผู้นี้ เกล็นมีความรู้สึกที่ผสมปนเปกันไป ทั้งอิจฉา ชื่นชม และริษยา ซึ่งการวิจัยในครั้งนี้ของพวกเขาก็เป็นการใช้แก้วที่อีกฝ่ายเป็นคนคิดค้นขึ้นมา","อย่างไรก็ตาม เกล็นผู้ยังหนุ่มแน่นและมีความทะเยอทะยาน เชื่อว่าสักวันหนึ่ง เขาจะสามารถเป็นเหมือนกับอีกฝ่าย ที่ได้วิจัยเกี่ยวกับทฤษฎีเวทมนตร์ที่สามารถเปลี่ยนแปลงระบบเวทมนตร์ทั้งหมดได้ และกลายมาเป็นดาวรุ่งแห่งวงการเวทมนตร์ที่ทุกคนต่างก็ตั้งหน้าตั้งตารอคอย","ในขณะที่เกล็นกำลังเพ้อฝันอยู่นั้น จู่ๆ ลินน์ก็เอ่ยปากพูดขึ้นมา","“งานวิจัยของพวกเจ้าถือว่าทำออกมาได้ดีมาก แต่ข้าจำเป็นที่จะต้องแก้ไขอะไรบางอย่างสักเล็กน้อย! แม่สีทั้งสามที่เจ้าเพิ่งจะพูดถึงนั้น ไม่ได้เป็นตัวแทนของต้นกำเนิดหรือธรรมชาติของแสง...”","“หรือถ้าจะพูดให้ถูกก็คือ สีมันไม่ได้มีอยู่ในวัตถุหรอกนะ!”","คำพูดอันน่าประหลาดใจของลินน์จุดประกายความสงสัยให้เกิดขึ้นในหอประชุมทันที","“ปรมาจารย์ลินน์ ท่านหมายความว่าอย่างไร? สีไม่มีอยู่จริงงั้นหรือ? แล้วสิ่งที่เรากำลังมองเห็นอยู่ในตอนนี้คืออะไรกันล่ะ?”","ซานเชซถามด้วยความสับสน","เกล็นและคนอื่นๆ ต่างก็รู้สึกไม่พอใจเป็นอย่างยิ่ง การแยกแสงและแม่สีเป็นผลมาจากความพยายามอย่างหนักของพวกเขา ซึ่งการทดลองที่เข้มงวดของพวกเขาก็ถูกนำมาใช้เป็นข้อพิสูจน์ แต่ลินน์กลับปฏิเสธมันด้วยคำพูดเพียงประโยคเดียว","หากสีไม่มีอยู่จริง นั่นก็เท่ากับเป็นการพิสูจน์แล้วว่างานวิจัยของข้ามันไม่มีความหมายเลยไม่ใช่หรือ...","“ท่านลินน์ ในฐานะของกรรมการตัดสินทางวิชาการ มันเป็นหน้าที่ของข้าที่จะให้คำแนะนำและชี้ให้เห็นถึงข้อผิดพลาดหรือข้อบกพร่อง แต่ทางที่ดีท่านไม่ควรพูดจาส่งเดชในสิ่งที่ท่านไม่เข้าใจ...”","บนที่นั่งของคณะกรรมการตัดสิน จอมเวทผู้ยิ่งใหญ่ในชุดคลุมสีม่วงเอ่ยตำหนิด้วยความไม่พอใจ","ก่อนที่ราฟาเอลจะเสนอให้ลินน์เข้ามาเป็นกรรมการตัดสิน เขาเป็นเพียงคนเดียวที่คัดค้านเรื่องนี้ เพราะท้ายที่สุด พ่อมดในวัยยี่สิบกว่าปีอาจจะประสบความสำเร็จในด้านหนึ่งหรือสองด้าน แต่ถึงอย่างนั้นความรู้ที่เขามีก็ยังไม่กว้างขวางพอ และนี่ก็คือสิ่งที่สำคัญที่สุดในการเป็นกรรมการตัดสินทางวิชาการ!"]},{"n":324,"t":"โลกใบนี้แท้จริงแล้วไร้สี!","c":["ท่ามกลางความสงสัยของฝูงชน ลินน์ไม่ได้รีบร้อนอธิบาย แต่กลับตั้งคำถามขึ้นมาแทน","“พวกท่านทุกคนน่าจะรู้ใช่ไหมว่าแสงสามารถสะท้อนได้?”","พ่อมดแม่มดในหอประชุมต่างพยักหน้า การสะท้อนคือธรรมชาติพื้นฐานของแสง และเวทโพลาไรเซชันส่วนใหญ่ก็ใช้หลักการนี้","“สีที่เรามองเห็นนั้น แท้จริงแล้วเกิดจากแสงที่ส่องกระทบวัตถุ สะท้อนเข้าสู่ดวงตาของเรา และถูกจดจำโดยเซลล์รับแสง”","ลินน์อธิบาย","“เซลล์รับความรู้สึกของมนุษย์สามารถแยกแยะได้เพียงสามสีเท่านั้น คือ แดง เขียว และน้ำเงิน เนื่องจากสเปกตรัมของแสงอาทิตย์ที่มองเห็นได้นั้นผสมผสานกันอย่างสม่ำเสมอ มันจึงไร้สีในสายตาของเรา...”","“เดี๋ยวก่อน ปรมาจารย์ลินน์ หากท่านกล่าวเช่นนั้น ทุกสิ่งทุกอย่างก็จะกลายเป็นสีเดียวกันภายใต้แสงเดียวกันไม่ใช่หรือ?”","ซานเชซขัดจังหวะขึ้นมาอย่างอดไม่ได้","“แน่นอนว่าไม่ เพราะแสงส่วนหนึ่งจะถูกวัตถุดูดซับเอาไว้ และสิ่งที่เรามองเห็นก็คือส่วนของแสงที่มองเห็นได้ที่สะท้อนกลับมาเท่านั้น...”","ลินน์กล่าว","หากจะพูดให้ถูกต้องกว่านั้น หลังจากที่แสงซึ่งสะท้อนจากวัตถุเข้าสู่ดวงตาของมนุษย์ มันจะถูกแปลงเป็นสัญญาณไฟฟ้าบนจอประสาทตาและส่งไปยังสมองผ่านทางเส้นประสาทตา โดยสิ่งที่เรียกว่าสีนั้น เป็นเพียงแค่คำนิยามของมนุษย์ที่มีต่อผลลัพธ์การมองเห็นของคลื่นแม่เหล็กไฟฟ้าในช่วงความถี่หนึ่งของแสงที่มองเห็นได้เท่านั้น...","เกี่ยวกับจุดนี้ หลังจากที่เขาเชี่ยวชาญในแรงแม่เหล็กไฟฟ้า เขาก็ได้ทำการตรวจสอบเรื่องนี้ในอิเยตา ดังนั้น เขาจึงมีความมั่นใจอย่างเต็มเปี่ยม","คำพูดของลินน์ดังก้องไปทั่วทั้งหอประชุม และการโต้เถียงพร้อมกับเสียงพูดคุยปรึกษาหารือกันท่ามกลางผู้ชมก็เริ่มดังขึ้นเรื่อยๆ","“ทฤษฎีนี้ช่าง...น่าทึ่งจริงๆ!”","ราฟาเอลมองไปที่ลินน์และอดไม่ได้ที่จะเอ่ยขึ้น","“นั่นไม่ได้หมายความว่าแท้จริงแล้วโลกใบนี้ไร้สีหรอกหรือ?”","ในอดีต พวกเขาเคยคิดว่าธาตุต่างๆ ล้วนมีสีเฉพาะตัว และวัตถุที่พวกมันประกอบเข้าด้วยกันก็จะแสดงระบบสีที่สอดคล้องกันออกมา โดยแสงทำหน้าที่เพียงแค่ช่วยให้พวกเขามองเห็นสีที่ปรากฏอยู่แต่เดิม หรือเกาะติดอยู่บนพื้นผิวของธาตุเท่านั้น","อย่างไรก็ตาม คำกล่าวของลินน์กลับตรงกันข้ามอย่างสิ้นเชิง สีทั้งหมดล้วนมาจากแสง และสิ่งที่พวกเขามองเห็นก็คือแสงที่ถูกวัตถุผลักไสออกมา ส่วนแสงที่ถูกดูดซับเข้าไปนั้นไม่สามารถมองเห็นได้งั้นหรือ?","นั่นก็คือ วัตถุสีแดงไม่ได้เป็นสีแดงเลยแม้แต่น้อย แต่มันจะสะท้อนแสงสีแดงทั้งหมดออกมา แล้วจากนั้นก็ดูดซับแสงสีอื่นๆ เข้าไป","ตามทฤษฎีแล้ว หากสามารถหาวิธี ‘มองเห็น’ สิ่งที่เรียกว่า ‘ธาตุแสง’ ที่อยู่ภายในวัตถุได้ สิ่งนี้ก็ควรจะแสดงสีที่ผสมผสานจากสีอื่นๆ ออกมาไม่ใช่หรือ?","ราฟาเอลรู้สึกยากที่จะทำความเข้าใจคำพูดของลินน์ และมันก็ยากที่จะจินตนาการถึงโลกที่สีถูกสลับสับเปลี่ยนไปมาจริงๆ","“ใช่แล้ว หากปราศจากแสง ก็จะไม่มีสี”","ลินน์พยักหน้าเห็นด้วยกับคำพูดของราฟาเอล","“นี่มันเป็นเพียงแค่ความเชื่อที่ผิด ชัดๆ!”","จอมเวทผู้ยิ่งใหญ่ในชุดคลุมสีม่วงตบโต๊ะแล้วลุกขึ้นยืน ก่อนจะตะโกนเสียงดัง","“ถ้าอย่างนั้น ทุกสิ่งที่เราเห็นก็กลับตาลปัตรไปหมดเลยสิ สิ่งที่เป็นสีดำซึ่งดูดซับแสงทั้งหมดเอาไว้ แท้จริงแล้วมันสว่างมาก แต่เราแค่มองไม่เห็นมันงั้นหรือ?”","“ไม่ มันไม่อาจกล่าวเช่นนั้นได้ ในเมื่อแสงถูกดูดซับเอาไว้และไม่สะท้อนออกมา โดยธรรมชาติแล้วมันย่อมไม่ส่องสว่าง”","ลินน์ยักไหล่ ก่อนจะพูดต่อไป","“และพวกท่านลองคิดดูสิ หากพวกท่านอยู่ในพื้นที่ปิดตายในตอนกลางคืน พวกท่านจะมองเห็นสีหรือไม่? ดังนั้น สีจึงดำรงอยู่ได้โดยอาศัยแสง”","เมื่อได้ยินเช่นนี้ ราฟาเอลและคนอื่นๆ ก็ผงะไปครู่หนึ่ง ส่วนซานเชซขมวดคิ้ว รู้สึกว่าคำกล่าวของลินน์นั้นไม่น่าเชื่อถือเอาเสียเลย","“ปรมาจารย์ลินน์ สิ่งที่เวทมนตร์ต้องการคือการพิสูจน์อย่างเข้มงวด ไม่ใช่การคาดเดา! การที่เราไม่สามารถมองเห็นสิ่งใดได้เมื่อปราศจากแสง นั่นหมายความว่าพวกมันไม่มีอยู่จริงหากเรามองไม่เห็นงั้นหรือ?”","เกล็นที่ยืนอยู่บนแท่นสูงรวบรวมความกล้าและเอ่ยแย้งขึ้นมา ซึ่งเป็นคนสุดท้ายที่จะเชื่อข้อโต้แย้งนี้","ท้ายที่สุดแล้ว เรื่องนี้ก็เกี่ยวข้องกับว่าเขาจะได้รับเหรียญตราจันทร์สีเงินหรือไม่ ทันทีที่ได้รับการพิสูจน์แล้วว่าแม่สีไม่ใช่แก่นแท้ของแสง แต่เป็นปรากฏการณ์ที่เกิดจากเหตุผลทางสรีรวิทยา ความสำคัญของผลงานการวิจัยของเขาก็จะดิ่งลงเหวอย่างแน่นอน","อย่างไรก็ตาม เขาเพิ่งจะโต้เถียงกับจอมเวทผู้ยิ่งใหญ่ และยังคงเป็นดาวรุ่งแห่งวงการเวทมนตร์ที่โด่งดังที่สุดในดินแดนพ่อมดอีกด้วย หลังจากที่ความกล้าหาญในใจของเกล็นค่อยๆ จางหายไป เหงื่อเย็นๆ ก็เริ่มผุดพรายขึ้นบนหน้าผากของเขา","เพื่อนที่อยู่ข้างๆ เขาก็ค่อยๆ กระตุกแขนเสื้อของเขาอย่างเงียบๆ เป็นเชิงส่งสัญญาณให้เกล็นอย่าไปขัดแย้งกับดาวรุ่งแห่งวงการเวทมนตร์อย่างวู่วาม อีกฝ่ายไม่จำเป็นต้องทำอะไรด้วยซ้ำ เพียงแค่แสดงเจตนาออกมาสักเล็กน้อย อนาคตของพวกเขาก็คงจะน่าเศร้ามากแล้ว","ลินน์ไม่ได้ใส่ใจกับคำถามอันเฉียบแหลมของเกล็น และกล่าวพร้อมกับรอยยิ้ม","“เป็นการโต้แย้งที่ดีมาก และสิ่งที่เจ้าพูดมาก็ไม่เลวเลย ทฤษฎีเวทมนตร์ทุกทฤษฎีจำเป็นต้องได้รับการตรวจสอบด้วยการทดลอง!”","“ตอนนี้ ทุกท่าน โปรดปิดหน้าต่างและประตูของหอประชุมแห่งนี้ให้มิดชิด...อย่าให้มีแสงใดๆ เล็ดลอดเข้ามาได้!”","เมื่อสิ้นเสียงของลินน์ พ่อมดแม่มดที่อยู่ริมหน้าต่างในหอประชุมก็ร่ายเวทอย่างพร้อมเพรียงกัน เพื่อปิดกั้นประตูและหน้าต่างทั้งหมด","ฉากงานสัมมนาวิชาการที่เดิมทีสว่างไสวก็กลายเป็นมืดมิดลงในทันที เหลือเพียงแสงสว่างจากด้านบนศีรษะของพวกเขา ซึ่งเป็นแสงที่ส่องลงมาจากยอดหอคอยโดยตรง เพื่อให้แสงสว่างเพียงเล็กน้อยเท่านั้น","“มีใครพกกระจกมาบ้าง?”","ลินน์ถามอีกครั้ง","“ข้ามี!”","เกล็นก้าวออกมาข้างหน้าหนึ่งก้าว และหยิบกระจกกลมบานหนึ่งออกมาจากอกเสื้อของเขา เมื่อเร็วๆ นี้เขาได้ทำการทดลองเกี่ยวกับแสง ดังนั้น แน่นอนว่ากระจกจะไม่มีทางอยู่ห่างจากตัวเขาอย่างแน่นอน","“ดีมาก!”","ลินน์พยักหน้า จากนั้นก็เรียกจอนนี่ให้เดินมาหา โดยให้เธอไปยืนอยู่ตรงหน้าแท่นสูง และใช้กระจกกลมสะท้อนแสงที่ส่องลงมาจากด้านบนศีรษะให้ตกลงไปบนร่างของเด็กสาว","ท่ามกลางความมืดมิด ร่างของจอนนี่ดูโดดเด่นสะดุดตาเป็นอย่างมาก เธอสวมกระโปรงยาวสีแดงสด ซึ่งกระโปรงนั้นก็พลิ้วไหวเบาๆ ราวกับเปลวเพลิง","“เจ้าพอจะรู้ไหมว่าเสื้อผ้าที่เธอสวมใส่อยู่นั้นเป็นสีอะไร?”","ลินน์ถาม","“แน่นอนว่าต้องเป็นสีแดงสิ!”","เกล็นตอบ","“ทุกคนก็เห็นเหมือนกันไม่ใช่หรือ?”","ราฟาเอลเม้มปาก ไม่เข้าใจเลยว่าทำไมลินน์ถึงถามคำถามงี่เง่าเช่นนี้ออกมา","“จงจดจำการตัดสินใจของพวกเจ้าในตอนนี้เอาไว้ให้ดี! เสื้อผ้าเป็นสีแดง อย่าลืมเสียล่ะ!”","ลินน์กล่าวอย่างมีความนัย","ราฟาเอลรู้สึกพูดไม่ออกเลยทีเดียว หรือว่าชุดนี้จะเปลี่ยนเป็นสีน้ำเงินในภายหลังได้งั้นหรือ?","เขาอยากจะรู้จริงๆ ว่าอีกฝ่ายต้องการจะทำบ้าอะไรกันแน่!","ลินน์หันสายตากลับไปมองเด็กสาวในชุดกระโปรงสีแดงอีกครั้ง และกล่าวพร้อมกับรอยยิ้ม","“ผิวพรรณของเจ้าช่างขาวเนียนและงดงามยิ่งนัก...”","จอนนี่ไม่คาดคิดเลยว่าศาสตราจารย์จะพูดเช่นนี้ออกมาต่อหน้าธารกำนัล ซึ่งเธอก็ดูจะเขินอายและประหม่าเล็กน้อยภายใต้สายตาที่คลุมเครือของพ่อมดแม่มดรอบกาย","สิ่งนี้เหมาะสำหรับการทดลองเป็นอย่างมาก...ลินน์กลืนประโยคครึ่งหลังลงคอไปอย่างเงียบๆ","“ต่อไปเจ้าจะต้องใช้...อุปกรณ์แยกแสงของเจ้า!”","ลินน์ก้าวไปข้างหน้าและตบไหล่ของเกล็นเพื่อเป็นการทักทาย","“ข้าควรจะทำอย่างไรดี ปรมาจารย์ลินน์?”","เกล็นถามด้วยความประหม่าขณะถือสิ่งประดิษฐ์เอาไว้ในมือ","“แยกแสงออกเหมือนที่เจ้าเคยทำ...”","ลินน์อธิบายขั้นตอนให้เกล็นฟังทีละขั้นตอนอย่างละเอียด จนกระทั่งเขามั่นใจแล้วว่าอีกฝ่ายเข้าใจ จากนั้นจึงประกาศว่าการทดลองสามารถเริ่มต้นขึ้นได้!"]},{"n":325,"t":"ปรมาจารย์ลินน์ ภูมิปัญญาของท่านช่างน่าทึ่งจริงๆ!","c":["พ่อมดแม่มดในหอประชุมต่างรู้สึกสงสัยเป็นอย่างมากเกี่ยวกับการทดลองที่ลินน์กำลังพูดถึง หลายคนยังคงจำได้ว่าดาวรุ่งแห่งวงการเวทมนตร์ผู้นี้ก็เคยมาที่นี่เมื่อหนึ่งปีก่อนเช่นกัน และได้ทำการทดลองลูกตุ้มอันน่าทึ่ง เพื่อพิสูจน์ว่าแผ่นดินใต้เท้าของพวกเขานั้นมีรูปร่างกลมและหมุนอยู่ตลอดเวลา","“ท่านแอนโธนี บนโลกใบนี้ไม่มีสีสันอยู่จริงๆ งั้นหรือ?”","ฟูล่าที่นั่งอยู่ท่ามกลางผู้ชมกระซิบถาม","แอนโธนีขมวดคิ้วและไม่ได้ตอบคำถาม เอล็อคและคนอื่นๆ ที่อยู่ข้างๆ เขาก็กำลังพึมพำอยู่ในใจเช่นกัน พวกเขายังคงเชื่อมั่นในคำพูดของคณบดี แต่ครั้งนี้มันก็ดูจะเกินจริงไปสักหน่อย...","เสียงพูดคุยในทำนองเดียวกันนี้ดังขึ้นไปทั่วทั้งหอประชุม ในขณะเดียวกัน เกล็นก็สูดหายใจเข้าลึกๆ และทำตามคำแนะนำของลินน์ โดยวางอุปกรณ์แยกแสงในมือของเขาไว้ใต้ลำแสงอาทิตย์ที่สาดส่องลงมาจากด้านบนศีรษะ","แสงสีขาวถูกแยกออกเป็นสายรุ้งเจ็ดสีอันงดงามตระการตาในทันที...","ทันใดนั้น เกล็นก็ปิดกั้นแสงสีอื่นๆ เอาไว้ เหลือเพียงแสงสีน้ำเงินเท่านั้น และเล็งมันไปที่จอนนี่","ลำแสงสีน้ำเงินอันสว่างจ้าสาดส่องลงบนร่างของเด็กสาวอย่างรวดเร็ว และพ่อมดแม่มดทุกคนในหอประชุมก็อดไม่ได้ที่จะลุกขึ้นยืนด้วยสีหน้าที่เต็มไปด้วยความตกตะลึง...","“นี่มัน... เป็นไปได้อย่างไรกัน? มันกลายเป็นสีดำงั้นหรือ?”","ราฟาเอลจ้องมองไปที่แท่นสูง ภายใต้แสงสีน้ำเงิน ผิวที่เดิมทีเคยขาวเนียนของเด็กสาวก็กลายเป็นสีฟ้าอมน้ำเงินเหมือนกับแสง ส่วนชุดกระโปรงสีแดงบนตัวของเธอกลับกลายเป็นสีดำสนิท","เกล็นเองก็พยายามข่มความประหลาดใจเอาไว้ และหมุนอุปกรณ์แยกแสงในมือ เพื่อเปลี่ยนจากแสงสีน้ำเงินเป็นแสงสีเขียว และจากนั้นก็เป็นแสงสีเหลือง แต่ไม่ว่าจะใช้แสงสีใดสาดส่องลงไป เสื้อผ้าของจอนนี่ก็ยังคงเป็นสีดำสนิท","หากไม่ใช่เพราะสีผิวของเธอที่เปลี่ยนไปตามแสงไฟ ทุกคนที่อยู่ในสายตาก็คงจะคิดว่าอุปกรณ์แยกแสงนั้นพังไปแล้วเสียอีก","จนกระทั่งเกล็นหมุนผ่านแสงสีน้ำเงินและเริ่มเปลี่ยนไปเป็นแสงสีแดง สถานการณ์ในที่สุดก็เปลี่ยนไป เมื่อแสงสีส้มสาดส่องลงบนร่างของจอนนี่ ชุดกระโปรงยาวก็กลับกลายเป็นสีแดงสดเหมือนเดิมในทันที","ปรากฏการณ์ทางแสงอันแปลกประหลาดนี้สร้างความประหลาดใจให้กับพ่อมดแม่มดที่อยู่ในเหตุการณ์เป็นอย่างมาก โดยเฉพาะจอมเวทผู้ยิ่งใหญ่ที่พูดต่อต้านลินน์ก่อนหน้านี้ ซึ่งตอนนี้ตกตะลึงไปจนทำอะไรไม่ถูก","“แสงสีเหลืองถูกดูดซับไปแล้ว!”","เกล็นพึมพำกับตัวเอง","ราฟาเอลและคนอื่นๆ นึกถึงสิ่งที่ลินน์เพิ่งพูดไปเมื่อครู่นี้ขึ้นมาได้อย่างรวดเร็ว สีส้มคือการผสมกันระหว่างสีแดงและสีเหลือง ในตอนนี้ที่แสงสีเหลืองถูกดูดซับไปแล้ว ก็จะมีเพียงแค่แสงสีแดงเท่านั้นที่สามารถสะท้อนกลับมาได้!","และก็เป็นไปตามที่พวกเขาคิด จากแสงสีส้มไปจนถึงแสงสีแดงและแสงสีม่วง ชั้นสีทั้งหมดจะแสดงให้เห็นเพียงแค่สีแดงที่มีความเข้มแตกต่างกันบนชุดกระโปรงเท่านั้น...","“นี่มันเป็นไปไม่ได้ ชุดนั้นจะต้องถูกร่ายมนตร์ใส่เอาไว้แน่ๆ!”","แม่มดคนหนึ่งตะโกนขึ้นมาด้วยความไม่เชื่อจากกลุ่มผู้ชม","“ใครก็ตามที่มีข้อสงสัยเกี่ยวกับการทดลองนี้ สามารถขึ้นมาลองทำดูด้วยตัวเองได้เลย ทุกสิ่งทุกอย่างที่พวกท่านสามารถหาได้ ล้วนแล้วแต่มีความสามารถในการสะท้อนและดูดซับแสง เพียงแต่ในระดับที่แตกต่างกันเท่านั้น”","ลินน์กล่าวพร้อมกับรอยยิ้ม","ตามคำแนะนำของลินน์ พ่อมดแม่มดสองสามคนที่อยากรู้อยากเห็นก็ได้เดินขึ้นไปบนแท่นสูง และวางเสื้อผ้า เศษผ้า สร้อยคอ เครื่องประดับต่างๆ ตลอดจนอุปกรณ์เล่นแร่แปรธาตุที่พวกเขาสามารถหาได้ลงบนใจกลางของแท่นสูง ก่อนจะสาดส่องพวกมันด้วยแสงสีต่างๆ","ผลลัพธ์ที่ได้นั้นเหมือนกับที่ลินน์พูดไว้ทุกประการ แต่เนื่องจากสิ่งของส่วนใหญ่ไม่ได้สะท้อนแสงสีใดสีหนึ่งออกมาอย่างบริสุทธิ์ มีเพียงชุดกระโปรงสีแดงบนตัวจอนนี่ที่ดูงดงามตระการตา และมีประสิทธิภาพที่ดีในการดูดซับแสงสีอื่นๆ มันจึงเกิดการเปลี่ยนแปลงที่ชัดเจนเช่นนี้","“มันกลายเป็นเรื่องจริงงั้นหรือเนี่ย... วัตถุไม่ได้มีสีสันอยู่ในตัวเองเลยแม้แต่น้อย และทุกสิ่งทุกอย่างที่เรามองเห็นก็คือการสะท้อนของแสง...”","หลังจากที่ได้ทำการทดลองบางอย่างด้วยตัวเองแล้ว ซานเชซก็ไม่รู้สึกสงสัยอีกต่อไป","หากวัตถุมีสีอยู่ในตัวเองแล้ว ภายใต้การสาดส่องของแสงสีต่างๆ มันก็ควรจะแสดงให้เห็นถึงการเปลี่ยนแปลงของสี แทนที่จะเปลี่ยนเป็นสีดำสนิท ดังนั้น คำอธิบายเพียงอย่างเดียวก็คือ วัตถุไม่ได้มีสีสัน และสีสันก็คือแสงที่พวกเขามองเห็น!","แต่ในไม่ช้า ซานเชซก็เอ่ยถามด้วยความสับสนราวกับว่าเขานึกอะไรบางอย่างขึ้นมาได้","“ปรมาจารย์ลินน์ ข้ายังมีข้อสงสัยบางอย่างที่อยากจะขอให้ท่านช่วยตอบ ในเมื่อวัตถุสามารถดูดซับแสงได้ แล้วมันมีขีดจำกัดหรือไม่ แล้วแสงที่ถูกดูดซับไปนั้นหายไปไหนกัน?”","ลินน์ชำเลืองมองซานเชซด้วยความประหลาดใจ คำถามนี้ลึกซึ้งมาก ท้ายที่สุดแล้ว มันคือการเปลี่ยนแปลงในระดับควอนตัม เขาสามารถอธิบายมันได้ แต่เขาไม่สามารถให้ข้อพิสูจน์ที่แน่ชัดได้...","หลังจากครุ่นคิดอยู่ครู่หนึ่ง ลินน์ก็ตอบอย่างระมัดระวัง","“ข้าคิดว่าพวกท่านอาจจะสังเกตเห็นว่าวัตถุสีขาวจะดูดซับความร้อนจากแสงอาทิตย์ได้ช้าที่สุด ในขณะที่วัตถุสีดำจะดูดซับความร้อนได้เร็วที่สุด ท้ายที่สุดแล้ว มันก็ดูดซับแสงทั้งหมดและได้รับพลังงานมากที่สุด!”","“เป็นอย่างนี้นี่เอง มันคือความร้อนที่เกิดจากการสะสมของ ‘ธาตุแสง’ งั้นหรือ?”","ราฟาเอลทำความเข้าใจด้วยทฤษฎีธาตุแสงที่แพร่หลายในดินแดนพ่อมด จากนั้นก็กล่าวด้วยความรู้สึกทึ่ง","“ภูมิปัญญาของท่านช่างน่าทึ่งจริงๆ ปรมาจารย์ลินน์... ดูเหมือนว่าการให้ท่านมาเป็นกรรมการตัดสิน จะเป็นการตัดสินใจที่ถูกต้องที่สุดแล้ว!”","หากลินน์ไม่ได้อยู่ที่นั่น พวกเขาคงจะยอมรับทฤษฎีแม่สีของเกล็นไปแล้วอย่างแน่นอน...","แม้ว่าการอนุมานทฤษฎีเวทมนตร์จะมักจะมาพร้อมกับความเชื่อที่ผิดๆ อยู่เสมอ และก็มีหลายทฤษฎีที่เคยได้รับการยอมรับและถึงขั้นได้รับการส่งเสริมจากสภาเวทมนตร์มาก่อน แต่สุดท้ายก็ถูกลบล้างไป ทว่าบรรดากรรมการที่ได้ทำการตัดสินใจไปแล้วก็ยังคงมีความรู้สึกราวกับว่าใบหน้าของพวกเขากำลังบวมเป่งจากการถูกตบหน้า","บนแท่นสูง เกล็นและคนอื่นๆ ดูหดหู่เป็นอย่างมาก แต่พวกเขาก็ไม่สามารถพูดอะไรเพื่อโต้แย้งได้ ท้ายที่สุดแล้ว ก็มีหลักฐานที่หนักแน่นดั่งเหล็กกล้าอยู่ตรงหน้าพวกเขา","“ปรมาจารย์ลินน์ ดูเหมือนว่างานวิจัยของพวกเราจะผิดพลาดนะ”","เกล็นกล่าวด้วยความผิดหวังขณะถืออุปกรณ์แยกแสงเอาไว้ในมือ","ลินน์กล่าวพร้อมกับรอยยิ้ม","“งานวิจัยของเจ้ามีข้อผิดพลาดก็จริง แต่มันก็มีคุณค่าเป็นอย่างมากเช่นกัน มันสามารถเป็นส่วนเสริมที่ดีให้กับทฤษฎีเวทมนตร์ของธาตุแสงได้ ท้ายที่สุดแล้ว ศัตรูของพวกเราก็มักจะเป็นมนุษย์”","“ในนามของข้า ข้าจะเสนอชื่อพวกเจ้าให้เข้ารับรางวัลเหรียญตราจันทร์สีเงิน!”","ลินน์กล่าวอย่างหนักแน่น","ในฐานะของกรรมการตัดสินทางวิชาการ เมื่อต้องเผชิญกับทฤษฎีเวทมนตร์ใหม่ๆ มันก็เป็นหน้าที่ของเขาที่จะต้องชี้ให้เห็นถึงข้อผิดพลาดและข้อบกพร่อง และการเสนอชื่ออีกฝ่ายให้เข้ารับรางวัลเหรียญตราจันทร์สีเงิน ก็เพื่อเป็นการส่งเสริมเจตนารมณ์ในการวิจัยเวทมนตร์","ใช้เวลาเพียงหนึ่งปีนับตั้งแต่ที่เขาคิดค้นแก้วขึ้นมา เกล็นและคนอื่นๆ ก็สามารถค้นพบคุณสมบัติของสิ่งนี้ สร้างปริซึมที่มีคุณสมบัติเหมาะสม และค้นพบการเปลี่ยนแปลงของแม่สีทั้งสามได้ ซึ่งนี่ก็ถือว่ายอดเยี่ยมมากแล้ว!","“พวกท่านคิดเห็นว่าอย่างไร?”","ลินน์ชำเลืองมองไปที่คณะกรรมการตัดสินและเอ่ยถาม","ราฟาเอลและคนอื่นๆ ต่างก็มองหน้ากัน ผลลัพธ์การวิจัยของเกล็นสมควรได้รับรางวัลเหรียญตราจันทร์สีเงินจริงๆ แต่พวกเขาก็เห็นได้ว่าลินน์มีความเข้าใจอย่างลึกซึ้งเกี่ยวกับทัศนศาสตร์ และเขาก็คุ้นเคยกับทฤษฎีแม่สีเป็นอย่างดี การที่เขาสามารถสั่งให้เกล็นทำการทดลองได้นั้น เขาควรจะรู้ทฤษฎีนี้มาตั้งนานแล้ว","แต่ในเมื่อลินน์เองก็ไม่ได้คัดค้าน หลังจากที่ทั้งสองสามคนหารือกันแล้ว พวกเขาก็เห็นพ้องต้องกันอย่างเป็นเอกฉันท์","เจตนารมณ์ของงานสัมมนาวิชาการเวทมนตร์คือการส่งเสริมให้พ่อมดทำการวิจัยเวทมนตร์และตีพิมพ์ผลลัพธ์ที่เกี่ยวข้อง ในเมื่อเกล็นและคนอื่นๆ ได้ศึกษาปรากฏการณ์ของแสงสีรุ้งและแม่สีทั้งสามด้วยตัวเอง พวกเขาก็ยังคงคู่ควรกับรางวัล..."]},{"n":326,"t":"ปฏิเสธการเสนอชื่อรับเหรียญตราจันทร์สีเงิน!","c":["หลังจากที่ได้รับการพิจารณาอย่างเป็นเอกฉันท์จากคณะกรรมการตัดสินหลายท่าน มติในการเสนอชื่อไปยังสภาเวทมนตร์เพื่อขอรับเหรียญตราจันทร์สีเงินก็ผ่านความเห็นชอบอย่างรวดเร็ว","พ่อมดแม่มดในหอประชุมต่างมองไปที่เกล็นด้วยความอิจฉา โดยทั่วไปแล้ว ตราบใดที่พวกเขาได้รับการอนุมัติจากจอมเวทผู้ยิ่งใหญ่ สิ่งที่เรียกว่าการเสนอชื่อไปยังสภาเวทมนตร์ก็เป็นเพียงแค่ขั้นตอนหนึ่งเท่านั้น","แต่ในขณะนั้นเอง เกล็นก็ลุกขึ้นยืนและพูดขัดจังหวะ","“เดี๋ยวก่อน ปรมาจารย์ทุกท่าน”","“เจ้ามีทฤษฎีเวทมนตร์แปลกใหม่ที่อยากจะอธิบายเพิ่มเติมอีกงั้นหรือ?”","ลินน์เอ่ยถามด้วยความอยากรู้อยากเห็น","“ไม่ ไม่มีเลยขอรับ”","เกล็นส่ายหัว จากนั้นก็พูดอย่างลังเล","“ขอบคุณสำหรับการยอมรับของท่าน ปรมาจารย์ลินน์ แต่ข้าอยากจะรู้ว่าเกี่ยวกับอุปกรณ์แยกแสงและทฤษฎีแม่สีนี้ ท่านน่าจะรู้อยู่ก่อนแล้วใช่หรือไม่?”","ลินน์ลังเลอยู่ครู่หนึ่ง เขาไม่อยากทำลายความมั่นใจของเกล็นมากเกินไป แต่เขาก็รู้ดีว่าสิ่งที่เขาเพิ่งพูดไปนั้นมันเกินไปจริงๆ ดังนั้นเขาจึงอธิบายออกมาหลังจากที่ครุ่นคิดอยู่นาน","“เมื่อประมาณกว่าหนึ่งเดือนก่อน บังเอิญว่าข้าได้ทำการทดลองที่คล้ายคลึงกันตอนที่ยังอยู่ในอาณาจักร ดังนั้นข้าจึงมีความเข้าใจอยู่บ้าง”","เอล็อคและคนอื่นๆ ท่ามกลางผู้ชมต่างก็พยักหน้าอย่างพร้อมเพรียง พวกเขาต่างก็เห็นด้วยตาตัวเองว่าท่านศาสตราจารย์ลินน์ได้ใช้ปริซึมขนาดเล็กในการทำการทดลองแยกแสงแบบเดียวกันนี้เป๊ะๆ","“เป็นอย่างนี้นี่เอง...”","เกล็นดูผิดหวังเล็กน้อย","แม้ว่าลินน์จะพูดอย่างถ่อมตัวมาก แต่เขาก็เข้าใจได้โดยธรรมชาติว่าทฤษฎีทั้งสองนั้นได้รับการตรวจสอบโดยอีกฝ่ายล่วงหน้าไปแล้ว ในฐานะผู้คิดค้นแก้วขึ้นมา นี่จึงไม่ใช่เรื่องน่าแปลกใจเลย","“ในกรณีนี้ ข้าก็ไม่สามารถรับเหรียญตราจันทร์สีเงินนี้ได้ เกียรติยศนี้ควรจะเป็นของท่าน...”","เกล็นมีความรู้สึกลังเลอยู่บ้าง แต่ก็ยังคงกล่าวออกมาอย่างหนักแน่น","เขารู้ดีว่าในฐานะผู้ที่ได้รับเหรียญตราโคโรนา และเป็นดาวรุ่งแห่งวงการเวทมนตร์ที่เปล่งประกายที่สุดในดินแดนพ่อมด ลินน์อาจจะไม่ได้ใส่ใจกับการเสนอชื่อเข้ารับเหรียญตราจันทร์สีเงินเลย แต่เกล็นก็ไม่ต้องการการกุศลแบบนี้ มันจะเป็นความอัปยศมากกว่าที่จะเป็นเกียรติแก่สถาบันเวทมนตร์ของเขา...","ทันทีที่คำพูดเหล่านี้ถูกกล่าวออกมา พ่อมดแม่มดทุกคนที่อยู่ในเหตุการณ์ต่างก็ตกตะลึง และเพื่อนๆ ของเกล็นก็ถึงกับขยิบตาให้เขาบ่อยครั้ง เพื่อพยายามทำให้อีกฝ่ายถอนคำพูดเหล่านี้กลับไป","ต้องรู้ก่อนนะว่า นี่คือเหรียญตราจันทร์สีเงินเชียวนะ!","ในงานสัมมนาวิชาการเวทมนตร์ประจำปี โดยปกติแล้วจะมีเพียงแค่สามหรือห้าคนเท่านั้นที่สามารถคว้ารางวัลอันทรงเกียรตินี้ไปได้ ไม่เกินจริงเลยที่จะกล่าวว่าเมื่อมีเหรียญตรานี้ ไม่ว่าพวกเขาจะไปที่ไหน พวกเขาก็จะกลายเป็นจุดสนใจอย่างแน่นอน","แม้แต่อัจฉริยะในด้านการวิจัยทางวิชาการเหล่านั้น ก็อาจจะมีโอกาสได้รับการเสนอชื่อเพียงแค่ครั้งเดียวในชีวิต และหากพลาดไป พวกเขาก็อาจจะไม่ได้รับการเสนอชื่ออีกเลย!","บนโต๊ะของคณะกรรมการตัดสิน ราฟาเอลและคนอื่นๆ ต่างก็แสดงความชื่นชมออกมาทางสีหน้า แม้ว่าพวกเขาทุกคนจะเชื่อว่าเหรียญตราจันทร์สีเงินนั้นควรจะเป็นของปรมาจารย์ลินน์ แต่เมื่อพวกเขาเห็นเกล็นปฏิเสธมันอย่างเด็ดขาด พวกเขาก็ทั้งประหลาดใจและรู้สึกยินดีไปพร้อมๆ กัน","ซึ่งก็เคยมีเรื่องทำนองนี้เกิดขึ้นมาแล้วในอดีต ตัวอย่างเช่น ในงานสัมมนาเมื่อห้าปีก่อน บังเอิญมีสถาบันสามสถาบันที่กำลังทำการวิจัยเกี่ยวกับธาตุเดียวกัน และพวกเขาก็ล้วนแต่ได้รับผลลัพธ์การวิจัยที่ดี แต่ปัญหาเพียงอย่างเดียวก็คือ หลายทฤษฎีนั้นทับซ้อนกันมากเกินไป","แน่นอนว่าพวกเขาไม่สามารถมอบเหรียญตราจันทร์สีเงินให้กับทุกคนได้ เพียงเพื่อที่จะแย่งชิงการเสนอชื่อนี้ ทั้งสามสถาบันก็ได้ต่อสู้กันในพื้นที่ของงานสัมมนา ซึ่งก่อให้เกิดผลกระทบที่เลวร้ายอย่างยิ่ง","และทางเลือกของเกล็นก็ฉลาดกว่ามากอย่างไม่ต้องสงสัย หากเขาได้รับเหรียญตรานี้โดยขัดต่อมโนธรรมของตัวเองในครั้งนี้ เขาจะต้องดึงดูดเสียงวิพากษ์วิจารณ์อย่างแน่นอน","การปฏิเสธในตอนนี้กลับเป็นการเปิดกว้างวิสัยทัศน์แทน ราฟาเอลพอจะจินตนาการได้เลยว่าชื่อของเกล็นจะแพร่กระจายไปทั่วทั้งดินแดนพ่อมดพร้อมกับงานสัมมนาในครั้งนี้","ท้ายที่สุดแล้ว นี่ก็เป็นครั้งแรกที่มีคนปฏิเสธการเสนอชื่อเข้ารับเหรียญตราจันทร์สีเงิน!","ลินน์ที่นั่งอยู่บนที่นั่งของคณะกรรมการตัดสินเช่นกันก็รู้สึกพูดไม่ออกเล็กน้อย เขาไม่คาดคิดเลยว่าการชี้ให้เห็นถึงข้อบกพร่องในทฤษฎีของเกล็น จะทำให้อีกฝ่ายยอมล้มเลิกการเสนอชื่อโดยสมัครใจ","เห็นได้ชัดว่านี่เป็นครั้งแรกของข้าในการเป็นกรรมการตัดสิน และข้าก็ยังจับจังหวะได้ไม่ดีพอ...","ลินน์ทบทวนตัวเองอย่างเงียบๆ แน่นอนว่าเขารู้ทฤษฎีเหล่านี้มาตั้งนานแล้ว แต่ท้ายที่สุดแล้ว เขาก็แค่ยืนอยู่บนไหล่ของยักษ์ เมื่อเทียบกับเกล็นและคนอื่นๆ แล้ว พวกเขาต่างหากที่เป็นผู้บุกเบิกวิทยาศาสตร์เวทมนตร์ที่แท้จริง!","มันคงจะแย่มากหากไปทำลายความมั่นใจของคนเหล่านี้","เนื่องจากเขากังวลว่าจะไปทำร้ายความภาคภูมิใจในตัวเองของอีกฝ่าย ลินน์จึงไม่ได้ยืนกรานที่จะมอบรางวัลให้กับเกล็น แต่กลับกล่าวด้วยน้ำเสียงทุ้มลึก","“ทัศนศาสตร์เป็นวิชาที่ใหม่มาก แม้แต่สมาคมเวทมนตร์เร้นลับก็ยังไม่เข้าใจธรรมชาติของมันอย่างถ่องแท้ ดังนั้นพวกเราทุกคนจึงอยู่ในเส้นทางเดียวกัน ในเมื่อพวกเจ้าได้ทำการวิจัยเกี่ยวกับอุปกรณ์แยกแสงและแม่สีทั้งสามนี้แล้ว ทำไมไม่ลองค้นคว้าเรื่องนี้ต่อไปล่ะ?”","“นอกจากแสงที่มองเห็นได้ด้วยตาเปล่าอย่างเช่นแม่สีทั้งสามแล้ว มันยังมีแสงอีกมากมายหลายชนิดที่เรามองไม่เห็น ซึ่งมีหลากหลายประเภท แปลกประหลาด และคุ้มค่าที่จะสำรวจ...”","ลินน์พูดอย่างฉะฉาน เป็นการเตือนให้เกล็นนึกถึงทิศทางของการวิจัย","มันมีรังสีที่มองไม่เห็นอยู่มากมาย เช่น รังสีอินฟราเรด รังสีอัลตราไวโอเลต รังสีเอ็กซ์ หรือสิ่งที่เรียกว่า รังสีแอลฟา เบตา และแกมมา เป็นต้น ตราบใดที่มีการวิจัยเพียงแค่อย่างใดอย่างหนึ่งในรังสีเหล่านี้ การจะมอบเหรียญตราจันทร์สีเงินให้ก็ไม่ใช่เรื่องที่เกินจริงไปเลย","หากเกล็นสามารถศึกษาธรรมชาติของแสงด้วยเหตุนี้ได้ นับประสาอะไรกับเหรียญตราจันทร์สีเงินเล็กๆ แม้แต่เหรียญตราโคโรนา ซึ่งเป็นรางวัลทางวิชาการที่สูงที่สุดในดินแดนพ่อมด ก็ยังไม่เพียงพอที่จะยกย่องความสำเร็จของเขา!","เกล็นรับฟังคำอธิบายของลินน์อย่างจริงจัง เขาไม่เต็มใจที่จะรับเกียรติยศที่มาจากการให้ทาน แต่นั่นก็ไม่ได้หมายความว่าเขาต้องการที่จะปฏิเสธคำแนะนำของอีกฝ่าย งานวิจัยที่ยากลำบากทั้งหมดไม่ได้สูญเปล่าไปเสียทีเดียว","“ปรมาจารย์ลินน์ พวกเราไม่สามารถมองเห็นแสงเหล่านี้ได้ และไม่อาจรับรู้ได้ผ่านทางพลังจิตวิญญาณ แล้วพวกเราควรจะศึกษามันได้อย่างไรกัน?”","ในหอประชุม นักเล่นแร่แปรธาตุที่อยู่แถวหน้าจู่ๆ ก็เอ่ยถามขึ้นมา","ลินน์เตือนอย่างใจเย็น","“พวกเราสามารถวิเคราะห์ แยกแยะ และสรุปได้โดยการสังเกตคุณลักษณะของผลกระทบจากแสงเหล่านี้ที่มีต่อวัตถุ และหาวิธีสร้างอุปกรณ์เล่นแร่แปรธาตุที่ช่วยให้พวกเรามองเห็นและรับรู้ถึงพวกมันได้...”","“บางทีเวทแปรสภาพก็อาจจะเป็นทางเลือกที่ดีเช่นกัน!”","ซานเชซที่อยู่ด้านข้างก็เสนอแนะขึ้นมาเช่นกัน","ในฐานะปรมาจารย์แห่งเวทมนตร์สายแปรสภาพ โดยธรรมชาติแล้วซานเชซได้สังเกตเห็นว่าสิ่งมีชีวิตที่แตกต่างกันสามารถมองเห็นสีที่แตกต่างกันได้ ตัวอย่างเช่น โทรลล์ยักษ์ที่เขามักจะจำแลงกายนั้น เกิดมาพร้อมกับอาการตาบอดสี และมันก็มองเห็นสิ่งต่างๆ มากมายเป็นสีเทา สีขาว และสีดำ","เพียงแต่ว่าเขามักจะคิดมาตลอดว่าสมองของสิ่งมีชีวิตเหล่านี้ไม่สามารถแยกแยะสีได้ แต่ตอนนี้เขารู้แล้วว่ามันเป็นเพราะการขาดสิ่งที่เรียกว่าเซลล์รับแสง","“ถูกต้อง นั่นเป็นทิศทางที่ดีมาก!”","ลินน์พยักหน้าเห็นด้วย สิ่งมีชีวิตบางชนิดมีเซลล์รูปกรวยถึงสี่ชนิดในจอประสาทตา และพวกมันก็สามารถมองเห็นความถี่ของแสงได้มากกว่ามนุษย์มาก...","พลังของพ่อมดแม่มดนั้นอยู่ที่เวทมนตร์อันน่าอัศจรรย์ ซึ่งช่วยให้พวกเขาสามารถกลายร่างเป็นสิ่งมีชีวิตเหล่านี้และสังเกตพวกมันได้โดยตรง เมื่อเทียบกับการใช้เครื่องมือวิจัยทางวิทยาศาสตร์ต่างๆ เพื่อวัดค่าแล้ว นี่ก็ถือเป็นข้อได้เปรียบที่ไม่น้อยเลยทีเดียว!","เพียงแต่ในอดีต พวกเขาไม่ได้คิดไปในทิศทางนี้ ตอนที่ลินน์อ่านหนังสือเกี่ยวกับการแปรสภาพเมื่อไม่นานมานี้ มันมีระบุเอาไว้ว่า งูเกิดมาพร้อมกับเวทมนตร์การรับรู้ชนิดหนึ่ง ซึ่งสามารถสัมผัสถึงความร้อนได้ด้วยลิ้นของพวกมัน ซึ่งก็เป็นแค่รังสีอินฟราเรดเท่านั้น..."]},{"n":327,"t":"ค่าคงที่พื้นฐานของจักรวาล!","c":["มีการพูดคุยถกเถียงกันอย่างไม่ขาดสายในหอประชุม และพ่อมดแม่มดที่มีความเชี่ยวชาญในเวทมนตร์สายแปรสภาพก็รู้สึกตื่นเต้นเป็นพิเศษ เพราะลินน์และซานเชซนั้นได้ชี้ให้เห็นถึงทิศทางสำหรับการศึกษาด้านทัศนศาสตร์อย่างไม่ต้องสงสัย","ตราบใดที่สามารถใช้เวทแปรสภาพแปลงร่างเป็นสิ่งมีชีวิตบางชนิด ศึกษาความสามารถในการรับรู้แสงของพวกมัน หรือแม้แต่ชำแหละสิ่งที่เรียกว่าเซลล์รับแสง แล้วเขียนรายงานสรุปออกมา จะไม่ได้รับเหรียญตราดาวประกายพฤกษ์หรอกหรือ?","“ถ้ารู้เร็วกว่านี้ ข้าก็คงไปเรียนวิชาเวทสายแปรสภาพแล้ว!”","เอล็อคกล่าวพร้อมกับถอนหายใจ เขาถนัดวิชาธาตุและการเล่นแร่แปรธาตุมากกว่า ส่วนเวทมนตร์สายแปรสภาพก็แค่พอผ่านเกณฑ์เท่านั้น","น่าเสียดายที่เหรียญตราดาวประกายพฤกษ์ซึ่งควรจะได้มาง่ายที่สุด กำลังจะหลุดลอยไปจากข้าเสียแล้ว!","อย่างไรก็ตาม เพียร์ซซึ่งมีความเชี่ยวชาญในเวทมนตร์สายแปรสภาพก็รู้สึกเศร้าใจอย่างยิ่งเช่นกัน เพียงแค่มองไปรอบๆ ก็จะรู้ได้เลยว่ามีผู้คนมากมายที่กำลังแข่งขันกันเพื่อชิงเหรียญตรานี้ ภายในไม่กี่สัปดาห์ ทฤษฎีเวทมนตร์ที่เกี่ยวข้องก็จะหลั่งไหลเข้าไปเต็มสภาเวทมนตร์ และมันก็อาจจะไม่ถึงคิวของเขาก็เป็นได้","เกล็นและคนอื่นๆ บนแท่นสูงต่างก็มองหน้ากันด้วยความรู้สึกท้อแท้ พวกเขาไม่มีประสบการณ์ในเวทมนตร์สายแปรสภาพมากนัก และมันก็คงจะเป็นเรื่องยากที่จะตามความคืบหน้าของคนอื่นๆ ในการวิจัยเรื่องแสงที่มองไม่เห็นให้ทัน","ลินน์เองก็พิจารณาถึงความกระตือรือร้นที่มีต่อวิชาทัศนศาสตร์ของพ่อมดแม่มดที่ไม่ได้อยู่ในภาคเวทมนตร์สายแปรสภาพเหล่านี้ เขาหยุดไปครู่หนึ่งแล้วจึงกล่าวต่อ","“นอกจากการค้นหารังสีที่มองไม่เห็นเหล่านั้นแล้ว พวกท่านยังสามารถเริ่มต้นการวิจัยจากอีกแง่มุมหนึ่งได้... เช่น การวัดความเร็วของแสง!”","วัดความเร็วของแสงงั้นหรือ?","ราฟาเอลและคนอื่นๆ ต่างก็ผงะไปครู่หนึ่ง โดยธรรมชาติแล้ว มีผู้คนมากมายที่สนใจในสิ่งมหัศจรรย์ที่อยู่ทุกหนทุกแห่งอย่างแสง แต่พวกเขาไม่สามารถรับรู้ถึง ‘ธาตุแสง’ ได้ ดังนั้น มันจึงเป็นเรื่องยากที่จะสังเกตและทำการวัดค่ามัน","เมื่อสิบกว่าปีก่อน ประธานสภาออโรร่า ได้ทำการทดลองโดยให้พ่อมดคนหนึ่งอยู่ห่างจากนางไปหนึ่งกิโลเมตร จากนั้นก็ใช้เวทมนตร์เพื่อสะท้อนแสงไปยังอีกคนหนึ่ง และความเร็วของแสงก็ถูกวัดจากเวลาที่แสงเดินทางไปถึง","แต่สิ่งนี้มีความเร็วสูงมากจนแม้แต่ความเร็วในการตอบสนองของพ่อมดระดับตำนานก็ไม่สามารถตรวจจับความแตกต่างเพียงเล็กน้อยนี้ได้ ในท้ายที่สุด แม่มดระดับตำนานผู้นี้ก็ทำได้เพียงแค่คาดเดาว่าความเร็วของแสงอาจจะเกิน 1,000 กิโลเมตรต่อวินาที และจำเป็นต้องทำการวัดจากระยะทางที่ไกลกว่านี้","แต่นี่ก็ก่อให้เกิดปัญหาที่สองตามมา นั่นก็คือแสงจะเกิดการกระเจิง และหากระยะทางไกลเกินไป แสงที่ส่งออกไปก็จะอ่อนลงเรื่อยๆ ทำให้ไม่สามารถวัดค่าได้แม่นยำยิ่งขึ้น...จนถึงขั้นมีบางคนสงสัยว่าแสงนั้นคงสามารถเดินทางไปถึงเป้าหมายได้ในพริบตา!","อย่างไรก็ตาม การทดลองนี้กลับได้รับผลพลอยได้ที่ไม่คาดคิด นั่นก็คือมันประสบความสำเร็จในการวัดความเร็วในการแพร่กระจายของเสียงว่าอยู่ระหว่าง 300 ถึง 400 เมตรต่อวินาที และมันก็จะผันผวนไปตามพื้นที่ที่แตกต่างกัน...","ซานเชซอธิบายให้ลินน์ฟังอย่างละเอียดเกี่ยวกับการทดลองวัดความเร็วแสงที่ประธานสภาออโรร่าเคยทำไว้","หนึ่งกิโลเมตร?","มันใกล้เกินไปจริงๆ และก็ยังขาดอุปกรณ์ที่เป็นมืออาชีพมากกว่านี้ ดังนั้น มันจึงเป็นเรื่องปกติที่จะล้มเหลว...","ลินน์เองก็ยังไม่รู้ความเร็วของแสงที่แน่นอนในโลกใบนี้...แต่มันต้องไม่ช้าเกินไปอย่างแน่นอน ตามข้อมูลจากชาติที่แล้วของเขา ระยะทางหนึ่งกิโลเมตรนั้นใช้เวลาเพียงแค่เศษหนึ่งส่วนแสนของวินาที ต่อให้จะเป็นพ่อมดระดับตำนาน ก็ไม่สามารถวัดค่ามันโดยอาศัยเพียงแค่ความเร็วในการตอบสนองได้","ลินน์ครุ่นคิดอยู่ครู่หนึ่ง แล้วจึงมองไปที่พ่อมดแม่มดในงานสัมมนา","“ข้ามีแนวคิดบางอย่างเกี่ยวกับการวัดความเร็วของแสงแล้ว แต่ข้ายังไม่ได้ตรวจสอบความถูกต้องของมัน มันต้องใช้เวลาเตรียมการสักสองสามวัน น่าจะเป็นหลังจากที่งานสัมมนาจบลง และก็ไม่อาจตัดความเป็นไปได้ที่จะล้มเหลวออกไปได้ ในช่วงเวลานี้ หากใครสามารถวัดความเร็วของแสงได้อย่างแม่นยำแล้วล่ะก็ ข้าก็จะเสนอให้สภาเวทมนตร์มอบเหรียญตราจันทร์สีเงินให้แก่เขา!”","“เหรียญตราจันทร์สีเงินงั้นหรือ? ปรมาจารย์ลินน์ นี่มันไม่พูดเกินจริงไปหน่อยหรือ?”","ซานเชซรีบพูดแทรกขึ้นมา","เพราะเงื่อนไขในการมอบเหรียญตราจันทร์สีเงินนั้นมีอยู่สองข้อ ข้อแรกคือต้องเสนอทฤษฎีที่สามารถเปลี่ยนแปลงระบบเวทมนตร์กระแสหลักบางอย่างได้","และในงานสัมมนาครั้งก่อน ตอนที่ลินน์เสนอทฤษฎีกฎแรงโน้มถ่วงสากล พวกเขาก็วางแผนที่จะมอบเหรียญตราจันทร์สีเงินให้กับเขา","เพียงแต่ ประธานสภาอย่างแฮร์รอฟสามารถโต้แย้งทุกความคิดเห็นได้ นอกจากนี้ ลินน์ยังได้คำนวณความเร็วของดาวเคราะห์ที่อยู่ใต้เท้าของเขา และใช้การทดลองเพื่อพิสูจน์ว่าดาวเคราะห์ดวงนี้หมุนและโคจรรอบดวงอาทิตย์อยู่ตลอดเวลา ซึ่งเป็นการลบล้างโลกทัศน์ของทุกคน ด้วยเหตุนี้ เขาจึงได้รับเหรียญตราโคโรนาอันทรงเกียรติมากยิ่งกว่ามาครอบครอง!","ข้อที่สองคือต้องสร้างคุณูปการอันใหญ่หลวงต่อดินแดนพ่อมดหรือสภาเวทมนตร์","แต่ตอนนี้มันเป็นเพียงแค่การวัดความเร็วของแสง ไม่ใช่การวิเคราะห์ถึงธรรมชาติของแสง เขาคิดว่าเหรียญตราดาวประกายพฤกษ์ก็เพียงพอแล้ว...","“ข้าไม่คิดว่ามันเป็นเรื่องเกินจริงเลย พ่อมดระดับตำนานในสมาคมเวทมนตร์เร้นลับ เคยกล่าวไว้ว่า เมื่อเทียบกับทัศนศาสตร์แล้ว ทฤษฎีเวทมนตร์ที่มีอยู่ในปัจจุบันนั้นเรียกได้ว่าเรียบง่ายหรือแม้กระทั่งหยาบ มันเป็นเพียงแค่การขยายความของปรากฏการณ์ในระดับมหภาคเท่านั้น ซึ่งทัศนศาสตร์นั้น เป็นหนึ่งในกุญแจสำคัญที่สุดในการเปิดเผยโลกแห่งความเป็นจริงในระดับจุลภาค!”","ลินน์กล่าวอย่างหนักแน่น","ความเร็วของแสงนั้นแตกต่างจากความเร็วของเสียง แรงต้านของอากาศ และแรงโน้มถ่วง ซึ่งจะเปลี่ยนแปลงไปเมื่อเปลี่ยนดาวเคราะห์","มันมีธรรมชาติแบบเดียวกับค่าคงที่แรงโน้มถ่วงที่ลินน์เคยวัดไว้ก่อนหน้านี้ เช่นเดียวกับศูนย์สัมบูรณ์ที่ยังไม่เคยวัด ค่าคงที่ฮับเบิล ค่าคงที่พลังค์ และอื่นๆ...","ค่าเหล่านี้ไม่ได้จำกัดอยู่เพียงแค่ดาวเคราะห์ดวงเดียว แต่มันเป็นกฎของวัตถุที่ผ่านไปทั่วทั้งจักรวาล...อย่างน้อยภายในขอบเขตการมองเห็นและการรับรู้ของมนุษย์ พวกมันก็ไม่มีวันเปลี่ยนแปลง!","และความเร็วของแสงก็มีความสำคัญเป็นพิเศษ และสูตรที่มีชื่อเสียงมากมายนั้นยังไม่อาจแยกออกจากค่าคงที่นี้เลย!","ตัวอย่างหนึ่งก็คือสมการมวล-พลังงานอันโด่งดัง E=mc^2!","E ทางด้านซ้ายหมายถึงพลังงาน m ทางด้านขวาหมายถึงมวล และ c คือความเร็วของแสง สูตรนี้มีความลึกลับของการแปลงสภาพระหว่างมวลและพลังงานซ่อนอยู่ ไม่ว่าจะเป็นการระเบิดของนิวเคลียร์หรือการทำลายล้างของปฏิสสารที่ทรงพลังยิ่งกว่า คุณก็สามารถใช้สูตรนี้ในการคำนวณมันได้!","แน่นอนว่า ยังคงมีเครื่องหมายคำถามว่าทฤษฎีความเร็วแสงคงที่นั้นเป็นเรื่องธรรมดาในโลกใบนี้หรือไม่ และสิ่งเหล่านี้ล้วนจำเป็นต้องได้รับการตรวจสอบโดยการทดลอง","ลินน์ต้องการที่จะคำนวณค่าคงที่พื้นฐานเหล่านี้มาโดยตลอด แต่ก่อนหน้านี้เขาทุ่มเทพลังงานส่วนใหญ่ไปกับสงครามในอาณาจักร ดังนั้นเขาจึงผัดวันประกันพรุ่งมาเรื่อยๆ","อาจกล่าวได้ว่า การเริ่มต้นจากการศึกษาด้านทัศนศาสตร์ได้ทำให้พวกเขาเปิดมุมมองหนึ่งของโลกแห่งความเป็นจริง จากสาขาในระดับมหภาคที่มีระเบียบแบบแผน ไปสู่สาขาในระดับจุลภาคที่วุ่นวายและแปลกประหลาด","แม้แต่สหพันธ์ในชาติที่แล้ว ก็ยังล้มเหลวในการศึกษาทฤษฎีควอนตัมอย่างถ่องแท้ แต่แม้เพียงความสำเร็จเล็กๆ น้อยๆ ก็เพียงพอที่จะบรรลุความสำเร็จอันยิ่งใหญ่อย่างเช่นการเดินทางข้ามดวงดาวได้แล้ว...","คำพูดที่ตรงไปตรงมาจนเกินไปของลินน์ ทำให้พ่อมดแม่มดที่อยู่ในเหตุการณ์รู้สึกยอมรับไม่ได้อยู่บ้าง ดินแดนพ่อมดได้พัฒนาเวทมนตร์มาเป็นเวลานับหลายร้อยปี แต่มันกลับถูกอีกฝ่ายอธิบายว่าเรียบง่ายและหยาบกระด้าง มันดูจะเป็นเรื่องที่น่าตื่นตระหนกไปสักหน่อย!","“ท่านระดับตำนานแห่งสมาคมเวทมนตร์เร้นลับผู้นี้ คงจะต้องเสียสติไปแล้วแน่ๆ ตอนที่เขากำลังศึกษาเรื่องแสง?”","จอมเวทผู้ยิ่งใหญ่คนหนึ่งในกลุ่มผู้ชมเย้ยหยันและกล่าวขึ้น เขารู้สึกไม่พอใจเป็นอย่างมากกับคำพูดของลินน์ที่ดูถูกทฤษฎีเวทมนตร์ที่มีอยู่ในปัจจุบัน แม้ธาตุแสงนั้นจะมีความมหัศจรรย์อย่างแน่นอน แต่อย่างดีที่สุด มันก็เป็นเพียงแค่อิฐก้อนหนึ่งที่ประกอบขึ้นเป็นสิ่งก่อสร้างทางเวทมนตร์เท่านั้น...","หลังจากผ่านการพัฒนาและปรับปรุงมาหลายทศวรรษ ทฤษฎีธาตุแสงในดินแดนพ่อมดก็ได้สร้างกรอบการทำงานทั่วไปขึ้นมาแล้ว เพียงแต่มันยังไม่ผ่านการตรวจสอบขั้นสุดท้ายก็เท่านั้น"]},{"n":328,"t":"แผนการใหญ่กระจกพันบานเพื่อวัดความเร็วแสง!","c":["ลินน์ได้ยินการพูดคุยถกเถียงและข้อสงสัยของทุกคน แต่เขาไม่ได้รีบร้อนที่จะโต้แย้ง ท้ายที่สุดแล้ว การทดลองก็ทรงพลังยิ่งกว่าคำพูด!","เมื่อเห็นว่าบรรยากาศในลานเริ่มตึงเครียด ราฟาเอลจึงรีบเอ่ยปากเพื่อคลี่คลายสถานการณ์","“เกี่ยวกับหัวข้อวิธีการวัดความเร็วของแสงและทฤษฎีธาตุแสง เอาไว้พวกเราค่อยไปหารือกันเป็นการส่วนตัวหลังจากที่งานสัมมนาในวันนี้สิ้นสุดลงก็แล้วกัน เวลาของเรามีจำกัด และตอนนี้เราจะเข้าสู่รายการต่อไป...”","เกล็นและคนอื่นๆ โค้งคำนับและเดินออกจากสนามไปพร้อมกับอุปกรณ์แยกแสง ประมาณสองนาทีต่อมา พ่อมดอีกคนก็เดินขึ้นมาบนเวทีเพื่อแสดงผลการวิจัยของเขาให้ทุกคนได้เห็น ซึ่งก็คือซากของไฮดราและรายงานการวิจัยที่เกี่ยวข้อง!","สิ่งนี้มีค่ามากอย่างไม่ต้องสงสัย เพราะจำนวนของไฮดราในดินแดนพ่อมดนั้นมีอยู่น้อยมาก ดังนั้นจึงไม่มีรายงานการชำแหละสัตว์ประหลาดชนิดนี้อย่างละเอียดมาก่อน","หากพ่อมดสายแปรสภาพต้องการที่จะแปลงร่างเป็นสิ่งมีชีวิตชนิดใดชนิดหนึ่งอย่างสมบูรณ์ ขั้นตอนแรกก็คือการทำความเข้าใจโครงสร้างของสิ่งมีชีวิตชนิดนั้นอย่างถ่องแท้ การแปลงร่างเป็นสิ่งมีชีวิตเวทมนตร์นั้นยากยิ่งกว่า เมื่อพูดถึงเซลล์เวทมนตร์ แม้แต่พ่อมดทางการก็สามารถเลือกสิ่งมีชีวิตเวทมนตร์เพื่อแปลงร่างได้เพียงชนิดเดียวเท่านั้น","“ดีมาก แต่งานวิจัยของเจ้าพลาดสิ่งสำคัญไปอย่างหนึ่ง นั่นก็คือไฮดรามีหลายหัว ทันทีที่พ่อมดเลือกที่จะใช้เวทแปรสภาพกับสิ่งมีชีวิตชนิดนี้ เขาจะต้องเผชิญกับความเสี่ยงที่ไม่รู้จัก มันอาจจะทำให้วิญญาณถูกแบ่งแยกออกไป...”","ซานเชซกล่าวด้วยน้ำเสียงหนักแน่นขณะมองดูรายงานในมือของเขา","อย่างไรก็ตาม แม้ว่ามันจะมีความเสี่ยง แต่นี่ก็เป็นลักษณะพิเศษของไฮดราเช่นกัน ความสามารถในการงอกใหม่ของสิ่งนี้นั้นน่าเหลือเชื่อเป็นอย่างมาก แม้ว่าหัวของมันจะถูกตัดขาด แต่มันก็สามารถงอกหัวใหม่ขึ้นมาได้ ประสิทธิภาพในการต่อสู้นั้นน่าประทับใจมาก พ่อมดสายแปรสภาพจะมีตัวเลือกในการแปลงร่างเป็นสิ่งมีชีวิตเวทมนตร์เพิ่มขึ้นมาอีกหนึ่งอย่าง","เมื่อคิดได้เช่นนี้ ซานเชซจึงขอให้เขาทำการวิจัยเชิงลึกต่อไป หากเขาสามารถแก้ไขความเสี่ยงในการแปรสภาพ หรือไขความลับของการงอกใหม่แบบไร้ขีดจำกัดของไฮดราได้ เขาก็จะเสนอชื่อให้อีกฝ่ายได้รับเหรียญตราดาวประกายพฤกษ์อย่างแน่นอน...","พ่อมดที่ได้รับการยอมรับจากซานเชซดูมีความสุขมาก และเขาก็รีบมองไปที่จอมเวทผู้ยิ่งใหญ่คนอื่นๆ","ความเข้าใจในวิชาแปรสภาพของลินน์ยังอยู่ในช่วงเริ่มต้น และมันก็ไม่อาจเทียบได้กับปรมาจารย์ด้านการแปรสภาพอย่างซานเชซ เขาทำได้เพียงแค่ให้คำแนะนำเกี่ยวกับการชำแหละและการเก็บรักษาซากศพในมุมมองทางชีววิทยาเท่านั้น","กรรมการตัดสินที่เหลือก็พูดเสริมขึ้นมาเช่นกัน ราฟาเอลไม่เห็นด้วยอย่างยิ่งกับการพัฒนาเวทแปรสภาพของไฮดรา ท้ายที่สุดแล้ว การแบ่งจิตสำนึกออกเป็นหลายหัวนั้นก็เป็นเรื่องที่น่าขนลุกเมื่อคิดถึงมัน และมันก็อาจจะทำให้เกิดความเสียหายทางจิตวิญญาณที่ไม่อาจซ่อมแซมได้","แต่โดยทั่วไปแล้ว มีหลายคนที่เห็นด้วยกับการตัดสินใจของซานเชซ หากเขาสามารถศึกษาต่อไปและได้ผลลัพธ์ที่เข้มงวดมากยิ่งขึ้น พวกเขาก็จะไม่ลังเลที่จะเสนอชื่อเขาต่อสภาเวทมนตร์","“ดูเหมือนว่าจะมีผู้ที่ได้รับเหรียญตราดาวประกายพฤกษ์หลายคนในงานสัมมนาวิชาการวันนี้...”","ราฟาเอลกล่าวด้วยความรู้สึกทึ่งขณะมองดูพ่อมดเดินลงจากแท่น","เขาไม่ได้เห็นเหตุการณ์ที่ยิ่งใหญ่เช่นนี้มานานหลายทศวรรษแล้ว ดูเหมือนว่าการที่ลินน์ได้รับเกียรติยศสูงสุดในแวดวงวิชาการเมื่อปีที่แล้ว จะเป็นแรงบันดาลใจให้เกิดกระแสการวิจัยขึ้นในหมู่พ่อมดแม่มด","อย่างไรก็ตาม ราฟาเอลได้ปักธงเอาไว้อย่างไม่ต้องสงสัย หลังจากที่เขาพูดจบ ก็ไม่มีทฤษฎีใหม่หรือสิ่งประดิษฐ์ใหม่ใดๆ ที่ดึงดูดสายตาของพวกเขาได้เลยตลอดทั้งช่วงบ่าย","ลินน์เองก็รู้สึกผิดหวังมากเช่นกัน พ่อมดคนหนึ่งเดินขึ้นมาและบอกว่าเขาได้ค้นพบความลึกลับของธาตุ ซึ่งเพียงพอที่จะล้มล้างระบบธาตุที่มีอยู่","ด้วยบทเรียนจากเกล็น ลินน์จึงไม่ได้โต้แย้งอย่างตรงไปตรงมา แต่เขากลับเลือกที่จะชี้ให้เห็นถึงช่องโหว่ในทฤษฎีอย่างแนบเนียนที่สุดเท่าที่จะทำได้ และยกย่องจิตวิญญาณของอีกฝ่ายที่กล้าตั้งคำถามต่อผู้มีอำนาจ","จนกระทั่งถึงช่วงเย็น งานสัมมนาก็ได้สิ้นสุดลง และพ่อมดแม่มดเกือบทุกคนที่เดินออกมาจากหอประชุมก็กำลังพูดคุยกันถึงการทดลองวัดความเร็วแสงที่ลินน์พูดถึง","ช่วยไม่ได้ เหรียญตราจันทร์สีเงินนั้นดึงดูดใจเป็นอย่างมาก ถึงแม้ว่าจอมเวทผู้ยิ่งใหญ่หลายคนอาจจะไม่สามารถได้รับเกียรติยศเช่นนี้ก็ตาม!","บางคนถึงกับคิดไปในทางร้ายว่า หรือปรมาจารย์ลินน์จะต้องการครอบครองเหรียญตราจันทร์สีเงินอีกเหรียญให้กับตัวเองกันแน่ นั่นเป็นเหตุผลที่เขาจงใจทำให้ทัศนศาสตร์มีความสำคัญมากขนาดนี้","เพียงแต่ว่าการคาดเดาเช่นนั้นเห็นได้ชัดว่าไม่มีน้ำหนักเลย เพราะในงานสัมมนาวันนี้ ปรมาจารย์ลินน์ได้ค้นคว้าทฤษฎีแม่สีทั้งสามสำเร็จไปแล้ว แต่เขาก็ยังคงเต็มใจที่จะเสนอชื่อเกล็น... หากเขาเป็นคนที่ให้ความสำคัญกับเกียรติยศอย่างมากแล้วล่ะก็ มันเป็นไปไม่ได้เลยที่เขาจะยอมยกสิ่งที่คู่ควรกับเหรียญตราดาวประกายพฤกษ์ให้คนอื่นไปง่ายๆ","“เกล็น เจ้าคิดออกหรือยังว่าจะวัดความเร็วของแสงได้อย่างไร?”","ที่ด้านนอกประตู แม่มดหน้าตาจิ้มลิ้มคนหนึ่งมองไปที่เกล็นและกล่าวด้วยใบหน้าเศร้าหมอง พร้อมกับน้ำเสียงที่แฝงไปด้วยความไม่พอใจเล็กน้อย","“เมื่อครู่นี้เจ้าไม่ควรปฏิเสธความหวังดีของปรมาจารย์ลินน์เลยนะ นั่นมันเป็นสิ่งที่เจ้าใช้เวลาค้นคว้ามาหลายเดือนเชียวนะ”","เกล็นกล่าวอย่างจนใจ","“แนนซี่ ทุกคนที่อยู่ในงานเมื่อครู่นี้ก็เห็นว่าปรมาจารย์ลินน์ได้ค้นพบทฤษฎีเหล่านี้มาตั้งนานแล้ว ข้าไม่ได้เป็นผู้คิดค้นเลยแม้แต่น้อย หากข้าได้รับเหรียญตราดาวประกายพฤกษ์เพราะเรื่องนี้ ข้าเกรงว่าข้าคงจะถูกวิพากษ์วิจารณ์อย่างหนักแน่”","“มันก็แค่พวกขี้อิจฉาบางคนพูดจาไร้สาระเท่านั้นแหละ การได้รับเหรียญตราดาวประกายพฤกษ์ต่างหากที่สำคัญ...”","แม่มดที่ชื่อแนนซี่เบ้ปาก นางยังคงรู้สึกไม่พอใจอยู่บ้าง","เกล็นส่ายหัว เขาไม่ได้โต้เถียงต่อไป แต่เปลี่ยนเรื่องและปั้นหน้าขรึมก่อนจะพูดขึ้น","“ส่วนเรื่องวิธีวัดความเร็วของแสง... ข้าคิดว่าเราสามารถทำตามวิธีของท่านออโรร่าได้”","“แต่การทดลองของท่านประธานสภามันล้มเหลวไม่ใช่หรือ?”","แนนซี่ถามด้วยความสงสัย","“นั่นเป็นเพราะระยะทางมันยังไม่ไกลพอต่างหาก!”","เกล็นกล่าวอย่างหนักแน่น","“ตราบใดที่เพิ่มระยะทางขึ้นสิบเท่า หรือแม้แต่ร้อยเท่า มันก็จะใช้ได้อย่างแน่นอน นี่เป็นวิธีที่โง่เขลาที่สุดและรวดเร็วที่สุด!”","ร้อยเท่า... นั่นหมายความว่าต้องอยู่ห่างออกไปอย่างน้อยหนึ่งร้อยกิโลเมตร แล้วยังจะมองเห็นแสงได้อยู่อีกหรือ?","แนนซี่พึมพำกับตัวเอง","เกล็นรีบอธิบายแนวคิดของเขา ก่อนหน้านี้เขาได้ใช้หลักการขยายและย่อส่วนของกระจกเว้า-นูน เพื่อพัฒนาเวทมนตร์เล็กๆ ในการรวมแสง ซึ่งมันสามารถรวบรวมแสงให้กลายเป็นแสงจ้าที่เจิดจ้ามากยิ่งขึ้นได้","ด้วยวิธีนี้ แม้ว่าแสงจะกระเจิงเมื่อเดินทางเป็นระยะทางไกล มันก็น่าจะสามารถรักษาความเข้มของแสงที่สามารถมองเห็นได้ด้วยตาเปล่าเอาไว้ได้","ส่วนวิธีที่จะทำให้ได้ระยะทาง 100 กิโลเมตรนั้น แนวคิดของเขาก็คือการปล่อยให้แสงสะท้อนไปมาอย่างไม่หยุดหย่อน!","กระจกหนึ่งบานห่างกัน 100 เมตร กระจกสิบบานคือหนึ่งกิโลเมตร กระจกร้อยบานคือสิบกิโลเมตร และกระจกหนึ่งพันบานก็คือหนึ่งร้อยกิโลเมตร!","ตามที่ท่านออโรร่าคาดเดาเอาไว้ ความเร็วของแสงคือ 1,000 กิโลเมตรต่อวินาที และมันก็ใช้เวลา 0.1 วินาทีในการเดินทางตลอดระยะทาง ด้วยความเร็วในการตอบสนองของพ่อมด ความแม่นยำระดับนี้ก็พอจะตัดสินได้อย่างเฉียดฉิว...","“กระจกหนึ่งพันบาน”","แนนซี่เดาะลิ้น นางชื่นชมเกล็นที่คิดแผนการอันยิ่งใหญ่เช่นนี้ได้ แต่แล้วนางก็ลังเลอีกครั้ง","“ของแบบนี้มันไม่ถูกเลยนะ...”","กระจกบานหนึ่งมีราคาตั้งหลายเหรียญทองเวทมนตร์ พวกเขาไม่สามารถจ่ายเงินจนหมดตัวเพื่อซื้อมันมาได้หรอก!","“ดังนั้นเราก็ทำได้แค่ยืมมาเท่านั้นแหละ!”","เกล็นยักไหล่ เพื่อให้การทดลองของเขาดำเนินไปอย่างราบรื่น เขาทำได้เพียงแค่ต้องบากหน้าไปขอยืมมา"]},{"n":329,"t":"ดูเหมือนว่าปรมาจารย์ลินน์จะคำนวณพลาดเสียแล้วในครั้งนี้!","c":["ในขณะที่พ่อมดแม่มดแห่งนครกรีนรีลกำลังศึกษาวิธีการวัดความเร็วของแสง การสนทนาหนึ่งก็กำลังดำเนินอยู่ในคฤหาสน์ของประธานสภาระดับตำนานอย่างแฮร์รอฟเช่นกัน","“ทฤษฎีเวทมนตร์ที่มีอยู่ในดินแดนพ่อมดนั้นหยาบกระด้างมาก... เขาพูดแบบนั้นจริงๆ งั้นหรือ?”","หลังจากที่ได้ฟังคำบอกเล่าของออโรร่า แฮร์รอฟก็ขมวดคิ้วอย่างอดไม่ได้ คำพูดของลินน์นั้นถือเป็นการยั่วยุต่อดินแดนพ่อมดทั้งหมดอย่างไม่ต้องสงสัย","และมันยังเป็นการไม่เคารพอย่างยิ่งต่อเหล่าผู้บุกเบิกที่ทำงานอย่างหนักเพื่อพัฒนาและศึกษาเวทมนตร์ แม้ว่าพวกเขาจะมีความรู้ที่ไม่ธรรมดา แต่พวกเขาก็ไม่ควรจะเย่อหยิ่งถึงเพียงนี้","“ไม่ ข้าไม่คิดว่าเขาหมายถึงแค่ดินแดนพ่อมดหรอก ทฤษฎีเวทมนตร์ที่ได้รับการวิจัยโดย [สมาคมเวทมนตร์เร้นลับ] เองก็ไม่มีข้อยกเว้นเช่นกัน พวกมันทั้งหมดล้วนดูหยาบกระด้างอย่างยิ่งเมื่ออยู่ต่อหน้าทัศนศาสตร์...”","ออโรร่าอธิบาย และในขณะเดียวกันนางก็นึกย้อนไปถึงสิ่งที่ลินน์พูดในงานสัมมนา","ทัศนศาสตร์เป็นกุญแจสำคัญที่สุดในการเปิดเผยโลกแห่งความเป็นจริงในระดับจุลภาค...","โลกแห่งความเป็นจริงที่ว่านี้ หมายถึงอะไรกันแน่?","หรือว่าโลกที่พวกเขามองเห็นอยู่ในตอนนี้ จะเป็นสิ่งจอมปลอมงั้นหรือ?","ออโรร่าครุ่นคิดด้วยความสับสน นางไม่อาจเข้าใจความหมายของคำพูดเหล่านี้ได้อย่างถ่องแท้","แฮร์รอฟเองก็จมอยู่ในห้วงความคิดเช่นกัน จากการติดต่อกันก่อนหน้านี้และทฤษฎีแปลกใหม่ต่างๆ ที่ลินน์เสนอขึ้นมา ทำให้เห็นได้ชัดว่า [สมาคมเวทมนตร์เร้นลับ] มีความเข้าใจเกี่ยวกับเวทมนตร์และโลกใบนี้ลึกซึ้งยิ่งกว่าพวกเขามาก","หากคำพูดเหล่านี้ไม่ได้เป็นการจงใจเยาะเย้ยหรือความเย่อหยิ่ง มันก็คุ้มค่าที่จะสำรวจว่าแสงที่อยู่ทุกหนทุกแห่งนั้นมีความลับแบบใดซ่อนอยู่ ถึงได้คู่ควรกับการประเมินเช่นนี้...","แฮร์รอฟอยากจะเข้าร่วมการชุมนุมของพ่อมดระดับตำนานอีกครั้งและเอ่ยปากถามด้วยตัวเอง แต่น่าเสียดายที่จนถึงตอนนี้เขาก็ยังไม่ได้รับคำเชิญอีกเลย","แม้ว่าแฮร์รอฟ ซึ่งเป็นเจ้าของ [แหวนแห่งเวทลับ] จะมีสิทธิ์ในการจัดการชุมนุมของคนอื่นๆ ด้วยเช่นกัน แต่ดูเหมือนว่าเขาจะกระตือรือร้นมากเกินไป สิ่งสำคัญที่สุดก็คือเขายังไม่สามารถทำความเข้าใจทฤษฎีบิ๊กแบงได้ และเขาก็ยังไม่สามารถค้นคว้าทฤษฎีแปลกใหม่เพื่อให้กลุ่มตำนานได้สำรวจออกมาได้เลย","เมื่อคิดถึงเรื่องนี้ แฮร์รอฟก็พอจะเข้าใจเลือนรางว่าทำไมการชุมนุมของพ่อมดระดับตำนานจึงยังไม่ถูกจัดขึ้น มันเป็นเรื่องปกติที่การวิจัยเวทมนตร์จะต้องใช้เวลาเจ็ดหรือแปดปี หรือแม้แต่สิบปีจึงจะเกิดผลลัพธ์ งานสัมมนาวิชาการปีละครั้งของดินแดนพ่อมดก็นับว่าจัดขึ้นบ่อยมากแล้ว","“ดูเหมือนว่าพวกเราจะต้องให้ความสนใจกับการศึกษาด้านทัศนศาสตร์ให้มากขึ้นเสียแล้ว”","สีหน้าของแฮร์รอฟกลายเป็นเคร่งขรึมอย่างยิ่ง จากนั้นเขาก็มองไปที่ออโรร่าและเอ่ยถามด้วยความอยากรู้อยากเห็น","“เจ้าสามารถวัดความเร็วของแสงได้หรือไม่?”","ออโรร่าคือผู้ที่มีความเข้าใจด้านทัศนศาสตร์ลึกซึ้งที่สุดในหมู่พวกเขา หากนางไม่สามารถทำได้ ดินแดนพ่อมดทั้งหมดก็อาจจะไม่สามารถวัดความเร็วของแสงได้เช่นกัน","“ข้าคิดว่าเราสามารถเริ่มต้นที่ดาราศาสตร์ได้!”","ออโรร่ากล่าวด้วยน้ำเสียงทุ้มลึก","สิ่งที่ยากที่สุดในการวัดความเร็วแสงคืออะไร? แน่นอนว่าความเร็วของแสงนั้นรวดเร็วจนน่าเหลือเชื่อ และพวกเขาก็ไม่สามารถหาสถานที่ที่ใหญ่พอสำหรับการทดลองได้ อีกทั้งยังเป็นเรื่องยากที่จะสร้างแสงที่สว่างมากพอให้ครอบคลุมระยะทางหลายพันกิโลเมตร","และเมื่อพูดถึงระยะทางอันกว้างใหญ่ไพศาล แน่นอนว่ามันย่อมต้องเป็นท้องฟ้าที่เต็มไปด้วยดวงดาวในจักรวาล!","ตามข้อมูลที่พวกเขาคำนวณเมื่อปีที่แล้ว เส้นผ่านศูนย์กลางของดาวเคราะห์ทั้งดวงนั้นมีขนาดหลายหมื่นกิโลเมตร และระยะห่างระหว่างดาวเคราะห์ก็ยิ่งไกลออกไปอีก สิ่งสำคัญที่สุดก็คือดวงอาทิตย์ที่อยู่เหนือหัวของพวกเขานั้นเป็นวัตถุเรืองแสงที่มีขนาดใหญ่มาก ตราบใดที่รู้ระยะห่างระหว่างทั้งสองฝ่าย จะไม่สามารถวัดความเร็วของแสงได้หรอกหรือ?","“วิธีนี้ดีมาก!”","แฮร์รอฟกล่าวด้วยความชื่นชม แต่ไม่นานเขาก็หยุดชะงักไปราวกับคิดอะไรบางอย่างขึ้นมาได้","“ไม่ ไม่สิ วินาทีที่เรามองเห็นดวงอาทิตย์ แสงก็เดินทางมาถึงแล้ว และมันก็ไม่มีวิธีใดที่จะวัดความเร็วของแสงได้เลย”","ตามที่ลินน์กล่าว ทุกสิ่งที่พวกเขามองเห็นนั้นคือการสะท้อนของแสง ก่อนที่แสงจะเดินทางมาถึงพวกเขา พวกเขาก็ไม่สามารถมองเห็นดวงอาทิตย์ได้เลย แล้วจะใช้มันเป็นจุดอ้างอิงได้อย่างไร?","ออโรร่าก็ขมวดคิ้วเช่นกัน นางไม่เคยพิจารณาเรื่องนี้มาก่อน แต่หลังจากผ่านไปเพียงไม่กี่วินาที นางก็ยิ้มออกมาอีกครั้ง","“ถ้าอย่างนั้นก็สามารถลองใช้ดวงดาวดวงอื่นที่อยู่ไกลออกไปได้!”","“ตัวอย่างเช่น ดาวบริวารของดาวไทร์จะหายไปเป็นครั้งคราว สันนิษฐานว่ามันหมุนไปอยู่ด้านหลังของดาวไทร์ และถูกบดบังจากแสงของดวงอาทิตย์ ดังนั้นเราจึงมองไม่เห็นมัน...","วัฏจักรการหมุนของดาวเคราะห์ควรจะมีเสถียรภาพและเป็นไปอย่างสม่ำเสมอ แต่มันกลับไม่เป็นเช่นนั้น ตามการสังเกตของข้า เวลาที่ดาวบริวารหายไปนั้นไม่สม่ำเสมอเลยในหนึ่งปี และในแต่ละเดือนก็ยังมีความเร็วช้าที่แตกต่างกันไป...”","ปรากฏการณ์ทางดาราศาสตร์ที่แปลกประหลาดนี้เคยทำให้นางงุนงง แต่ตอนนี้นางมีคำตอบแล้ว!","เป็นเพราะในเวลาหนึ่งปี ดาวไทร์จะอยู่ในระยะห่างที่แตกต่างกันจากพวกเขาในวงโคจรของดวงอาทิตย์ แสงของดวงอาทิตย์ต้องใช้เวลาในการเดินทางไปยังดาวบริวารและสะท้อนกลับมาเพื่อให้พวกเขามองเห็น และมันก็ไม่ได้เดินทางมาถึงในทันที หากพวกเรารู้ระยะห่างระหว่างดาวทั้งสองดวงและดาวนิรันดร์ ก็อาจจะสามารถอนุมานความเร็วของแสงได้!","หลังจากที่ได้ฟังคำอธิบายของออโรร่า แฮร์รอฟก็รู้สึกทึ่งมาก","“เจ้ายังมีวิธีนี้อยู่นี่เอง ดูเหมือนว่าเจ้าจะได้รับเหรียญตราจันทร์สีเงินในปีนี้ไปแล้วล่ะ!”","ในขณะที่พูด แฮร์รอฟก็อดไม่ได้ที่จะหัวเราะออกมาดังๆ ดูเหมือนว่าในครั้งนี้ลินน์อาจจะคำนวณพลาดไปเสียแล้ว","การที่ลินน์กล้าที่จะให้สัญญาอย่างเปิดเผยว่าจะเสนอชื่อเพื่อรับเหรียญตราจันทร์สีเงินให้กับบุคคลที่สามารถวัดความเร็วแสงได้นั้น เห็นได้ชัดว่าเขามั่นใจมากว่าพวกเขาจะไม่สามารถหาวิธีวัดความเร็วแสงได้ภายในเวลาเพียงไม่กี่วัน แต่อีกฝ่ายก็ประเมินความสามารถของพวกเขาต่ำไปอย่างเห็นได้ชัด!","“มันยังมีปัญหาอยู่อีกอย่างหนึ่ง...”","ออโรร่ากล่าวอย่างลังเล","“ปัญหาอะไรหรือ?”","แฮร์รอฟเอ่ยถามพร้อมกับรอยยิ้ม","“เส้นผ่านศูนย์กลางและระยะทางของดาวเคราะห์แต่ละดวงนั้นยังคงอยู่ในระหว่างการคำนวณ ในปัจจุบันนี้ พวกเราคำนวณได้เพียงว่าดวงอาทิตย์และดวงจันทร์อยู่ห่างจากดาวนิรันดร์ที่อยู่ใต้เท้าของพวกเราไปไกลแค่ไหนเท่านั้น มันยังไม่ถึงคิวของดาวไทร์เลย...”","ออโรร่ากล่าวอย่างจนใจ","วิธีที่พวกเขาใช้ในการวัดเส้นผ่านศูนย์กลางและระยะทางของดาวเคราะห์ก็คือกฎสามข้อของดวงดาว และวิธีตรีโกณมิติแพรัลแลกซ์ที่ลินน์มอบให้ เนื่องจากดาวเคราะห์มีขนาดใหญ่มาก ข้อมูลที่คำนวณได้จึงน่าเหลือเชื่อ และก็มักจะจำเป็นต้องคำนวณและยืนยันซ้ำแล้วซ้ำเล่า ดังนั้นความคืบหน้าจึงเป็นไปอย่างเชื่องช้ามาก","“นี่มันก็ผ่านไปเกือบปีแล้วนะ และพวกเจ้ายังคำนวณไม่เสร็จอีกงั้นหรือ?”","สีหน้าของแฮร์รอฟดูไร้คำพูดเป็นอย่างมาก นั่นมันไม่ต่างอะไรกับการไม่ได้พูดเลยไม่ใช่หรือ? ลินน์จะทำการตรวจสอบหลังจากงานสัมมนานี้ แล้วพวกเขาจะมีเวลารอให้คำนวณอย่างเชื่องช้าได้อย่างไร?","ออโรร่ามองไปที่แฮร์รอฟด้วยสายตาว่างเปล่า พวกเขายังคงต้องตรวจสอบทฤษฎีที่ลินน์เสนอขึ้นมาในปีนี้ และต้องวาดแผนที่ดวงดาวอย่างละเอียดขึ้นมาใหม่อีกครั้ง ดาวไทร์นั้นไม่สำคัญมากนัก ดังนั้นมันจึงอยู่ในอันดับค่อนข้างต่ำของรายการโดยธรรมชาติ","นอกจากนี้ แม้ว่าการใช้วิธีนี้เพื่อวัดความเร็วแสงจะเป็นไปได้ แต่เมื่อพิจารณาถึงการหมุนของดาวเคราะห์แล้ว มันก็อาจจะมีข้อผิดพลาดบางอย่างเกิดขึ้นได้ และสามารถประมาณได้แค่ค่าโดยคร่าวเท่านั้น","“ในกรณีนี้ เจ้าก็สามารถใช้วิธีโง่ๆ ได้เท่านั้น เช่นการจำลองการทดลองดั้งเดิมของเจ้าขึ้นมาใหม่ หากหนึ่งกิโลเมตรไม่เพียงพอ ถ้าอย่างนั้นก็สิบกิโลเมตร หรือแม้แต่หนึ่งร้อยกิโลเมตร!”","แฮร์รอฟกล่าวอย่างหนักแน่น","“ที่จริงแล้ว มีผู้คนมากมายที่กำลังเตรียมที่จะทำการทดลองที่คล้ายคลึงกัน แนวคิดของพวกเขานั้นน่าสนใจมาก ปล่อยให้คนพวกนั้นดิ้นรนไปเถอะ”","ออโรร่าส่ายหัว ในเมื่อมีคนกำลังช่วยนางทำการตรวจสอบแล้ว ถ้าอย่างนั้นการประหยัดแรงไปได้สักหน่อยก็ไม่ใช่เรื่องแย่อะไร"]},{"n":330,"t":"ดูเหมือนว่าความเร็วของแสงจะไม่เร็วมากนัก","c":["ในช่วงเย็นของวันรุ่งขึ้น พ่อมดแม่มดและชาวเมืองนับพันคนต่างมารวมตัวกันที่ด้านนอกถนนสายหนึ่งในนครกรีนรีล เพื่อเฝ้าดูเกล็นและคนอื่นๆ แขวนกระจกผิวเรียบเอาไว้บนกำแพงทุกบานของถนน...","“เหลือกระจกอีกเพียงแค่ห้าสิบบานเท่านั้น ข้าจะจัดวางพวกมันตามแบบแปลน มุมของมันจะต้องไม่ผิดเพี้ยนไปเด็ดขาด!”","เกล็นสั่งการแนนซี่และคนอื่นๆ เสียงดัง เพื่อให้จัดวางกระจกในตำแหน่งที่เหมาะสม และปรับมุมตามผลลัพธ์จากการคำนวณอย่างแม่นยำของเขา","ต้องขอบคุณมือที่มั่นคงและความแม่นยำสูงของพ่อมด หากมุมคือ 15 องศา มันก็จะไม่มีทางถูกวางไว้ที่ 16 องศาอย่างเด็ดขาด มิฉะนั้นแล้ว การจะเชื่อมต่อแสงสะท้อนของกระจกนับร้อยบานเหล่านี้ก็ไม่ใช่เรื่องง่ายเลย","พ่อมดทั้งเจ็ดคนต้องใช้เวลาถึงหนึ่งวันเต็มในการคำนวณมุมหักเหเพียงอย่างเดียว!","เกล็นรู้สึกโล่งใจเล็กน้อยที่กระบวนการขอยืมกระจกนั้นราบรื่นมาก หลังจากที่รู้ว่าเขาจะใช้มันสำหรับการทดลองวัดความเร็วของแสง พ่อมดแม่มดที่อยากรู้อยากเห็นหลายคนก็ยอมมอบกระจกกลมที่พวกเขาเคยซื้อมาให้ด้วยความเต็มใจ","เขายังได้รับการอนุมัติจากสภาเวทมนตร์ ให้ใช้ถนนและจัตุรัสของนครกรีนรีลเป็นสถานที่ทดลองได้ เมื่อดวงอาทิตย์ตกดินและร้านค้าต่างๆ ปิดทำการ","เกล็นและคนอื่นๆ ต้องใช้เวลามากกว่าหนึ่งชั่วโมงในการจัดวางกระจกห้าสิบบานสุดท้ายให้เสร็จสิ้น เมื่อถึงเวลาที่พวกเขาทำเสร็จ ดวงอาทิตย์ก็ตกดินไปแล้ว และทั้งนครกรีนรีลก็ตกอยู่ในความมืดมิด","ภายใต้คำขอของเขา ทุกบ้านไม่มีการจุดเทียนเลยแม้แต่เล่มเดียว และทุกคนก็สามารถมองเห็นสิ่งต่างๆ รอบตัวได้อย่างชัดเจนด้วยแสงจันทร์เพียงเล็กน้อยเท่านั้น","“เกล็น ตอนนี้เจ้าพูดได้หรือยัง? เจ้าขอให้พวกเรายืมกระจกมาตั้งมากมายเพื่ออะไรกัน? เจ้าตั้งใจจะใช้สิ่งนี้เพื่อวัดความเร็วของแสงงั้นหรือ?”","พ่อมดคนหนึ่งที่คุ้นเคยกับเกล็นเอ่ยถามด้วยความร้อนรน","ทุกคนที่อยู่ในเหตุการณ์ต่างก็มีสีหน้าคาดหวังเช่นกัน เนื่องจากสิ่งล่อใจอย่างเหรียญตราจันทร์สีเงิน จึงมีพ่อมดแม่มดจำนวนไม่น้อยเลยที่ต้องการทำการทดลองนี้ให้สำเร็จ พวกเขามีแนวคิดที่หลากหลาย แต่เกล็นเป็นคนแรกที่นำแนวคิดของเขาไปปฏิบัติจริง!","เมื่อต้องเผชิญกับสายตาของทุกคน เกล็นก็ดูจะประหม่าเล็กน้อย แต่เขาก็ยังคงอธิบายต่อไป","“แผนของข้าก็คือการใช้หลักการที่กระจกสามารถสะท้อนแสงได้ เพื่อเพิ่มระยะทางในการเดินทางของแสง เพื่อใช้ในการวัดความเร็วของแสง...”","เขาได้วางกระจกจำนวนมากเอาไว้ในนครกรีนรีล หลังจากนี้ เขาจะสร้างลำแสงที่รุนแรงจากทางเข้าของเขตเมืองฝั่งตะวันออก สะท้อนผ่านกระจกไปจนถึงเขตเมืองฝั่งตะวันตก จากนั้นก็ไปยังเขตเมืองฝั่งใต้ และวนกลับมาเป็นวงกลม...","“ต้องใช้การสะท้อนทั้งหมด 1,000 ครั้ง และระยะทางรวมก็คือ 100 กิโลเมตร!”","เกล็นกล่าวด้วยความภาคภูมิใจ","เขาได้คำนวณจุดวางกระจกแต่ละจุดอย่างแม่นยำแล้ว นั่นก็หมายความว่า พวกเขาเพียงแค่ต้องยืนอยู่กับที่และรอให้แสงสะท้อนไปรอบๆ นครกรีนรีล และจุดตกลงสุดท้ายก็คือหอคอยที่อยู่เหนือหัวของพวกเขานั่นเอง!","“ข้าได้วางผ้าสีขาวเอาไว้บนยอดหอคอย ตราบใดที่พวกเจ้าเห็นจุดแสงที่มองเห็นได้ชัดเจนบนนั้น นั่นก็หมายความว่าแสงได้สะท้อนกลับมาครบรอบแล้ว และหลังจากที่มันเดินทางไปครบหนึ่งร้อยกิโลเมตร พวกเจ้าก็สามารถคำนวณความเร็วของแสงได้โดยใช้เวลาที่มันใช้ในการสะท้อนกลับมา...”","เกล็นอธิบาย","“ช่างเป็นแนวคิดที่แปลกใหม่จริงๆ มันยังสามารถทำแบบนี้ได้ด้วย...”","ราฟาเอลตระหนักได้ในทันที และมองดูพ่อมดที่ชื่อเกล็นผู้นี้ด้วยความชื่นชม ด้วยวิธีนี้ เพียงแค่ใช้ถนนไม่กี่สาย ก็สามารถสร้างระยะทาง 100 กิโลเมตรในการทดลองภายใต้สายตาของทุกคนได้แล้ว","พ่อมดแม่มดที่เหลือต่างก็ให้ความสนใจในทันที แผนการของเกล็นฟังดูเป็นไปได้มาก นี่มันคือระยะทาง 100 กิโลเมตรเต็ม ท้ายที่สุดแล้ว ธาตุแสงก็จำเป็นต้องใช้เวลาวิ่งสักหนึ่งหรือสองวินาทีใช่หรือไม่?","“คณบดีลินน์ ท่านคิดว่าวิธีนี้จะสามารถวัดความเร็วของแสงได้หรือไม่?”","เอล็อคอดไม่ได้ที่จะถามขึ้น แต่เขาก็รู้ดีว่าเมื่อเร็วๆ นี้คณบดีก็กำลังเตรียมการทดลองที่เกี่ยวข้องอยู่เช่นกัน ซึ่งมันจะเป็นตัวกำหนดว่าเหรียญตราจันทร์สีเงินจะตกเป็นของใคร","“มันเป็นไปได้ แต่ก็เป็นไปไม่ได้...”","ลินน์ยิ้มและกล่าวอย่างลึกลับ โดยไม่ได้เปิดเผยคำตอบออกมา","ข้าต้องบอกเลยว่าเกล็นนั้นมีความคิดสร้างสรรค์มาก เขาสามารถคิดวิธีนี้ขึ้นมาได้ แต่วิธีของเขาก็ยังขาดการพิจารณาในบางเรื่องอยู่...","เมื่อเห็นความคลุมเครือในสิ่งที่ลินน์พูด พ่อมดแม่มดในลานก็อดไม่ได้ที่จะเบ้ปาก ดูเหมือนว่าแม้แต่ดวงดาวแห่งเวทมนตร์เองก็ยังไม่รู้ผลลัพธ์ ดังนั้นเขาจึงทำได้เพียงใช้ข้ออ้างนี้เพื่อรักษาหน้าเท่านั้น","แต่นั่นก็ถูกต้องแล้ว หากอีกฝ่ายรู้ล่วงหน้า ข้าเกรงว่าพวกเขาคงจะวัดความเร็วของแสงไปนานแล้ว... ท้ายที่สุด การทดลองนี้ก็ไม่ได้ซับซ้อนอะไรเลย ตราบใดที่มีกระจกเพียงพอ การทดลองนี้ก็สามารถจำลองขึ้นมาใหม่ได้อย่างง่ายดาย","เกล็นไม่ได้พยายามโต้เถียงกับคำพูดของทุกคน เขาหยิบแบบแปลนในมือขึ้นมาเพื่อยืนยันเป็นครั้งสุดท้าย สูดหายใจเข้าลึกๆ และปรับสภาพของตัวเอง","เวลาผ่านไปทีละน้อย เมื่อถึงเวลาเกือบสามวินาทีก่อนเที่ยงคืน เกล็นก็ยกมือขึ้น และลูกไฟที่แผดเผาก็ปรากฏขึ้นกลางอากาศ ส่องสว่างไปทั่วทั้งถนน","แต่นี่เป็นเพียงแค่จุดเริ่มต้นเท่านั้น เกล็นและพ่อมดอีกห้าคนได้ร่ายเวทมนตร์ร่วมกัน ภายใต้พลังเวทมนตร์ที่พลุ่งพล่าน ชั้นสะท้อนแสงทรงกลมก็เริ่มปรากฏขึ้นรอบๆ ลูกไฟ ก่อตัวเป็นทรงกลมปิดในอากาศที่ปกคลุมลูกไฟเอาไว้ด้านใน โดยเหลือเพียงแค่รูเล็กๆ ที่มีเส้นผ่านศูนย์กลางหนึ่งเซนติเมตรเอาไว้...","แสงที่ปล่อยออกมาจากลูกไฟทั้งหมดถูกรวบรวมเข้าด้วยกัน และพุ่งออกไปผ่านรูเล็กๆ นั่น โดยมีเป้าหมายคือกระจกกลมบานแรก","เกล็นควบคุมเวลาได้อย่างแม่นยำมาก มันเป็นจังหวะที่นาฬิกาเวทมนตร์เดินไปถึงเลขศูนย์พอดี ในสายตาของผู้คนนับไม่ถ้วน ลำแสงที่เจิดจ้าก็ได้ปรากฏขึ้นทั่วทั้งถนน ซึ่งมันทอดยาวไปจนสุดสายตา","ด้านข้าง แนนซี่หันหลังให้กับเกล็น สายตาของนางจับจ้องไปที่ยอดหอคอยเพียงอย่างเดียว นางไม่กล้าแม้แต่จะกะพริบตา เพราะกลัวว่าจะพลาดจุดแสงที่ปรากฏขึ้นมา นางถือนาฬิกาเวทมนตร์เอาไว้ในมือ ทันทีที่นางเห็นจุดแสง นางจะต้องหยุดมันในทันที และเวลาที่ได้ก็คือเวลาที่แสงใช้ในการเดินทางผ่านระยะทางหนึ่งร้อยกิโลเมตร","หนึ่งวินาที... สามวินาที... ห้าวินาที... สิบวินาที...","แนนซี่จ้องมองจนแสบตา แต่บนผ้าสีขาวบนหอคอยกลับไม่มีอะไรเลย และก็ไม่มีจุดแสงใดๆ ปรากฏขึ้นมา","“ดูเหมือนว่าความเร็วของแสงจะไม่ค่อยเร็วนัก... นี่ก็ผ่านไปกว่าสิบวินาทีแล้ว ทำไมมันถึงยังมาไม่ถึงอีกล่ะ”","เอล็อคพึมพำและกล่าวขึ้น","“นี่คือระยะทาง 100 กิโลเมตรเต็มนะ ไม่ว่ามันจะเร็วแค่ไหน มันก็ต้องใช้เวลาครึ่งนาทีในการวิ่งไม่ใช่หรือ?”","เพียร์ซกล่าวพร้อมกับรอยยิ้ม","ราฟาเอลและคนอื่นๆ ขมวดคิ้ว และความคิดหนึ่งก็ปรากฏขึ้นในใจของพวกเขาอย่างเลือนราง หรือว่าการทดลองนี้จะมีอะไรผิดพลาดกัน?","เมื่อคิดได้เช่นนี้ จอมเวทผู้ยิ่งใหญ่หลายคนก็บินขึ้นไปในทันที โดยตั้งใจที่จะมองไปรอบๆ ทั้งเมืองจากที่สูง เพื่อมองหาต้นตอของปัญหา","เกล็นที่อยู่ด้านล่างก็สังเกตเห็นถึงความผิดปกติเช่นกัน เพราะความเข้มของแสงนั้นอ่อนลงเร็วกว่าที่เขาคาดไว้มาก เนื่องจากแสงสะท้อนของกระจกหลายบานที่เขามองเห็น...","ประมาณสิบวินาทีต่อมา ราฟาเอลและคนอื่นๆ ก็บินกลับลงมาจากกลางอากาศ และสีหน้าของพวกเขาก็ดูจนใจอยู่บ้าง","“ปรมาจารย์ราฟาเอล สถานการณ์เป็นอย่างไรบ้างขอรับ? เป็นเพราะแสงยังเดินทางมาไม่ถึงงั้นหรือ?”","เพื่อนของเกล็นรีบก้าวไปข้างหน้าและเอ่ยถามด้วยความสงสัย"]},{"n":331,"t":"เขตแดนสุญญากาศที่ครอบคลุมครึ่งเมือง!","c":["หลังจากที่ราฟาเอลกลับลงมาจากกลางอากาศ ประโยคแรกที่เขาพูดก็ทำให้ทุกคนที่อยู่ในเหตุการณ์ถึงกับตะลึงงัน","“ข้าเกรงว่ามันคงจะเป็นเรื่องยากที่จะทำการทดลองนี้ต่อไป!”","“ท่านปรมาจารย์ เกิดอะไรขึ้นงั้นหรือ? หรือว่ามุมหักเหของแสงจะผิดพลาด?”","แนนซี่ถามด้วยความร้อนรน แต่พวกเขาก็ยืนยันอย่างชัดเจนไปมากกว่าสิบครั้งแล้ว และกระจกแต่ละบานก็ถูกจัดวางอย่างระมัดระวังตามแบบแปลน","แต่ก่อนที่ราฟาเอลจะทันได้ตอบ เกล็นก็ถอนหายใจออกมา","“เป็นเพราะแสงอ่อนลงใช่หรือไม่?”","“ถูกต้อง!”","ราฟาเอลพยักหน้า","“ข้าเพิ่งตรวจสอบดูจากบนอากาศ ลำแสงที่เจ้าสร้างขึ้นมานั้นอ่อนแอมากจนไม่สามารถมองเห็นได้ด้วยตาเปล่า หลังจากที่มันสะท้อนผ่านกระจกบานที่เจ็ดสิบสาม...”","“มันเสื่อมสลายเร็วขนาดนั้นเลยงั้นหรือ?!”","สีหน้าของเกล็นซีดเผือด หากแสงสามารถทะลุผ่านกระจกไปได้สักสามหรือสี่ร้อยบาน มันก็อาจจะมีวิธีชดเชยได้ เพียงแค่หาพ่อมดมาเพิ่มอีกสองสามคนเพื่อช่วยกันร่ายเวท และสร้างลำแสงที่มีพลังมากกว่านี้ก็เพียงพอแล้ว","แต่นี่เป็นเพียงกระจกเจ็ดสิบสามบาน และพวกเขาก็เพิ่งเดินทางไปได้เพียงหนึ่งในสิบสี่ของระยะทางทั้งหมดเท่านั้น ด้วยความถี่ในการเสื่อมสลายเช่นนี้ พวกเขาจะต้องเพิ่มความเข้มของลำแสงขึ้นสิบหรือเป็นร้อยเท่าเลยงั้นหรือ?","นี่มันจะเป็นไปได้อย่างไร?","“ศาสตราจารย์ลินน์ ข้าคิดว่าท่านน่าจะรู้ว่าเกิดอะไรขึ้นใช่หรือไม่?”","ราฟาเอลหันไปมองลินน์และเอ่ยถาม","ทุกคนที่อยู่ในเหตุการณ์ต่างก็หันความสนใจไปที่ดาวรุ่งแห่งเวทมนตร์ และนึกขึ้นได้ทันทีถึงการประเมินการทดลองนี้ของลินน์เมื่อสักครู่","มันเป็นไปได้และเป็นไปไม่ได้...","ลินน์ไม่ได้พยายามทำตัวเป็นเรื่องตลกในเวลานี้ และอธิบายว่า","“การปล่อยให้แสงเดินทางไกลออกไปผ่านหลักการสะท้อนนั้นเป็นไปได้ แต่ถึงแม้ว่ากระจกจะสามารถสะท้อนแสงได้ แต่มันก็ไม่สามารถสะท้อนกลับมาได้อย่างสมบูรณ์ และแน่นอนว่ามันย่อมต้องสูญเสียพลังงานบางส่วนไปในทุกๆ ครั้งที่สะท้อน...”","“อีกนัยหนึ่งก็คือ เราควรจะลดจำนวนกระจกลง และเพิ่มระยะทางในการสะท้อนแต่ละครั้งใช่หรือไม่?”","พ่อมดคนหนึ่งคิดวิธีแก้ปัญหาขึ้นมาได้อย่างรวดเร็ว","“ไม่ มันจะไม่ได้ผลเลย”","เกล็นกล่าวพร้อมกับถอนหายใจ","“แสงไม่สามารถเดินทางไปได้ไกลมากนัก”","เขาได้ลองวิธีนี้ไปแล้ว เขาจึงได้ลดระยะห่างระหว่างกระจกสองบานลงเหลือเพียงประมาณ 100 เมตร","“นั่นเป็นเพราะธาตุในอากาศก็สะท้อนและดูดซับแสงเช่นกัน และตัวแสงเองก็ไม่ได้เดินทางขนานกัน แต่มันกระจายไปในทุกทิศทาง ดังนั้นเราจึงสามารถมองเห็นแสงได้...”","ลินน์อธิบายต่อไป","หรืออีกนัยหนึ่งก็คือ ตราบใดที่สามารถมองเห็นแสงได้ นั่นก็หมายความว่าแสงได้กระจายและสะท้อนเข้าสู่ดวงตาของพวกเขา... ราฟาเอลเข้าใจความหมายของลินน์ในทันที แต่จากนั้นเขาก็รีบโต้แย้งขึ้นมา","“นี่มันไม่น่าจะถูกต้อง แล้วแสงของดวงอาทิตย์เดินทางข้ามระยะทางหลายสิบล้านกิโลเมตรมาถึงดาวนิรันดร์ดวงนี้ได้อย่างไร?”","หลังจากคำเตือนของราฟาเอล พ่อมดแม่มดหลายคนก็ค้นพบ ‘ช่องโหว่‘ ในคำพูดของลินน์เช่นกัน หากแสงเสื่อมสลายลงอย่างต่อเนื่อง มันก็เป็นไปไม่ได้เลยที่แสงจากดวงอาทิตย์จะมาถึงที่นี่!","พ่อมดแห่งสถาบันพยากรณ์ได้คำนวณระยะห่างระหว่างดาวนิรันดร์และดวงอาทิตย์ ซึ่งมันเป็นค่าที่น่าอัศจรรย์มาก แม้แต่จุดที่ใกล้ที่สุดก็ยังห่างออกไปหลายร้อยล้านกิโลเมตร!","“ภายนอกดาวเคราะห์ของเรา ในจักรวาลอันกว้างใหญ่ ปริมาณของธาตุนั้นหาได้ยากมาก และแสงก็จะไม่สูญเสียพลังงานเมื่ออยู่ในสุญญากาศ ส่วนการเดินทางมาถึงดาวเคราะห์ดวงนี้นั้น มันก็เพียงแค่ถูกกระเจิงและถูกดูดซับโดยธาตุต่างๆ และมันก็ไม่ได้หายไป...”","ลินน์ส่ายหัว","ลินน์ตอบเพื่อคลายข้อสงสัยของทุกคน แต่ปัญหาที่ตามมาก็ทำให้เกล็นและคนอื่นๆ ถึงกับตะลึงงันไปอย่างสิ้นเชิง","ด้วยวิธีนี้ ปัญหาเรื่องความเข้มของแสงที่เสื่อมสลายไปตามระยะทางก็ไม่สามารถแก้ไขได้ เกล็นครุ่นคิดอย่างหนักอยู่ครู่หนึ่ง แต่เขาก็คิดไม่ออกว่าจะทำให้แสงเดินทางไปไกลกว่าระยะทาง 100 กิโลเมตร และให้พวกเขามองเห็นมันได้อย่างไร...","เป็นไปได้ไหมว่าพวกเราทำได้เพียงแค่ประกาศความล้มเหลว?","เกล็นไม่ยอมแพ้ เขาได้เตรียมการมามากมายและจัดการทดลองที่ยิ่งใหญ่ขนาดนี้ แต่ผลลัพธ์ก็ยังคงล้มเหลว...","เป็นเรื่องที่พอจะเดาได้เลยว่า ในวันพรุ่งนี้พวกเขาจะต้องกลายเป็นตัวตลกในหัวข้อการนินทาของพวกพ่อมดอย่างแน่นอน","ในตอนนั้นเอง จู่ๆ น้ำเสียงที่ดังกังวานราวกับระฆังก็ดังขึ้นในหูของทุกคน","“ถ้าอย่างนั้นก็ทำให้ธาตุที่ขัดขวางเหล่านี้หายไป สร้างเขตแดนสุญญากาศให้ใหญ่พอ และจำลองสภาพแวดล้อมของจักรวาลขึ้นมา แบบนี้มันจะไม่ดีกว่าหรือ?”","ผู้คนที่อยู่ในเหตุการณ์ต่างก็มองไปทางต้นเสียง และจากนั้นก็พบว่ามีประธานสภาระดับตำนานหลายคนกำลังเดินมาทางนี้ และคนที่พูดก็คือแฮร์รอฟ!","“ปรมาจารย์แฮร์รอฟ!”","เกล็นรู้สึกประหลาดใจและยินดีเป็นอย่างมาก","ถูกต้อง ตราบใดที่สามารถสร้างเขตแดนสุญญากาศที่ครอบคลุมระยะทางการแพร่กระจายของแสงได้ การอ่อนกำลังของความเข้มแสงก็จะลดลงอย่างมาก","มีเพียงพ่อมดระดับตำนานอย่างแฮร์รอฟเท่านั้น ที่สามารถคิดวิธีแก้ปัญหาที่บ้าบิ่นแต่ได้ผลลัพธ์ที่มีประสิทธิภาพมากเช่นนี้ขึ้นมาได้!","หลังจากที่แฮร์รอฟพูดจบ พ่อมดแม่มดที่รวมตัวกันอยู่ใกล้ๆ ก็เสนอคำแนะนำให้กับเกล็นเช่นกัน","ยกตัวอย่างเช่น กระจกหนึ่งพันบานนั้นมากเกินไป พวกเขาสามารถเพิ่มระยะทางของการสะท้อนแต่ละครั้งขึ้นเป็นหนึ่งกิโลเมตรได้ ดังนั้นกระจกเพียงร้อยบานก็เพียงพอแล้ว!","แม้แต่แอนโทนี่ก็ยืนขึ้นเช่นกัน เขามีความสนใจอย่างมากในการทดลองวัดความเร็วของแสงบนกระจก และยังเสนอว่าเขาสามารถใช้เวทสายฟ้าเพื่อสร้างแหล่งกำเนิดแสงที่มีพลังมากกว่านี้ได้...","ท่ามกลางการพูดคุยถกเถียงกันในหมู่ฝูงชน ปัญหาแล้วปัญหาเล่าก็ถูกแก้ไขไปทีละเรื่อง บรรยากาศการวิจัยเวทมนตร์ที่กระตือรือร้นเช่นนี้ทำให้ลินน์รู้สึกสบายใจเป็นอย่างมาก","แม้ว่าจะมีผู้คนจำนวนมากในสนามที่กำลังเฝ้าดูความตื่นเต้น และยังคงรอคอยที่จะได้เห็นเรื่องตลก แต่ก็ยังมีพ่อมดแม่มดจำนวนไม่น้อยที่ให้ความสำคัญกับการวิจัยเวทมนตร์ และต้องการที่จะค้นหาว่าความเร็วของแสงนั้นรวดเร็วแค่ไหน","เกล็นก็มีกำลังใจขึ้นมาเช่นกัน เขาปรับเปลี่ยนตำแหน่งและมุมของกระจกแต่ละบานบนแบบแปลน และลดจำนวนลงเหลือร้อยบาน เพื่อเตรียมการทดลองอีกครั้งด้วยแสงที่ทรงพลังกว่าเดิม!","“ทุกคนที่ไม่เกี่ยวข้องควรจะถอยออกไปก่อน และจอมเวทผู้ยิ่งใหญ่ทุกคนจงอยู่ต่อ!”","แฮร์รอฟกล่าวอย่างเคร่งขรึม ว่าการผลักไสธาตุในสเกลที่ใหญ่ขนาดนี้ แม้แต่เขาที่เป็นระดับตำนานก็ไม่สามารถทำมันเพียงคนเดียวได้ และเขาก็จะต้องรวบรวมความแข็งแกร่งของทุกคน","การเตรียมความพร้อมต้องใช้เวลาอีกหนึ่งชั่วโมงจึงจะถือว่าเสร็จสมบูรณ์","แอนโทนี่เป็นผู้นำ และแสงสายฟ้าที่กะพริบก็เริ่มปรากฏขึ้นในฝ่ามือของเขา และมันก็สว่างไสวมากขึ้นเรื่อยๆ สายฟ้าที่รุนแรงยังคงพุ่งทะยานต่อไป และทั้งพลเรือนและพ่อมดต่างก็ต้องหรี่ตาลง แสงสว่างจ้ามากจนผู้คนไม่สามารถมองดูมันโดยตรงได้...","“เริ่มกันเลย!”","แฮร์รอฟเน้นน้ำเสียงของเขา และเสียงของเขาก็ดังก้องไปทั่วทุกมุมเมือง","ในขณะเดียวกัน จอมเวทผู้ยิ่งใหญ่ยี่สิบคนและตำนานอีกสามคนก็ได้ร่ายเวทมนตร์ร่วมกัน และธาตุที่พลุ่งพล่านรอบตัวพวกเขาก็ถูกผลักออกไปอย่างรวดเร็วภายใต้การกระทำของพลังเวทมนตร์อันมหาศาล ในเวลาเพียงสามวินาที เขตแดนสุญญากาศที่ครอบคลุมพื้นที่ครึ่งหนึ่งของเมืองก็ก่อตัวขึ้นอย่างเงียบๆ !","“ช่างยิ่งใหญ่จริงๆ ...”","ลินน์กล่าวด้วยความรู้สึก ทักษะความคิดและความสามารถในทางปฏิบัติของพวกพ่อมดนั้นเหนือความคาดหมายของเขาไปมาก แต่พวกเขาก็รีบดึงสติกลับมาอย่างรวดเร็ว เขายกมือขึ้นเพื่อขยายอาณาเขตของตนเอง และทำภารกิจในส่วนเขตแดนสุญญากาศที่เขารับผิดชอบจนเสร็จสมบูรณ์"]},{"n":332,"t":"ลำแสงที่ทะลวงผ่านท้องฟ้า!","c":["หลังจากที่เขตแดนสุญญากาศค่อยๆ ก่อตัวขึ้น เกล็นก็ร่ายเวทรวบรวมแสงของเขาอีกครั้ง และลูกบอลสายฟ้าที่กะพริบลอยอยู่กลางอากาศก็ถูกห่อหุ้มเอาไว้","ลำแสงที่รุนแรงจนยากจะมองตรงๆ พุ่งออกมาจากรูเล็กๆ แต่เนื่องจากในเขตแดนสุญญากาศไม่มีธาตุใดๆ สำหรับสะท้อนแสง ทุกคนที่อยู่ในเหตุการณ์จึงไม่สามารถมองเห็นการดำรงอยู่ของลำแสงนั้นได้เลย และสามารถทำได้เพียงแค่ใช้กระจกกลมหนึ่งร้อยบานที่ตั้งขึ้นมาในนครแห่งพ่อมด เพื่อกำหนดวิถีของแสงเท่านั้น","“มันปรากฏขึ้นแล้ว ปรากฏขึ้นแล้ว!”","กลุ่มพ่อมดที่รออยู่ด้านนอกเขตแดนสุญญากาศมองไปที่ยอดหอคอยด้วยความประหลาดใจ แม้ว่าการสะท้อนที่ไม่สมบูรณ์ของกระจกจะทำให้ความเข้มของแสงลดลงไปทีละชั้น แต่ในครั้งนี้ แสงก็ไม่ได้หายไปหลังจากที่มันเดินทางครบหนึ่งร้อยกิโลเมตร ในทางกลับกัน ยอดหอคอยและผ้าสีขาวทั้งหมดกลับถูกส่องสว่างอย่างเจิดจ้า","“พวกเจ้าเห็นตอนที่มันมาถึงหรือไม่?”","เพียร์ซถามด้วยความอยากรู้อยากเห็น เมื่อสักครู่นี้เขากะพริบตา แต่เขาก็มองไม่ทันอยู่ดีว่าแสงเดินทางมาถึงยอดหอคอยเมื่อใด","“ราวกับเกิดขึ้นในพริบตาเดียว? มันเร็วเกินไป...”","เอล็อคส่ายหัว เมื่อสักครู่นี้เขาไม่ได้กะพริบตาเลยด้วยซ้ำ แต่เขาก็มองไม่ทันเช่นกัน","เขตแดนสุญญากาศที่ครอบคลุมพื้นที่ครึ่งหนึ่งของเมืองกำลังถอยร่นอย่างช้าๆ เพราะการรักษาระยะเขตแดนให้กว้างใหญ่ขนาดนี้ย่อมไม่ใช่เรื่องง่ายเลย แม้จะเป็นพ่อมดระดับตำนานก็ตาม","“เป็นอย่างไรบ้าง? มีผลลัพธ์อะไรออกมาหรือไม่?”","ราฟาเอลรีบบินกลับมาจากเขตเมืองฝั่งตะวันตกและรีบเอ่ยถาม","เกล็นรีบหันไปมองแนนซี่ แม่มดผู้รับหน้าที่บันทึกเวลา และนาฬิกาเวทมนตร์ในมือของนาง","เวลาบนหน้าปัดยังคงหยุดอยู่ที่ศูนย์นาที ศูนย์วินาที...","เกล็นขมวดคิ้ว หรือว่าอีกฝ่ายจะลืมจับเวลางั้นหรือ?","การทดลองที่สำคัญเช่นนี้ แม้แต่ประธานสภาก็ยังเข้าร่วมด้วย แล้วมันจะเกิดความผิดพลาดครั้งใหญ่ขนาดนี้ได้อย่างไร...","“ข้า...ข้ากดมันแล้วนะ!”","แนนซี่กล่าวด้วยความร้อนรนจนแทบจะร้องไห้ เพราะจุดเริ่มต้นและจุดสิ้นสุดของแสงมันแทบจะเกิดขึ้นในเวลาเดียวกัน!","นาฬิกาเวทมนตร์เรือนนี้เป็นเครื่องมือแปรธาตุที่มีความแม่นยำอย่างยิ่ง ซึ่งมีทรายแห่งกาลเวลาถูกเก็บเอาไว้ข้างใน และเวทมนตร์ก็ถูกทำให้แข็งตัวอยู่บนนั้น มันจะต้องร่วงหล่นสิบเม็ดต่อวินาที ซึ่งหมายความว่าความแม่นยำของมันสามารถไปถึงระดับ 0.1 วินาที","ซึ่งความเร็วของมือแนนซี่นั้นก็รวดเร็วมากอย่างเห็นได้ชัด และนางก็กดมันได้ทันเวลาอย่างยิ่ง ดังนั้นจึงไม่มีทรายแห่งกาลเวลาหล่นลงมาเลยแม้แต่เม็ดเดียว","“เมื่อครู่นี้พวกเจ้ามองเห็นชัดเจนหรือไม่?”","แฮร์รอฟหันหน้าไปมองออโรร่าและวิตโตริโอ ประธานสภาทั้งสองก็ส่ายหัวเช่นกัน พวกเขาก็ให้ความสนใจอยู่ตลอดเวลา แต่พวกเขาก็ยังคงมองไม่ทันอยู่ดี","ทุกคนที่อยู่ในเหตุการณ์ต่างก็มีสีหน้าตกตะลึง แสงเดินทางผ่านระยะทางหนึ่งร้อยกิโลเมตรและไปปรากฏขึ้นที่นั่น โดยที่แม้แต่พ่อมดระดับตำนานก็ยังไม่สามารถตรวจจับเบาะแสใดๆ ได้เลยในระหว่างกระบวนการทั้งหมด","ถ้างั้นความเร็วของมันคือเท่าไหร่กัน? 10,000 กิโลเมตร? 100,000 กิโลเมตร? หรือ 1,000,000 กิโลเมตร?","“หรือว่าจริงๆ แล้วแสงจะเดินทางมาถึงในทันที?”","ซานเชซคาดเดา นี่ก็คือทฤษฎีความเร็วแสงที่เป็นอนันต์ซึ่งเคยแพร่หลายในดินแดนพ่อมดมาก่อน ไม่ว่าระยะทางจะไกลแค่ไหน มันก็สามารถเดินทางไปถึงจุดหมายได้ในชั่วพริบตา","ในเมื่อเป็นเช่นนี้ แล้วทำไมถึงยังต้องมาทดสอบความเร็วของแสงอยู่อีก?","ไม่ว่าเจ้าจะวัดมันอย่างไร มันก็คงจะไม่มีผลลัพธ์ใดๆ ออกมา","ออโรร่าส่ายหัว นางเข้าใจดีว่ามันจะต้องมีขีดจำกัด ในช่วงหลายวันนี้ นางก็มีความคืบหน้าในการวิจัยทางดาราศาสตร์อยู่บ้าง นอกจากดาวไทร์แล้ว ดาวเคราะห์และดาวบริวารหลายดวงก็สามารถสังเกตเห็นปรากฏการณ์วัฏจักรที่ไม่เสถียรได้เช่นกัน","สิ่งนี้จะต้องเกี่ยวข้องกับการแพร่กระจายของความเร็วแสง...เพียงแต่ว่าค่านี้อาจจะมากกว่าที่พวกเขาจินตนาการเอาไว้","“ดูเหมือนว่าการทดลองในครั้งนี้จะล้มเหลวแล้ว!”","เกล็นถอนหายใจและกล่าวขึ้น แม้ว่าเขาจะไม่เต็มใจอย่างมาก แต่เขาก็ต้องยอมรับความจริงข้อนี้ อาจกล่าวได้เลยว่าพวกเขาทำทุกอย่างเท่าที่ทำได้ไปหมดแล้ว!","แม้แต่ความสำเร็จในการปล่อยให้แสงเดินทางผ่านระยะทาง 100 กิโลเมตร แต่ตอนนี้ดูเหมือนว่าระยะทางนี้ จะไม่แตกต่างอะไรจากระยะทาง 100 เมตรสำหรับแสงเลย และมันก็เดินทางมาถึงในชั่วพริบตา!","เกล็นรู้สึกละอายใจเป็นอย่างมาก เขาไม่คาดคิดมาก่อนเลยว่าตนเองจะต้องใช้ความพยายามมากมาย และได้รับความช่วยเหลือจากกลุ่มจอมเวทผู้ยิ่งใหญ่และประธานสภา แต่สุดท้ายแล้ว เขากลับไม่ได้อะไรเลย","“ข้าคิดว่าการทดลองนี้มีคุณค่าอย่างมาก”","จู่ๆ เสียงของลินน์ก็ดังขึ้น","“อย่างน้อยการได้รับเหรียญตราดาวประกายพฤกษ์สักหนึ่งเหรียญก็ไม่ใช่เรื่องแปลกอะไร”","“ศาสตราจารย์ลินน์ แม้ว่าท่านจะต้องการเข้าข้างเขา แต่ท่านก็ไม่ควรเอาชื่อเสียงของสภาเวทมนตร์มาล้อเล่นใช่หรือไม่?”","จอมเวทผู้ยิ่งใหญ่คนหนึ่งกล่าวอย่างไม่พอใจนัก","แผนการของเกล็นในการวัดความเร็วของแสงด้วยการสะท้อนของกระจกนั้นน่าสนใจมาก แต่มันก็เป็นความจริงที่ว่า ไม่ได้รับผลลัพธ์จากการวิจัยใดๆ ออกมาเลย!","หากการทำแบบนี้สามารถรับเหรียญตราดาวประกายพฤกษ์ได้ ถ้าอย่างนั้นทุกคนก็คงจะมีเหรียญตราแบบนี้กันหมดแล้ว!","ลินน์ไม่ได้ตอบ แต่เขาชี้ไปที่กระจกกลมบานแรก...","ทุกคนที่อยู่ในเหตุการณ์ต่างก็มองตามไปด้วยความงุนงง แม้ว่าเขตแดนสุญญากาศโดยรอบจะถูกถอนออกไปแล้ว แต่เวทมนตร์รวบรวมแสงนั้นก็ยังคงทำงานอยู่ และเกลียวความร้อนบางๆ ก็กำลังลอยขึ้นมา...","แคร็ก...","พร้อมกับเสียงดังเบาๆ จู่ๆ กระจกบานนั้นก็แตกละเอียด","พลังงานที่อยู่ภายในลำแสงนี้มีความน่าสะพรึงกลัวเป็นอย่างมาก แม้ว่ากระจกกลมจะสามารถสะท้อนแสงได้ 99% แต่พลังงานที่ถูกดูดซับเอาไว้อีก 1% ที่เหลือนั้น ก็เกินขีดจำกัดที่กระจกจะสามารถทนทานได้!","เมื่อปราศจากสิ่งกีดขวางอย่างกระจก พลังและความน่าสะพรึงกลัวของลำแสงก็ถูกเปิดเผยออกมาอย่างไม่ต้องสงสัย!","พ่อมดคนหนึ่งที่ยืนอยู่ด้านหลังถูกลำแสงพุ่งชนอย่างโชคร้าย และไหล่ทั้งข้างของเขาก็ถูกทะลวงผ่านไปในชั่วพริบตา เสียงกรีดร้องอันแหลมคมดังก้องไปทั่วทั้งถนนในทันที และพ่อมดแม่มดที่รวมตัวกันอยู่ใกล้ๆ ก็รีบแยกย้ายกันไปด้วยความตื่นตระหนก แต่ความเร็วของแสงนั้นรวดเร็วเกินไป ทั้งหมดนี้จึงไร้ประโยชน์...","เกล็นไม่คาดคิดว่าเรื่องแบบนี้จะเกิดขึ้น แต่แก่นแท้ของแสงนั้นยังอยู่ในการควบคุมของเขา เขาจึงทำได้เพียงแค่เบี่ยงลำแสงออกไปโดยสัญชาตญาณ...","ลำแสงที่บางเฉียบแต่ทว่ารุนแรงนั้น ราวกับเป็นดาบศักดิ์สิทธิ์ที่มีความยาวเกือบจะไม่มีที่สิ้นสุด มันฉีกกระชากทุกสิ่งที่ขวางหน้า พ่อมดที่ได้รับบาดเจ็บถูกตัดไหล่ขาดไปครึ่งหนึ่ง จากนั้นมันก็ผ่ากำแพงด้านหลังเขาขาดออกเป็นสองซีกในแนวเฉียงราวกับมีดหั่นเนย และทิ้งรอยไหม้สีแดงสดใสเอาไว้บนพื้น ซึ่งเป็นฉากที่กระเบื้องถูกทำลายและหลอมละลาย ก่อนที่ท้ายที่สุดลำแสงจะพุ่งตรงขึ้นไปบนอากาศ","หลังจากที่ตอบสนองได้ แอนโธนี่ก็รีบยกเลิกเวทสายฟ้าของเขาในทันที และเมื่อสูญเสียแหล่งกำเนิดแสงที่ทรงพลังไป ลำแสงที่เจิดจ้าก็หายไปอย่างไร้ร่องรอย","ความวุ่นวายในสนามก็สงบลงเช่นกัน ฟูล่าปาดเหงื่อเย็นบนหน้าผาก เมื่อครู่นี้นางก็อยู่ในระยะโจมตีของลำแสงเช่นกัน แต่เมื่อนางเห็นว่าสิ่งนั้นเริ่มเบี่ยงเบนออกไป นางก็ก้มศีรษะลงตามสัญชาตญาณ ดังนั้นศีรษะของนางจึงไม่ถูกตัดขาด","โดยที่อุณหภูมิอันน่าอัศจรรย์และพลังทำลายล้างนั้น ยังคงทิ้งเงามืดขนาดใหญ่เอาไว้ในใจของนาง...","อุบัติเหตุในการทดลองที่เกิดขึ้นอย่างกะทันหันนี้ ทำให้มีผู้ได้รับบาดเจ็บมากกว่าสิบคน สิ่งเดียวที่ควรขอบคุณก็คือ ไม่มีใครเสียชีวิตจากเหตุการณ์นี้","จากสองคนที่โชคร้ายที่สุด คนหนึ่งถูกตัดไหล่ขาดไปครึ่งหนึ่ง ส่วนอีกคนหนึ่งถูกลำแสงพุ่งชนเข้าอย่างจังเมื่อลำแสงเปลี่ยนทิศทาง!","โชคดีที่อีกฝ่ายมีความระมัดระวังมากพอ ที่จะร่ายโล่เวทมนตร์คุ้มครองตัวเองเอาไว้ในขณะที่เฝ้าดูการทดลอง แต่ถึงอย่างนั้นก็ยังมีรอยแผลเป็นลึกที่หน้าอกของเขา และไม่มีเลือดไหลออกมาจากบาดแผล เพราะบาดแผลนั้นถูกทำให้แข็งตัวโดยตรงจากอุณหภูมิที่สูงลิ่ว","คนที่เหลือยังโชคดีที่อยู่ห่างจากลำแสงออกไปหลายร้อยเมตร พวกเขาเพียงแค่ถูกเผาไหม้ หรือตาบอดชั่วคราวจากแสงที่รุนแรง และมันก็ไม่ใช่อาการบาดเจ็บที่คุกคามถึงชีวิต..."]},{"n":333,"t":"เวทมนตร์ระดับตำนาน แสงตะวัน!","c":["แม้ว่าอุบัติเหตุในการทดลองที่อยู่นอกเหนือการควบคุม จนทำให้มีผู้ได้รับบาดเจ็บจำนวนมาก แต่พ่อมดแม่มดที่รวมตัวกันอยู่รอบๆ ก็ไม่ได้ถอยกลับไป หลังจากที่เสริมการป้องกันของตนเองแล้ว พวกเขาก็พูดคุยกันอย่างตื่นเต้นเกี่ยวกับลำแสงอันน่าสะพรึงกลัวเมื่อสักครู่นี้...","ในขั้นตอนของการศึกษาเวทมนตร์ มักจะมีความเสี่ยงตามมาด้วยเสมอ และมันเป็นเรื่องปกติที่จะมีอุบัติเหตุต่างๆ เกิดขึ้น ดังนั้น จึงมีพ่อมดแม่มดไม่น้อยที่ได้รับบาดเจ็บสาหัส ตาบอด สูญเสียแขนขา หูหนวก และแม้กระทั่งถูกพิษจนตาย","อย่างไรก็ตาม สิ่งนี้ก็ไม่ได้หยุดยั้งการวิจัยและความกระตือรือร้นที่มีต่อเวทมนตร์ของพวกเขาได้","เมื่อพิจารณาจากระดับของการปรุงยาในดินแดนพ่อมดแล้ว ตราบใดที่พวกเขาไม่ตายคาที่ พวกเขาก็สามารถรอดชีวิตมาได้","“มันเป็นเวทมนตร์ที่ทรงพลังมากจริงๆ ...”","ราฟาเอลถอนหายใจในขณะที่เขาสังเกตดูบ้านเรือนที่ถูกทำลาย และกระเบื้องอันแข็งแกร่งที่ถูกตัดจนแยกออก","ในที่สุดพ่อมดแม่มดที่อยู่ในเหตุการณ์ก็เข้าใจ ว่าทำไมลินน์ถึงมอบเหรียญตราดาวประกายพฤกษ์ให้กับเกล็น มันไม่ใช่เพราะการทดลองด้วยกระจกที่อีกฝ่ายใช้เพื่อวัดความเร็วของแสง แต่เป็นเพราะเวทมนตร์รวบรวมแสงนี้ต่างหาก!","เมื่อตัดสินจากความเสียหายที่เกิดขึ้นบนถนนสายนี้ ลำแสงที่ถูกรวบรวมเข้าด้วยกันสามารถตัดผ่านบ้านเรือนที่อยู่ในระยะ 50 เมตรได้อย่างง่ายดาย ซึ่งทะลวงผ่านโล่เวทมนตร์ และสร้างความเสียหายร้ายแรงต่อศัตรูที่ไม่มีชุดเกราะและเวทป้องกันภายในระยะ 100 เมตร...","แม้ว่ามันจะขยายออกไปไกลถึงสามร้อยเมตร แต่แสงที่รุนแรงนี้ก็สามารถทำให้ผู้คนตาบอดหรือถูกเผาไหม้ได้","“นี่มันคือเวทมนตร์ระดับสี่ ไม่สิ เวทมนตร์ระดับห้าอย่างน้อยใช่หรือไม่?”","ซานเชซกล่าวด้วยน้ำเสียงทุ้มต่ำ","พลังของลำแสงนั้นนับว่าแข็งแกร่ง แต่ความน่าสะพรึงกลัวที่แท้จริงของมันก็คือความเร็วของมัน ด้วยระยะทางหนึ่งร้อยกิโลเมตรที่สามารถไปถึงได้ในชั่วพริบตา และไม่มีความเป็นไปได้เลยที่จะหลบเลี่ยง มันจึงสามารถใช้เพื่อลอบโจมตีทีละคนได้อย่างยอดเยี่ยม","แม้ว่าจะเป็นการต่อสู้แบบเผชิญหน้า แต่มันก็เทียบเท่ากับการถืออาวุธที่มีระยะสังหารมากกว่า 100 เมตรเอาไว้ในมือ หากโจมตีออกไปแบบสุ่มๆ มันก็ไม่มีที่ให้ซ่อนตัวได้เลย!","เกล็นก็ไม่อยากจะเชื่อเลยเช่นกัน ว่าเวทมนตร์รวบรวมแสงของเขาจะน่าสะพรึงกลัวได้ถึงเพียงนี้","ไม่ใช่ว่าเขาไม่เคยทำการทดลองที่เกี่ยวข้องมาก่อนในอดีต แต่เขาไม่เคยรวบรวมลำแสงให้ไปถึงระดับที่น่าทึ่งเช่นนี้มาก่อน","แน่นอนว่านี่ไม่ใช่ผลงานของเขาเพียงคนเดียว เพราะเวทมนตร์สายฟ้าที่ร่ายโดยแอนโธนี่นั้นก็เป็นสิ่งที่ขาดไปไม่ได้ และเกล็นเพียงคนเดียวก็ไม่สามารถสร้างแสงที่รุนแรงเช่นนี้ได้","“ดูเหมือนว่าเวทมนตร์ธาตุแสงจะไม่ถูกใช้เป็นเพียงแค่เวทสนับสนุนอีกต่อไปในอนาคต!”","ออโรร่ากล่าวพร้อมกับรอยยิ้ม และภายในใจของนาง ก็ได้คิดถึงวิธีใช้เวทมนตร์รวบรวมแสงเอาไว้มากมายแล้วเช่นกัน","แม้ว่าเวทมนตร์โพลาไรซ์ที่นางสร้างขึ้นในอดีตจะทรงพลังและแปลกประหลาดมาก แต่มันก็มักจะถูกใช้เพื่อวัตถุประสงค์ในการสนับสนุน เช่น การล่องหน การหลอกลวงทางสายตา การฉายภาพเวทมนตร์ การสร้างแสงจ้าเพื่อทำให้ผู้คนตาบอด ฯลฯ แต่ตอนนี้ มันสามารถถูกใช้เป็นวิธีหลักในการต่อสู้ได้แล้ว!","“ขอแสดงความยินดีด้วยเกล็น เจ้าจะเป็นคนแรกที่ได้รับการเสนอชื่อให้รับเหรียญตราดาวประกายพฤกษ์ในงานสัมมนาวิชาการครั้งนี้!”","ราฟาเอลกล่าวแสดงความยินดี","เกล็นมีสีหน้าที่ตะลึงงัน และไม่เคยคิดเลยว่าการทดลองวัดความเร็วแสงที่เขาตั้งความหวังเอาไว้สูง จะไม่ได้รับผลลัพธ์ใดๆ กลับมา แต่กลับเป็นเวทมนตร์รวบรวมแสงที่เขาไม่ได้สนใจมากนักในตอนแรก ที่ทำให้เขาได้รับเหรียญตราดาวประกายพฤกษ์ไปครอง","อย่างไรก็ตาม ถนนที่ถูกทำลายและผู้บาดเจ็บจากอุบัติเหตุในการทดลองก็ทำให้เขาต้องปวดหัวอย่างหนัก เพราะเขาต้องจ่ายเงินชดเชย ซึ่งโชคดีที่ไม่มีใครเสียชีวิตจากเหตุการณ์นี้ มิฉะนั้นแล้วเขาคงจะต้องเจอกับปัญหาใหญ่แน่","“ขอบคุณสำหรับคำแนะนำของท่านศาสตราจารย์ลินน์...”","เกล็นไม่ลืมที่จะขอบคุณลินน์ที่ช่วยเตือนสติเขาได้ทันเวลา","ก่อนหน้านี้ เกล็นทั้งอิจฉาและริษยาดาวรุ่งแห่งเวทมนตร์ผู้โด่งดังคนนี้เล็กน้อย แต่ตอนนี้เขามีเพียงแค่ความชื่นชมเท่านั้น","ความรู้ที่ลึกซึ้งและกว้างขวางของอีกฝ่ายนั้น เกินกว่าที่เขาจะจินตนาการไปมาก จากความสามารถในการชี้ให้เห็นอย่างแม่นยำ ว่ากระจกไม่สามารถสะท้อนแสงได้อย่างสมบูรณ์ และปรากฏการณ์การกระเจิงของแสง มันก็ไม่ยากเลยที่จะมองออกว่าลินน์น่าจะเคยทำการทดลองที่คล้ายคลึงกันนี้มานานแล้ว","“วิธีการมันขึ้นอยู่กับเจ้า ข้าต้องบอกเลยว่าเวทมนตร์รวบรวมแสงและการทดสอบความเร็วแสงด้วยการสะท้อนกระจกของเจ้านั้นยอดเยี่ยมมาก”","ลินน์กล่าวพร้อมกับรอยยิ้ม","“น่าเสียดายที่การทดลองยังคงล้มเหลว”","เกล็นกล่าวพร้อมกับถอนหายใจ","ลินน์ยิ้มและไม่ได้ตอบกลับ ในความเป็นจริง แนวคิดของเกล็นนั้นไม่ได้มีปัญหาอะไรมากนัก และมันเป็นไปได้จริงๆ ที่จะวัดความเร็วของแสงออกมาอย่างคร่าวๆ","แน่นอนว่า ข้อกำหนดเบื้องต้นนี้ก็คือความเร็วในการตอบสนองจะต้องรวดเร็วพอ!","ตามข้อมูลจากชาติที่แล้วของเขา แสงจะใช้เวลาประมาณสามในหมื่นวินาทีในการเดินทางผ่านระยะทางหนึ่งร้อยกิโลเมตร ซึ่งเขาก็ไม่แน่ใจว่าพ่อมดระดับตำนานจะสามารถตรวจจับความเปลี่ยนแปลงเพียงเล็กน้อยนี้ได้หรือไม่ แต่ตอนนี้ดูเหมือนว่าพวกเขาจะไม่สามารถทำได้!","เขาประเมินความสามารถในการตอบสนองของพ่อมดเหล่านี้สูงเกินไป...","แต่เวทมนตร์รวบรวมแสงของเกล็นก็ทำให้เขาประหลาดใจเช่นกัน","และความสะดวกสบายของเวทมนตร์นั้น ก็เหนือความคาดหมายจริงๆ ลินน์อดไม่ได้ที่จะนึกถึง กระจกรวมแสงตะวัน ขนาดใหญ่ยักษ์ที่ถูกสร้างขึ้นโดยสหพันธ์ในชาติก่อนในพื้นที่รกร้าง โดยอุณหภูมิที่สูงลิ่วที่ถูกสร้างขึ้นมานั้นก็สามารถหลอมละลายเหล็กกล้าได้ในชั่วพริบตา และหากมันถูกรวบรวมอยู่ที่จุดเดียว มันก็อาจจะสามารถไปถึงอุณหภูมิพื้นผิวของดวงดาวได้หลายเท่า...","ลินน์รู้สึกว่าเขาอาจจะสามารถบินขึ้นไปในอากาศ และร่ายเวทมนตร์รวบรวมแสงขนาดใหญ่เพื่อจำลองสิ่งนี้ขึ้นมาได้ นั่นแหละคือ แสงตะวัน ที่แท้จริง!","เมื่อคิดถึงเรื่องนี้ ลินน์ก็รู้สึกประหลาดใจที่พบว่า เขาดูเหมือนจะเชี่ยวชาญเวทมนตร์ระดับตำนานอีกบทหนึ่งแล้ว แต่มันก็มีความต้องการที่สูงกว่าในเรื่องของฤดูกาลและสภาพอากาศ ซึ่งจะทรงพลังพอที่จะใช้มันได้ก็ในตอนเที่ยงวันของฤดูร้อน...","บางทีเขาอาจจะก้าวไปอีกขั้น และสร้างเวทมนตร์เลเซอร์ที่แท้จริงออกมาได้...","ในขณะที่ลินน์กำลังคิดเกี่ยวกับเวทมนตร์ใหม่ กลุ่มพ่อมดก็กำลังพูดคุยกันเกี่ยวกับการทดลองสะท้อนกระจกที่ล้มเหลว","ในความเป็นจริง มีพ่อมดแม่มดไม่น้อยที่ต้องการทดสอบการวัดลำแสงให้เสร็จสิ้นและรับเหรียญตราจันทร์สีเงิน ซึ่งวิธีการที่พวกเขาคิดขึ้นมานั้นก็มีทุกรูปแบบ แต่มันก็แยกไม่ออกจากข้อโต้แย้งเดียว นั่นก็คือการสร้างระยะทางที่ยาวพอ และหาวิธีบันทึกเวลาที่แสงเดินทางผ่าน แต่ความเป็นจริงก็สาดน้ำเย็นเข้าใส่พวกเขา","การทดลองของเกล็นในครั้งนี้ สามารถกล่าวได้ว่าประสบความสำเร็จสูงสุดในทุกๆ ด้าน แม้แต่ประธานสภาก็ยังลงมือด้วยตัวเอง นั่นทำให้พวกเขาคิดไม่ออกจริงๆ ว่าจะจำลองระยะทางที่ยาวกว่านี้ เพื่อวัดความเร็วของแสงได้อย่างไร...","“ศาสตราจารย์ลินน์ มันมีวิธีวัดความเร็วของแสงจริงๆ งั้นหรือ?”","ซานเชซถามด้วยความสับสน","พ่อมดแม่มดที่อยู่ในเหตุการณ์ทั้งหมดต่างก็มองไปที่ดาวรุ่งแห่งเวทมนตร์เช่นกัน","“แน่นอน!”","ลินน์พยักหน้า หยุดไปครู่หนึ่ง แล้วพูดต่อ","“อันที่จริง วิธีการของข้านั้นไม่ได้ซับซ้อนอะไร และก็ไม่ได้มีฉากที่ใหญ่โตเช่นนี้...”","สิ่งนี้ทำให้ราฟาเอลและคนอื่นๆ ยิ่งอยากรู้อยากเห็นมากขึ้นไปอีก แต่ลินน์ก็แค่ส่ายหัวและแสร้งทำเป็นปกปิดเอาไว้","“อุปกรณ์ทดลองยังต้องใช้เวลาเตรียมการอีกสักหน่อย แต่อย่างไรก็ตาม พวกเจ้าก็จะได้รู้ในอีกไม่กี่วันข้างหน้า!”","ราฟาเอลและคนอื่นๆ ต่างก็พูดไม่ออก แต่พวกเขาก็ไม่มีทางเลือกอื่น นอกจากต้องเดาอยู่ในใจว่าวิธีการ ‘ไม่ซับซ้อน’ ที่ลินน์พูดถึงคืออะไร","แฮร์รอฟสงสัยว่ามันจะใช้เวทมนตร์บางอย่างเพื่อชะลอความเร็วของแสงให้ช้าลง เพื่อตอบสนองต่อความต้องการในการวัดหรือไม่ หรือสร้างแสงจ้าเพื่อยิงขึ้นไปบนดวงจันทร์ จากนั้นก็วัดมันตามเวลาที่มาถึงและระยะทางที่ถูกประเมินเอาไว้","พ่อมดบางคนถึงกับคิดด้วยความมุ่งร้ายว่า ดาวรุ่งแห่งเวทมนตร์ผู้นี้อาจจะกำลังเล่นตุกติกอยู่ มันคงจะน่าขันมากหากการทดลองในภายหลังต้องพบกับความล้มเหลวแบบเกล็น..."]},{"n":334,"t":"ข้าต้องการเพียงแค่เฟืองเล็กๆ หนึ่งตัว เพื่อใช้วัดความเร็วของแสง!","c":["การทดลองวัดลำแสงของเกล็น แม้ว่าท้ายที่สุดแล้วจะล้มเหลวอย่างไม่เป็นท่า แต่มันก็ผลักดันความอยากรู้อยากเห็นของพ่อมดแม่มดเกี่ยวกับความเร็วของแสง ให้ขึ้นไปสู่จุดสูงสุดอีกครั้ง","เพราะผลลัพธ์ของการทดลองทำให้พวกเขาตกตะลึงมากเกินไป และพลังอันน่าสะพรึงกลัวของการรวบรวมแสงที่รุนแรงจนกลายเป็นลำแสง ก็ทำให้พ่อมดแม่มดทุกคนพูดถึงเรื่องนี้เช่นกัน","เป็นที่คาดการณ์ได้เลยว่า วิชาทัศนศาสตร์จะกลายเป็นทิศทางการวิจัยของพ่อมดแม่มดหลายคนในอนาคต","อย่างไรก็ตาม เกี่ยวกับการวัดความเร็วของแสง พ่อมดแม่มดก็ถูกแบ่งออกเป็นสองฝ่าย บางคนยืนกรานว่าความเร็วของแสงนั้นเป็นอนันต์ เพราะท้ายที่สุด พวกเขาก็สามารถมองเห็นดวงอาทิตย์และดวงจันทร์ที่อยู่ห่างไกลจากที่นี่ได้ในพริบตาเดียว","การวัดความเร็วของแสงเป็นเรื่องไร้สาระ!","ในขณะที่อีกกลุ่มหนึ่งคิดว่า ความเร็วของแสงนั้นมีขีดจำกัด เพราะทุกสิ่งย่อมมีขีดจำกัดของมัน และ ‘ธาตุแสง’ ก็ไม่มีข้อยกเว้น เพียงแต่พวกเขาคิดไม่ออกว่าจะทำการทดลองเช่นนี้ต่อไปได้อย่างไร","สำหรับแสง แม้แต่ระยะทาง 100 กิโลเมตรก็เกิดขึ้นในชั่วพริบตา หากสิ่งนี้มีความเร็ว มันก็จะต้องเกิน 10,000 กิโลเมตรต่อวินาทีแน่ๆ ในขณะที่เส้นรอบวงของดาวนิรันดร์มีเพียงแค่ 40,000 กว่ากิโลเมตรเท่านั้น!","“เป็นไปได้ไหมที่จะทำการทดลองที่ปลายทั้งสองด้านของดาวเคราะห์?”","แนวคิดนี้ผุดขึ้นมาในใจของซานเชซ ด้วยวิธีนี้ สถานที่ทดลองก็จะมีขนาดใหญ่พอ แล้วพวกเขาจะไปที่นั่นได้อย่างไร?","“เจ้าทึ่ม ดาวเคราะห์ดวงนี้เป็นทรงกลม และแสงก็เดินทางเป็นเส้นตรง มันจะถูกปิดกั้นหรือไม่ก็บินออกไปในจักรวาล แต่มันไม่สามารถไปถึงอีกฝั่งหนึ่งได้หรอก”","ราฟาเอลกล่าวเยาะเย้ย","“ถ้างั้นเจ้ามีวิธีไหนอีกเล่า?”","ซานเชซถามด้วยความโกรธ","ราฟาเอลอ้าปากค้าง จากนั้นก็ส่ายหัวอย่างช่วยไม่ได้","“แล้วข้าจะไปรู้ได้อย่างไร?”","ดาวรุ่งแห่งเวทมนตร์ผู้นี้มีความคิดมากมายเหลือเกิน ก่อนงานสัมมนาเวทมนตร์เมื่อปีที่แล้ว ใครจะไปคิดว่าเพียงแค่การตั้งแท่งน้ำแข็งบนพื้นทะเล และวัดความยาวของเงา ก็สามารถคำนวณเส้นรอบวง ความยาว และปริมาตรของดาวเคราะห์ทั้งดวงได้แล้ว?","ดังนั้น ราฟาเอลจึงเดาไม่ออกเลยว่า ครั้งนี้อีกฝ่ายจะมีความคิดที่แปลกใหม่และยอดเยี่ยมแบบไหนออกมาให้เห็นอีก...","ความอยากรู้อยากเห็นก็คือความอยากรู้อยากเห็น งานสัมมนาเวทมนตร์ในปีนี้จะยังคงดำเนินต่อไป หลังจากผ่านไปสามวัน ก็มีผู้ได้รับเหรียญตราดาวประกายพฤกษ์สามคน","เกล็นผู้สร้างเวทมนตร์รวบรวมแสง ฟูล่าผู้เป็นตัวแทนของแอนโธนีขึ้นไปบนเวทีเพื่ออธิบายทฤษฎีแม่เหล็กไฟฟ้า และ...โยลันด์ ผู้สร้างกล้องจุลทรรศน์แบบเรียบง่าย...โดยพ่อมดแห่งสถาบันพยากรณ์ผู้นี้ถึงกับพูดไม่ออก หลังจากที่ถูกลินน์หักล้างแนวคิดในงานสัมมนาปีที่แล้ว ดังนั้น เขาจึงเรียนรู้จากความเจ็บปวด และอุทิศตนให้กับงานวิจัย","ในขณะที่ใช้กล้องโทรทรรศน์ดาราศาสตร์เพื่อสังเกตดูดวงดาวที่อยู่ห่างไกล โยลันด์ก็ทำการปรับปรุงสิ่งนั้นตามอำเภอใจ และสร้างกล้องจุลทรรศน์ขึ้นมาได้สำเร็จ","แม้ว่าทั้งสองจะเคยเผชิญหน้ากันในงานสัมมนาเมื่อปีที่แล้ว แต่ลินน์ก็ไม่ได้เก็บเอาความขัดแย้งเล็กๆ น้อยๆ นี้มาใส่ใจ มันเป็นเพียงแค่ข้อพิพาททางวิชาการ ไม่ว่าการโต้เถียงจะรุนแรงแค่ไหน มันก็เป็นเรื่องปกติ เพื่อไม่ให้ตนเองต้องรู้สึกรังเกียจ ลินน์จึงใจกว้างมากที่จะเสนอชื่อโยลันด์ให้รับเหรียญตราดาวประกายพฤกษ์","ความมีน้ำใจเช่นนี้ทำให้โยลันด์รู้สึกละอายใจเป็นอย่างยิ่ง","เขาเตรียมตัวรับมือกับการถูกเพ่งเล็งในครั้งนี้ไว้แล้ว และถึงขั้นเขียนสุนทรพจน์ล่วงหน้านับหมื่นคำ เพื่ออธิบายถึงความสำคัญของงานวิจัยชิ้นนี้ แต่เขาไม่คาดคิดเลยว่ามันจะไม่จำเป็นต้องใช้เลย เพราะลินน์เป็นคนแรกที่เสนอชื่อของเขาต่อคณะกรรมการเพื่อมอบเหรียญตราดาวประกายพฤกษ์ให้","ในช่วงไม่กี่วันที่ทำงานร่วมกัน ราฟาเอลพยายามพูดอ้อมค้อมอยู่เสมอ โดยหวังว่าลินน์จะเปิดเผยรายละเอียดบางอย่าง แต่ฝ่ายหลังก็ปฏิเสธที่จะตอบกลับ...เขาจึงทำได้เพียงแค่พึมพำกับตัวเอง ซึ่งบางทีข้อสันนิษฐานของซานเชซอาจจะถูกต้อง ดาวรุ่งแห่งเวทมนตร์ผู้นี้ยังไม่แน่ใจเกี่ยวกับการทดลองอย่างเต็มที่ เขาจึงเก็บมันไว้เป็นความลับ","ลินน์ไม่ได้ให้ความสนใจกับข่าวลือต่างๆ ที่แพร่กระจายอย่างบ้าคลั่งในดินแดนพ่อมด และหลังจากที่กลับไปที่ห้องรับรองของสถาบันอิเยตา เขาก็เรียกเอล็อคและคนอื่นๆ มา และถามเกี่ยวกับการเตรียมตัวของพวกเขา","“ศาสตราจารย์ลินน์ เฟืองที่ท่านให้พวกเราสร้างเสร็จเรียบร้อยแล้ว!”","เอล็อคและเพียร์ซกล่าวอย่างเหนื่อยล้า","เพราะพวกเขานั้นใช้เวลาสามวันในการผลิตเฟืองขนาดเดียวกันสิบตัว ซึ่งมีตั้งแต่ 500 ซี่ไปจนถึง 1,200 ซี่ และตามคำแนะนำของศาสตราจารย์ ว่าต้องมั่นใจในความแม่นยำ และระยะห่างระหว่างช่องว่างของเฟืองแต่ละซี่จะต้องเท่ากันทุกประการ และความแม่นยำจะต้องไปถึงระดับหนึ่งในพันของเซนติเมตร","นั่นจึงมีเพียงพ่อมดเต็มตัวเท่านั้นที่สามารถทำงานละเอียดเช่นนี้ได้ ซึ่งนั่นก็คือเหตุผลที่ลินน์ตั้งใจพาพวกเขามาที่นี่ด้วย ท้ายที่สุดแล้ว มันก็ต้องมีคนรับผิดชอบงานนี้!","และลิเดียกับจอห์นนี่ก็รับผิดชอบในการผลิตกระจกกึ่งสะท้อนและกระจกเงา ซึ่งตอนนี้ก็เสร็จสมบูรณ์แล้วเช่นกัน","“ดีมาก ดูเหมือนว่าการทดลองจะสามารถเริ่มได้ในคืนนี้!”","ลินน์ตรวจสอบอุปกรณ์ทดลองต่างๆ และพยักหน้าด้วยความพึงพอใจ","เอล็อคและคนอื่นๆ รู้สึกแปลกใจเป็นอย่างยิ่ง ศาสตราจารย์ขอให้พวกเขาสร้างเฟืองจำนวนมากไปทำไมกัน?","“เราจะใช้สิ่งเหล่านี้เพื่อวัดความเร็วของแสงงั้นหรือ?”","ลิเดียยกมือขึ้นแล้วถาม","“ใช่แล้ว มีแค่เฟืองพวกนี้ก็พอ!”","ลินน์พยักหน้า","ในตอนกลางคืน ภายในนครกรีนรีล พ่อมดแม่มดที่ได้รับข่าวและมาเฝ้าดูการทดลองต่างก็หลั่งไหลกันเข้ามาจนเต็มจัตุรัส","ด้วยฉายาดาวรุ่งแห่งเวทมนตร์ ควบคู่ไปกับการทดลองวัดความเร็วของแสง จึงไม่มีใครอยากพลาดโอกาสสำคัญเช่นนี้","“ศาสตราจารย์ลินน์ พวกเรารอมาหลายวันแล้ว ตอนนี้ท่านคงจะไม่ปิดบังอะไรแล้วใช่หรือไม่?”","ราฟาเอลกล่าวอย่างช่วยไม่ได้","“วิธีการของข้านั้นง่ายมาก และทุกอย่างที่ข้าต้องการก็อยู่ที่นี่แล้ว!”","ลินน์กล่าวพร้อมกับรอยยิ้ม","ราฟาเอลและคนอื่นๆ มองไปที่อุปกรณ์ทดลองตรงหน้าลินน์ด้วยความอยากรู้อยากเห็น โดยมีสิ่งที่สะดุดตาที่สุดก็คือ เครื่องมือแปรธาตุที่ดูแปลกประหลาด ซึ่งหลังจากที่ลินน์อธิบาย พวกเขาก็ตระหนักได้ว่าสิ่งนี้ถูกใช้เพื่อปล่อยลำแสงออกมา และหลักการของมันก็ใกล้เคียงกับเวทมนตร์รวบรวมแสงของเกล็น","มีกระจกสะท้อนแสงถูกวางเอาไว้บนกำแพงเมืองของเขตพื้นที่โดยรอบ ซึ่งอยู่ห่างจากจัตุรัสแห่งนี้เพียงแค่สี่กิโลเมตร...","“นี่มันไม่ใช่กระจกที่เกล็นสร้างขึ้นมาเมื่อไม่กี่วันก่อนเพื่อวัดความเร็วแสงหรอกหรือ?”","แนนซี่พึมพำเบาๆ และพ่อมดแม่มดที่อยู่ในเหตุการณ์ทั้งหมดก็พยักหน้าอย่างพร้อมเพรียงกัน","ต้องรู้ก่อนว่า เกล็นใช้กระจกหนึ่งร้อยบานเพื่อสร้างระยะทางหนึ่งร้อยกิโลเมตร แต่ท้ายที่สุดมันก็ยังคงจบลงด้วยความล้มเหลว แม้ว่ากระจกที่ลินน์ตั้งไว้จะทอดยาวผ่านนครกรีนรีลไปกว่าครึ่งเมือง แต่เมื่อนับรวมระยะทางไปกลับแล้ว มันก็เป็นระยะทางเพียงแค่แปดกิโลเมตร ซึ่งยังไม่ถึงหนึ่งในสิบเลยด้วยซ้ำ","มันเป็นไปไม่ได้เลยที่จะวัดความเร็วของแสงออกมาได้!","“ดังนั้นเราจึงต้องเพิ่มสิ่งนี้เข้าไป!”","ลินน์ชี้ไปที่สิ่งที่อยู่ในมือของเอล็อค","“นี่คือส่วนที่สำคัญที่สุดของการทดลองนี้!”","“เฟืองงั้นหรือ?”","ราฟาเอลจำมันได้ตั้งแต่แรกเห็น และไม่ใช่เรื่องแปลกใหม่สำหรับนักเล่นแร่แปรธาตุ เพราะมันเคยปรากฏอยู่ในเครื่องจักรไอน้ำที่สร้างโดยสมาคมการเล่นแร่แปรธาตุมาก่อนหน้านี้แล้ว","แล้วสิ่งนี้มันเกี่ยวอะไรกับการวัดความเร็วของแสงกัน?"]},{"n":335,"t":"วิธีของข้าคือการใช้เฟืองและแสงเพื่อเปรียบเทียบความเร็ว!","c":["ภายใต้สายตาที่งุนงงของทุกคน เอล็อคได้ติดตั้งเฟืองเอาไว้ที่ด้านหน้าของเครื่องมือแปรธาตุที่ใช้ปล่อยลำแสง และวางกระจกที่มีลักษณะแปลกประหลาดมากเอาไว้ระหว่างพวกมัน","ลินน์อธิบายในที่สุด","“นี่คือกระจกกึ่งสะท้อน! มันแตกต่างจากกระจกธรรมดาทั่วไป เพราะตามชื่อของมันเลย มีเพียงด้านเดียวเท่านั้นที่ปล่อยให้ลำแสงส่องผ่านไปได้!”","เกล็นมองไปมาด้วยความประหลาดใจ ด้านหนึ่งสามารถมองเห็นฉากที่อยู่ด้านหลังได้อย่างชัดเจน ในขณะที่อีกด้านหนึ่งกลับเบลอ","“การทดลองนี้เรียบง่ายมาก นั่นก็คือเครื่องมือแปรธาตุนี้จะปล่อยลำแสงออกมา เมื่อเฟืองหยุดนิ่ง แสงก็จะสะท้อนกลับมาทางเดิมหลังจากที่ผ่านช่องว่างของซี่เฟืองไปกระทบเข้ากับกระจกเงา ในอีกด้านหนึ่งของกระจกกึ่งสะท้อนก็จะเกิดจุดแสงที่ใหญ่ขึ้น ซึ่งช่วยให้เราสามารถมองเห็นมันได้อย่างชัดเจน!”","ในขณะที่พูด ลินน์ก็เปิดการทำงานของเครื่องมือแปรธาตุ และลำแสงสองเส้นก็ปรากฏขึ้นกลางอากาศทันที","อย่างที่เขาพูดเอาไว้ แสงผ่านกระจกกึ่งสะท้อน ข้ามช่องว่างของซี่เฟือง ไปกระทบเข้ากับกระจกสะท้อนที่อยู่ห่างออกไปอย่างแม่นยำ ก่อนจะสะท้อนกลับมา และผ่านช่องว่างของซี่เฟืองมากระทบเข้ากับกระจกกึ่งสะท้อนอีกครั้ง","“แต่ถ้าเฟืองเริ่มหมุน...แสงที่ผ่านช่องว่างของซี่เฟืองไปก็อาจจะถูกปิดกั้นได้เมื่อมันสะท้อนกลับมา”","ลินน์หยุดไปครู่หนึ่ง และด้วยความคิด ภายใต้การควบคุมของหัตถ์เวท เฟืองก็ค่อยๆ หมุนขึ้นมา","ลินน์ไม่จำเป็นต้องอธิบายให้มากความ ทุกคนก็สามารถมองเห็นได้ว่าลำแสงที่อยู่ด้านหลังเฟืองขนาดยักษ์เริ่มปรากฏและหายไป และจุดแสงบนกระจกกึ่งสะท้อนก็กะพริบเช่นกัน นั่นเป็นเพราะเมื่อแสงสะท้อนกลับมา มันอาจจะผ่านช่องว่างของซี่เฟืองได้พอดี หรือมันอาจจะถูกบดบังด้วยตัวเฟืองก็ได้...","ในขณะที่พ่อมดแม่มดกำลังขมวดคิ้วและครุ่นคิดเกี่ยวกับปรากฏการณ์นี้ คำพูดของลินน์ก็ดังขึ้นอีกครั้ง","“ในทางทฤษฎี หากความเร็วของเฟืองนั้นมากพอ แสงที่ผ่านช่องว่างซี่แรกไปและสะท้อนกลับมาในระยะทางแปดกิโลเมตร ก็จะผ่านช่องว่างซี่ที่สองได้พอดี ด้วยวิธีนี้...”","ก่อนที่ลินน์จะพูดจบ เกล็นก็พูดขึ้นด้วยความตกใจ ราวกับว่าคิดอะไรบางอย่างออก","“ถ้าเป็นอย่างนั้น ธาตุแสงทุกตัวที่สามารถผ่านช่องว่างแรกไปได้ ก็จะสะท้อนกลับมาจากช่องว่างที่สองอย่างแน่นอน และมันก็ไม่มีความเป็นไปได้เลยที่จะถูกบดบัง ซึ่งลำแสงและจุดแสงก็จะปรากฏออกมาให้เห็นอย่างชัดเจนมาก!”","คำพูดของเกล็นเปรียบเสมือนการโยนหินก้อนใหญ่ลงไปในทะเลสาบที่เงียบสงบ และพ่อมดแม่มดที่อยู่ในเหตุการณ์ก็ระเบิดความตื่นเต้นออกมาทันที","“นี่มันเป็น...แนวคิดที่อัจฉริยะมาก!”","ราฟาเอลกล่าวด้วยน้ำเสียงที่สั่นเครือ","ก่อนหน้านี้ เขาเอาแต่คิดอยู่เสมอว่าดาวรุ่งแห่งเวทมนตร์ผู้นี้จะใช้วิธีไหนในการวัดความเร็วของแสง แต่เขาไม่คาดคิดเลยว่าอีกฝ่ายจะสามารถทำมันได้ด้วยเฟืองเล็กๆ เพียงแค่ตัวเดียวเท่านั้น!","วิธีการนี้โดดเด่นมาก และมีอยู่แค่สองคำเท่านั้น นั่นก็คือ กลอุบาย!","ส่วนที่สำคัญที่สุดของการทดลองนี้ ก็คือการทำให้เวลาที่เฟืองหมุนไปหนึ่งซี่ สัมพันธ์กับเวลาที่แสงถูกปล่อยออกไปและสะท้อนกลับมา","ความละเอียดอ่อนก็คือ แสงจะต้องเดินทางผ่านระยะทางเต็มแปดกิโลเมตร ในขณะที่เฟืองตรงหน้าเพียงแค่ต้องหมุนไปเพียงเล็กน้อย เพื่อไปให้ถึงช่องว่างซี่ที่สอง!","นั่นก็หมายความว่า ระยะห่างของเฟืองแต่ละซี่นั้น แสดงถึงระยะทางที่แสงเดินทางไปแล้วแปดกิโลเมตร หากมีช่องว่างเฟืองทั้งหมดหนึ่งพันซี่ และพวกมันหมุนครบหนึ่งรอบ แสงก็จะต้องเดินทางไปแล้วแปดพันกิโลเมตร!","พ่อมดแม่มดที่เข้าใจประเด็นนี้ก็อดไม่ได้ที่จะสูดหายใจเข้าลึกๆ เฟืองเล็กๆ ตัวนี้ก็เปรียบเสมือนเครื่องขยายเสียงชั้นยอดเลย!","ความเร็วของแสงอาจจะรวดเร็วอย่างไม่น่าเชื่อ แต่ความเร็วของเฟืองก็สามารถเพิ่มขึ้นได้อย่างรวดเร็วเช่นกัน...","“นี่คืออัตราส่วนความเร็วระหว่างเฟืองและแสง!”","แฮร์รอฟถอนหายใจออกมาเช่นกัน","มันก็แค่ลินน์ไม่ได้ปฏิบัติตามกฎเกณฑ์ เฟืองเดินทางไปเพียงแค่ห้ามิลลิเมตร (ระยะทางของหนึ่งซี่) และแสงก็ต้องวิ่งไปแปดกิโลเมตร...ช่องว่างที่แตกต่างกันนับแสนเท่า!","ท้ายที่สุด เจ้าก็เพียงแค่ต้องรู้ระยะทางที่เฟืองเคลื่อนที่ไป แล้วคูณด้วยความแตกต่างที่หลากหลายนี้ นั่นก็คือ ให้ดูที่จำนวนซี่ที่แยกเฟืองเอาไว้ และจำนวนรอบของเฟืองในหนึ่งวินาที และเจ้าก็สามารถคำนวณความเร็วของแสงกลับมาได้!","มิน่าล่ะลินน์ถึงมั่นใจนักว่าเขาสามารถวัดความเร็วของแสงได้...","“มันน่าทึ่งมาก สมกับเป็นดาวรุ่งแห่งเวทมนตร์จริงๆ!”","ซานเชซกล่าวด้วยความถอนหายใจ","เขาเชื่อมั่นอย่างหมดใจ ว่าสมองแบบไหนกันที่จะสามารถคิดวิธีแบบนี้ขึ้นมาได้","อย่างไรก็ตาม ก็ยังมีพ่อมดแม่มดอีกจำนวนไม่น้อยที่เฝ้าดูด้วยสีหน้าที่งุนงง","บ้าอะไรกันที่พวกเจ้ากำลังพูดถึง? ทำไมข้าถึงไม่เข้าใจเลย...","แต่เพื่อรักษาศักดิ์ศรีในฐานะพ่อมด พวกเขาก็ยังคงพยักหน้าแสร้งทำเป็นเข้าใจ และพูดคำชมเชยออกไปสองสามคำ","“สมกับเป็นดาวรุ่งแห่งเวทมนตร์...”","“วิธีนี้ดีมาก! ข้ารู้ว่าเขาจะต้องมีวิธีแน่!”","ท่ามกลางเสียงสรรเสริญ ก็ยังมีเสียงต่อต้านซ่อนอยู่ และคนอื่นๆ ยืนกรานว่าความเร็วของแสงนั้นเป็นอนันต์ ไม่ว่าลินน์จะเร่งความเร็วของเฟืองได้เร็วแค่ไหน มันก็เปล่าประโยชน์!","“ศาสตราจารย์ลินน์ พวกเราเริ่มได้เลยหรือไม่?”","ลิเดียตะโกนถามเสียงดัง","ลินน์พยักหน้า และขอให้เด็กสาวฮาล์ฟลิงสตาร์ทเครื่องยนต์สันดาปภายใน เพื่อเพิ่มความเร็วของเฟือง","ภายใต้สายตาของทุกคน เฟือง 720 ซี่ที่อยู่ตรงหน้าเขาเริ่มหมุนอย่างช้าๆ จากนั้นความเร็วก็ค่อยๆ เพิ่มขึ้น ห้ารอบต่อวินาที สิบรอบ สิบห้ารอบ...และในไม่ช้ามันก็กลายเป็นภาพติดตา","ลำแสงและจุดแสงบนกระจกกึ่งสะท้อนก็กะพริบอย่างต่อเนื่องเช่นกัน และความถี่ก็เร็วขึ้นเรื่อยๆ เพราะแสงเปลี่ยนไปมาระหว่างผ่านกับไม่ผ่านอยู่เสมอ...","“มันเร็วมาก...”","แม่มดแนนซี่พึมพำกับตัวเอง ซึ่งนางไม่สามารถมองเห็นความเร็วของเฟืองได้เลย","“ด้วยความเร็วระดับนี้ แสงจะสามารถแยกแยะช่องว่างเล็กๆ ระหว่างซี่เฟืองได้จริงๆ งั้นหรือ?”","จำเป็นต้องรู้ว่า ระยะห่างระหว่างช่องว่างของซี่เฟืองแต่ละซี่นั้นมีเพียง 0.5 ซม. เท่านั้น และมันก็จะกลายเป็นเครื่องมือตัดอันแหลมคมเมื่อมีความเร็วสูง แล้วถ้าเกิดธาตุแสงไม่สามารถหาช่องว่างของซี่เฟืองเจอในตอนที่มันวิ่งผ่านไปล่ะ?","พวกเขาจะไม่สามารถมองเห็นมันได้เลยใช่หรือไม่?","“พวกเราอาจจะไม่สามารถแยกแยะได้ แต่แสงจะต้องทำได้อย่างแน่นอน!”","ลินน์กล่าวด้วยความมั่นใจ","“ดูสิ ความถี่ในการกะพริบของลำแสงและจุดแสงดูเหมือนจะ...ช้าลงนะ!”","ราฟาเอลรีบเตือน","เขาไม่ได้เป็นเพียงคนเดียวที่สังเกตเห็นสิ่งนี้ เพราะการเปลี่ยนแปลงนั้นชัดเจนมากจนไม่สามารถเป็นเพียงแค่ภาพลวงตาได้ หลังจากที่ความเร็วในการหมุนของเฟืองเพิ่มขึ้นอีกครั้ง ใบหน้าของพ่อมดแม่มดที่อยู่ในเหตุการณ์ก็แสดงความตกใจออกมา...","“จุดแสง...หายไปแล้ว!”","ซานเชซเบิกตากว้าง และก็มีฉากที่แปลกประหลาดอย่างมากปรากฏขึ้นตรงหน้าเขา ลำแสงเล็กๆ ที่ถูกปล่อยออกมาจากเครื่องมือแปรธาตุ ได้หยุดอยู่ที่เฟืองเมื่อมันสะท้อนกลับมา แต่ลำแสงในระยะห่างจากเฟืองไปจนถึงกระจกกึ่งสะท้อนกลับหายไปในทันที มันไม่ปรากฏขึ้นและหายไปเหมือนเมื่อก่อนแล้ว และบนกระจกกึ่งสะท้อนก็ไม่มีจุดแสงใดๆ เลย","ซึ่งนี่มันตรงกันข้ามกับสิ่งที่ลินน์พูดเอาไว้อย่างสิ้นเชิง...","“นี่มันเกิดอะไรขึ้น?”","ราฟาเอลแทบจะกระชากเคราของเขาออกมา ในหัวเต็มไปด้วยความสงสัย","“นั่นเป็นเพราะแสงที่ผ่านช่องว่างของซี่เฟืองไป ได้กระทบเข้ากับซี่เฟืองพอดีเมื่อมันสะท้อนกลับมา สิ่งนี้แสดงให้เห็นว่าความเร็วของแสงนั้นมีขีดจำกัด และพวกเราก็ประสบความสำเร็จไปแล้วครึ่งหนึ่ง!”","คำพูดของลินน์ดังก้องอยู่ในหูของทุกคน"]},{"n":336,"t":"แสงสามารถโคจรรอบทวีปได้เจ็ดรอบครึ่งในเวลาเพียงหนึ่งวินาที!","c":["ภายใต้คำอธิบายของลินน์ พ่อมดแม่มดที่อยู่ในเหตุการณ์ก็ตอบสนองกลับมา พวกเขามองไปที่เฟืองที่หมุนอยู่อย่างต่อเนื่องตรงหน้า และใบหน้าของพวกเขาก็เต็มไปด้วยความตกตะลึง","เฟืองตัวนี้ได้ปิดกั้นธาตุแสงทั้งหมดที่พยายามจะผ่านช่องว่างของซี่เฟืองไป โดยไม่มีข้อยกเว้น!","“นี่มันไม่ใช่เวทมนตร์!”","คนอื่นๆ ตะโกนออกไปด้วยความไม่เชื่อ","การเกิดสถานการณ์ที่แปลกประหลาดเช่นนี้ พิสูจน์ให้เห็นโดยตรงเลยว่าความเร็วของแสงนั้นไม่ได้เป็นอนันต์! มิฉะนั้น แสงทุกลำที่ผ่านช่องว่างของซี่เฟืองไป จะต้องสะท้อนกลับมาในทันที และมันก็ไม่มีความเป็นไปได้เลยที่จะถูกบดบัง...","“มันเป็นไปได้ วิธีนี้มันเป็นไปได้จริงๆ!”","เกล็นพึมพำกับตัวเอง","อย่างที่ลินน์บอก พวกเขาประสบความสำเร็จไปแล้วครึ่งหนึ่ง จากนั้นพวกเขาก็เพียงแค่ต้องเพิ่มความเร็วต่อไป และแสงที่สะท้อนกลับมาก็จะค่อยๆ เคลื่อนถอยหลัง ข้ามระยะห่างของซี่เฟืองที่ปิดกั้นเอาไว้ และไปถึงช่องว่างของซี่เฟืองถัดไป!","“ตอนนี้ความเร็วอยู่ที่เท่าไหร่แล้ว?”","ราฟาเอลถามอย่างกระตือรือร้น","“ยี่สิบห้ารอบต่อวินาที!”","ลิเดียรายงานเสียงดัง","“เร่งความเร็วขึ้นอีก เร็วขึ้นอีก!”","ราฟาเอลตะโกนเสียงดัง","ลิเดียเหลือบมองลินน์ จากนั้นก็เพิ่มกำลังของเครื่องยนต์สันดาปภายในอีกครั้งตามคำแนะนำ และความเร็วของเฟืองก็เพิ่มขึ้นหลายระดับในทันที ซึ่งมันสามารถอธิบายได้เพียงแค่คำว่าเกินจริงเท่านั้น และเสียงที่ดังสนั่นก็ดังก้องอยู่ในหูของทุกคน","แม้แต่เอล็อคและคนอื่นๆ ที่อยู่รอบนอกก็ยังรู้สึกกังวลเล็กน้อย ว่าสิ่งนี้จะพังทลายลงมาอย่างกะทันหันหรือไม่","หลังจากที่เร่งความเร็วไปถึงสามสิบห้ารอบต่อวินาที จุดแสงก็ยังคงไม่ปรากฏขึ้น แต่ความเร็วของเฟืองก็ใกล้จะถึงขีดจำกัดแล้ว!","แม้ว่าลินน์จะขอให้พวกเขาและคนอื่นๆ ลดระยะห่างระหว่างซี่เฟืองลงเหลือ 0.5 เซนติเมตร แต่ถึงกระนั้น เส้นรอบวงของตัวเฟืองเองก็มีความยาวที่น่าทึ่งถึงเจ็ดเมตร และมันก็อาจจะพังทลายลงมาได้ทุกเมื่อในขณะที่รักษาความเร็วสูงเป็นพิเศษเอาไว้!","“หลีกไป ข้ามาแล้ว!”","แฮร์รอฟก้าวไปข้างหน้า ซึ่งขัดจังหวะพลังการหมุนที่ถูกสร้างขึ้นโดยเครื่องยนต์สันดาปภายใน และใช้เวทมนตร์เพื่อเร่งความเร็วของเฟืองให้มากกว่าสี่สิบรอบในทันที!","เพื่อรับประกันความแม่นยำ แฮร์รอฟนั้นไม่ได้เพิ่มความเร็วให้เร็วเกินไป แต่เพิ่มขึ้นด้วยความเร็วที่สมดุล...","เมื่อความเร็วในการหมุนของเฟืองเกิน 52 รอบต่อวินาที พ่อมดแม่มดทุกคนที่อยู่ในเหตุการณ์ก็สามารถมองเห็นได้อย่างชัดเจน ว่ามีจุดแสงที่สะดุดตาปรากฏขึ้นบนกระจกกึ่งสะท้อนอีกครั้ง!","นี่หมายความว่าแสงที่ผ่านช่องว่างซี่แรกไป ได้สะท้อนกลับมาจากช่องว่างซี่ที่สองแล้ว!","ในขณะที่ทุกคนกำลังโห่ร้องด้วยความดีใจ เฟืองทั้งหมดก็ระเบิดออก และเศษซากของมันก็ปลิวว่อนไปทั่วทุกทิศทางราวกับมีดที่แหลมคม!","มีเสียงกรีดร้องดังออกมาจากฝูงชน โชคดีที่แฮร์รอฟไม่ยอมให้อุบัติเหตุในการทดลองเกิดขึ้นซ้ำสอง เศษเฟืองที่ปลิวว่อนเหล่านี้ดูเหมือนจะตกลงไปในปลักโคลน ภายใต้ผลลัพธ์ของอาณาเขตชะลอความเร็ว ความเร็วในการปลิวของมันก็ช้าลงเรื่อยๆ และในที่สุดมันก็ลอยนิ่งอยู่กลางอากาศโดยตรง","“เมื่อกี้ความเร็วอยู่ที่เท่าไหร่? ท่านประธานสภา?”","ราฟาเอลถามอย่างตื่นเต้น","“ห้าสิบสองรอบต่อวินาที!”","แฮร์รอฟกล่าวอย่างมั่นใจ","ค่านี้ไม่มีทางผิดพลาดอย่างแน่นอน!","ราฟาเอลคำนวณในใจของเขาทันที","เจ็ดร้อยยี่สิบซี่ คูณด้วยแปดกิโลเมตร และคูณด้วยห้าสิบสองรอบ นั่นก็คือ...สองแสนเก้าหมื่นเก้าพันห้าร้อยยี่สิบกิโลเมตรต่อวินาที!","เมื่อคำนวณค่านี้ออกมา ใบหน้าของพ่อมดแม่มดทุกคนก็แสดงความไม่เชื่อออกมา และพวกเขาก็อดไม่ได้ที่จะสงสัยว่าตนเองคำนวณผิดหรือไม่","นี่มันเร็วเกินไปแล้ว...","มิน่าล่ะ พวกเขาถึงไม่สามารถหาเส้นทางการเดินทางของแสงพบได้ ไม่ว่าจะวัดอย่างไรก่อนหน้านี้","“นี่ไม่ได้หมายความว่า แสงสามารถโคจรรอบดาวนิรันดร์ทั้งดวงได้เจ็ดรอบครึ่งในเวลาเพียงหนึ่งวินาทีหรอกหรือ?”","แม่มดแนนซี่ก็ตระหนักถึงสิ่งนี้ขึ้นมาทันที","เส้นรอบวงของทวีปใต้ฝ่าเท้าของพวกเขามีเพียง 40,000 กิโลเมตรเท่านั้น","“นี่มันจะเกินจริงไปหน่อยหรือไม่?”","ซานเชซขมวดคิ้ว ความเร็วเกือบ 300,000 กิโลเมตรต่อวินาที ภายในขอบเขตความรู้ของพวกเขา มันไม่มีความแตกต่างระหว่างช่วงเวลากับช่วงเวลาเลย","“มีเพียงความเร็วที่รวดเร็วเช่นนี้เท่านั้น ที่เพียงพอสำหรับการเดินทางผ่านจักรวาลอันกว้างใหญ่...”","ออโรร่าเตือนสติ","ยกตัวอย่างเช่น จุดที่ใกล้ที่สุดจากดวงอาทิตย์มายังดาวนิรันดร์ดวงนี้คือประมาณ 140 ล้านกิโลเมตร และมันก็ต้องใช้เวลามากกว่าแปดนาทีแม้จะใช้ความเร็วของแสงก็ตาม!","แต่เมื่อต้องเผชิญกับระยะทางและความเร็วเช่นนี้ แม้แต่พ่อมดระดับตำนานอย่างพวกเขาก็ยังเล็กจ้อยราวกับฝุ่นผง...","“ดังนั้น สิ่งที่เราเห็นทุกวันก็คือดวงอาทิตย์เมื่อหลายนาทีก่อนงั้นหรือ!”","ลิเดียนับนิ้วของนาง และจู่ๆ ก็ได้ข้อสรุปที่น่าอัศจรรย์ออกมา","พ่อมดแห่งสถาบันพยากรณ์อย่างโยลันด์ก็คิดขึ้นมาได้ในทันที ว่าพวกเขาอาจจะสามารถวัดระยะห่างระหว่างดวงดาวได้ผ่านทางความเร็วของแสง ซึ่งจะช่วยคำนวณข้อมูลต่างๆ ที่ประเมินได้ยากในอดีตให้ออกมาได้อย่างง่ายดาย","แน่นอนว่าข้อกำหนดเบื้องต้นนี้ก็คือ พวกเขาจำเป็นต้องวัดความเร็วในการเดินทางของแสงในสุญญากาศของจักรวาล...","ในขณะที่พ่อมดแม่มดต่างตกตะลึงกับความเร็วที่น่าสะพรึงกลัวของแสง ลินน์ก็กำลังคิดถึงอีกเรื่องหนึ่งอยู่ในใจ","ความเร็วของแสงในทั้งสองโลกนั้นใกล้เคียงกันมาก...","ลินน์ครุ่นคิดอยู่ในใจอย่างเงียบๆ หากข้อมูลในสมองของเขาไม่ผิดพลาด ความเร็วของแสงที่ถูกวัดได้ในชาติก่อนของเขาก็คือ 299,792 กิโลเมตรต่อวินาที ซึ่งความแตกต่างระหว่างทั้งสองนั้นน้อยมาก บางทีมันอาจจะเป็นแค่เรื่องของความแม่นยำในการวัดที่ทำให้เกิดความแตกต่างขึ้น...","สิ่งนี้สามารถพิสูจน์ได้หรือไม่ว่า ทั้งสองโลกนั้นดำรงอยู่ในจักรวาลเดียวกัน?","นี่ไม่ใช่สิ่งที่เป็นไปไม่ได้ แม้ว่าจะไม่มีสิ่งที่เรียกว่าพลังเวทมนตร์ในสหพันธ์เมื่อชาติก่อน แต่มนุษยชาติก็ยังไม่สามารถควบคุมระบบสุริยะเล็กๆ ได้อย่างสมบูรณ์เลยด้วยซ้ำ เช่นเดียวกับคนป่าเถื่อนที่อาศัยอยู่ในทะเลทราย และคิดว่าทรายสีเหลืองทั่วพื้นดินคือโลกทั้งใบ","อย่างไรก็ตาม ความกว้างใหญ่ของจักรวาลนั้นไกลเกินกว่าจินตนาการของทุกคน บางทีในกาแล็กซีใดกาแล็กซีหนึ่งในจักรวาล อาจจะมีสสารเวทมนตร์ที่เรียกว่าพลังเวทมนตร์ หรือพลังงานอยู่ก็ได้?","แน่นอนว่าความคล้ายคลึงกันระหว่างทั้งสองโลกนั้นมีมากเกินไป และมันอาจจะเป็นโลกในอีกจักรวาลคู่ขนานหนึ่ง...","อย่างไรก็ตาม ข้อสันนิษฐานเหล่านี้ก็เห็นได้ชัดว่าไม่สามารถตรวจสอบได้ในตอนนี้ และลินน์ก็ไม่ได้ใช้ความพยายามมากเกินไปกับมัน แต่ใช้เฟืองที่มีระยะห่างของซี่ฟันที่แตกต่างกัน ซึ่งถูกเตรียมเอาไว้เมื่อนานมาแล้ว เพื่อทำการทดลองซ้ำอีกสองสามครั้ง เพื่อตรวจสอบความถูกต้องของการทดลองนี้","ซึ่งมันก็มีความผันผวนบางอย่างในข้อมูลขั้นสุดท้าย โดยมีช่องว่างประมาณหลายร้อยเมตร","แต่พ่อมดแม่มดที่อยู่ในเหตุการณ์ก็พอใจกับผลลัพธ์นี้เป็นอย่างมาก ท้ายที่สุดแล้ว มันก็ไม่คู่ควรที่จะถูกนำไปพูดถึงเลยเมื่อเทียบกับขนาดอันมหาศาลของความเร็วแสง","บางคนถึงกับคาดเดาว่า ความเร็วของแสงจะแตกต่างกันในภูมิภาคต่างๆ เหมือนกับความเร็วของเสียงหรือไม่ ดังนั้น ข้อมูลของการวัดหลายครั้งจึงมีการเปลี่ยนแปลง","มีเพียงลินน์คนเดียวเท่านั้นที่รู้สึกไม่พอใจเล็กน้อย แน่นอนว่ายิ่งแม่นยำมากเท่าไหร่ก็ยิ่งดีสำหรับการวัดความเร็วของแสง แต่ภายใต้เงื่อนไขที่หยาบกระด้างในปัจจุบัน มันจะไม่มีเครื่องมือที่แม่นยำกว่านี้อีกเลยในระยะเวลาอันสั้น และสิ่งเดียวที่ทำได้ก็คือการทดลองด้วยเฟืองและกระจกแปดด้าน ซึ่งทั้งสองวิธีนี้สะดวกและใช้งานง่าย แต่ข้อผิดพลาดเล็กๆ น้อยๆ ก็เป็นสิ่งที่หลีกเลี่ยงไม่ได้อยู่เสมอ"]},{"n":337,"t":"อัศวินกริฟฟอนแห่งจักรวรรดิ!","c":["หลังจากที่การทดลองวัดความเร็วของแสงเสร็จสิ้นลง งานสัมมนาวิชาการในปีนี้ก็สิ้นสุดลงในที่สุด แต่ผู้คนก็ยังคงพูดถึงวิธีการใช้เฟืองเพื่อวัดระยะทาง","ทันทีหลังจากนั้น พิธีมอบรางวัลก็ถูกจัดขึ้นที่อาณาจักรท้องฟ้า โดยผู้ได้รับการเสนอชื่อทั้งสามคน ได้แก่ ฟูล่า เกล็น และโยลันด์ ต่างก็ได้รับเหรียญตราดาวประกายพฤกษ์อย่างประสบความสำเร็จ","และลินน์ก็ได้รับเหรียญตราจันทร์สีเงินอีกหนึ่งเหรียญ จากการทดลองคำนวณความเร็วของแสงในครั้งนี้!","เพียงแต่สำหรับพิธีมอบรางวัลนี้ พ่อมดแม่มดก็มีความคิดเห็นที่แตกแยกกันเป็นอย่างมาก","พ่อมดแม่มดส่วนใหญ่คิดว่า วิธีการวัดลำแสงที่ลินน์เสนอมานั้นสามารถอธิบายได้เพียงแค่คำว่าอัจฉริยะเท่านั้น!","แม้ว่าการทดลองนี้เพียงอย่างเดียว จะยังห่างไกลจากข้อกำหนดในการได้รับเหรียญตราจันทร์สีเงิน แต่มันก็ไม่ใช่เรื่องใหญ่อะไรที่จะผ่อนปรนให้กับอัจฉริยะสักเล็กน้อย","ยิ่งไม่ต้องพูดถึงว่าอีกฝ่ายได้รับเหรียญตราโคโรนามาแล้ว ดังนั้นมันจึงไม่ทำให้ผู้คนรู้สึกอิจฉา","อย่างไรก็ตาม พ่อมดแม่มดบางคนก็บ่นเกี่ยวกับการที่ดาวรุ่งแห่งเวทมนตร์ผู้นี้ได้รับเหรียญตราจันทร์สีเงิน เพราะแม้ว่าการทดลองของลินน์จะน่าตื่นเต้นและน่าทึ่งมาก แต่ผลลัพธ์สุดท้ายก็มีเพียงแค่ความเร็วของแสงเท่านั้น","และเหรียญตราแบบนี้ มักจะมอบให้กับผู้ที่ทำคุณูปการอันโดดเด่นต่อดินแดนพ่อมด ซึ่งพัฒนาเวทมนตร์ระดับตำนาน หรือเพิ่มเติมองค์ความรู้ที่สำคัญให้กับระบบเวทมนตร์ที่มีอยู่","ในความคิดของพวกเขา การวัดความเร็วของแสงนั้นไม่ได้สอดคล้องกับข้อกำหนดใดๆ เลย กล่าวได้ว่าสภาพ่อมดได้เริ่มต้นได้อย่างเลวร้ายมากในครั้งนี้...","แต่ในฐานะศูนย์กลางของกระแสน้ำ ลินน์ไม่ได้มุ่งเน้นไปที่การได้รับคำชมเชยและการหักล้างคำใส่ร้าย และยังคงศึกษาธาตุพื้นฐานต่อไป ในบางครั้งเขาก็ถูกราฟาเอลและคนอื่นๆ ดึงตัวออกไป และได้ทำความรู้จักกับเหล่าจอมเวทผู้ยิ่งใหญ่ที่ยังอยู่ในนครกรีนรีล","ลินน์ไม่ได้ปฏิเสธการสื่อสารระหว่างจอมเวทผู้ยิ่งใหญ่ เพราะคนเหล่านี้คือผู้ที่เก่งกาจที่สุดในหมู่พ่อมดแม่มด และหลายคนก็ได้รับเหรียญตราดาวประกายพฤกษ์ แม้กระทั่งเหรียญตราจันทร์สีเงินมาแล้วหลายครั้ง ในแง่หนึ่ง พวกเขาต่างก็เป็นเหมือนนิวตันและไอน์สไตน์ของอีกโลกหนึ่ง ซึ่งเป็นกระดูกสันหลังของการพัฒนาเวทมนตร์","ในวันที่สามหลังจากงานสัมมนาวิชาการสิ้นสุดลง สมาชิกสภาทั้งหมดที่อยู่ในนครกรีนรีล ก็ได้รับคำเชิญจากสภาพ่อมด และลินน์ก็ไม่มีข้อยกเว้น ซึ่งเขารู้ว่าจุดประสงค์ของการประชุมครั้งนี้ ส่วนใหญ่ก็เพื่อหารือว่าควรจะทำอย่างไรต่อไป เมื่อเผชิญหน้ากับการรุกรานของศาสนจักร...","อย่างไรก็ตาม ก่อนที่ลินน์จะออกไป ฮาล์ฟลิงดาร์เรนที่ตอนนี้น่าจะอยู่ไกลถึงสถาบันอิเยตา กลับวิ่งมาหาอย่างตื่นตระหนกพร้อมกับผู้คน","“ท่านศาสตราจารย์ แย่แล้ว แย่แล้ว!”","“มีเรื่องอะไรหรือ? ดาร์เรน?”","ลินน์ขมวดคิ้ว และมีข้อสันนิษฐานอยู่ในใจแล้ว","“มันเป็นข้อมูลจากอาณาจักรฮัดลาตา...เมื่อเช้าวานนี้ กองทหารของจักรวรรดิได้ข้ามพรมแดนมาอย่างกะทันหัน!”","ดาร์เรนหอบหายใจ และยื่นจดหมายที่ถูกปิดผนึกมาให้","นี่มันเร็วกว่าที่เขาคาดคิดไว้มาก...ลินน์เปิดซองจดหมายทันทีหลังจากที่ครุ่นคิด หลังจากที่อ่านจบ สีหน้าของเขาก็เคร่งขรึมขึ้นมาในทันที","เมื่อหนึ่งวันก่อน ที่ชายแดนของอาณาจักรฮัดลาตา มีเรือเหาะขนาดยักษ์สองลำกำลังลอยอยู่เหนือระดับความสูงหนึ่งพันเมตร เพื่อลาดตระเวนตามปกติ","ในฐานะนักบินเรือเหาะผู้รุ่งโรจน์ ฮามิใฝ่ฝันที่จะสามารถโบยบินบนท้องฟ้าได้อย่างอิสระเหมือนกับนกมาตั้งแต่เด็ก","เพียงแต่เขาผู้ซึ่งไม่มีพรสวรรค์ทางเวทมนตร์ ซึ่งรู้ดีว่ามันเป็นจินตนาการที่เพ้อฝัน แต่ตั้งแต่ที่ศาสตราจารย์คนใหม่มาถึงสถาบันอิเยตาเมื่อสองปีก่อน ทุกอย่างก็เปลี่ยนไป!","ฮามิวางจอบของเขาลง และเข้าร่วมกับโรงงานกระจกที่เพิ่งเปิดใหม่ เพราะเขาสามารถหารายได้ครึ่งปีได้ภายในหนึ่งเดือนที่นั่น และจากนั้นเขาก็ได้ยินว่าศาสตราจารย์วางแผนที่จะคัดเลือกสามัญชนบางคน และฝึกฝนให้พวกเขากลายเป็นนักบินเรือเหาะ","ฮามิที่ได้รับข่าวแทบจะไม่เชื่อหูตัวเอง ในความคิดของเขา เรือเหาะที่ใหญ่กว่าบ้านแต่สามารถลอยขึ้นไปบนท้องฟ้าได้เหล่านี้ คือสิ่งประดิษฐ์ทางเวทมนตร์ที่ยิ่งใหญ่ที่สุดของพ่อมด","มันก็เป็นของขวัญที่ยิ่งใหญ่มากแล้ว ที่อนุญาตให้พวกเขาจ่ายเงินเพื่อสัมผัสกับมัน","แล้วสามัญชนอย่างพวกเขาที่ไม่รู้จักเวทมนตร์ จะสามารถควบคุมสิ่งประดิษฐ์เวทมนตร์ที่น่าทึ่งเช่นนี้ได้จริงๆ งั้นหรือ?","แต่ความสับสนก็คือความสับสน เพราะฮามินั้น ได้ลาออกจากโรงงานในทันที และเข้าร่วมการฝึกฝนเป็นนักบิน","นอกจากการคิดหาหาวิธีควบคุมสัตว์ประหลาดยักษ์ตัวนี้ และทำความเข้าใจกับเครื่องมือแปรธาตุเวทมนตร์ที่ชี้ไปทางเหนือและใต้เสมอแล้ว เขาก็ยังต้องเรียนรู้คณิตศาสตร์และองค์ความรู้อื่นๆด้วย","ยกตัวอย่างเช่น วิธีการประเมินระยะห่างระหว่างเรือเหาะกับเป้าหมายผ่านวัตถุอ้างอิงที่เหมาะสม และสูตรที่ ‘เรียบง่าย’ บางสูตร ซึ่งนี่เป็นเพียงแค่วิชาพื้นฐานที่สุดสำหรับการสำรวจเท่านั้น","ฮามิผู้ยากจนใช้เวลาส่วนใหญ่ในชีวิตไปกับการขุดดิน ดังนั้น เขาจึงรู้สึกวิงเวียนศีรษะเมื่อเรียนรู้สิ่งเหล่านี้ ตามข่าวลือ สิ่งที่เรียกว่าคณิตศาสตร์นั้นเป็นเรื่องยากแม้แต่พ่อมดบางคนด้วยซ้ำ...","อย่างไรก็ตาม ความพยายามเหล่านี้ก็ได้มอบรางวัลตอบแทนที่ใจกว้างอย่างมากให้กับเขา ค่าตอบแทนรายเดือนเปลี่ยนจากสิบเหรียญเงินเป็นยี่สิบเหรียญเงิน และก็ไม่จำเป็นต้องทำงานในโรงงานทั้งวันทั้งคืนอีกต่อไป ซึ่งสิ่งนี้ก็ทำให้ความฝันของเขากลายเป็นจริงในอีกทางหนึ่ง!","ดังนั้น เมื่อเขาได้ยินว่าศาสตราจารย์ลินน์ต้องการคัดเลือกนักบินเรือเหาะ เพื่อไปปฏิบัติภารกิจที่อันตราย ฮามิจึงเลือกที่จะเข้าร่วมโดยไม่ลังเล","ครึ่งหนึ่งเป็นเพราะต้องการตอบแทนความเมตตาของศาสตราจารย์ และอีกส่วนหนึ่งเป็นเพราะในช่วงระหว่างการทำภารกิจ เงินเดือนจะเพิ่มขึ้นเป็นสองเท่า และหากพวกเขาเสียชีวิตโดยไม่ได้ตั้งใจ สมาชิกในครอบครัวก็จะได้รับเงินบำนาญเต็มจำนวนสิบเหรียญทองเวทมนตร์ และในอนาคต พวกเขาก็จะได้รับการดูแลเป็นอย่างดี และถึงขั้นเข้าเรียนในโรงเรียนสำหรับสามัญชนได้ฟรี","อย่างไม่ต้องสงสัยเลย ว่าฮามิและนักบินที่เหลือได้ออกปฏิบัติภารกิจด้วยสภาพจิตใจที่เตรียมพร้อมรับมือกับอันตรายถึงชีวิต แต่หลังจากที่บินวนเวียนอยู่รอบชายแดนของอาณาจักรมานานกว่าหนึ่งเดือน จิตใจที่ตึงเครียดของพวกเขาก็ค่อยๆ ผ่อนคลายลง และพวกเขาก็ถึงขั้นรู้สึกว่าสิ่งที่ศาสตราจารย์พูดนั้น เกินจริงไปหน่อย","ในขณะนี้ พวกเขาอยู่ที่ระดับความสูงหลายพันเมตร พวกเขาเพียงแค่ต้องใช้กล้องส่องทางไกลสอดแนม และหลังจากที่เห็นกองทัพจักรวรรดิข้ามพรมแดนจากระยะไกล พวกเขาก็แค่กลับไปรายงานที่สถาบันอิเยตา ซึ่งมันไม่มีอันตรายใดๆ เลย...","ในช่วงหนึ่งเดือนที่ผ่านมา ฮามิรู้สึกเบื่อหน่ายมากกับการลาดตระเวนไปมาในพื้นที่เดิมๆ แม้ว่าเขาจะชอบความรู้สึกที่ได้บินอยู่บนท้องฟ้า แต่มันก็ต้องอยู่ในสถานที่เดียวเสมอ และมันก็ค่อนข้างจะน่าเบื่อหลังจากที่บินมาเป็นเวลานาน","ฮามิจินตนาการอยู่ในใจ ถ้าเขาเพียงแค่สามารถบินไปดูอีกฟากหนึ่งของโลกได้...","“เดี๋ยวก่อน ฮามิ เจ้ามองเห็นอะไรตรงนั้นไหม?”","รองผู้บัญชาการที่อยู่ข้างๆ จู่ๆ ก็ตะโกนเสียงดังราวกับว่าค้นพบอะไรบางอย่าง","ฮามิหันศีรษะไปมองทันที ในท้องฟ้าที่อยู่ห่างไกล ดูเหมือนว่าจะมีเมฆสีทองลอยพุ่งตรงมาทางพวกเขา","มันดูแปลกประหลาดมาก...","ฮามิใช้กล้องส่องทางไกลที่ถูกติดตั้งไว้บนเรือเหาะเพื่อสังเกตดู จากนั้นม่านตาของเขาก็หดตัวลง นี่ไม่ใช่เมฆ แต่เป็นฝูงสัตว์ประหลาดขนาดใหญ่ที่มีหัวเหมือนนกอินทรี และมีส่วนหลังเหมือนสิงโตเพลิง ภายใต้แสงสว่าง จะปรากฏรัศมีสีทองออกมาให้เห็น ซึ่งมองจากระยะไกลแล้ว ก็ดูเหมือนกับเมฆที่กำลังเคลื่อนตัว...","นั่นคือกริฟฟอน อัศวินกริฟฟอนแห่งจักรวรรดิ!"]},{"n":338,"t":"เรือเหาะที่ได้รับความเสียหาย และการต่อสู้ทางอากาศที่ชายแดน","c":["ไม่มีสิ่งที่เรียกว่ากริฟฟอนอยู่ในดินแดนพ่อมด แต่ก่อนที่พวกเขาจะจากมา พ่อมดเหล่านั้นก็ได้บอกพวกเขาเกี่ยวกับข้อมูลของกองทหารพิเศษหลายหน่วยในจักรวรรดิ และอัศวินกริฟฟอนก็คือหนึ่งในนั้น","“ถอย ถอยเร็วเข้า!”","ฮามิตะโกนเสียงดัง และรองผู้บัญชาการก็หันหัวเรือเหาะทันที ซึ่งหลบหนีไปทางอาณาจักร พร้อมกับกดปุ่มล่องหนในทันที","โล่ทรงกลมปรากฏขึ้นรอบๆ เรือเหาะทันที และเรือเหาะขนาดยักษ์ก็หายวับไปอย่างรวดเร็วท่ามกลางแสงที่บิดเบี้ยว","กริฟฟอนที่ตามมาข้างหลังส่งเสียงร้องแหลมคม แต่มันก็ไม่ได้วิ่งวนไปมาอย่างงุนงงเพราะสูญเสียเป้าหมายอย่างที่ฮามิคาดเอาไว้ ในทางกลับกัน พวกมันเร่งความเร็วขึ้นอีกครั้ง และรวมตัวกันเป็นวงกลมอย่างเป็นระเบียบเรียบร้อย ซึ่งล้อมรอบเข้ามาด้วยความเร็วที่มากกว่าเดิมถึงสองเท่า...","“บ้าเอ๊ย เจ้าพวกนี้รับมือยากเกินไปแล้ว การล่องหนก็ยังไม่สามารถหลอกพวกมันได้เลย!”","ฮามิสบถในใจ","เนื่องจากมีความรู้เกี่ยวกับกริฟฟอนเพียงเล็กน้อย เขาจึงไม่รู้เลยว่าสิ่งมีชีวิตเวทมนตร์นี้มีประสาทสัมผัสในการรับกลิ่นที่สูงมาก และถึงขั้นสามารถได้กลิ่นเลือดของเหยื่อได้จากระยะทางหลายกิโลเมตร","ดังนั้น การหายตัวไปจากการมองเห็นเพียงอย่างเดียว ย่อมไม่ทำให้เกิดอุปสรรคต่อพวกมันได้มากนัก และยิ่งไปกว่านั้น มันก็เป็นการล่องหนที่ไม่สมบูรณ์...","อย่างไรก็ตาม พวกเขาก็ไม่สามารถตำหนิฮามิและคนอื่นๆ ได้ที่ไม่ระมัดระวังให้มากพอ แม้ว่าเวทมนตร์โพลาไรซ์บนเรือเหาะจะใช้งานได้ง่าย แต่มันก็สิ้นเปลืองพลังเวทมนตร์เป็นอย่างมากในการซ่อนสัตว์ประหลาดยักษ์เช่นนี้ และมันก็สามารถใช้ได้เฉพาะในช่วงเวลาที่สำคัญเท่านั้น!","เมื่อพิจารณาว่าครั้งนี้พวกเขาอาจจะต้องอยู่ในโลกภายนอกเป็นเวลาสองหรือสามเดือน แน่นอนว่านักบินเหล่านี้จึงต้องประหยัดคริสตัลเวทมนตร์เอาไว้","“เร็ว เร็ว เร็วเข้า...”","ฮามิและคนอื่นๆ ต้องแข่งขันกับเวลา และรีบดึงคันบังคับไปจนสุด หลังจากที่เรือเหาะขนาดยักษ์เสร็จสิ้นการเปลี่ยนทิศทางที่ยากลำบาก พลังเวทมนตร์จำนวนมหาศาลก็ถูกเปลี่ยนให้กลายเป็นไฮโดรเจน และเครื่องยนต์สันดาปภายในก็ทำงานอย่างเต็มกำลัง!","ลูกเรือที่เหลือต่างก็กำปืนคาบศิลาในมือเอาไว้แน่นทีละคน แต่มันก็ยังอยู่ไกลเกินกว่าที่พวกเขาจะยิงออกไปอย่างสุ่มสี่สุ่มห้าได้","ความเร็วของเรือเหาะเพิ่มขึ้นเรื่อยๆ โดยที่อัศวินกริฟฟอนนั้นเข้ามาใกล้มากแล้ว และถึงขั้นกำลังจะก่อตัวเป็นวงล้อมอย่างเลือนราง ก็ต้องประหลาดใจเมื่อพบว่า สิ่งที่มีขนาดใหญ่โตราวกับเรือที่ลอยอยู่บนท้องฟ้านี้ ได้ปะทุความเร็วออกมาและพุ่งทะยานแซงหน้ากริฟฟอนไป...","ในฐานะกัปตันของอัศวินกริฟฟอน เดวี่ก็ไม่ได้คาดคิดถึงเรื่องนี้เช่นกัน ในความคิดของเขา เครื่องมือแปรธาตุขนาดยักษ์เช่นนี้ควรจะทำงานอย่างช้าๆ แต่ความเร็วของเรือเหาะกลับรวดเร็วอย่างคาดไม่ถึง...","หากเป็นเช่นนี้ต่อไป พวกเขาก็ทำได้เพียงแค่มองดูอีกฝ่ายหลบหนีไปต่อหน้าต่อตา...","นั่นทำให้สายตาของเดวี่เย็นชาเป็นอย่างมาก เมื่อตัดสินจากการสัมผัสกันในช่วงสั้นๆ นี้ เขาก็ได้ระบุให้สิ่งประดิษฐ์เล่นแร่แปรธาตุที่แปลกประหลาดนี้ ว่าเป็นภัยคุกคามหลักที่ต้องถูกกวาดล้างแล้ว!","เดวี่รู้ดีว่า วัตถุบินได้ที่มีคนขับ ล่องหนได้ และบินได้เร็วเป็นพิเศษนั้น มีประโยชน์มากเพียงใดในการทำสงคราม!","พวกเขาจะต้องรั้งอีกฝ่ายเอาไว้ให้ได้!","และมันจะดีที่สุด หากสามารถยึดสิ่งประดิษฐ์เล่นแร่แปรธาตุนี้มา ในสภาพสมบูรณ์ที่สุดเท่าที่จะเป็นไปได้!","เมื่อคิดได้เช่นนี้ เดวี่ก็ก้มศีรษะลงและสื่อสารกับกริฟฟอนที่อยู่ด้านล่างทันที โดยประเมินตำแหน่งและระยะห่างของทั้งสองฝ่ายคร่าวๆ ว่ามันอยู่ในทิศตะวันออกเฉียงเหนือ และห่างออกไปประมาณ 600 เมตร!","นี่เป็นระยะที่ธนูและลูกศรไม่สามารถไปถึงได้ แต่เดวี่กลับเต็มไปด้วยความมั่นใจ เพราะก่อนที่เขาจะมาเป็นอัศวินกริฟฟอน...เขาก็เคยเป็นนักบวชมาก่อน!","“โชคดีที่เราหนีมาได้เร็ว!”","เมื่อเห็นเรือเหาะพุ่งออกมาจากวงล้อมของศัตรูด้วยความเร็วที่รวดเร็วเป็นพิเศษ ฮามิและคนอื่นๆ ก็ถอนหายใจด้วยความโล่งอก และหัวใจของพวกเขาก็เต็มไปด้วยความสุขของการรอดชีวิตจากหายนะ","แม้ว่าพวกเขาจะเตรียมพร้อมที่จะเสียสละแล้วก็ตาม แต่ถ้าหากสามารถหลบหนีไปได้ มันก็คงไม่มีใครคิดว่าตนเองมีอายุที่ยืนยาวเกินไปหรอก...","ตราบใดที่พวกเขาวิ่งไปให้ไกลกว่านี้ และฝ่ายตรงข้ามสูญเสียทิศทางของพวกเขาไป เมื่อถึงตอนนั้น พวกเขาก็จะปลอดภัยอย่างสมบูรณ์","ลูกเรือหลายคนที่อยู่ในเหตุการณ์ต่างก็ผ่อนคลายลงเช่นกัน","รองผู้บัญชาการที่คอยจับตาดูความเคลื่อนไหวของศัตรูอยู่เสมอ สัมผัสได้ถึงสัญญาณเตือนในใจ และจากนั้นเขาก็พุ่งเข้าหาฮามิโดยไม่ลังเล แล้วกดเขาลงกับพื้นทันที","แทบจะในวินาทีต่อมา คลื่นกระแทกที่รุนแรงก็ลอยข้ามมาจากระยะไกล และพุ่งชนเข้ากับห้องนักบินของเรือเหาะโดยตรง","เรือเหาะขนาดยักษ์สั่นสะเทือนอย่างรุนแรง และทุบทำลายแผ่นกั้นด้านหนึ่งจนแตกละเอียด","ยกเว้นฮามิและรองผู้บัญชาการที่ถูกกดให้ล้มลงก่อน นักบินที่เหลือก็ถูกโยนออกไปตามแรงกระแทก และกระแทกเข้ากับผนังด้านข้างของพวกเขาอย่างแรง...","อย่างไรก็ตาม ก่อนที่พวกเขาจะทันได้ฟื้นตัว การโจมตีระลอกที่สองก็มาถึงอีกครั้ง!","“สรรเสริญ เอลา คลื่นแสงศักดิ์สิทธิ์!”","เดวี่และอัศวินกริฟฟอนหลายคนที่เคยเป็นนักบวชตะโกนเสียงดังอีกครั้ง และคลื่นแสงที่รุนแรงก็พุ่งเข้ามาในพริบตา โจมตีเข้าใส่ทุกส่วนของห้องนักบิน","แม้ว่าเรือเหาะจะถูกสร้างขึ้นมาด้วยวัสดุพิเศษ และมีวงเวทเล่นแร่แปรธาตุ อย่างเช่น ความเหนียว, การทำให้แข็ง, ความเบา, และกันลม แต่มันก็ไม่สามารถต้านทานการระดมยิงด้วยพลังศักดิ์สิทธิ์อย่างต่อเนื่องได้","ถ้าไม่ใช่เพราะเดวี่และคนอื่นๆ ต้องการสกัดกั้นสิ่งประดิษฐ์แปรธาตุที่แปลกประหลาดนี้เอาไว้อย่างสมบูรณ์ เรือเหาะก็คงจะถูกยิงตกไปนานแล้ว","แต่ถึงกระนั้น ภายใต้การโจมตีระลอกที่สอง เรือเหาะก็ได้รับความเสียหายอย่างหนัก และความเร็วของมันก็เริ่มช้าลงเรื่อยๆ","“บ้าเอ๊ย ใบพัดด้านนอกต้องพังไปแล้วแน่ๆ!”","ดวงตาของฮามิแดงก่ำ หลังจากที่ศึกษาโครงสร้างของเรือเหาะมาแล้ว เขาก็รู้ดีว่าสิ่งนี้หมายความว่าอย่างไร การไม่มีพลังงานก็หมายความว่า พวกเขาได้สูญเสียความหวังในการหลบหนีไปแล้ว...","“ทุกคน ในเมื่อไอ้สารเลวพวกนี้ไม่ยอมเปิดทางรอดให้กับเรา ถ้างั้นพวกเราก็ทำได้เพียงแค่สู้กับพวกมันเท่านั้น!”","ฮามิหันศีรษะไปมองผู้คนที่อยู่ในเหตุการณ์ และตะโกนออกไปสุดเสียง","“สู้กับพวกมัน!”","“ฆ่าหนึ่งไม่ขาดทุน ฆ่าสองคือกำไร!”","นักบิน พลปืน และลูกเรือที่อยู่ในเหตุการณ์ต่างก็ตะโกนอย่างพร้อมเพรียงกัน พร้อมกับมีสีหน้าที่เด็ดเดี่ยว","ชีวิตของสามัญชนเหล่านี้มีราคาถูกมาก และคงจะไม่มีใครมาสนใจชีวิตของพวกเขา แต่มันแตกต่างออกไปในสถาบันอิเยตา ที่ซึ่งพวกเขาสามารถแลกมันมาได้ด้วยสิบเหรียญทองเวทมนตร์!","นั่นก็เพียงพอแล้ว!","และถ้าพวกเขาสามารถฆ่าศัตรูได้อีกสองสามคน มันก็คือกำไรมหาศาล!","หลังจากที่ตะโกนจบ ฮามิและคนอื่นๆ ก็ไม่หลบเลี่ยงอีกต่อไป แต่หยิบปืนคาบศิลาในมือขึ้นมา และยิงไปที่อัศวินกริฟฟอนที่กำลังเข้าใกล้อย่างรวดเร็ว...","เสียงปืนดังขึ้นอย่างต่อเนื่องบนท้องฟ้าที่ระดับความสูงหนึ่งพันเมตร เนื่องจากนี่เป็นครั้งแรกที่อัศวินกริฟฟอนต้องเผชิญหน้ากับปืนคาบศิลา พวกเขาจึงไม่ได้มีการป้องกันต่ออาวุธที่แปลกประหลาดนี้มากนัก และกริฟฟอนหลายตัวก็ถูกยิงเข้าอย่างจัง...","เพียงแต่ว่าผลลัพธ์ในการต่อสู้ของพวกเขาก็น่าสมเพชมากเช่นกัน ในฐานะผู้นำของกลุ่มสัตว์วิเศษ กริฟฟอนนั้นมีพลังชีวิตที่แข็งแกร่งเป็นอย่างมาก เว้นแต่ว่าจะถูกยิงเข้าที่ศีรษะอย่างจัง หรือถูกปืนคาบศิลาหลายกระบอกยิงอย่างต่อเนื่อง มันก็ยังห่างไกลจากคำว่าถึงตาย...","อัศวินกริฟฟอนผู้กล้าหาญถึงขั้นพุ่งตัวไปข้างหน้า อาศัยทักษะการบินอันประณีตของเขาควบคู่ไปกับเส้นทางการบินที่ยากจะเข้าใจ ซึ่งโชคดีมากพอที่จะหลีกเลี่ยงการยิงรอบแรกไปได้ และก่อนที่กระสุนรอบต่อไปจะถูกบรรจุ เขาก็บินไปถึงเรือเหาะแล้ว"]},{"n":339,"t":"ไฟฟอสฟอรัสขาวที่ถูกถอดรหัส!","c":["“ยอมรับการพิพากษาของพระเจ้าซะเถอะ คนบาป!”","อัศวินกริฟฟอนชูค้อนในมือขึ้น และตะโกนใส่ฮามิและคนอื่นๆ","ในเวลาเพียงไม่กี่วินาที ระยะห่างระหว่างทั้งสองฝ่ายก็ลดลงเหลือประมาณ 20 เมตร และฮามิกับคนอื่นๆ บนเรือเหาะก็ยังคงรีบเร่งบรรจุกระสุน","เห็นได้ชัดว่า เครื่องมือแปรธาตุที่ทรงพลังประเภทนี้ไม่สามารถยิงรัวได้!","วันนี้ เขาได้ตัดสินใจใช้ท่าไม้ตายแล้ว!","ท่าทางพึงพอใจปรากฏขึ้นบนใบหน้าของอัศวินกริฟฟอน แต่ในวินาทีต่อมา เขาก็เห็นฮามิทิ้งปืนคาบศิลาในมือลงกะทันหัน ก่อนจะหยิบขวดน้ำยาที่กำลังเขย่าของเหลวแปลกประหลาดออกมาจากกระเป๋า แล้วขว้างมันใส่หน้าเขาโดยตรง","ภายใต้การพุ่งทะยานด้วยความเร็ว เห็นได้ชัดว่ามันสายเกินไปที่จะหลบหลีก กริฟฟอนที่อยู่ใต้เท้าของอัศวินส่งเสียงร้องแหลมคม เมื่อปีกสั่นสะเทือน สายลมที่รุนแรงก็กลายเป็นใบมีดสายลม และตัดขวดน้ำยาที่ลอยอยู่ตรงหน้ามัน","แต่นี่คือสิ่งที่ฮามิต้องการพอดี เพราะน้ำยาขวดนี้คือสิ่งประดิษฐ์ใหม่ล่าสุดของสถาบันวิจัยการแปรธาตุ มันคือน้ำยา ลมหายใจแห่งสายลมหนาว!","แน่นอนว่านี่คือวิธีการของลินน์เพื่อให้เข้ากับชื่อของพ่อมด อันที่จริงแล้ว มันบรรจุไนโตรเจนเหลวเอาไว้!","เมื่อของที่อยู่ข้างในถูกทำลาย อุณหภูมิที่ต่ำสุดขั้วเกือบ -200 องศา ก็แสดงให้เห็นถึงพลังทำลายล้างที่น่าทึ่งในทันที หมอกสีขาวขยายตัวอย่างรวดเร็วเพื่อห่อหุ้มอัศวินกริฟฟอนเอาไว้ และแทบจะในพริบตา น้ำค้างแข็งบางๆ ก็ปรากฏขึ้นบนชุดเกราะ ศีรษะ และมือของเขาทันที...","กริฟฟอนที่อยู่ใต้เท้าของเขาก็ไม่มีข้อยกเว้น พลังชีวิตและความต้านทานเวทมนตร์ที่แข็งแกร่งของมัน ทำให้มันสามารถดิ้นรนได้นานขึ้นอีกหนึ่งวินาที จากนั้นมันก็กระแทกเข้ากับแผ่นกั้นห้องนักบินด้วยโมเมนตัมที่น่าอัศจรรย์ และกลายเป็นประติมากรรมน้ำแข็งที่ตกลงมาจากระดับความสูงหนึ่งพันเมตรในอากาศ...","อัศวินกริฟฟอนหลายคนที่ต้องการจะแย่งความดีความชอบ เมื่อเห็นสถานการณ์ที่น่าสลดใจของเพื่อนร่วมรบ พวกเขาก็รีบเปลี่ยนทิศทาง บินขึ้นไปบนที่สูงอย่างรวดเร็ว และเริ่มทำลายถุงลมที่เตะตาอยู่เหนือเรือเหาะ","แม้ถุงลมนั้นจะทำมาจากหนังอูฐที่เหนียวเป็นอย่างมาก แต่ภายใต้กรงเล็บของกริฟฟอน มันก็ไม่ต่างอะไรกับกระดาษบางๆ แผ่นหนึ่ง และมันก็ถูกฉีกขาดอย่างรวดเร็วจนเกิดรอยแยก","และไฮโดรเจนจำนวนมหาศาลที่ถูกเติมเต็มอยู่ข้างใน ก็พวยพุ่งออกมาอย่างต่อเนื่อง...","เหตุผลที่ไม่ใช่ฮีเลียม แต่เป็นไฮโดรเจนที่อันตรายกว่า แน่นอนว่าก็เพื่อความสะดวกในการระเบิดตัวเอง!","การต่อต้านของฮามิและคนอื่นๆ ก็มาถึงขีดจำกัดในไม่ช้า","เรือเหาะลำนี้ไม่ได้ติดตั้งอาวุธต่อสู้อากาศยาน ท้ายที่สุดแล้ว มันเป็นเรื่องยากที่ปืนใหญ่จะยิงโดนศัตรูที่เคลื่อนที่ด้วยความเร็วสูงในอากาศ และมันก็ไม่สามารถใช้งานได้ง่ายเหมือนกับปืนคาบศิลาในมือของพวกเขาด้วยซ้ำ","หลังจากที่ได้ลิ้มรสพลังของปืนคาบศิลา อัศวินกริฟฟอนก็ไม่ได้บินอยู่ในระดับเดียวกันกับพวกเขาเลย โดยจะบินให้สูงขึ้นหรือต่ำลงเพื่อทำการโจมตี","“ทุกคน ตอนนี้คือช่วงเวลาสุดท้ายแล้ว การที่พวกมันไม่ได้ใช้การโจมตีที่ทรงพลังนั้นต่อไป มันก็มีความเป็นไปได้เพียงอย่างเดียว นั่นก็คือพวกมันต้องการจะจับเป็นพวกเรา และยึดเรือเหาะลำนี้!”","ฮามิกล่าวด้วยน้ำเสียงทุ้มต่ำ ขณะที่มองไปยังผู้คนที่อยู่ในเหตุการณ์","“เมื่อใดที่พวกมันทำสำเร็จ สิ่งที่รอพวกเราอยู่ ก็คือการทรมานและความอัปยศอดสูที่ไม่มีวันสิ้นสุด...”","สิ่งที่ตอบกลับเขามาก็คือความเงียบ แม้ไม่มีใครตอบอะไร แต่ดวงตาของพวกเขากลับแน่วแน่อย่างถึงที่สุด","ฮามิกดปุ่มไม้ และด้านล่างของห้องโดยสารเรือเหาะก็เปิดออก ภายในนั้นคือลูกบอลสีดำที่มีขนาดเท่ากับศีรษะมนุษย์ ซึ่งเต็มไปด้วยดินปืนและฟอสฟอรัสขาว ซึ่งมีพลังต่อต้านภาคพื้นดินที่ทรงพลังมาก","แม้เรือเหาะจะมีความสามารถในการต่อสู้อากาศยานที่จำกัด แต่มันมีพลังทำลายล้างภาคพื้นดินสูงมาก หากกองทหารล่วงหน้าที่ข้ามพรมแดนมาในครั้งนี้มีจำนวนน้อยกว่าหนึ่งพันคน เรือเหาะลำนี้ก็สามารถเอาชนะพวกมันได้อย่างสมบูรณ์...","แต่ตอนนี้มันได้กลายมาเป็นวิธีการตายตกไปตามกัน!","ทุกคนจุดคบเพลิงอย่างเงียบๆ และพวกเขาก็ต้องการจะตัดสินชะตากรรมด้วยมือของพวกเขาเอง","ในเวลานี้ เดวี่กำลังทำลายเรือเหาะจากด้านล่างของเรือเหาะร่วมกับอัศวินกริฟฟอนอีกสองสามคน แต่การรับรู้ถึงอันตรายที่เกิดจากการต่อสู้ในสนามรบมาเป็นเวลานาน ได้ส่งสัญญาณเตือนขึ้นมาในใจของเขาอย่างเลือนราง ซึ่งเดวี่ก็เชื่อมั่นในการรับรู้ของตนเองเป็นอย่างมาก และบังคับกริฟฟอนใต้เท้าของเขาให้ออกห่างจากที่นี่ทันที พร้อมกับตะโกนเสียงดัง","“กระจายกำลัง...กระจายกำลังออกไปให้หมด!”","เหล่าอัศวินที่เหลือก็ปฏิบัติตามคำสั่งของเขาอย่างซื่อสัตย์ แต่น่าเสียดายที่มันยังคงช้าไปก้าวหนึ่ง เมื่อคบเพลิงห้าอันถูกโยนลงไป เสียงคำรามที่รุนแรงก็ดังก้องขึ้นบนท้องฟ้าที่ระดับความสูงหนึ่งพันเมตร!","ระเบิดนับร้อยลูกระเบิดขึ้นพร้อมกัน และเรือเหาะขนาดยักษ์ก็แตกสลายจากภายใน ในพริบตา และในที่สุดมันก็จุดชนวนถุงลมที่เต็มไปด้วยก๊าซไฮโดรเจนที่อยู่ด้านบน ซึ่งทำให้คลื่นไฟที่พลุ่งพล่าน กวาดพัดเอาอัศวินกริฟฟอนหลายสิบคนที่อยู่ใกล้เคียงเข้าไปในพริบตา...","เสียงร้องที่น่าสลดใจดังขึ้นอย่างต่อเนื่อง ราวกับว่ามีฝนไฟตกลงมาจากท้องฟ้า อัศวินกริฟฟอนที่ตายไปโดยตรงจากการระเบิดระลอกแรกนั้นยังถือว่าโชคดี แต่อัศวินกริฟฟอนที่ได้รับผลกระทบจากคลื่นไฟเท่านั้น นั่นคือความสิ้นหวังที่แท้จริง","เดวี่ก็เป็นหนึ่งในนั้น ด้วยการพึ่งพาสัมผัสที่หกอันพิเศษของเขา เขาจึงสามารถหลบหนีออกมาจากพื้นที่แกนกลางของการระเบิดได้ แต่ร่างกายของเขาก็ยังคงถูกคลื่นไฟแผดเผา","มันเป็นความรู้สึกแผดเผาที่ไม่อาจจะอธิบายได้ และเดวี่ก็ตบไฟฟอสฟอรัสขาวบนร่างกายของเขาอย่างเปล่าประโยชน์ ซึ่งทำให้มือของเขาถูกเผาไหม้","กริฟฟอนใต้เท้าของเขายิ่งบ้าคลั่งมากกว่า มันสะบัดตัวอย่างบ้าคลั่งและทำท่าทางต่างๆ กลางอากาศ จนกระทั่งร่างกายของมันถูกจุดไฟ และพุ่งลงพื้นราวกับลูกไฟ","ในเมื่อตอนนี้ศาสนจักรได้ตัดสินใจที่จะยึดอาณาจักรกลับคืนมา แน่นอนว่าศาสนจักรย่อมไม่สามารถส่งเพียงแค่กองทหารอากาศบางส่วนมาได้","หลังจากที่เดวี่ตกลงสู่พื้นพร้อมกับกริฟฟอนใต้เท้า บิชอปที่อยู่รอบๆ ก็ล้อมรอบเขาทันที และใช้พลังวารีศักดิ์สิทธิ์ พร้อมระดมโมเลกุลของน้ำในอากาศมาด้วยความพยายามที่จะดับเปลวไฟ อย่างไรก็ตาม สถานการณ์ไม่ได้ดีขึ้นเลยแม้แต่น้อย และเดวี่ที่อยู่ที่นั่น ก็ร้องคำรามด้วยความเจ็บปวด โดยมีเปลวไฟที่คอยแทรกซึมเข้าไปในเนื้อและเลือดของเขา แล้วเริ่มแผดเผาจากภายใน","ในขณะที่เหล่าบิชอปกำลังตกตะลึงและทำอะไรไม่ถูก เสียงหนึ่งก็ดังขึ้นในหูของทุกคน","“หยุดซะ! นี่คือไฟแห่งนรกที่ถูกอัญเชิญมาโดยพ่อมด และมันก็ไม่สามารถถูกชำระล้างได้ด้วยวิธีการปกติ...”","คนที่พูดคือชายวัยกลางคนในชุดคลุมสีแดงทอง และสวมหน้ากากเหล็ก","“ท่านเอ็ดเวลล์!”","ทุกคนที่อยู่ในเหตุการณ์รีบก้มศีรษะลงทำความเคารพอย่างรวดเร็ว และถามด้วยความเคารพ","“ถ้างั้นเราจะจัดการกับมันยังไงดี?”","เอ็ดเวลล์มองตรงไปที่เดวี่ และพูดขึ้นมาทันที","“กลั้นหายใจซะ!”","เดวี่ที่ถูกทรมานด้วยไฟฟอสฟอรัสขาวอันน่าสะพรึงกลัวจนแทบจะเสียสติไปแล้ว แต่หลังจากที่ได้ยินคำพูดของเอ็ดเวลล์ เขาก็ยังคงกัดฟันและกลั้นหายใจ","“สกัดกั้นอากาศออกไปก่อน นี่คือเงื่อนไขแรกสำหรับการเผาไหม้...”","เอ็ดเวลล์ยกมือขึ้น แสงที่นุ่มนวลพวยพุ่งออกมาห่อหุ้มเดวี่เอาไว้ และไฟฟอสฟอรัสขาวที่น่าสะพรึงกลัวก็ถูกระงับลงในทันที","“ประการที่สอง ลอกเนื้อและเลือดที่ได้รับบาดเจ็บเหล่านี้ออก เพื่อป้องกันไม่ให้มันดูดซับสารอาหาร...และสุดท้าย ก็รักษามันซะ!”","เมื่อเอ็ดเวลล์พูด แสงสีขาวที่นุ่มนวลในตอนแรก ก็กลายเป็นอาวุธสังหารในทันที!","ชั้นผิวหนังและเนื้อจากทั่วทั้งร่างกายของเดวี่ถูกลอกออกโดยตรง ซึ่งสามารถมองทะลุเห็นกระดูกได้อย่างเลือนราง โดยมีดวงตาเดวี่ที่เบิกกว้าง และแทบจะหมดสติ","โชคดีที่ความเจ็บปวดกินเวลาเพียงไม่กี่วินาที โดยเนื้อและเลือดที่สูญเสียไป ก็งอกกลับคืนมาในไม่ช้าภายใต้ผลลัพธ์ของพลังศักดิ์สิทธิ์..."]},{"n":340,"t":"ถึงเวลาที่ไฟฟอสฟอรัสขาวจะถูกกำจัดทิ้งแล้ว!","c":["กระบวนการรักษาทั้งหมดสิ้นสุดลงในเวลาเพียงแค่สามนาที และเมื่อเดวี่ยืนขึ้นอีกครั้ง อาการบาดเจ็บของเขาก็หายเป็นปลิดทิ้ง","เอ็ดเวลล์เคยมีประสบการณ์โดยตรงกับไฟประหลาดที่ดับไม่ได้นี้ที่เมืองท่า และข้อมูลที่ส่งต่อมาจากอาณาจักร ก็เน้นย้ำด้วยว่าอีกฝ่ายใช้สิ่งนี้เพื่อทำลายกองทหารชั้นยอดของอาณาจักรฮัดลาตา...","ในเมื่อครั้งนี้เขาเป็นผู้นำกองทัพมาด้วยตนเอง แน่นอนว่าเขาย่อมต้องเตรียมพร้อมมาเป็นอย่างดี!","“ขอบคุณ ท่านเอ็ดเวลล์...”","เดวี่กล่าวด้วยความซาบซึ้ง และสีหน้าของเขาก็เต็มไปด้วยความละอายใจอย่างถึงที่สุด","เขาเป็นฝ่ายริเริ่มที่จะนำทีมไปยึดสิ่งประดิษฐ์เล่นแร่แปรธาตุขนาดยักษ์นั่น เพื่อที่เขาจะได้หาวิธีรับมือกับมัน","ด้วยวิธีนี้ ความสูญเสียในสงครามครั้งต่อๆ ไปก็จะสามารถลดลงได้ ใครจะไปคิดว่าอีกฝ่ายจะระเบิดตัวเองในท้ายที่สุด และอัศวินกริฟฟอนกว่าสิบคนต้องตกตายไป...","เดวี่รู้สึกเสียใจเป็นอย่างมาก หากเขาไม่ต้องการที่จะจับเป็นศัตรู พวกเขาก็คงจะใช้พลังศักดิ์สิทธิ์ทำลายสิ่งประดิษฐ์เล่นแร่แปรธาตุนั้นไปโดยตรงแล้ว","“เพื่อเป็นการลงโทษสำหรับความล้มเหลวในภารกิจนี้ ตราบใดที่อัศวินกริฟฟอนถูกส่งออกไปในอนาคต เจ้าจะต้องพุ่งไปแนวหน้าเพื่อเผชิญหน้ากับศัตรู จนกว่าข้าจะออกคำสั่งให้ล่าถอย ศัตรูพ่ายแพ้ หรือ...ตาย!”","คำพูดที่เย็นชาของเอ็ดเวลล์ดังก้องอยู่ในหูของเดวี่ เพราะความตายของอัศวินกริฟฟอนกว่าสิบคน ถูกแลกมาด้วยผลลัพธ์ในการทำลายเรือเหาะลำเดียว ซึ่งเห็นได้ชัดว่ามันเป็นสิ่งที่เอ็ดเวลล์ไม่สามารถยอมรับได้","โดยปกติแล้ว อัศวินกริฟฟอนจะสามารถคัดเลือกได้จากกองทหารชั้นยอดของจักรวรรดิ หรือแม้แต่กองกำลังพิพากษาของพระเจ้าเท่านั้น เมื่อประกอบกับการฝึกฝนความเข้าขากัน และการฝึกฝนการต่อสู้ มันก็ต้องใช้เวลาหลายปีจึงจะเป็นรูปเป็นร่าง ซึ่งนี่ยังไม่รวมถึงค่าใช้จ่ายสำหรับกริฟฟอนอีก","อาจกล่าวได้ว่า การฝึกฝนทีมอัศวินกริฟฟอนขึ้นมานั้น ก็เพียงพอแล้วที่จะทำให้ดินแดนที่ร่ำรวยล้มละลายได้ แต่ตอนนี้พวกเขากลับมาตายอยู่ที่นี่!","หากไม่ใช่เพราะตอนนี้สงครามกำลังจะปะทุขึ้น และพลังต่อสู้ทุกหยดมีความล้ำค่าอย่างยิ่ง ชะตากรรมของเดวี่ก็ควรจะถูกควบคุมตัวกลับไป เพื่อรับการตัดสิน!","“ข้าขอสาบานในนามของพระเจ้า ตั้งแต่วันนี้เป็นต้นไป ข้าจะเป็นผู้นำแนวหน้าและสู้จนตัวตาย!”","เดวี่สาบานด้วยความตื่นเต้น","เอ็ดเวลล์พยักหน้า ในขณะเดียวกัน อัศวินกริฟฟอนที่เหลือก็บินกลับมา โดยมีศพของเพื่อนร่วมทางที่ถูกนำกลับมาด้วยเช่นกัน!","สภาพความตายของคนเหล่านี้น่าสะพรึงกลัวยิ่งกว่าคนก่อนหน้านี้ บางคนตายจากการระเบิดและร่างกายก็แหลกเหลว ในขณะที่บางคนถูกกัดกร่อนด้วยฟอสฟอรัสขาวที่ยังคงลุกไหม้อยู่...","อัศวินกริฟฟอนที่ยังมีชีวิตอยู่ต้องทนทุกข์ทรมานอย่างมาก เพื่อนำศพของเพื่อนร่วมทางกลับมา เนื่องจากขาดข้อมูล พวกเขาส่วนใหญ่จึงปนเปื้อนไปกับเปลวไฟที่น่าสะพรึงกลัวนี้","โดยไม่รอให้เอ็ดเวลล์ทำอะไร บิชอปที่เหลือก็ทำตามและเริ่มรักษาคนเหล่านี้","แม้ไฟแห่งนรกที่แปลกประหลาดนี้มีความน่าประหลาดใจและยากที่จะดับ แต่เมื่อรู้วิธีจัดการกับมันแล้ว แม้แต่บิชอปก็สามารถจัดการกับมันได้","เอ็ดเวลล์สั่งการเพียงไม่กี่คำ จากนั้นเขาก็เดินไปที่ศพสองศพที่ถูกปกคลุมไปด้วยน้ำแข็ง และเอื้อมมือออกไปสัมผัส แม้ว่าเขาจะไม่ได้สัมผัสมันจริงๆ แต่อุณหภูมิที่ต่ำสุดขั้วมากกว่าลบหนึ่งร้อยองศา ก็ยังคงทำให้เขารู้สึกไม่สบายใจ ช่างเป็นความเหน็บหนาวที่น่าสะพรึงกลัวยิ่งนัก...","สีหน้าของเอ็ดเวลล์ดูเคร่งขรึมขึ้นเล็กน้อย นี่มันเป็นเวทมนตร์ที่รับมือยากอีกชนิดหนึ่ง โดยสิ่งที่ทำให้เขากังวลมากขึ้นก็คือ ตามรายงานของเดวี่ มันเป็นเพียงแค่สามัญชนที่ใช้เวทมนตร์ไม่ได้ เป็นผู้ควบคุมสิ่งประดิษฐ์เล่นแร่แปรธาตุขนาดยักษ์นั่น แต่สิ่งประดิษฐ์เล่นแร่แปรธาตุนี้ กลับทำให้เกิดความสูญเสียอย่างมากต่ออัศวินกริฟฟอนชั้นยอดของจักรวรรดิ...","ขณะที่กำลังครุ่นคิด จู่ๆ เอ็ดเวลล์ก็ดูเหมือนจะสัมผัสได้ถึงบางสิ่ง และหันศีรษะไปมองยังทิศทางของท้องฟ้าที่อยู่ห่างไกล","ซึ่งในระดับความสูงที่ห่างออกไปสี่กิโลเมตร มีเรือเหาะอีกลำหนึ่งซึ่งกำลังมุ่งหน้าไปยังสถาบันอิเยตาด้วยความเร็วที่รวดเร็วเป็นพิเศษ และในฐานะกัปตัน อเล็กซ์ก็กำลังสังเกตสถานการณ์ของศัตรูด้วยกล้องส่องทางไกล แต่เมื่อเขาเห็นเอ็ดเวลล์หันศีรษะมามองทางนี้ เขาก็ต้องตกตะลึงทันที","“ระยะทางไกลขนาดนี้ เขายังหาเจอได้อีก...”","อเล็กซ์อ้าปากค้างโดยไม่รู้ตัว พร้อมกับขาของเขาที่รู้สึกอ่อนแรง","เรือเหาะที่ลาดตระเวนในพื้นที่ต่างๆ ล้วนไปเป็นกลุ่มละสองลำ ซึ่งมีระยะห่างสามถึงห้ากิโลเมตร","โดยประการแรกก็คือ เพื่อให้มีการสนับสนุนซึ่งกันและกัน และหลีกเลี่ยงอุบัติเหตุในระหว่างทาง ประการที่สองคือเพื่อป้องกันไม่ให้ศัตรูแอบเข้ามาในอาณาเขตของอาณาจักรอย่างเงียบๆ","เดิมที เมื่ออเล็กซ์เห็นว่าเรือเหาะที่ฮามิอยู่กำลังถูกโจมตี เขาต้องการจะรีบเข้าไปช่วยเหลือ แต่ใครจะไปจินตนาการได้ว่า ภายในเวลาเพียงไม่กี่นาที พวกเขาก็ได้เป็นพยานเห็นเรือเหาะถูกล้อมรอบด้วยอัศวินกริฟฟอน และระเบิดตัวเองในท้ายที่สุด...","อเล็กซ์ตระหนักได้ทันทีว่ามันสายเกินไปแล้ว และล้มเลิกแผนการสนับสนุนในทันที โดยหันหัวเรือเหาะแล้วรีบหนีไป","เพราะสิ่งที่สำคัญที่สุดในตอนนี้ ก็คือนำข้อมูลทั้งหมดที่นี่กลับไปอย่างครบถ้วน!","นครกรีนรีล หอคอยโคโรนา อาณาจักรท้องฟ้า","สมาชิกสภากว่าหนึ่งร้อยคนรวมตัวกันในห้องประชุม โดยส่งต่อข้อมูลที่ถูกส่งมาจากสถาบันอิเยตากันไปทีละคน","“ดูเหมือนว่าสงครามจะมาถึงเร็วกว่าที่เราคาดไว้มาก...”","ราฟาเอลกระซิบหลังจากที่อ่านจดหมายในมือ จากนั้นก็หันศีรษะไปมองลินน์ และพูดพร้อมกับถอนหายใจ","“เจ้ามีกลุ่มนักบินที่ยอดเยี่ยมมาก...ศาสตราจารย์ลินน์”","สมาชิกสภาที่เหลือก็พยักหน้าเช่นกัน การที่สามัญชนห้าคนที่ไม่รู้จักเวทมนตร์ เพิ่งจะแลกชีวิตของพวกเขากับอัศวินกริฟฟอนกว่าสิบคน ในแง่หนึ่ง ความตายของพวกเขานั้นก็มีค่าเป็นอย่างมาก...","โดยเทียบกับเรือเหาะรุ่นใหม่ล่าสุดที่มีมีราคาเพียงแค่ 2,000 เหรียญทองเวทมนตร์ และต้นทุนการผลิตก็ยิ่งต่ำกว่านั้น...","ลินน์รู้สึกเสียใจกับฮามิและคนอื่นๆ ในความคิดของเขา นักบินที่มีทักษะห้าคนนั้นล้ำค่ามากกว่าการฆ่าอัศวินกริฟฟอนเพียงไม่กี่คนเสียอีก","ตอนนี้โรงงานของสถาบันอิเยตากำลังผลิตเรือเหาะออกมาอย่างรวดเร็วมาก แต่กำลังคนสำหรับนักบินนั้นหายากมาก และมันก็ไม่ใช่เรื่องง่ายเลยที่จะฝึกฝนพวกเขาขึ้นมา","“ข้าเพิ่งอ่านข้อมูลเมื่อครู่นี้ และมันบอกว่าศาสนจักรดูเหมือนจะค้นพบวิธีทำลายไฟแห่งนรกลงได้แล้ว...”","สมาชิกสภาคนหนึ่งพูดขึ้นมาอย่างลังเล","เมื่อได้ยินเช่นนี้ ทุกคนที่อยู่ในเหตุการณ์ก็หันไปมองลินน์","เนื่องจากการโฆษณาชวนเชื่อของสภาและข่าวลือต่างๆ ที่แพร่สะพัดไปทั่ว พวกเขาจึงคุ้นเคยกับวีรกรรมระดับตำนานของดาวรุ่งแห่งเวทมนตร์ที่อยู่ตรงหน้าเป็นอย่างดี และแน่นอนว่าพวกเขาก็รู้ดีว่าอีกฝ่ายสามารถสร้างไฟแห่งนรกที่ไม่มีวันดับขึ้นมาได้","และตอนที่ลินน์เป็นพ่อมดระดับสามวงแหวน เขาก็ได้ใช้มันเพื่อทำลายเมืองท่าไปครึ่งหนึ่ง เมื่อไม่นานมานี้ เขาก็เพิ่งใช้มันเพื่อเอาชนะกองทหารชั้นยอดของอาณาจักรฮัดลาตา ด้วยสถิติการทำลายกองทัพทั้งสองครั้งนี้ ไม่ต้องสงสัยเลยว่ามันน่าทึ่งมาก ดังนั้น เปลวไฟที่แปลกประหลาดนี้ จึงแทบจะกลายเป็นสัญลักษณ์ของดาวรุ่งแห่งเวทมนตร์ผู้นี้ไปแล้ว!","ซึ่งมีข่าวลือว่า สิ่งนี้อาจจะถูกอัญเชิญมาจากขุมนรกที่ไม่มีวันสิ้นสุด โดยเปลวไฟชนิดนี้จะแผดเผาและกลืนกินผิวหนังและเนื้อของมนุษย์","การเสียสละของฮามิและคนอื่นๆ ที่สามารถทำผลงานได้ดีเยี่ยมในครั้งนี้ และระเบิดฟอสฟอรัสขาวที่ถูกพัฒนาขึ้นโดยลินน์ ก็มีส่วนช่วยเป็นอย่างมากเช่นกัน","แน่นอนว่าราฟาเอลไม่เชื่อว่าจะมีสิ่งที่เรียกว่าไฟแห่งนรกอยู่จริง แต่เขาก็ไม่ได้คาดคิดเลยว่าศาสนจักรจะหาวิธีรับมือได้รวดเร็วขนาดนี้..."]},{"n":341,"t":"ทำไมพวกท่านไม่ลองปืนใหญ่เลเซอร์ของข้าดูล่ะ?","c":["ภายใต้การจับจ้องของฝูงชน ลินน์มีท่าทีเป็นปกติและพูดขึ้นมาอย่างสบายๆ","“เวทมนตร์ใดๆ ล้วนมีความเป็นไปได้ที่จะถูกทำลาย และไฟฟอสฟอรัสขาวของข้าก็ไม่มีข้อยกเว้น”","เป็นเพราะเหตุนี้เอง หลังจากที่เข้ามาในดินแดนพ่อมด เขาจึงระมัดระวังเป็นอย่างมากที่จะเก็บข้อมูลเกี่ยวกับฟอสฟอรัสขาวเอาไว้","เพราะสิ่งนี้ มีไว้เพื่อรังแกพวกบิชอปที่ไร้การศึกษาในจักรวรรดิเซคัสเท่านั้น แต่หากเขากล้าใช้มันในปริมาณมหาศาลในดินแดนพ่อมด พ่อมดก็จะสามารถสร้างมันขึ้นมาใหม่ได้อย่างรวดเร็ว","ท้ายที่สุดแล้ว ฟอสฟอรัสก็ไม่ได้ผลิตยากอะไร และเพื่อให้สามารถผลิตจำนวนมากได้ เขาก็ได้ส่งมอบเทคโนโลยีนี้ให้กับพ่อมดที่เชื่อถือได้หลายคนในสถาบันวิจัยการแปรธาตุแล้ว","อันที่จริงแล้ว หลังจากที่ทะลวงขึ้นเป็นจอมเวทผู้ยิ่งใหญ่ ความสำคัญของฟอสฟอรัสขาวสำหรับลินน์ก็ลดลงเป็นอย่างมาก เพราะสิ่งนี้แทบจะไม่มีความหมายอะไรเลยในการต่อสู้ระดับจอมเวทผู้ยิ่งใหญ่ นอกเหนือจากสิ่งอื่นใดแล้ว อาณาเขตสุญญากาศก็สามารถลดพลังของมันลงได้อย่างมาก และต่อให้จะมีการผลิตไฟฟอสฟอรัสขาวออกมาเป็นจำนวนมาก แต่มันก็เทียบเท่ากับพลังของเวทมนตร์ระดับสี่หรือระดับห้าวงแหวนเท่านั้น","และลักษณะเฉพาะของฟอสฟอรัสขาวเอง ก็ยังเป็นตัวกำหนดด้วยว่าขีดจำกัดสูงสุดของมันจะไม่สูงเกินไปนัก...","แต่นั่นก็ไม่สำคัญ ในบรรดาอาวุธที่น่าสะพรึงกลัวมากมายที่ถูกบันทึกเอาไว้ในสมองของเขา ระเบิดฟอสฟอรัสขาวก็ทำได้เพียงถูกอธิบายว่าอยู่ในระดับปานกลางเท่านั้น...","และการที่เขาระบุให้มันเป็นตัวเลือกแรกนั้น ก็เป็นเพราะว่ามันสร้างได้สะดวกกว่าเป็นหลัก","“ประจวบเหมาะกับที่ข้าเพิ่งจะคิดค้นเวทมนตร์แห่งไฟแบบใหม่ที่ทรงพลังมากกว่าเดิมขึ้นมาในช่วงไม่กี่วันนี้พอดี และนี่ก็ถึงเวลาที่มันจะถูกกำจัดทิ้งแล้ว...”","ลินน์กล่าวด้วยความรู้สึกที่เต็มเปี่ยม","ไฟฟอสฟอรัสขาวเคยเป็นไพ่ตายของเขา และแก้ปัญหาให้กับเขามามากมาย แต่ตอนนี้มันไม่สามารถตามการเติบโตของเขาได้ทันแล้ว","ในฐานะจอมเวทผู้ยิ่งใหญ่ เขาสามารถทำหลายสิ่งหลายอย่างที่เขาไม่สามารถทำได้มาก่อนได้อย่างง่ายดาย อย่างเช่นการสร้างองค์ประกอบการผสมบางอย่างที่มีคุณสมบัติทางเคมีที่ซับซ้อนมากขึ้น...","สำหรับพ่อมดคนอื่นๆ การสร้างเวทมนตร์แบบใหม่ที่ทรงพลังขึ้นมานั้น ไม่ใช่งานง่ายเลย และโดยปกติแล้วก็มักจะต้องใช้เวลาหลายปี หรือแม้แต่หลายทศวรรษในการค้นหาข้อมูล และต้องใช้แรงบันดาลใจด้วย ซึ่งทำให้ใบหน้าของราฟาเอลและคนอื่นๆ กระตุก","นี่มันมีเวทมนตร์แห่งไฟที่ทรงพลังยิ่งกว่าไฟแห่งนรกแบบนั้นอยู่จริงๆ งั้นเหรอ พวกเขาคิดว่าแค่นี้มันก็เกินจริงพอแล้ว","ลินน์ไม่ได้ตั้งใจจะอธิบายอะไรมากนัก เขาเพียงแค่ยกมือขึ้นเคาะโต๊ะประชุม เพื่อดึงความสนใจของทุกคนให้หันเหไปจากไฟฟอสฟอรัสขาว เพราะพวกเขามีเรื่องสำคัญให้ต้องจัดการมากกว่านั้น","“ตามข้อมูลที่ได้รับจากนักบินที่ใช้กล้องส่องทางไกล คาดว่าครั้งนี้มีกองทหารจักรวรรดิกว่า 30,000 คนข้ามพรมแดนมา นอกจากอัศวินกริฟฟอนแล้ว ยังมีกองทหารพิเศษอีกประมาณ 5,000 คน ซึ่งทั้งหมดสวมชุดเกราะสีเงินแวววาว ที่ดูไม่ธรรมดา”","“และผู้นำของพวกมันก็คือชายที่สวมหน้ากากเหล็กและชุดคลุมสีแดงทอง ซึ่งไม่สามารถมองเห็นใบหน้าของเขาได้ และอายุของเขาด้วย”","ลินน์กล่าวด้วยน้ำเสียงทุ้มต่ำ","แม้ว่าทั้งสองจะเคยมองหน้ากันข้ามทะเลในเมืองท่า แต่ในตอนนั้นสายตาของลินน์ก็ยังไม่ดีมากนัก ดังนั้น เขาจึงรู้เพียงแค่ว่า มีคนอัญเชิญร่างเงาของเทพธิดาออกมา เพื่อหยุดยั้งการแพร่กระจายของไฟฟอสฟอรัสขาว แต่เขาก็ไม่รู้ว่าคนผู้นั้นเป็นใคร","“ผู้นำของพวกมันน่าจะเป็น เอ็ดเวลล์ พระคาร์ดินัลแห่งศาสนจักร และมีข่าวลือว่าเขามีความสำคัญมากในศาสนจักร โดยเขาอาจจะกลายมาเป็นประธานผู้พิพากษาคนต่อไป...”","แฮร์รอฟอธิบาย","เขามักจะอาศัยอยู่ในดินแดนพ่อมด และไม่เคยออกไปไหนเลย แต่นั่นก็ไม่ได้หมายความว่าสภาจะไม่มีสายลับอยู่ในจักรวรรดิ","เมื่อปีที่แล้ว นครกรีนรีลเกือบจะถูกทำลายโดยลัทธิวันสิ้นโลกที่บ้าคลั่งเหล่านั้น แฮร์รอฟจึงได้เรียนรู้จากความเจ็บปวด และเพิ่มการลงทุนในระบบข่าวกรองมากขึ้น","เพียงแต่ว่ามันดูเหมือนจะส่งผลลัพธ์เพียงเล็กน้อยในตอนนี้ เพราะสายลับของเขาเพิ่งจะบอกเขาเมื่อสามวันก่อน ว่ากองทัพของจักรวรรดิยังคงน่าจะรวมตัวกันอยู่ทางทิศตะวันออก แต่ผลลัพธ์ก็คือ อีกฝ่ายได้หันกลับมาและเข้าไปในอาณาจักรแล้ว หากไม่ใช่เพราะเรือเหาะที่ลินน์จัดเตรียมเอาไว้ให้พวกเขาสังเกตการณ์ชายแดน เกรงว่าพวกเขาก็คงจะยังคงถูกปิดหูปิดตาอยู่","หลังจากหยุดชะงักไปครู่หนึ่ง แฮร์รอฟก็พูดต่อ","“สำหรับกองทหารชุดเกราะสีเงินเหล่านั้น พวกมันน่าจะเป็นกองกำลังทัณฑ์ศักดิ์สิทธิ์ของศาสนจักร!”","ลินน์ขมวดคิ้ว แน่นอนว่าเขาเคยได้ยินเกี่ยวกับกองทหารที่ยอดเยี่ยมที่สุดของศาสนจักรหน่วยนี้มาบ้าง โดยมีข่าวลือว่าทุกคนในกองทหารหน่วยนี้ ล้วนแต่ได้รับพรจากทวยเทพ ซึ่งมีความกล้าหาญในการต่อสู้อย่างมาก และพวกมันก็เป็นสุดยอดในหมู่สุดยอด","“นี่น่าจะเป็นเพียงแค่กองทหารล่วงหน้าเท่านั้น!”","ออโรร่ากล่าวเตือนความจำ","พวกเขาเข้าควบคุมอาณาจักรทั้งหมด และการต่อสู้ในเมืองหลวง ก็ได้เปิดเผยความแข็งแกร่งส่วนหนึ่งของสมาคมเวทมนตร์เร้นลับออกมาแล้ว ไม่ว่าศาสนจักรจะยิ่งใหญ่ขนาดไหน มันก็เป็นไปไม่ได้เลยที่จะส่งคนมาเพียงแค่นี้ ต่อให้จะเป็นกองทหารชั้นยอดก็ตาม","ข่าวร้ายที่เข้ามาอย่างต่อเนื่อง ก็ทำให้สมาชิกสภาที่อยู่ในเหตุการณ์รู้สึกเศร้า แต่ก็โชคดีที่กองกำลังทัณฑ์ศักดิ์สิทธิ์บนพื้นดินนั้น ไม่ว่าพวกมันจะยอดเยี่ยมขนาดไหน พวกเขาก็ยังมีทุนมากพอที่จะต่อสู้ ด้วยกองกำลังปืนคาบศิลาที่ล้ำสมัยยิ่งกว่า","แต่อัศวินกริฟฟอนบนท้องฟ้านั้น ถือว่าเป็นปัญหาใหญ่ที่ยากจะแก้ไข ตราบใดที่พวกมันยังคงอยู่ เรือเหาะก็ไม่สามารถขึ้นสู่อากาศและทิ้งระเบิดได้","มันเป็นไปไม่ได้เลยที่จะปล่อยให้เรือเหาะต้องระเบิดในทุกๆ ครั้ง จริงมั้ย?","ข่าวกรองระบุอย่างชัดเจนว่า อัศวินกริฟฟอนต้องการจะยึดการควบคุมเรือเหาะในครั้งนี้ และพวกมันก็มีโอกาสดีมากที่จะจับเป็นนักบิน มิฉะนั้นพวกมันก็คงจะใช้เวทมนตร์จากระยะไกล และทำลายเรือเหาะทิ้งไปโดยตรงแล้ว","“บางทีพวกเราอาจจะพิจารณาเปลี่ยนพ่อมดสายแปรสภาพบางคน ให้กลายเป็นสัตว์ประหลาดบินได้ เพื่อปกป้องเรือเหาะเหล่านี้”","จอมเวทผู้ยิ่งใหญ่คนหนึ่งเสนอแนะขึ้นมา","“ให้พวกเขาไปต่อสู้กับกริฟฟอนบนที่สูงงั้นเหรอ เจ้าบ้าไปแล้วรึไง?”","ซานเชซดุด่าอีกฝ่ายด้วยความโกรธ สำหรับแนวคิดที่ไม่สมจริงของเขา ซึ่งนี่มันเป็นเพียงแค่เรื่องตลกเกี่ยวกับชีวิตของพ่อมดสายแปรสภาพ","เมื่อการแปรสภาพด้วยเวทมนตร์เสร็จสิ้น พ่อมดก็จะสูญเสียความสามารถในการร่ายคาถาไปบางส่วน มันจึงเป็นเรื่องยากที่จะเอาชนะสัตว์ประหลาดที่ดุร้ายอย่างกริฟฟอนบนท้องฟ้าแบบตัวต่อตัวได้ นับประสาอะไรกับอัศวินกริฟฟอนเหล่านั้นที่สามารถร่วมมือกันร่ายพลังศักดิ์สิทธิ์ได้อีก","“เป็นไปได้มั้ยว่าเจ้ามีวิธีจัดการที่ดีกว่านี้?”","จอมเวทผู้ยิ่งใหญ่ถามด้วยรอยยิ้มเยาะ","แม้ว่าความคิดของเขาจะก่อให้เกิดความสูญเสียอย่างมาก แต่มันก็ยังคงเป็นทางออก...","ซานเชซสำลักไปครู่หนึ่ง และหลังจากครุ่นคิดอยู่นาน เขาก็เสนอให้พวกตนไม่ต้องส่งเรือเหาะขึ้นสู่อากาศ แล้วยอมแพ้ในเรื่องความได้เปรียบทางอากาศไปก่อน และหากอัศวินกริฟฟอนกล้าเข้าใกล้พื้นดินเพื่อโจมตี พวกเขาก็จะใช้ปืนคาบศิลาและเวทมนตร์เพื่อต่อโต้กลับอย่างดุเดือด","“ทำไมพวกท่านไม่ลองใช้เลเซอร์ดูล่ะ?”","จู่ๆ ลินน์ก็พูดขึ้นมาท่ามกลางการสนทนาของฝูงชน","การปรากฏตัวของอัศวินกริฟฟอนเหล่านี้เกินความคาดหมายของเขาไปบ้าง เห็นได้ชัดว่ามันสายเกินไปแล้วที่จะพัฒนาเรือบินรุ่นใหม่ขึ้นมา ดังนั้น ทำไมไม่ลองปืนใหญ่ต่อสู้อากาศยานเลเซอร์ดูล่ะ!","“เลเซอร์?!”","ออโรร่ามองไปที่ลินน์ด้วยความประหลาดใจ จากนั้นก็ตอบสนอง","“เจ้าหมายถึงเวทมนตร์ลำแสงอันใหม่นั่นน่ะเหรอ?”","ดวงตาของแฮร์รอฟและคนอื่นๆ ก็เปล่งประกายขึ้นมาทันที นึ่ถือเป็นวิธีที่ดีจริงๆ","อัศวินกริฟฟอนเหล่านั้นบินได้เร็วและคล่องตัวไม่ใช่เหรอ?","แต่ต่อให้พวกมันจะเร็วแค่ไหน มันจะยังเร็วเท่ากับแสงได้อีกมั้ยล่ะ?","นั่นคือเลเซอร์ที่มีความเร็วเกือบ 300,000 กิโลเมตรต่อวินาที และสามารถโคจรรอบทวีปได้ถึงเจ็ดรอบครึ่งเชียวนะ!"]},{"n":342,"t":"ต่อให้ได้รับความช่วยเหลือจากสมาคมเวทมนตร์เร้นลับ ก็อาจจะไม่สามารถเอาชนะสัตว์ประหลาดเช่นนี้ได้","c":["คำพูดของลินน์เปิดประตูสู่โลกใบใหม่ให้กับทุกคนที่อยู่ในเหตุการณ์ และพลังของเวทมนตร์เลเซอร์ พวกเขาก็ได้สัมผัสกับมันมาแล้วในการทดลองวัดความเร็วของแสงเมื่อไม่กี่วันก่อน มันทำได้เพียงถูกอธิบายว่าน่าสะพรึงกลัว โดยเฉพาะช่วงเวลาที่มีการยิงลำแสงออกมา ซึ่งจะไม่มีใครสามารถหลบหนีได้พ้น...","แต่มันก็ใช่ว่าจะไม่มีข้อเสียซะทีเดียว นั่นก็คือยิ่งระยะทางไกลออกไปมากเท่าไหร่ ความรุนแรงก็จะยิ่งลดลงมากเท่านั้น และระยะสังหารที่มีประสิทธิภาพก็คือประมาณสามหรือสี่ร้อยเมตร แต่หากพวกเขาต้องการจะรับมือกับกริฟฟอนที่สามารถบินได้สูงถึงหนึ่งพันเมตร พวกเขาก็จะต้องทำการปรับปรุงเพิ่มเติมเพื่อเพิ่มพลังให้กับสิ่งนี้เสียก่อน มิฉะนั้น...","สมาชิกสภาคนหนึ่งได้พูดคุยถึงแผนการปรับปรุงเวทมนตร์ลำแสงนี้อย่างกระตือรือร้น","เนื่องจากความเข้าใจเกี่ยวกับทัศนศาสตร์ยังอยู่ในช่วงเริ่มต้น ทำให้การปรับปรุงเหล่านี้จึงเป็นเพียงการสร้างแหล่งกำเนิดแสงที่ทรงพลังมากขึ้นเท่านั้น และจะโฟกัสมันไปที่จุดเดียวได้อย่างไร","ราฟาเอลเสนอแนะว่า พวกเขาสามารถประจำการพ่อมดเวทมนตร์แสงบางคนไว้บนเรือเหาะได้โดยตรง เพื่อทำการโจมตีจากทางอากาศ ซึ่งจะสามารถลดระยะทางลงได้อย่างมาก...","ลินน์ไม่ได้เข้าร่วมการพูดคุยในหมู่ผู้คน แต่เขามีแผนการที่สอดคล้องกันอยู่ในใจแล้ว ที่เขาบอกว่าเวทมนตร์เลเซอร์ ไม่ได้เรียบง่ายแค่การรวบรวมแสงเท่านั้น...","เลเซอร์มักจะถูกเรียกว่าการปล่อยแสงที่ถูกกระตุ้นของอะตอม มันคือพลังงานที่ถูกปล่อยออกมาในรูปของโฟตอน เมื่ออิเล็กตรอนในอะตอมดูดซับพลังงานและกระโดดจากระดับพลังงานต่ำไปยังระดับพลังงานสูง และจากนั้น ก็จะตกลงมาจากระดับพลังงานสูงไปยังระดับพลังงานต่ำ ซึ่งเป็นที่รู้จักกันในนามของไม้บรรทัดที่แม่นยำที่สุด และมีดที่เร็วที่สุด!","และเทคโนโลยีอาวุธเลเซอร์ของสหพันธรัฐก็สมบูรณ์แบบแล้วเช่นกัน ดังนั้น สิ่งที่เขาต้องทำก็มีเพียงแค่การเปลี่ยนทฤษฎีที่เกี่ยวข้องให้กลายเป็นเวทมนตร์ ซึ่งมันก็น่าจะใช้เวลาเพียงแค่ไม่กี่วัน","อีกคนหนึ่งที่ไม่ได้เข้าร่วมการพูดคุยก็คือซานเชซ ซึ่งมีการวิจัยเกี่ยวกับทัศนศาสตร์เพียงเล็กน้อย แต่เขากลับมีความสนใจในเรื่องอื่นเป็นอย่างมาก","“ศาสตราจารย์ลินน์ ข้าได้ยินมาว่าก่อนหน้านี้...ในระหว่างการต่อสู้เพื่อยึดเมืองหลวง พระคาร์ดินัลของอาณาจักรได้อัญเชิญร่างจำแลงของ...พระเจ้าจอมปลอมนั่นออกมา มันเป็นเรื่องจริงงั้นเหรอ?”","“จริง!”","ลินน์พยักหน้า","“ข้าไม่รู้ว่าพ่อมดระดับตำนานคนไหนจากสมาคมเวทมนตร์เร้นลับที่เป็นคนลงมือ?”","แฮร์รอฟถามด้วยความอยากรู้อยากเห็น","แม้ว่ามันจะเป็นเพียงแค่ร่างจำแลงของเอลา แต่มันก็มีพลังที่เหนือกว่าจอมเวทผู้ยิ่งใหญ่ ซึ่งไม่ใช่สิ่งที่ลินน์และคนอื่นๆ จะรับมือได้","เกี่ยวกับประเด็นนี้ พ่อมดที่อยู่ในเหตุการณ์ต่างก็มีความสงสัยใคร่รู้เป็นอย่างมาก แม้ว่าหนังสือพิมพ์เวทมนตร์รายวัน จะได้อธิบายถึงผลลัพธ์สุดท้ายของการต่อสู้ไปแล้ว แต่มันก็ไม่ได้กล่าวถึงกระบวนการทั้งหมดมากนัก","ลินน์ส่ายหัวและกล่าวอย่างตรงไปตรงมา","“อันที่จริงแล้ว แผนการสร้างอาณาจักรเวทมนตร์ในครั้งนี้ ได้รับการตกลงร่วมกันโดยข้าและแอนโธนี มันไม่มีนักวิชาการเข้ามาเกี่ยวข้องมากนัก และมันก็ไม่ใช่คำสั่งที่ถูกออกโดยสมาคมเวทมนตร์เร้นลับด้วย”","กล่าวอีกนัยหนึ่งก็คือ มันไม่ได้รับความช่วยเหลือจากพ่อมดระดับตำนานเลยงั้นเหรอ?","แฮร์รอฟรู้สึกแปลกใจมาก ว่าพวกเขาสามารถเอาชนะร่างจำแลงของพระเจ้าจอมปลอมนั่นมาได้อย่างไร...","เมื่อเห็นผู้คนถามถึงเรื่องนี้ ลินน์ก็ไม่ได้ตั้งใจจะปิดบังอะไร โดยเขาก็ได้พูดคุยเกี่ยวกับการต่อสู้ในเมืองหลวงอย่างคร่าวๆ ในท้ายที่สุด เพื่อที่จะทำลายตัวกลางของร่างจำแลง เขาจึงรวบรวมพลังของพ่อมดเต็มตัวหลายร้อยคนและจอมเวทผู้ยิ่งใหญ่ระดับหกวงแหวนอย่างแอนโธนี โดยทุกคนจะใช้เวทมนตร์สายฟ้าเพื่อชาร์จปืนใหญ่แม่เหล็กไฟฟ้าชนิดพิเศษ และเมื่อนั้นพวกเขาก็ได้ปลดปล่อยการโจมตีระดับตำนานออกมา","แน่นอนว่าหลังจากยิงปืนใหญ่นั้นออกไป ปืนใหญ่แม่เหล็กไฟฟ้าก็ได้รับความเสียหายจากการโอเวอร์โหลด และถูกส่งไปซ่อมแซมแล้ว...","“พวกเจ้านี่กล้าหาญกันจริงๆ!”","ออโรร่ากล่าวด้วยความประหลาดใจ","เมื่อนางได้ยินเกี่ยวกับแผนการสร้างอาณาจักรเวทมนตร์ครั้งแรก นางก็คิดว่ามันถูกสร้างขึ้นมาโดยผู้นำของสมาคมเวทมนตร์เร้นลับ","เพราะท้ายที่สุด จากดินแดนของจักรวรรดิ ซึ่งเป็นสถานที่ที่ศาสนจักรมีอำนาจมากที่สุด กลับถูกแบ่งแยกออกมาอย่างใช้กำลัง เรื่องใหญ่ขนาดนี้น่าตกใจจริงๆ!","และสิ่งที่สำคัญที่สุดก็คือ ลินน์และคนอื่นๆ สามารถทำมันได้จริงๆ!","โดย ผู้สร้างเวทมนตร์ วิกโตริโอ ก็มีความสนใจในอาวุธแม่เหล็กไฟฟ้าชนิดนี้เป็นอย่างมาก เพราะลินน์ก็เคยใช้มันครั้งหนึ่งเมื่อหนึ่งปีที่แล้วตอนที่เผชิญหน้ากับออกัสต์ และเขาก็ยังคงจำพลังของมันได้ดี","“โชคดีที่ทุกอย่างผ่านไปด้วยดี ไม่ใช่เหรอ?”","ลินน์กล่าวอย่างไม่ใส่ใจ","ตอนนี้เมื่อนึกถึงมัน การต่อสู้ในครั้งนั้นก็น่าตื่นเต้นมากจริงๆ แม้ว่าเขาจะใช้วิธีการที่ปลอดภัยที่สุด และสังหารโลซัคไปด้วยปรากฏการณ์ทางธรรมชาติและค่ายกลเล่นแร่แปรธาตุ แต่เขาก็ไม่ได้คาดคิดเลยว่าอีกฝ่ายจะมีความปรารถนาที่จะฝังจิตวิญญาณของตัวเองไว้กับผู้อื่น แม้กระทั่งได้รับความช่วยเหลือจากคำอธิษฐานของผู้ศรัทธาที่เคร่งศาสนาหลายหมื่นคน และอัญเชิญร่างจำแลงของเทพธิดาออกมาได้","จนกระทั่งในเวลาต่อมา เขาก็ได้รู้จากฮัตตาร์ว่า ตัวกลางของโลซัคในการอัญเชิญร่างจำแลงของพระเจ้า ก็คือวัตถุศักดิ์สิทธิ์ที่ถูกเก็บรักษาเอาไว้ในโบสถ์ เพื่อให้ผู้ศรัทธาเคารพบูชานั่นเอง","โชคดีที่เขาได้เตรียมปืนใหญ่แม่เหล็กไฟฟ้าเอาไว้เป็นไพ่ตายล่วงหน้า มิฉะนั้นเขาก็คงจะรับมือไม่ไหว","และตอนนี้ ความสนใจของศาสนจักรก็ถูกดึงดูดไปที่นั่นอย่างที่พวกเขาคาดหวังเอาไว้แล้ว...","“ในเมื่อเจ้าเคยเผชิญหน้ากับร่างจำแลงของนาง และยังเคยต่อสู้กับมันมาแล้ว เจ้าสามารถตัดสินระดับในปัจจุบันของนางคร่าวๆ ได้มั้ย?”","ออโรร่าถามอย่างเคร่งขรึม","นี่ถือเป็นตัวแปรที่ใหญ่ที่สุดในสงครามครั้งนี้ และยังเป็นสิ่งที่พวกเขากังวลมากที่สุดอีกด้วย","เพราะหลังจากชนะสงครามแห่งศรัทธา สิ่งที่เอลาทำนั้นบ้าคลั่งยิ่งกว่าพ่อมดพลังจิตวิญญาณทุกคนก่อนหน้านี้เสียอีก!","นางได้สร้างศาสนจักร ประกาศตนเป็นพระเจ้าที่แท้จริง และหล่อหลอมตำนานการสร้างโลกขึ้นมาในพระคัมภีร์ หลังจากหลายร้อยปีของการเลี้ยงดูให้เชื่อง นางก็ได้เปลี่ยนจักรวรรดิทั้งหมดให้กลายเป็นทุ่งหญ้าแห่งศรัทธา ซึ่งทำให้ไม่มีใครรู้เลยว่าพลังของนางเติบโตขึ้นไปถึงระดับไหนแล้ว...","ออโรร่าไม่สามารถเดาได้เลยว่าอีกฝ่ายได้หาวิธีกำจัดมลพิษทางจิตวิญญาณได้แล้วหรือยัง","สำหรับสิ่งที่เรียกว่าสวรรค์จุติของศาสนจักรนั้น ตามการคาดเดาของนาง มันก็น่าจะเป็นเวทมนตร์สร้างร่างจำแลงที่ทรงพลังมากกว่า ซึ่งจะใช้วัตถุศักดิ์สิทธิ์แห่งศรัทธาเป็นจุดยึดเหนี่ยว ทำให้เจตจำนงของใครบางคนสามารถจุติลงมาได้...","“มันพูดยาก...แต่ข้าคิดว่านางน่าจะได้รับผลกระทบไปไม่น้อยเลย”","ลินน์ครุ่นคิดอยู่นาน","เขาเคยเห็นร่างจำแลงของพระเจ้ามาสองครั้งแล้ว และเขาก็รู้สึกประทับใจในตัวนางมาก เพราะร่างอวตารเหล่านี้ล้วนแต่เผยให้เห็นถึงความศักดิ์สิทธิ์และความเมตตา","การที่จะบอกว่าอีกฝ่ายถูกกัดกร่อนด้วยศรัทธาไปจนหมดแล้วหรือไม่นั้น ลินน์ไม่กล้าที่จะตัดสินใจอย่างง่ายดาย แต่สิ่งที่แน่นอนก็คือ ร่างอวตารที่พวกเขาเผชิญหน้านั้นขาดความคล่องแคล่วที่ควรจะมีไปบ้าง ซึ่งนั่นก็เป็นเหตุผลสำคัญที่ทำให้ปืนใหญ่แม่เหล็กไฟฟ้าสามารถโจมตีโดนได้","โดยลินน์ก็กล่าวถึงรายละเอียดทั้งหมดเกี่ยวกับการอนุมานและการสังเกตของเขา","ซึ่งทำให้ประธานสภาหลายคนรู้สึกโล่งใจอย่างเห็นได้ชัด เพราะสิ่งที่พวกเขากังวลมากที่สุดก็คือ เอลาอาจจะค้นพบวิธีกำจัดมลพิษทางจิตวิญญาณได้แล้ว","แม้ว่าการสั่งสมมาหลายร้อยปีและผู้ศรัทธาหลายสิบล้านคนในจักรวรรดิ จะสามารถมอบพรทางเวทมนตร์ที่ไม่อาจจินตนาการได้ให้กับอีกฝ่าย แต่สิ่งที่สำคัญที่สุดสำหรับพ่อมด ก็คือการสั่งสมความรู้!","นี่คือแก่นแท้แห่งความแข็งแกร่งของพ่อมด!","นั่นทำให้ออโรร่าจินตนาการไม่ออกเลยว่า คู่ต่อสู้ที่มีชีวิตอยู่มาแปดหรือเก้าร้อยปี ซึ่งเก็บเกี่ยวจิตวิญญาณของผู้คนนับไม่ถ้วนและเปลี่ยนพวกมันให้กลายเป็นพลัง จะเป็นศัตรูที่น่าสะพรึงกลัวจนไม่มีใครอยากจะเผชิญหน้าด้วยได้ขนาดไหน!","ไม่ต้องพูดถึงการพึ่งพาพลังของสภาเลย ต่อให้ได้รับความช่วยเหลือจากสมาคมเวทมนตร์เร้นลับ พวกเขาก็อาจจะไม่สามารถเอาชนะสัตว์ประหลาดเช่นนี้ได้..."]},{"n":343,"t":"ฮัตตาร์ที่หวาดกลัว และขุนนางที่ก่อกบฏ","c":["“นี่เป็นข่าวดีที่สุดที่เราได้รับมาเลย!”","แฮร์รอฟกล่าวด้วยน้ำเสียงผ่อนคลาย หากระดับเวทมนตร์ของเอลา ยังอยู่ในระดับเดียวกับเมื่อหลายร้อยปีก่อน ความพยายามร่วมกันของพวกเขาก็เพียงพอแล้วที่จะเอาชนะนางได้","“อย่าประมาทไป แฮร์รอฟ!”","วิกโตริโอเตือน","“นอกจากความแข็งแกร่งของร่างต้นของเอลาแล้ว ลำพังแค่ศาสนจักรก็ไม่ใช่เรื่องง่ายที่จะจัดการ เพราะหลังจากหลายร้อยปีของการพัฒนา มันก็ได้กลายเป็นยักษ์ใหญ่ไปแล้ว”","อย่างน้อยในเบื้องหน้า พวกเขาก็ต้องเผชิญหน้ากับศัตรูระดับตำนานอย่างน้อยห้าคน...","ลินน์พยักหน้าเช่นกัน ร่างเงาของพระเจ้าก่อนหน้านี้ ได้แสดงพลังแห่งเวลาบางอย่างที่ดูเหมือนว่าจะสามารถบิดเบือนพื้นที่ และแม้กระทั่งทำให้มันช้าลงได้ ซึ่งนั่นทำให้เขากังวลเป็นอย่างมาก","นี่เป็นเพียงแค่ร่างอวตารเท่านั้น และเขาก็ไม่รู้เลยว่าร่างต้นของเอลา จะทรงพลังมากขนาดไหนเมื่อใช้ออกมา","การพูดคุยเรื่องสงครามกินเวลาไปตลอดช่วงเช้า และการตอบสนองของสภาก็รวดเร็วเป็นพิเศษ โดยการถ่ายทอดคำสั่งสงครามอย่างรวดเร็ว","เรือเหาะมากกว่าสองร้อยลำมารวมตัวกันจนเสร็จสิ้นในช่วงเย็น และมุ่งหน้าออกไปยังสถานที่ที่ห่างไกล...โดยมีเรือหุ้มเกราะทั้งสี่ลำที่จอดอยู่ที่ท่าเรือของอิเยตา ก็แล่นออกไปพร้อมกับเสียงหวูด ภายใต้ความสนใจของชาวเมือง","“สงครามกำลังจะเริ่มต้นขึ้น...”","แมรี่มองดูเรือเหาะและกองเรือหุ้มเกราะขนาดยักษ์ที่ปกคลุมไปทั่วท้องฟ้า และพึมพำกับตัวเอง โดยมีความกังวลเล็กน้อยอยู่ในใจ","สงครามเป็นคำที่ไม่คุ้นเคยสำหรับชาวเมืองอิเยตาที่สงบสุขมาอย่างยาวนาน แต่ในอดีต กะลาสีจากจักรวรรดิเซคัส ก็มักจะอธิบายให้พวกเขาฟังถึงฉากอันน่าสลดใจ ที่บรรดาลอร์ดโจมตีซึ่งกันและกัน ในโรงเตี๊ยม","โดยแมรี่ก็ทำได้เพียงแค่หวังอยู่เงียบๆ ในใจ ว่าพวกเขาจะสามารถเอาชนะสงครามครั้งนี้ได้","บนเรือเหาะและเรือหุ้มเกราะ มันกลับเป็นฉากที่แตกต่างออกไป เพราะทหารที่ถูกส่งไปยังอาณาจักรเพื่อปฏิบัติภารกิจ กำลังคุยโวว่า พวกเขาจะเอาชนะกระป๋องเหล็กที่สวมชุดเกราะเหล็กพุ่งเข้ามาได้อย่างง่ายดาย และไม่มีผู้เสียชีวิตเลยในการรบทั้งหมด","โดยมีทหารผู้โชคดีคนหนึ่งกลายเป็นลอร์ดที่มีดินแดนขนาดใหญ่ เพราะเขาสังหารเจ้าชายไปหนึ่งคน...หรือคนอื่นๆ ที่เหลือซึ่งสร้างผลงานอันยิ่งใหญ่ในสงครามเพื่อยึดครองเมืองหลวง ก็ได้รับรางวัลมากมายเช่นกัน","เฒ่ายอร์คก็ไม่มีข้อยกเว้น เนื่องจากความกล้าหาญของเขาในการต่อสู้ เขาได้ติดตามเรย์เดลและคนอื่นๆ เพื่อไปยึดประตูเมือง ยศของเขาได้รับการเลื่อนจากพลทหารธรรมดา ให้กลายเป็นหัวหน้าหน่วยที่สามารถนำทีมเล็กๆ ได้ แถมเขายังได้รับรางวัลเป็นเหรียญทองเวทมนตร์เต็มสิบเหรียญอีกด้วย","สำหรับเฒ่ายอร์ค ผู้ซึ่งเคยเป็นนายพรานเมื่อสองปีที่แล้ว เหรียญทองเวทมนตร์สิบเหรียญนั้นเป็นเงินจำนวนมหาศาลอย่างไม่ต้องสงสัย และไม่เคยเห็นว่าเหรียญทองหน้าตาเป็นอย่างไรมาก่อน แต่ตอนนี้เขาก็ได้เห็นมันแล้ว ซึ่งมีลวดลายที่สวยงามอย่างเหลือเชื่อ...","เหรียญทองเหล่านี้ สามารถนำไปแลกเป็นกองข้าวสาลีขนาดเท่าภูเขา ซึ่งช่วยให้เขามีอาหารกินไปได้เกือบตลอดชีวิต แต่ตอนนี้เฒ่ายอร์คไม่พอใจแค่การมีอาหารกินให้เพียงพออีกต่อไป เพราะตอนนี้เขาต้องการมากขึ้นไปอีก","นอกเหนือจากการกลายเป็นร้อยโทแล้ว เขายังต้องการซื้อรถยนต์สันดาปภายในเล่นแร่แปรธาตุที่สวยงาม และแม้กระทั่งส่งลูกๆ ของเขาไปโรงเรียนพลเรือนด้วย บางทีในอนาคตลูกๆ ของเขาอาจจะสามารถเข้าร่วมสถาบันวิจัยการแปรธาตุ และกลายมาเป็นผู้ช่วยของพ่อมดได้...","ทั้งหมดนี้ล้วนแต่เป็นสิ่งที่เฒ่ายอร์คไม่เคยกล้าคิดในอดีต แต่ตอนนี้มันกลับกลายเป็นบางสิ่งที่ดูเหมือนว่าจะอยู่ใกล้แค่เอื้อมแล้ว","นอกจากนี้ เมื่อเร็วๆ นี้อิเยตาก็เพิ่งจะเปิดโรงงานหลายแห่ง และผลิตอุปกรณ์แปลกใหม่มากมาย ซึ่งทำให้เฒ่ายอร์ครู้สึกตื่นเต้นมาก","อย่างเช่นสิ่งที่เรียกว่า หลอดไฟ โดยมันสามารถให้แสงสว่างในตอนกลางคืนได้สว่างไสวราวกับตอนกลางวัน ซึ่งมันใช้งานได้ง่ายกว่าเทียนมาก และตอนนี้มันได้กลายเป็นแฟชั่นใหม่ในเมืองอิเยตาไปแล้ว...","ทั้งหมดนี้จำเป็นต้องคว้ามาให้ได้ในสนามรบ โดยเขายังมีความมั่นใจอย่างมากในฝีมือการยิงปืนของเขา ซึ่งสามารถยิงโดนเป้าหมายภายในระยะ 70 เมตรได้อย่างแม่นยำ","“ครั้งนี้ข้าต้องระวังตัวให้ดี และจะต้องไม่ถูกไอ้พวกเวรนั่นแย่งผลงานไปอีก...”","เฒ่ายอร์คกำปืนคาบศิลากระบอกใหม่ในมือแน่น และพึมพำกับตัวเอง","เพราะตอนที่ทั้งเมืองค้นหาตัวองค์ชายใหญ่ก่อนหน้านี้ เฒ่ายอร์คก็โชคดีมากที่บังเอิญไปเจอเขา แต่เขากลับถูกแย่งผลงานไปโดยเด็กหนุ่มที่กำลังตื่นตระหนก ซึ่งมีฝีมือการยิงปืนที่แย่กว่าตัวเองมาก","ในวันต่อมา เวลาเที่ยงตรง ภายในเมืองหลวงของฮัดลาตา ในโถงใหญ่ของพระราชวัง ซึ่งขุนนางทั้งหมดของอาณาจักรมารวมตัวกันที่นี่ แต่พวกเขาแต่ละคนกลับเงียบงันราวกับหุ่นไม้","กษัตริย์องค์ใหม่ฮัตตาร์ กำลังโกรธเกรี้ยวและเอาแต่ตะโกนด่าทอ","“ไอ้พวกสารเลวพวกนี้...บัดซบเอ๊ย...”","ฮัตตาร์ได้รับข่าว การเข้ามาของกองทัพจักรวรรดิเมื่อสามวันก่อน ในตอนแรก เขาไม่ได้ให้ความสนใจกับมันมากนัก เพื่อที่จะรับมือกับสงครามในครั้งนี้ กองทัพของอาณาจักรก็ได้มารวมตัวกันแล้ว","อย่างไรก็ตาม การพัฒนาของสถานการณ์กลับเกินความคาดหมายของเขาไปมาก!","เพราะลอร์ดชายแดนในภาคตะวันตกของอาณาจักรต่างก็หันหลังให้เขากันไปทีละคน และพวกเขาก็ไม่มีความตั้งใจที่จะต่อต้านเลย ดังนั้น ภายในเวลาเพียงแค่สามวัน กองทัพจักรวรรดิก็ได้เข้าสู่พื้นที่ห่างไกลของอาณาจักร และเข้าควบคุมเมืองหลายแห่งได้อย่างรวดเร็ว","ไม่เพียงแค่นั้น ลอร์ดทางชายแดนตอนเหนือของอาณาจักรก็เตรียมพร้อมที่จะเคลื่อนไหวเช่นกัน และเอิร์ลชายแดนหลายคน ก็ถึงกับปฏิเสธการเรียกตัวของอาณาจักรอย่างหน้าไม่อาย","แล้วแบบนี้ จะไม่ให้ฮัตตาร์รู้สึกโกรธได้อย่างไร","ขุนนางที่เคยบอกว่าจงรักภักดีต่อเขา เปลี่ยนสีหน้าไปในชั่วพริบตา สิ่งนี้ยังนำไปสู่ความจริงที่ว่า จากกองทหาร 50,000 นายที่คาดว่าจะมารวมตัวกันเพื่อต่อสู้กับจักรวรรดิ ในท้ายที่สุด พวกเขาก็แทบจะรวบรวมคนมาได้เพียงประมาณ 30,000 คนเท่านั้น","และส่วนใหญ่ก็ยังเป็นทหารเกณฑ์ที่เป็นทาสติดที่ดิน ซึ่งถูกเกณฑ์มาเพียงชั่วคราวและขาดการฝึกฝน","ท่ามกลางเสียงคำรามอย่างบ้าคลั่งของฮัตตาร์ ขุนนางที่จงรักภักดีต่อกษัตริย์อย่างการ์ด ต่างก็แสดงสีหน้าเป็นกังวล แต่หลายคนกลับกำลังดูเรื่องตลกอยู่","โดยพวกเขานั้นเยาะเย้ยสิ่งที่เรียกว่า สงครามประกาศอิสรภาพ เพราะเมื่อกองทัพของศาสนจักรมาถึง การต่อต้านทั้งหมดก็จะไร้ประโยชน์!","และเป็นเพราะฮัตตาร์กักบริเวณพวกเขาไว้ในเมืองหลวงเท่านั้น พวกเขาจึงต้องยอมเชื่อฟังคำสั่ง","ในวินาทีต่อมา ประตูห้องโถงใหญ่ที่ปิดอยู่ก็ถูกเปิดออก และในขณะเดียวกัน ก็มีน้ำเสียงที่คุ้นเคยและน่าหวาดกลัวสำหรับทุกคนที่อยู่ในเหตุการณ์ดังขึ้น","“โปรดวางใจเถิด ฝ่าบาทฮัตตาร์ พวกเขาก็เป็นเพียงลอร์ดบางคน ที่ไม่สามารถมองเห็นสถานการณ์ได้อย่างชัดเจนก็เท่านั้น ตราบใดที่พระองค์เอาชนะกองทหารของศาสนจักรได้ พระองค์ก็จะสามารถกวาดล้างพวกมันในภายหลังได้”","“ท่านลินน์ ท่านแอนโธนี ในที่สุดพวกท่านก็มาถึง”","ฮัตตาร์มองไปที่ประตูและกล่าวด้วยความประหลาดใจ","ในโถงใหญ่ ขุนนางที่มีความคิดเป็นของตัวเองต่างก็สั่นสะท้าน หลังจากที่เห็นร่างของลินน์ ซึ่งรีบเก็บงำความคิดเล็กๆ น้อยๆ ของพวกเขาเอาไว้ทันที","เพราะเดือนที่ผ่านมา พวกเขานั้นได้เป็นพยานด้วยตาตนเอง ว่าอีกฝ่ายยกมือขึ้นเพื่อกระตุ้นปรากฏการณ์บนท้องฟ้า และกวาดล้างองครักษ์ไปหลายพันคนในการโจมตีเพียงครั้งเดียวได้อย่างไร พร้อมกับสังหารพระเจ้า...ที่จุติลงมาในรูปแบบของร่างอวตาร ภายใต้สายตาของชาวเมืองหลายหมื่นคนในเมืองหลวง","พ่อมดที่ดูเหมือนว่าจะยังเด็กอยู่ตรงหน้าพวกเขา ได้กลายเป็นพ่อมดที่ทรงพลังและน่าสะพรึงกลัวที่สุดในใจของพวกเขาไปแล้ว"]},{"n":344,"t":"ขบวนทหารที่ทำให้ทั้งอาณาจักรต้องตกตะลึง","c":["“ฝ่าบาทฮัตตาร์ โปรดยกโทษให้พวกเราด้วยที่มาสาย”","ลินน์พยักหน้าเล็กน้อย และให้เกียรติกษัตริย์องค์ใหม่อย่างเพียงพอ","โดยฮัตตาร์ที่เป็นเหมือนกับนักเดินทางที่คว้าฟางช่วยชีวิตเอาไว้ในความสิ้นหวัง จึงรีบพูดขึ้นมา","“ท่านลินน์ ในเมื่อตอนนี้กองทัพของศาสนจักรได้เข้าสู่อาณาจักรแล้ว พวกเราก็จะต้องรวบรวมกองกำลัง เพื่อขับไล่พวกมันออกไปจากพรมแดนให้เร็วที่สุด!”","“โปรดอยู่ในความสงบเถิดฝ่าบาท”","ลินน์ปลอบโยนฮัตตาร์ที่กำลังร้อนรนอย่างใจเย็น","เขาต้องบอกเลยว่า เมื่อเทียบกับผู้เป็นพ่ออย่างกษัตริย์บาเซลแล้ว การบ่มเพาะตนเองและความอดทนขององค์ชายรองนั้นแย่กว่ามาก...ส่วนขุนนางที่แปรพักตร์ในทิศตะวันตกของอาณาจักร ลินน์ก็ไม่ได้รู้สึกแปลกใจเลยแม้แต่น้อย","เพราะท้ายที่สุด อำนาจของศาสนจักรก็แทรกซึมอยู่ในอาณาจักรมาอย่างยาวนาน และพวกเขาก็เพิ่งจะยึดครองเมืองหลวงได้ ซึ่งนั่นยังไม่เพียงพอที่จะโน้มน้าวใจสาธารณชน การที่เกิดสถานการณ์เช่นนี้ขึ้น มันก็เป็นสิ่งที่เขาคาดการณ์เอาไว้แล้ว","ลินน์มองไปรอบๆ ขุนนางที่มีความคิดแตกต่างกันในสนาม และพูดช้าๆ","“กองหนุนจากดินแดนพ่อมดน่าจะมาถึงแล้ว หากพวกท่านสนใจ พวกท่านก็อาจจะลองออกไปดูด้วยกันก็ได้!”","“ถ้าอย่างนั้น ข้าก็อยากจะเห็นมันซะแล้วสิ!”","มาร์ควิสมอร์แทนกล่าวอย่างเยาะเย้ย","เมื่อไม่กี่ปีที่ผ่านมา เขามีโอกาสได้เห็นกองกำลังทัณฑ์ศักดิ์สิทธิ์ ที่เดินทางกลับมาจากการทำสงครามครูเสดเพื่อต่อต้านปีศาจประหลาดในเมืองศักดิ์สิทธิ์ ซึ่งสามารถอธิบายได้แค่ว่าไร้เทียมทาน!","โดยว่ากันว่า สมาชิกของกองกำลังทัณฑ์ศักดิ์สิทธิ์ ล้วนแต่ถูกคัดเลือกมาจากผู้ที่ยอดเยี่ยมที่สุดของกองทัพ หรือนักล่าแม่มด และพวกเขาทั้งหมดก็ยังเป็นอัศวินที่ได้รับพรจากพระเจ้า มันไม่ใช่เรื่องเกินจริงเลยที่จะบอกว่า คนเพียงแค่สามหรือสี่พันคน จะสามารถกวาดล้างได้ทั้งอาณาจักร!","นอกจากอัศวินกริฟฟอน และนักบวชที่ล้ำค่าเหล่านั้นแล้ว จะมีกองทัพประเภทไหนที่สามารถแข่งขันกับศาสนจักรได้อีก?","นำโดยลินน์ กษัตริย์ฮัตตาร์และกลุ่มขุนนางได้เดินออกไปจากโถงใหญ่ของพระราชวัง","ทันทีที่เขาออกไป มอร์แทนก็สังเกตเห็นแล้วว่ามีบางอย่างผิดปกติ เพราะข้างนอกนั้นไม่มีแสงแดดอันอบอุ่นสาดส่องลงมา แต่กลับกลายเป็นความมืดมิดแทน","“มันเริ่มมืดแล้ว แต่มันยังไม่ถึงเวลาคืนไม่ใช่เหรอ?”","การ์ด ซึ่งได้รับการเลื่อนยศให้เป็นอัครมหาเสนาบดี กล่าวด้วยความงง ในขณะที่ขุนนางข้างๆ เขา มองขึ้นไปบนท้องฟ้าด้วยความหวาดกลัว","“ดูบนท้องฟ้านั่นสิ!”","ทุกคนที่อยู่ในเหตุการณ์ต่างก็เงยหน้าขึ้นมองทีละคน และจากนั้นก็เห็นฉากที่น่าตกตะลึงเป็นอย่างยิ่ง","เรือเหาะหลายร้อยลำกำลังลอยอยู่ที่ความสูง 100 เมตร โดยแต่ละลำนั้นมีขนาดใหญ่เท่ากับบ้าน และพวกมันก็ปกคลุมท้องฟ้าเอาไว้ด้วยกัน ซึ่งเงาของพวกมันก็ได้ทอดยาวไปทั่วทั้งพระราชวัง สร้างฉากแปลกประหลาดที่ดูเหมือนว่าจะใกล้เข้าสู่ช่วงกลางคืนแล้ว ทั้งๆ ที่ตอนนี้ยังเป็นเวลาเที่ยงวัน...","แม้ว่าลินน์จะเคยใช้เรือเหาะในสงครามเพื่อทำลายกองกำลังชั้นยอดของอาณาจักร แต่ก็ถือเป็นครั้งแรกที่สิ่งนี้ได้ปรากฏขึ้นต่อหน้าทุกคนจริงๆ","และความตกใจที่เกิดจากวัตถุบินได้ขนาดยักษ์นี้ ก็เห็นได้อย่างชัดเจน แม้แต่มอร์แทนที่เคยเยาะเย้ยก่อนหน้านี้ ในตอนนี้ก็ยังต้องพูดไม่ออกด้วยความตกใจ","“ไปกันเถอะ พวกเขาจะลงจอดที่จัตุรัส!”","เสียงตะโกนของลินน์ปลุกขุนนางที่กำลังตกตะลึงให้ตื่นขึ้นจากความฝัน","ในตอนที่พวกเขามาถึงจัตุรัส เรือเหาะเหล่านี้ก็ได้จอดอย่างเป็นระเบียบเรียบร้อย บนจัตุรัสขนาดยักษ์แล้ว","โดยมีกองทัพจากดินแดนพ่อมดลึกลับ ซึ่งแตกต่างจากสิ่งที่พวกเขาเคยรู้จักมาอย่างสิ้นเชิง โดยองค์ประกอบของกองทัพนี้น่าแปลกประหลาดมาก เพราะไม่มีใครถือดาบ หอก หรือหน้าไม้เลย...","แถวของทหารที่สวมเครื่องแบบทางการ เดินลงมาจากเรือเหาะภายใต้สายตาของทุกคน โดยมีดาบปลายปืนอันแวววาวของพวกเขาส่องประกายเจิดจ้าภายใต้แสงแดดที่แผดเผา","มอร์แทนและคนอื่นๆ ขมวดคิ้ว เพราะพวกเขานั้นได้รวบรวมข้อมูลมากมายมาตั้งแต่การต่อสู้ในเมืองหลวงเมื่อกว่าหนึ่งเดือนก่อน ดังนั้น โดยธรรมชาติแล้ว พวกเขาก็สามารถรับรู้ได้ว่าสิ่งที่คนเหล่านี้ถืออยู่นั้นคืออาวุธที่เรียกว่าปืนคาบศิลา ซึ่งเป็นอาวุธที่แปลกใหม่ และมันทรงพลังพอที่จะเจาะทะลุชุดเกราะเหล็กได้จากระยะห่างร้อยก้าว โดยมีเสียงราวกับฟ้าร้องเมื่อถูกยิงออกไป...","ก่อนหน้านี้ มอร์แทนมักจะคิดอยู่เสมอว่า ทหารปืนคาบศิลา 3,000 นายที่ยึดเมืองหลวงได้นั้น เป็นขีดจำกัดที่ผู้ศรัทธาปีศาจเหล่านี้จะสามารถหามาได้แล้ว เพราะท้ายที่สุด อุปกรณ์เล่นแร่แปรธาตุประเภทนี้น่าจะสร้างได้ยากมาก และไม่น่าเพียงพอที่จะติดตั้งให้กับกองทัพที่มีคนนับหมื่นคนได้!","แต่สิ่งที่ดึงดูดความสนใจของเขามากยิ่งกว่า ก็คือก้อนเหล็กหน้าตาประหลาดที่ถูกนำลงมาจากเรือเหาะ...","ของที่หนักขนาดนี้ สามารถเคลื่อนที่ไปข้างหน้าได้อย่างอิสระ โดยไม่ต้องใช้ม้าหรืออูฐมาลากจูง มอร์แทนไม่สามารถคิดออกได้เลยว่าพลังของสิ่งนี้มาจากไหน ซึ่งทำได้เพียงเดาว่ามันเป็นเวทมนตร์อันชั่วร้ายของพ่อมดเหล่านั้น","สำหรับการต่อสู้ในช่วงแรกกับศาสนจักรนี้ ทั้งลินน์และสภาต่างก็ให้ความสนใจอย่างเต็มที่ โดยที่พวกเขาต้องชนะเท่านั้นและจะแพ้ไม่ได้ มิฉะนั้นความพยายามทั้งหมดก่อนหน้านี้ก็จะสูญเปล่า","นั่นจึงทำให้ลินน์นำทุกสิ่งที่เขาสามารถนำมาได้ มาด้วย!","ปืนใหญ่ รถหุ้มเกราะเล่นแร่แปรธาตุ ปืนใหญ่แม่เหล็กไฟฟ้า และเรือหุ้มเกราะที่แล่นอยู่บนทะเลเหล่านั้น...","อย่างไรก็ตาม เนื่องจากข้อจำกัดในการบรรทุกของเรือเหาะ นี่จึงเป็นเพียงกองทหารสนับสนุนระลอกแรกเท่านั้น ซึ่งมีจำนวนทั้งสิ้นประมาณ 12,000 คน","แต่ถึงกระนั้น ขบวนทหารขนาดเล็กเช่นนี้ ก็สร้างความตกตะลึงให้กับมอร์แทนและคนอื่นๆ ได้มากพอแล้ว!","“ท่านลินน์ ข้าไม่รู้เลยว่ากล่องเหล็กประหลาดเหล่านี้มีไว้ทำอะไร?”","กษัตริย์ฮัตตาร์ถามด้วยความอยากรู้อยากเห็น","สิ่งที่เขาสามารถคิดออกได้ก็มีเพียงแค่การให้กล่องเหล็กเหล่านี้ พุ่งชนเข้าไปในสนามรบ แต่เขารู้ว่ามันคงจะไม่ง่ายอย่างนั้น","“ท่านจะรู้ในอีกไม่กี่วัน”","ลินน์ยิ้ม แต่ไม่ได้ตั้งใจจะเปิดเผย","ขุนนางผู้ยิ่งใหญ่ของอาณาจักรเหล่านี้ ถูกพวกเขาบีบบังคับกึ่งหนึ่ง และถูกกักขังเอาไว้ในเมืองหลวง และฮัตตาร์ก็สามารถควบคุมส่วนใหญ่ของอาณาจักรได้ในระยะเวลาอันสั้น แต่ใครจะรู้ว่าจะมีใครสามารถหลบเลี่ยงการสอดแนมของพวกเขา และแอบรายงานข้อมูลเกี่ยวกับพวกเขาให้กับศาสนจักรเป็นการส่วนตัวได้หรือไม่","เหตุผลที่ขบวนทหารแบบนี้ถูกจัดขึ้นอย่างเปิดเผย ก็เพื่อรักษาสถานการณ์ให้มีเสถียรภาพ โดยไม่ให้บางคนเกิดความระแวดระวังและก่อให้เกิดความโกลาหลภายในอาณาจักร ซึ่งจะทำให้เกิดความยากลำบากทั้งภายในและภายนอก ดังนั้น อาวุธรุ่นใหม่เหล่านั้นจึงไม่สามารถเปิดเผยข้อมูลออกไปได้อย่างง่ายดาย...","ตอนนี้ดูเหมือนว่าผลลัพธ์น่าจะออกมาไม่เลว...สายตาของลินน์กวาดไปทั่วใบหน้าที่หวาดกลัวของขุนนาง จากนั้นก็มองไปที่ผู้ชมที่อยู่ไกลออกไป","การจงใจปกปิดของลินน์ ทำให้ฮัตตาร์ซึ่งเป็นกษัตริย์รู้สึกไม่พอใจเล็กน้อย แต่เขาก็ตระหนักดีว่าอาณาจักรฮัดลาตา จำเป็นต้องพึ่งพาพ่อมดเหล่านี้ในการต่อสู้กับศาสนจักร ดังนั้น เขาจึงทำได้เพียงสะกดกลั้นความไม่พอใจเล็กๆ น้อยๆ ในใจของเขาลงไป","หลังจากขบวนทหารสั้นๆ จบลง ลินน์ก็ได้ส่งมอบพิมพ์เขียวของเครื่องส่งสัญญาณเลเซอร์ที่เขาเตรียมไว้เมื่อนานมาแล้วให้กับแอนโธนี เพื่อให้ปรมาจารย์แห่งแม่เหล็กไฟฟ้าสามารถดำเนินการวิจัยได้ และเป็นการดีที่สุดที่จะผลิตมันขึ้นมาให้เร็วที่สุด เพื่อให้ทันกับสงครามครั้งต่อไป","สำหรับลินน์นั้น เขาได้กลับไปที่คฤหาสน์ที่ฮัตตาร์จัดเตรียมไว้ให้ เพื่อเตรียมพร้อมสำหรับการพัฒนาเวทมนตร์ไฟบทใหม่","ในครั้งนี้เขาไม่ได้ปรากฏตัวในอาณาจักรฮัดลาตา ในรูปแบบของร่างจำลองทางเวทมนตร์ แต่เขามาด้วยตัวเองจริงๆ","เพื่อสนับสนุนสงครามครั้งนี้ สภาได้ส่งพ่อมดหลายพันคนไปยังเมืองหลวง และยังมีจอมเวทผู้ยิ่งใหญ่อีกหลายคน แม้กระทั่งประธานสภาก็ยังต้องลงมือเมื่อจำเป็น และสมาคมเวทมนตร์เร้นลับย่อมไม่มีข้อยกเว้น"]},{"n":345,"t":"เปลวไฟแห่งนรกที่ไม่มีวันดับอย่างแท้จริง คลอรีนไตรฟลูออไรด์!","c":["ลินน์เข้าไปในส่วนลึกของคฤหาสน์เพียงลำพัง และหลังจากสั่งเอล็อคและคนอื่นๆ รวมถึงคนรับใช้และทหารยามในคฤหาสน์ไม่ให้รบกวนเขา เขาก็พูดขึ้นมาเงียบๆ ในใจ","‘071 แสดงสถานะปัจจุบันของฉันที’","[เป้าหมาย: ลินน์","สถานะทางกายภาพ: สูง","ระดับพลังเวท: 485","ระดับพลังจิตวิญญาณ: จอมเวทผู้ยิ่งใหญ่ (สี่วงแหวน)","ช่องเก็บเวท: [ฟอสฟอรัสขาว สัมผัสเพลิง], [ไนโตรเจนเหลว อาณาเขตน้ำแข็ง], [โล่จอมเวท], [บาเรียเวทมนตร์], [สนามพลังเบี่ยงเบนแบบย่อย]...","สี่วงแหวน: [สั่นสะเทือนมิติ], [พายุทรายเหล็ก], [ปืนใหญ่แม่เหล็กไฟฟ้า (ความเร็วเสียง 3 เท่า)], [สนามพลังเบี่ยงเบน], [จำลองร่างขั้นสูง], [อาณาเขตสุญญากาศ], [อาณาเขตแห่งความเชื่องช้า]","ผู้ใช้เครือข่ายเวทมนตร์: 43 คน]","หลังจากเลื่อนขั้นขึ้นเป็นจอมเวทผู้ยิ่งใหญ่ ลินน์ก็พบว่าพลังเวทมนตร์ของเขาเพิ่มขึ้นเป็นประมาณห้าเท่าของระดับเดิม และพลังในการคำนวณของเขาก็เพิ่มขึ้นในเวลาเดียวกัน แถมการควบคุมองค์ประกอบของเขาก็ได้รับการปรับปรุงให้ดีขึ้นไปอีกระดับด้วย","เพียงแต่ว่าเมื่อเทียบกับจอมเวทผู้ยิ่งใหญ่คนอื่นๆ แล้ว เขายังมีเวทมนตร์ระดับสี่วงแหวนไม่มากนัก โดยมีเวทมนตร์รวมทั้งหมดเพียงแค่เจ็ดชนิดเท่านั้น","ในหมู่พวกมัน เวทมนตร์สุญญากาศและเวทมนตร์แห่งความเชื่องช้า สามารถถือได้ว่าเป็นการใช้อาณาเขตของตัวเองในรูปแบบหนึ่ง ซึ่งเป็นวิธีการของจอมเวทผู้ยิ่งใหญ่","สำหรับเวทมนตร์ประเภทอื่นๆ อย่างการใช้มานาในการสั่นสะเทือนมิตินั้นก็สูงเป็นมาก ซึ่งสามารถถือได้ว่าเป็นเวทมนตร์เจาะเกราะระยะกลางที่สั้น และมีพลังทำลายล้างสูง","ส่วนปืนใหญ่แม่เหล็กไฟฟ้า ที่ถูกใช้โดยลินน์เพื่อชดเชยข้อบกพร่องในการต่อสู้ระยะไกล มันก็ทรงพลังและรวดเร็ว และใช้เวลาเตรียมการเพียงแค่หนึ่งหรือสองวินาทีเท่านั้น","แต่ในการต่อสู้ระดับจอมเวทผู้ยิ่งใหญ่ เขายังคงขาดเวทมนตร์พื้นที่ขนาดใหญ่ ที่สามารถปลดปล่อยออกมาได้อย่างรวดเร็ว และใช้เพื่อปราบปรามคู่ต่อสู้","แม้เวทมนตร์ระดับสี่วงแหวนอย่าง พายุทรายเหล็ก จะถือว่าดีมาก และมันก็ทรงพลังมากเมื่อได้รับการเสริมพลังจากเวทมนตร์สายฟ้า แต่มันก็เห็นได้ชัดว่ายังไม่สามารถทำให้ลินน์พอใจได้","ต้องรู้ก่อนว่าก่อนที่เขาจะกลายมาเป็นจอมเวทผู้ยิ่งใหญ่ ตำแหน่งนี้ก็มักจะถูกครอบครองโดยไฟฟอสฟอรัสขาวอยู่เสมอ","โดยเฉพาะพ่อมดเต็มตัวและบิชอปที่ไม่สามารถสร้างอาณาเขตสุญญากาศได้ ไฟฟอสฟอรัสขาวก็สามารถอธิบายได้เพียงแค่ว่า เป็นฝันร้าย และสิ่งที่ลินน์ตั้งใจจะเตรียมในครั้งนี้ ก็คือสิ่งที่จะสามารถนำมาแทนที่ฟอสฟอรัสขาวได้!","สารประกอบที่แม้แต่กองทัพสุดอื้อฉาวยังมองว่ามันอันตรายเกินกว่าจะนำมาใช้งาน และเหล่าผู้ก่อการร้ายที่เหี้ยมโหดที่สุดยังต้องหวาดผวา มันมีชื่อเรียกว่า...คลอรีนไตรฟลูออไรด์!","หากจะมีสิ่งใดที่สามารถเรียกว่าเพลิงนรกได้ และฟอสฟอรัสขาวทำได้เพียงแค่เฉียดใกล้คำนั้นแล้วล่ะก็...คลอรีนไตรฟลูออไรด์ก็คือสิ่งที่สมควรได้รับฉายานี้อย่างแท้จริง!","สารประกอบอนินทรีย์ที่มีพิษและมีฤทธิ์กัดกร่อนสูงชนิดนี้ มีจุดเดือดอยู่ที่ 11.3 องศาเซลเซียส และจุดหลอมเหลวอยู่ที่ -76.3 องศาเซลเซียส ซึ่งเป็นก๊าซไม่มีสีที่อุณหภูมิห้อง และจะกลายเป็นของเหลวสีเขียวเมื่อถูกทำให้เย็นลง โดยประโยชน์หลักๆ ของมันคือ การนำไปใช้เป็นเชื้อเพลิงขับเคลื่อนจรวด รวมถึงใช้ในกระบวนการผลิตและบำบัดเชื้อเพลิงนิวเคลียร์","ตัวมันเองนั้นไม่ไวไฟ แต่มันจะทำปฏิกิริยากับสารต่างๆ อย่างรุนแรง...","ในแง่หนึ่ง คลอรีนไตรฟลูออไรด์ก็ถือเป็นเวอร์ชันอัปเกรดของฟอสฟอรัสขาว ซึ่งมีคุณลักษณะของฟอสฟอรัสขาวอยู่มากมาย และมันก็ยังทรงพลังและน่าสะพรึงกลัวยิ่งกว่า!","อย่างน้อยไฟฟอสฟอรัสขาวก็สามารถถูกระงับได้ด้วยน้ำ ไม่สามารถลุกไหม้ได้ในอุณหภูมิต่ำ ไม่ลุกไหม้ขึ้นมาอีกครั้งจนกว่าอุณหภูมิจะสูงขึ้น และมันก็ยังจะถูกฝังด้วยทรายและสารที่ไม่ติดไฟอื่นๆ ได้ด้วย...","เพียงแต่วิธีการเหล่านี้ที่เคยถูกใช้เพื่อรับมือกับเปลวไฟฟอสฟอรัสขาว กลับไร้ประโยชน์เมื่ออยู่ต่อหน้าคลอรีนไตรฟลูออไรด์ เพราะสิ่งนี้สามารถเผาไหม้ได้แม้กระทั่งโลหะ คอนกรีตแข็ง และทราย!","นั่นก็คือ มันจะเผาไหม้จริงๆ ไม่ใช่การกัดกร่อนอย่างช้าๆ เหมือนฟอสฟอรัสขาว...","เมื่อคลอรีนไตรฟลูออไรด์สัมผัสกับน้ำ มันก็จะทำให้เกิดการระเบิดที่มีอุณหภูมิสูงเป็นพิเศษในทันที!","มันสามารถอธิบายได้เพียงแค่ว่าไร้เหตุผล!","เนื่องจากทั้งฟลูออรีนและคลอรีนต่างก็เป็นธาตุที่มีค่าอิเล็กโทรเนกาติวิตี (ความสามารถดึงดูดอิเล็กตรอน) สูงลิ่ว เมื่อพวกมันมารวมตัวกัน พวกมันจึงช่วงชิงอิเล็กตรอนจากสิ่งรอบข้างอย่างบ้าคลั่ง!","และพวกเราก็รู้กันดีว่า สสารทุกอย่างล้วนประกอบด้วยนิวเคลียสและอิเล็กตรอน ดังนั้นในทางทฤษฎีแล้ว ไม่ว่าจะเป็นวัสดุแบบไหน มันก็สามารถกลายเป็นสารอาหารให้กับคลอรีนไตรฟลูออไรด์ได้ทั้งนั้น","นี่คือเปลวไฟอมตะและเป็นไฟแห่งนรกที่แท้จริง...","เมื่อสิ่งนี้เกิดการลุกไหม้ขึ้นในห้องปฏิบัติการ ความหวังเดียวก็คือการวิ่งทวนลมไปทันทีที่พบเห็นมัน เพราะบนโลกนี้ยังไม่มีวิธีที่จะดับมันได้เลย!","เหตุผลที่ก่อนหน้านี้ลินน์ไม่นำสิ่งนี้ออกมา ก็เป็นเพราะคลอรีนไตรฟลูออไรด์นั้นไม่เสถียรเป็นอย่างยิ่ง และมันก็เป็นไปได้อย่างมากที่จะเผาตัวเขาเองจนควบคุมไม่ได้","นี่เป็นเหตุผลว่าทำไมคลอรีนไตรฟลูออไรด์ถึงได้มีประสิทธิภาพมาก แต่มันกลับไม่ได้ถูกสร้างเป็นอาวุธเพื่อครอบงำสนามรบ และในประวัติศาสตร์ก็มีคนจำนวนมากที่พยายามจะทำ แต่ก็ไม่ต้องสงสัยเลยว่าพวกเขาทั้งหมดต้องทนทุกข์ทรมานอย่างมากในขั้นตอนการขนส่ง...เพราะต่อให้สิ่งนี้จะถูกเก็บไว้ในภาชนะโลหะที่ได้รับการดูแลเป็นพิเศษ แต่มันก็ไม่ปลอดภัย 100%!","แต่ตอนนี้ เนื่องจากลินน์ได้รับการเลื่อนขั้นขึ้นเป็นจอมเวทผู้ยิ่งใหญ่แล้ว การควบคุมพลังเวทมนตร์และองค์ประกอบของเขาจึงได้รับการปรับปรุงให้ดีขึ้นเป็นอย่างมาก ดังนั้น เขาจึงกล้าที่จะพยายามควบคุมสารประกอบที่อันตรายอย่างยิ่งยวดนี้","ลินน์เรียกค้นข้อมูลทั้งหมดเกี่ยวกับคลอรีนไตรฟลูออไรด์ออกมาจากในสมองของเขา และสามารถดูสูตรทางเคมีสำหรับการเตรียมมันได้จากชื่อ","CI₂ + 3F₂ = 2CIF₃!","หลังจากตรวจสอบบันทึกสีแดงอย่างระมัดระวังหลายครั้ง ลินน์ก็หลับตาลงและเริ่มสังเคราะห์องค์ประกอบที่ซับซ้อน","พลังเวทในบริเวณโดยรอบพุ่งพล่านอย่างรวดเร็ว โดยสร้างพื้นที่สุญญากาศขึ้นมาเพื่อป้องกันไม่ให้คลอรีนไตรฟลูออไรด์หลุดการควบคุม ซึ่งอาจเป็นวิธีเดียวที่จะควบคุมมันได้...เพื่อหลีกเลี่ยงการสัมผัสของคลอรีนไตรฟลูออไรด์กับสารอื่นๆ!","แน่นอนว่า ไม่จำเป็นต้องใช้ออกซิเจนเพื่อจุดไฟสิ่งนี้ และมันก็สามารถลุกไหม้ได้แม้ว่ามันจะสัมผัสกับวัตถุในสภาพสุญญากาศก็ตาม เพราะโดยพื้นฐานแล้วมันคือการช่วงชิงอิเล็กตรอน...","ในอาณาเขตสุญญากาศที่ถูกแบ่งออก ลินน์ก็ได้เปิดขวดโหลทั้งสองใบ ซึ่งภายในมีองค์ประกอบของฟลูออรีนและคลอรีนถูกเก็บเอาไว้อยู่","พวกมันทั้งสองลอยออกมาอย่างรวดเร็ว และแขวนลอยอยู่ในอาณาเขตภายใต้การควบคุมของพลังจิตวิญญาณ","ลินน์ระมัดระวังเป็นอย่างมาก เขาบังคับเหนี่ยวรั้งองค์ประกอบทั้งหมดเอาไว้ในพื้นที่ขนาดเท่าฝ่ามือ เพื่อให้พวกมันสัมผัสและพุ่งชนกันเอง","ด้วยพลังของจอมเวทผู้ยิ่งใหญ่ มันยังห่างไกลจากความสามารถในการควบคุมองค์ประกอบบางอย่างได้อย่างแม่นยำ อย่างเช่นการทำให้พวกมันหยุดนิ่งไปโดยสมบูรณ์ หรือการร่ายเวทมนตร์ที่คล้ายคลึงกับการหยุดเวลาในระยะใดระยะหนึ่ง","พ่อมดทำได้เพียงชี้นำทิศทางขององค์ประกอบผ่านทางพลังจิตวิญญาณ เช่น การเคลื่อนที่ไปทางซ้ายและขวา หรือการใช้เวทมนตร์เพื่อบังคับให้พวกมันช้าลงให้มากที่สุด โดยรักษาให้อยู่ในสภาวะเกียจคร้าน","ไม่ว่าจะเป็นการบังคับสร้างอาณาเขตสุญญากาศ หรือการควบคุมองค์ประกอบให้มาสัมผัสและพุ่งชนกันตามอัตราส่วนที่กำหนด การใช้พลังเวทมนตร์และพลังจิตวิญญาณก็ไม่ใช่จำนวนน้อยๆ เลย","หากลินน์ยังคงเป็นพ่อมดระดับสามวงแหวน เขาคงจะต้องเผชิญหน้ากับสถานการณ์ที่น่าอึดอัด ซึ่งพลังจิตวิญญาณจะเหือดแห้งไปในเวลาเพียงแค่ไม่กี่วินาที แต่โชคดี ที่ตอนนี้การเลื่อนขั้นสำเร็จลงแล้ว และระดับการใช้พลังงานเช่นนี้ก็ยังอยู่ในขอบเขตที่ยอมรับได้","ถึงอย่างนั้น ลินน์ก็ยังคงต้องดิ้นรนไปตลอดทั้งบ่าย และหลังจากพยายามอยู่หลายครั้ง ในที่สุดเขาก็สามารถสังเคราะห์สิ่งที่ต้องการได้สำเร็จ","สารประหลาดชนิดหนึ่งปรากฏขึ้นบนฝ่ามือของลินน์ โดยอะตอมทั้งสี่ที่อยู่ภายในนั้นยึดเกาะกันอย่างแน่นหนา ก่อตัวขึ้นเป็นโครงสร้างรูปตัวที (T) ซึ่งประกอบไปด้วยพันธะสั้นหนึ่งเส้นและพันธะยาวสองเส้น...","นี่คือคลอรีนไตรฟลูออไรด์ ซึ่งเป็นที่รู้จักกันในนามของหนึ่งในสารประกอบที่อันตรายที่สุด!"]},{"n":346,"t":"ลินน์พ่ายแพ้?","c":["ในเวลานี้ สารประกอบที่อันตรายและน่าสะพรึงกลัวได้แขวนลอยอยู่บนฝ่ามือของเขา","รอยยิ้มปรากฏขึ้นบนใบหน้าที่ดูเหนื่อยล้าเล็กน้อยของลินน์ และจากนั้นเขาก็ร่ายเวทมนตร์—[การแยกองค์ประกอบสสารขั้นสูง]!","พลังเวทเปรียบเสมือนฉลามที่ได้กลิ่นเลือด ภายใต้การควบคุมของพลังจิตวิญญาณ มันได้พุ่งขึ้นมาอย่างบ้าคลั่งและห่อหุ้มคลอรีนไตรฟลูออไรด์เอาไว้","“มันไม่เกิดปฏิกิริยา...”","ลินน์พึมพำอย่างลับๆ","แต่มันก็เป็นเรื่องปกติเมื่อลองคิดดู เพราะพลังเวทนั้นไม่มีอิเล็กตรอน ดังนั้นแน่นอนว่ามันจะไม่มีปรากฏการณ์การถูกช่วงชิงเกิดขึ้น","ในขณะที่กำลังคิดเกี่ยวกับเรื่องนี้ พลังเวทก็ได้หลั่งไหลเข้าสู่คลอรีนไตรฟลูออไรด์ โดยประทับโครงสร้างและคุณลักษณะของมันลงไป และจากนั้นการคัดลอกก็เริ่มต้นขึ้น...","ในขณะเดียวกัน ลินน์ก็ได้ปลดปล่อยอาณาเขตสุญญากาศออกไป และหลังจากที่คลอรีนไตรฟลูออไรด์ได้สัมผัสกับสสารอื่นๆ มันก็เผยให้เห็นถึงความน่าสะพรึงกลัวในทันที เปลวไฟอันร้อนระอุและแปลกประหลาดได้ลุกไหม้ขึ้นอย่างรวดเร็ว...","ภายใต้การรับรู้ของลินน์ ไฮโดรเจน ออกซิเจน ไนโตรเจน และองค์ประกอบหายากต่างๆ ในอากาศ ล้วนแต่ถูกดึงเข้าไปใน “ไฟแห่งนรก” ดูเหมือนว่าคลอรีนไตรฟลูออไรด์จะไม่มีความละอายใจเลย และมันก็เปรียบเสมือนคนตะกละที่ไม่มีวันอิ่ม ซึ่งกลืนกินองค์ประกอบทั้งหมดที่อยู่ใกล้เคียงอย่างบ้าคลั่ง และเปลี่ยนมันให้กลายเป็นสารอาหารของตัวเอง","ในเวลาเพียงแค่ไม่กี่วินาที เปลวเพลิงที่เดิมทีมีขนาดเท่ากับนิ้วมือ ก็พองตัวขึ้นจนมีขนาดเท่ากับกำปั้นอย่างรวดเร็ว พร้อมกับก๊าซพิษจำนวนมากที่ถูกปล่อยออกมา...","นี่เป็นลักษณะประการที่สองของคลอรีนไตรฟลูออไรด์ มันจะสร้างก๊าซที่มีพิษร้ายแรงเมื่อทำปฏิกิริยากับสารอื่นๆ ซึ่งคล้ายคลึงกับฟอสฟอรัสขาว","“เรียกมันว่า เพลิงอมตะ ก็แล้วกัน”","ลินน์ลูบคางของเขา ท้ายที่สุดแล้ว สิ่งนี้ก็จำเป็นต้องมีชื่อ มันตรงไปตรงมาเกินไปที่จะเรียกมันว่าคลอรีนไตรฟลูออไรด์ ซึ่งโดยพื้นฐานแล้วมันก็เทียบเท่ากับการประกาศตัวตน","หลังจากยืนยันว่าลักษณะเฉพาะของ ‘คลอรีนไตรฟลูออไรด์‘ นั้นเหมือนกับสิ่งที่ถูกบันทึกเอาไว้ในสมองจริงๆ ลินน์ก็เริ่มพยายามที่จะใช้มัน","เนื่องจากคลอรีนไตรฟลูออไรด์เหล่านี้ใช้การเลียนแบบทางเวทมนตร์ พวกมันจึงสามารถถูกควบคุมได้อย่างอิสระเหมือนกับเวทมนตร์อื่นๆ แต่ความยากก็จะสูงกว่าเล็กน้อย ท้ายที่สุดแล้ว อิเล็กตรอนที่ถูกแย่งชิงโดยคลอรีนไตรฟลูออไรด์นั้นเป็นของจริง และมันก็ต้องใช้การควบคุมทางจิตวิญญาณเพิ่มเติมในการบริโภค...","สำหรับเรื่องที่ว่า มันจะสามารถต่อต้านเวทมนตร์และวิชาศักดิ์สิทธิ์ได้ตามที่เขาจินตนาการเอาไว้หรือไม่นั้น ยังไม่มีใครรู้","นี่เป็นคำถามที่จำเป็นต้องได้รับการตรวจสอบ...","หลังจากอาหารค่ำ ลินน์ก็ได้เชิญแอนโธนี ซึ่งกำลังค้นคว้าเกี่ยวกับเครื่องส่งสัญญาณเลเซอร์ และเสนอให้ทำการต่อสู้ทางเวทมนตร์เพื่อทดสอบพลังของเวทมนตร์บทใหม่","แอนโธนีก็ตกลงด้วยความสนใจเป็นอย่างยิ่ง","สถานที่ถูกเลือกไว้ที่สนามฝึกซ้อมแบบเปิดภายในคฤหาสน์แห่งนี้!","หลังจากได้รับข่าว เอล็อคและคนอื่นๆ ก็วางมือจากงานของพวกเขาไปทีละคน พวกเขามีความสนใจในเวทมนตร์บทใหม่ของคณบดีเป็นอย่างมาก แม้แต่ราฟาเอลและคนอื่นๆ ก็ย่อมไม่มีข้อยกเว้น","“เจ้าคิดว่าท่านลินน์มีโอกาสชนะมากแค่ไหน?”","ซานเชซกระซิบกับเพื่อนร่วมงานหลายคนที่อยู่ข้างๆ เขา","“น้อยกว่า 10%...”","เดนนิสครุ่นคิดอยู่ครู่หนึ่ง แล้วตอบด้วยน้ำเสียงทุ้มลึก","ต้องรู้ก่อนว่า แอนโธนีเป็นจอมเวทผู้ยิ่งใหญ่ระดับหกวงแหวน ซึ่งอยู่ห่างจากขอบเขตแห่งตำนานเพียงแค่ก้าวเดียวเท่านั้น แถมเขายังได้พัฒนาเวทมนตร์แม่เหล็กไฟฟ้าที่เป็นเอกลักษณ์ขึ้นมาด้วย!","และลินน์ก็เพิ่งจะเลื่อนขั้นสำเร็จเมื่อไม่นานมานี้...","ระดับสี่วงแหวน ปะทะ ระดับหกวงแหวน...ช่องว่างนี้ไม่สามารถชดเชยได้ด้วยการพึ่งพาเวทมนตร์ที่แปลกใหม่เพียงแค่หนึ่งหรือสองบท","อันที่จริง หากคู่ต่อสู้ของแอนโธนีไม่ใช่ดวงดาวแห่งเวทมนตร์ เขาเกรงว่าแม้แต่โอกาสชนะ 10% นี้ ก็คงจะไม่มีอยู่จริง","“นั่นก็ไม่แน่เสมอไป”","ราฟาเอลส่ายหัว ไม่เห็นด้วยกับข้อสรุปของเดนนิส","“อย่าลืมสิว่า ท่านลินน์เกือบจะสังหารออกัสต์ได้เชียวนะ!”","เขาและลินน์เคยต่อสู้เคียงบ่าเคียงไหล่กันมาแล้ว ในตอนที่จัดการกับลัทธิวันสิ้นโลก ลินน์ ซึ่งในเวลานั้นยังเป็นเพียงแค่พ่อมดระดับสามวงแหวน ได้พัฒนาเวทมนตร์มิติที่ทรงพลังขึ้นมา ซึ่งช่วยเหลือเขาในการเอาชนะสายลับของศาสนจักรที่แทรกซึมเข้ามาในดินแดนพ่อมด และเกือบจะสังหารออกัสต์ที่อาจก้าวเท้าเข้าสู่ระดับตำนานด้วยปืนใหญ่แม่เหล็กไฟฟ้า...","“แต่ถ้าข้าจำไม่ผิด คราวนั้นน่าจะเป็นท่านออโรร่าที่คอยช่วยเหลืออย่างลับๆ ไม่ใช่เหรอ?”","จอมเวทผู้ยิ่งใหญ่คนหนึ่งเตือนสติ และในความเห็นของเขา ดวงดาวแห่งเวทมนตร์ดวงนี้ก็แค่เก็บเกี่ยวความดีความชอบมาได้เปล่าๆ ด้วยความโชคดี...","ไม่ว่าจะเปลี่ยนเป็นใครก็ตาม ตราบใดที่มีประธานสภาระดับตำนานคอยช่วยเหลือ มันก็คงไม่ใช่เรื่องยากเลยที่จะแก้ไขการจลาจลในเมืองกรีนรีเอล","เมื่อเทียบกับซานเชซและคนอื่นๆ ที่ตัดสินจากโลกภายนอกและชั่งน้ำหนักผลลัพธ์ตามความแข็งแกร่งของทั้งสองฝ่ายแล้ว แอนโธนี ซึ่งอยู่ท่ามกลางพวกเขากลับดูเคร่งขรึมเป็นอย่างยิ่ง","เขารู้ดีว่าคนที่ยืนอยู่ฝั่งตรงข้ามไม่ใช่พ่อมดระดับสี่วงแหวนธรรมดาๆ แต่เป็นตำนานจากอดีต แม้ว่าพลังของเขาจะยังไม่ฟื้นตัวกลับมาในตอนนี้ แต่มันก็ไม่ใช่เรื่องง่ายเลยที่จะรับมือ!","แอนโธนีรู้สึกคลุมเครือว่าเลือดในร่างกายของเขา ที่สงบนิ่งมาอย่างยาวนานเริ่มเดือดพล่าน เมื่อต้องเผชิญหน้ากับพ่อมดระดับตำนานในยุครุ่งเรือง เขาก็ไม่ได้เป็นคู่ต่อสู้เลยแม้แต่น้อย แต่ตอนนี้เขาสามารถใช้โอกาสนี้ เพื่อสัมผัสกับพลังของตำนานได้","“พวกเราเริ่มกันเลยมั้ย? ท่านลินน์...” แอนโธนีถาม","เมื่ออยู่ต่อหน้าคนนอก เขาไม่ได้เรียกลินน์ว่าอาจารย์อย่างหุนหันพลันแล่น ท้ายที่สุดแล้ว เขาก็ยังไม่สามารถแก้ไขสมการของแมกซ์เวลล์ที่ซับซ้อนได้ และยังไม่ได้รับการยอมรับจากอีกฝ่ายอย่างแท้จริง","“แน่นอน!”","ลินน์กล่าวอย่างสบายๆ โดยไม่รู้เลยว่าแอนโธนี ซึ่งตกอยู่ในความคิดของตัวเอง ได้เริ่มจริงจังขึ้นมาแล้ว","นับตั้งแต่ทะลวงผ่านขอบเขตขึ้นมา นี่เป็นครั้งแรกที่เขาได้ต่อสู้กับจอมเวทผู้ยิ่งใหญ่ตัวจริง แม้ว่าเขาจะเคยต่อสู้กับแฮร์รัมและออกัสต์มาก่อนในอดีต แต่เขาก็ไม่ได้ใช้ประโยชน์จากความประมาทของคู่ต่อสู้ ก็ต้องพึ่งพาความช่วยเหลือจากคนอื่นๆ","ในครั้งนี้ เขาอาศัยความแข็งแกร่งของตัวเองจริงๆ เพื่อต่อสู้กับพ่อมดระดับหกวงแหวน!","ในวินาทีที่ลินน์พยักหน้าตอบ แอนโธนีก็ยกมือขึ้น และในขณะที่ริมฝีปากของเขาขยับเล็กน้อย สายฟ้าสีน้ำเงินอมม่วงก็ปรากฏขึ้นบนปลายนิ้วของเขา","【อัสนีบาต】","นี่เป็นเพียงแค่เวทมนตร์ระดับสี่วงแหวน แต่ข้อได้เปรียบของมันก็คือความเร็วในการร่ายที่รวดเร็วเป็นอย่างยิ่ง แทบจะในพริบตาที่เขายกปลายนิ้วขึ้นมา สายฟ้าที่กระพริบวาบก็เปรียบเสมือนงูสายฟ้าที่ดุร้าย ซึ่งควบตะบึงไปหาลินน์!","อย่างไรก็ตาม แสงสายฟ้าที่กระพริบวาบกลับถูกสกัดกั้นเอาไว้อย่างแน่นหนาในระยะสามเมตรจากร่างกาย และลินน์ที่อยู่ภายในนั้นก็ไม่ได้รับอันตรายใดๆ เลย","แน่นอนว่านี่คือกรงฟาราเดย์!","เมื่อต่อสู้กับแอนโธนี ผู้เชี่ยวชาญด้านเวทมนตร์สายฟ้า ลินน์ย่อมไม่ปล่อยปละละเลยในการป้องกันใดๆ","สีหน้าของแอนโธนียังคงไม่เปลี่ยนแปลง ความคิดของเขาขับเคลื่อนไป องค์ประกอบโลหะที่ไม่มีนัยสำคัญเหล่านั้น ซึ่งปะปนอยู่ในแสงไฟฟ้าที่กระพริบวาบ ได้กลายเป็นอาวุธสังหารในชั่วพริบตา พวกมันรวมตัวกันและยืดขยายออกไปอย่างรวดเร็ว...","กระบวนการทั้งหมดใช้เวลาเพียงแค่ชั่วขณะ และลินน์ ซึ่งยืนอยู่ตรงหน้าเขา ก็ถูกแทงทะลุด้วยตะปูทองแดงขนาดใหญ่ที่แหลมคมหลายตัว และถูกตอกตรึงอยู่กับที่อย่างแน่นหนา...","“ท่านคณบดี!”","เมื่อมองดูลินน์ที่ร่างกายถูกแทงทะลุด้วยตะปูทองแดง เอล็อคก็ตะโกนออกมาด้วยความตื่นตระหนก และเพียร์ซรวมถึงคนอื่นๆ ก็ไม่มีข้อยกเว้น พวกเขาทั้งหมดต่างก็แสดงสีหน้าที่หวาดกลัวออกมา","พวกเขาไม่ได้คาดคิดเลยว่า มันจะเป็นเพียงแค่การทดลองเวทมนตร์ และจู่ๆ แอนโธนีก็ลงมือสังหารเขาต่อหน้าทุกคน"]},{"n":347,"t":"เปลวไฟอมตะที่กลืนกินทุกสรรพสิ่ง!","c":["เหล่าจอมเวทผู้ยิ่งใหญ่ไม่ได้รู้สึกตกใจเหมือนกับเอล็อคและคนอื่นๆ พวกเขาสามารถเห็นได้ว่า ตะปูทองแดงที่แทงทะลุออกไปนั้น ล้วนแต่หลีกเลี่ยงจุดสำคัญทั้งหมด แต่มันก็แค่ดูน่ากลัวเท่านั้น","พลังทำลายล้างของเวทมนตร์ระดับสูงมักจะน่าประหลาดใจมาก ในการต่อสู้ระดับจอมเวทผู้ยิ่งใหญ่ มันไม่ใช่เรื่องง่ายอีกต่อไปที่จะออมมือถึงระดับนี้","ท้ายที่สุดแล้ว ก็ไม่มีใครรู้ว่าคู่ต่อสู้มีคาถาประเภทไหน และมันสามารถป้องกันได้หรือไม่","“นี่คือเวทมนตร์สายฟ้าเหรอ? มันพิเศษจริงๆ...”","ซานเชซขมวดคิ้วโดยไม่รู้ตัว [อัสนีบาต] ที่แอนโธนีเพิ่งจะร่ายออกมานั้นเร็วมากจนแม้แต่ตัวเขาเองก็อาจจะไม่สามารถตอบสนองได้ทัน","เพียงแต่ราฟาเอลไม่ได้คาดคิดเลยว่าการต่อสู้นี้จะจบลงเร็วขนาดนี้ มันกินเวลาประมาณหนึ่งวินาที? และผู้ชนะก็ถูกตัดสินโดยตรง...","เขาคิดว่าจะได้ต่อสู้อย่างน้อยสักพัก เพื่อเพลิดเพลินไปกับการต่อสู้ที่ยอดเยี่ยม","ท้ายที่สุดแล้ว ช่องว่างของความแข็งแกร่งก็ยังคงมากเกินไปอยู่ดี!","“ท่านคิดว่านี่คือจุดจบแล้วงั้นเหรอ? นี่มันเป็นเพียงแค่จุดเริ่มต้นชัดๆ!”","เดนนิสเตือนสติด้วยความโกรธ","หลังจากได้รับการเตือนจากเดนนิส ทุกคนที่อยู่ในเหตุการณ์ต่างก็สังเกตเห็นว่า สีหน้าของลินน์ยังคงเป็นปกติหลังจากถูกแทงด้วยตะปูทองแดง ไม่มีร่องรอยของความเจ็บปวดบนใบหน้าของเขา และไม่มีเลือดไหลออกมาจากส่วนที่ถูกแทง แต่มันกลับลุกไหม้ขึ้นมาแทน","นั่นก็คือ มันกำลังลุกไหม้อยู่จริงๆ!","เปลวไฟอันร้อนระอุระเบิดออกมาจากภายนอกร่างกาย และเสื้อผ้า ผิวหนัง และเนื้อของลินน์ก็ล้วนแต่ถูกแยกชิ้นส่วน และกลายเป็นเชื้อเพลิงสำหรับเปลวไฟ ไม่เพียงแค่นั้น เปลวไฟกำลังขยายตัวอย่างรวดเร็วและกลืนกินทุกสิ่งรอบตัว ไม่ว่าจะเป็นตะปูทองแดงสีเหลืองอมส้ม หรือสายฟ้า!","รูม่านตาของแอนโธนีหดตัวลงเล็กน้อย เพราะเขารู้สึกว่าพลังเวทในการควบคุมของเขาถูกพรากไป ไม่เพียงแค่นั้น ไฟเหล่านี้ยังกำลังกลืนกินสายฟ้า!","“ลมหายใจแห่งไฟ...”","ก่อนที่แอนโธนีจะคิดออก เสียงของลินน์ก็ดังมาจากด้านหลังเปลวไฟ","นับตั้งแต่วินาทีที่การต่อสู้เริ่มต้นขึ้น เขาได้ใช้เวทมนตร์หักเห และสิ่งที่ยังคงอยู่ในตำแหน่งเดิม ก็เป็นเพียงแค่ร่างจำลองทางเวทมนตร์เท่านั้น!","‘เพลิงอมตะ‘ อันร้อนระอุ ได้กลืนกินทุกสิ่งที่ขวางหน้า และในการขยายตัวอย่างต่อเนื่อง มันก็ได้กลายเป็นคลื่นไฟที่พวยพุ่งเข้าหาแอนโธนี","【อาณาเขตสุญญากาศ】","แอนโธนีดูเคร่งขรึม และพื้นที่รอบตัวเขาก็ขยายออกไปในทุกทิศทางอย่างรวดเร็ว เพื่อลอกเอาองค์ประกอบทั้งหมดออกไป และพลังเวทในร่างกายของเขาก็ถูกเปลี่ยนให้กลายเป็นม่านน้ำอย่างรวดเร็ว เพื่อสกัดกั้นมันเอาไว้ตรงหน้าเขา","ตราบใดที่ไม่มีอากาศ เปลวไฟก็จะดับลงตามธรรมชาติ!","และน้ำก็คือศัตรูตัวฉกาจของไฟ!","นี่เป็นสามัญสำนึกอย่างไม่ต้องสงสัย และราฟาเอลรวมถึงคนอื่นๆ ที่กำลังเฝ้าดูก็รู้สึกแบบเดียวกัน แต่ในขณะนี้ สามัญสำนึกนี้กลับใช้ไม่ได้ผล!","หลังจากเข้าสู่อาณาเขตสุญญากาศแล้ว ‘เพลิงอมตะ‘ ก็ยังคงลุกไหม้อยู่ ไม่เพียงแค่นั้น ในวินาทีที่มันพุ่งชนเข้ากับม่านน้ำ ‘เพลิงอมตะ‘ ก็ไม่ได้ดับลง แต่มันกลับกลืนกินม่านน้ำเข้าไป ระเบิดความร้อนและการระเบิดราวกับดวงอาทิตย์ออกมา...","สีหน้าของแอนโธนีเปลี่ยนไปอย่างมาก และเขาก็ถอยกลับไปครั้งแล้วครั้งเล่า ในขณะที่ความคิดของเขาพลิกผัน พลังเวทก็เปลี่ยนเป็นองค์ประกอบต่างๆ โดยธรรมชาติ แต่ไม่ว่าจะเป็นเกราะป้องกันที่ทำจากองค์ประกอบโลหะ กำแพงทราย หรือบาเรียแม่เหล็กไฟฟ้า พวกมันทั้งหมดต่างก็สูญเสียประสิทธิภาพไปโดยสิ้นเชิง!","ความแตกต่างของพวกมันก็คือ พวกมันถูกเปลี่ยนเป็นสารอาหารไม่ช้าก็เร็ว และถูกกลืนกินโดยเปลวไฟ...","ในพริบตา แอนโธนีก็ถูกกลืนกินเข้าไปในทะเลเพลิง และรอบตัวเขาก็เหลือเพียงแค่บาเรียสุดท้ายที่ทำจากเกล็ดงูเท่านั้น เขาสามารถรู้สึกได้ว่าพลังของบาเรียกำลังถูกทำให้อ่อนแอลงอย่างต่อเนื่อง ในขณะที่พลังของเปลวไฟกำลังเพิ่มขึ้นอย่างรวดเร็ว","ภายใต้กลไกเช่นนี้ อย่างมากที่สุดเพียงครึ่งนาที การป้องกันที่แข็งแกร่งที่สุดของเขาก็จะถูกทำลาย...","“สมกับที่เป็นตำนานจากอดีต...ไม่คิดเลยว่าจะเชี่ยวชาญเวทมนตร์ไฟที่น่าสะพรึงกลัวเช่นนี้”","แอนโธนีถอนหายใจอย่างลับๆ ในใจ ที่บังคับตัวเองให้ตกอยู่ในสถานการณ์ที่อันตรายได้อย่างง่ายดาย","เพียงแต่แอนโธนีไม่ได้ตั้งใจจะยอมแพ้ เพราะมันยังมีอีกวิธีหนึ่งที่จะชนะได้ นั่นก็คือการโจมตีผู้ร่ายเวทโดยตรง!","อย่างไรก็ตาม เขาได้ลองใช้องค์ประกอบมาแล้วถึง 17 ชนิด ไม่ว่าอันไหนจะถูกกัดกร่อนโดยเปลวไฟ ส่วนที่เหลือก็อาจจะไม่มีข้อยกเว้น แต่มันมีองค์ประกอบที่พิเศษกว่าซึ่งน่าจะมีประสิทธิภาพ","นั่นก็คือแสง!","ความคิดนี้แวบเข้ามาในใจของแอนโธนี และในวินาทีต่อมา ลำแสงสีขาวบริสุทธิ์ก็พุ่งออกมาจากคลื่นไฟที่พวยพุ่ง และทะลวงร่างของลินน์อีกครั้ง","เห็นได้ชัดว่า นี่เป็นร่างจำลองทางเวทมนตร์อีกร่าง นับตั้งแต่ที่เขาได้เรียนรู้ [การจำลองร่างขั้นสูง] ลินน์ก็ทำงานอย่างหนักกับมัน และแน่นอนว่าเขาก็เชี่ยวชาญมันเป็นอย่างมาก","ภายใต้การห่อหุ้มของ ‘เพลิงอมตะ‘ แอนโธนีไม่สามารถรับรู้ได้อย่างรอบคอบว่าร่างกายที่แท้จริงของลินน์อยู่ที่ไหน แต่เขาก็ไม่จำเป็นต้องทำเช่นนั้น เพราะไม่มีสิ่งใดที่จะสามารถเร็วกว่าแสงได้!","ภายใต้การสแกนของเลเซอร์ รั้วเหล็กและเสาไม้ที่ถูกวางไว้บนสนามฝึกซ้อม ก็ถูกตัดขาดในพริบตา รอยตัดนั้นเรียบเนียนเป็นอย่างยิ่ง และยังทิ้งรอยขีดข่วนลึกเอาไว้บนกำแพงที่อยู่ห่างออกไป...","“หยุด หยุด!”","ราฟาเอลตะโกนด้วยความตื่นตระหนก","แอนโธนีกวาดเลเซอร์ไป พวกเขาไม่รู้ว่าเกิดอะไรขึ้นกับลินน์ และราฟาเอลก็ไม่ได้กังวลเกี่ยวกับความปลอดภัยของเขา พวกเขาอยู่ด้านนอกสนามรบ และยังคงสามารถต้านทานเลเซอร์ที่อ่อนแรงลงมาได้","แต่พ่อมดเต็มตัวอย่างเอล็อค อาจจะเหลือร่างกายเพียงแค่ครึ่งเดียว!","ท่ามกลางเสียงอุทานของราฟาเอล แสงเลเซอร์ที่เจิดจ้าก็หยุดลงอย่างรวดเร็ว และลินน์ก็รู้ด้วยว่าสนามฝึกซ้อมไม่สามารถทนต่อการต่อสู้ของพวกเขาได้ ดังนั้นเขาจึงร่ายเวทเพื่อดับเปลวไฟที่กำลังลุกไหม้","‘เพลิงอมตะ‘ ที่ปกคลุมร่างกายของแอนโธนีถูกระงับอย่างรวดเร็ว แต่สิ่งที่ทำให้ลินน์ประหลาดใจก็คือ ยังมีเปลวไฟจำนวนมากที่ติดอยู่กับสนามฝึกซ้อม ซึ่งแสดงให้เห็นสัญญาณจางๆ ของการหลุดการควบคุม","ลินน์ขมวดคิ้วโดยไม่รู้ตัว แตกต่างจากฟอสฟอรัสขาว คลอรีนไตรฟลูออไรด์ไม่สามารถเผาไหม้ได้ด้วยตัวเอง และปรากฏการณ์การเผาไหม้นั้นเกิดจากการปล้นอิเล็กตรอนมาจากองค์ประกอบอื่นๆ นั่นก็คือ เปลวไฟเป็นเพียงแค่อนุพันธ์ของมัน","ในการทดลองก่อนหน้านี้ เขาเพิ่งจะสร้าง ‘เพลิงอมตะ‘ ขนาดเท่ากำปั้นขึ้นมา ซึ่งเขาสามารถควบคุมมันได้อย่างอิสระด้วยพลังจิตวิญญาณ แต่ตอนนี้เขากลับสูญเสียการควบคุม หลังจากที่มันกลืนกินสารอาหารจำนวนมหาศาลเข้าไป","ลินน์ครุ่นคิดอยู่ครู่หนึ่ง และทำได้เพียงแค่ใช้พลังเวทที่บริสุทธิ์ที่สุด เพื่อบังคับลอกสถานที่ที่ถูกเปลวไฟกัดกร่อนออก ปล่อยให้พวกมันแขวนลอยอยู่ในอาณาเขตสุญญากาศ และเผาไหม้มันอย่างช้าๆ...ในใจของเขาแอบระแวดระวังขึ้นมา และในอนาคต เขาจะต้องใช้เวทมนตร์ชนิดนี้ให้ระมัดระวังมากขึ้น","พลังของสิ่งนี้น่าสะพรึงกลัวจริงๆ มันสามารถกดดันได้แม้กระทั่งจอมเวทผู้ยิ่งใหญ่ระดับหกวงแหวนอย่างแอนโธนี แต่ถ้าหากไม่ระวัง มันก็อาจจะส่งผลย้อนกลับมาหาตัวเองได้ มันเปรียบเสมือนดาบสองคม...","อย่างน้อยด้วยพลังจิตวิญญาณในปัจจุบันของเขา มันก็ยังไม่เพียงพอที่จะควบคุมองค์ประกอบที่อันตรายนี้ได้อย่างสมบูรณ์","หลังจากที่เปลวไฟโดยรอบถูกลอกออกและดับลง แอนโธนีก็แอบถอนหายใจด้วยความโล่งอก เมื่อกี้เขาเกือบจะคิดว่าตัวเองกำลังจะถูกฝังอยู่ในทะเลเพลิงแล้ว","ราฟาเอลและคนอื่นๆ เดินไปที่สนามฝึกซ้อมที่ขรุขระด้วยกัน และซานเชซก็แทบจะรอไม่ไหวที่จะถาม","“ท่านลินน์ เวทมนตร์ไฟที่ท่านเพิ่งจะใช้ไปนั้น เป็นของจริงเหรอ? หรือมันเป็นเพียงแค่กลอุบายของเวทมนตร์ลวงตา? ข้าเพิ่งจะเห็นว่ามันดูเหมือนจะกำลังลุกไหม้อยู่ในสุญญากาศ...”"]}];
let idx = 0;
function initIdx(){const h=parseInt(location.hash.replace('#',''));if(h>=1&&h<=CHAPTERS.length)idx=h-1;}
function render(){
  const ch=CHAPTERS[idx];
  const paras=ch.c.map(function(p){return '<p>'+escapeHtml(p)+'</p>';}).join('');
  const isLast=idx===CHAPTERS.length-1;
  const endNote='';
  document.getElementById('reader').innerHTML=
    '<h2 class="chap-title">บทที่ '+ch.n+' : '+escapeHtml(ch.t)+'</h2>'+
    '<div class="body">'+paras+'</div>'+
    '<div class="nav">'+
      '<button class="btn" onclick="go(-1)" '+(idx===0?'disabled':'')+'>← ตอนก่อนหน้า</button>'+
      '<button class="btn" onclick="go(1)" '+(isLast?'disabled':'')+'>ตอนถัดไป →</button>'+
    '</div>'+endNote;
  location.hash=idx+1;buildTOC();window.scrollTo(0,0);
}
function go(d){const n=idx+d;if(n>=0&&n<CHAPTERS.length){idx=n;render();}}
function buildTOC(){document.getElementById('toc').innerHTML=CHAPTERS.map(function(ch,i){return '<li class="'+(i===idx?'active':'')+'" onclick="jump('+i+')"><span class="n">'+ch.n+'</span>'+escapeHtml(ch.t)+'</li>';}).join('');}
function jump(i){idx=i;render();toggleTOC();}
function toggleTOC(){document.getElementById('overlay').classList.toggle('open');}
function toggleTheme(){const h=document.documentElement,d=h.getAttribute('data-theme')==='dark';h.setAttribute('data-theme',d?'light':'dark');document.getElementById('themeBtn').textContent=d?'🌙':'☀️';}
let fs=19;
function changeFont(d){fs=Math.min(30,Math.max(15,fs+d*2));document.documentElement.style.setProperty('--reader-size',fs+'px');}
function escapeHtml(s){return s.replace(/&/g,'&').replace(/</g,'<').replace(/>/g,'>');}
initIdx();render();
['contextmenu','copy','cut','selectstart','dragstart'].forEach(function(ev){document.addEventListener(ev,function(e){e.preventDefault();return false;});});
document.addEventListener('keydown',function(e){var k=(e.key||'').toLowerCase();if((e.ctrlKey||e.metaKey)&&['c','x','a','s','u','p'].includes(k))e.preventDefault();if(k==='f12')e.preventDefault();});
</script></body></html>
