<style>
  :root{--bg:#ffffff;--card:#fff;--text:#2a2a2a;--muted:#6b6b6b;--accent:#a6543a;--border:#e3ddd3;--shadow:0 2px 10px rgba(0,0,0,.06)}
  html[data-theme="dark"]{--bg:#15171c;--card:#1e2128;--text:#dfe1e6;--muted:#8b90a0;--accent:#e0895f;--border:#2c3038;--shadow:0 2px 12px rgba(0,0,0,.4)}
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
  body{font-family:'Segoe UI','Sarabun',Tahoma,sans-serif;background:var(--bg);color:var(--text);line-height:1.75;transition:background .25s,color .25s;-webkit-user-select:none;-moz-user-select:none;-ms-user-select:none;user-select:none;-webkit-touch-callout:none}
